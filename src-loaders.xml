// AegisDNS.BpfLoader/LibBpf.cs
// P/Invoke bindings for libbpf — the Linux userspace BPF loader library

using System;
using System.Runtime.InteropServices;

namespace AegisDNS.BpfLoader;

internal static class LibBpf
{
    private const string LibName = "libbpf";

    // ── Object loading ──────────────────────────────────────────────────────

    // Load a BPF object file (.bpf.o) into memory (no options)
    // Returns: bpf_object* pointer (opaque handle) or IntPtr.Zero on failure
    [DllImport(LibName, EntryPoint = "bpf_object__open")]
    internal static extern IntPtr ObjectOpen(string path);

    // Load a BPF object file with options (bpf_object_open_opts).
    // opts.sz must equal Marshal.SizeOf<BpfObjectOpenOpts>() so libbpf
    // knows which fields in the struct are valid.
    // Returns: bpf_object* or IntPtr.Zero on failure.
    [DllImport(LibName, EntryPoint = "bpf_object__open_opts")]
    internal static extern IntPtr ObjectOpenOpts(string path, ref BpfObjectOpenOpts opts);

    // Load the object into the kernel (creates all maps, verifies program)
    // Returns: 0 on success, negative errno on failure
    [DllImport(LibName, EntryPoint = "bpf_object__load")]
    internal static extern int ObjectLoad(IntPtr obj);

    // Close and free the BPF object
    [DllImport(LibName, EntryPoint = "bpf_object__close")]
    internal static extern void ObjectClose(IntPtr obj);

    // ── Program operations ──────────────────────────────────────────────────

    // Find a BPF program by its section name (e.g. "cgroup/skb")
    [DllImport(LibName, EntryPoint = "bpf_object__find_program_by_name")]
    internal static extern IntPtr FindProgramByName(IntPtr obj, string name);

    // Get the file descriptor of a loaded program
    [DllImport(LibName, EntryPoint = "bpf_program__fd")]
    internal static extern int ProgramFd(IntPtr prog);

    // Get an fd for a BPF program by its kernel-assigned numeric ID.
    // Returns a valid fd (≥ 0) on success, or negative (ENOENT) if no
    // program with that ID exists.
    [DllImport(LibName, EntryPoint = "bpf_prog_get_fd_by_id")]
    internal static extern int ProgGetFdById(uint id);

    // Walk the kernel BPF program ID space.
    // On success (return 0) fills next_id with the next ID after start_id.
    // Returns negative (ENOENT) when there are no more programs.
    [DllImport(LibName, EntryPoint = "bpf_prog_get_next_id")]
    internal static extern int ProgGetNextId(uint start_id, ref uint next_id);

    // ── Map ID iteration ────────────────────────────────────────────────────

    // Get an fd for a BPF map by its kernel-assigned numeric ID.
    // Returns a valid fd (≥ 0) on success, or negative (ENOENT) if not found.
    [DllImport(LibName, EntryPoint = "bpf_map_get_fd_by_id")]
    internal static extern int MapGetFdById(uint id);

    // Walk the kernel BPF map ID space.
    // On success (return 0) fills next_id with the next map ID after start_id.
    // Returns negative (ENOENT) when there are no more maps.
    [DllImport(LibName, EntryPoint = "bpf_map_get_next_id")]
    internal static extern int MapGetNextId(uint start_id, ref uint next_id);

    // Retrieve kernel metadata for any BPF object fd (program, map, …).
    // info must point to a zeroed struct; info_len must be set to sizeof(struct).
    [DllImport(LibName, EntryPoint = "bpf_obj_get_info_by_fd")]
    internal static extern int ObjGetInfoByFd(int bpf_fd, IntPtr info, ref uint info_len);

    // Set extra load flags on a BPF program before bpf_object__load().
    // BPF_F_TEST_RND_HI32 = 0x4 — randomises upper 32 bits of registers,
    // narrowing verifier scalar ranges and reducing state-space explosion.
    [DllImport(LibName, EntryPoint = "bpf_program__set_extra_flags")]
    internal static extern int ProgramSetExtraFlags(IntPtr prog, uint flags);

    // ── cgroup attachment ───────────────────────────────────────────────────

    // Attach a BPF program to a cgroup directory
    // cgroup_fd: open() fd of the cgroup directory (e.g. /sys/fs/cgroup)
    // type: BPF_CGROUP_INET_EGRESS = 1, BPF_CGROUP_INET_INGRESS = 0
    // flags: BPF_F_ALLOW_OVERRIDE = 1, BPF_F_ALLOW_MULTI = 2
    [DllImport(LibName, EntryPoint = "bpf_prog_attach")]
    internal static extern int ProgAttach(int prog_fd, int cgroup_fd,
                                          BpfAttachType type, uint flags);

    // Detach a BPF program from a cgroup
    [DllImport(LibName, EntryPoint = "bpf_prog_detach")]
    internal static extern int ProgDetach(int cgroup_fd, BpfAttachType type);

    // Detach a specific BPF program (identified by prog_fd) from a cgroup.
    // Unlike ProgDetach which removes by type, this targets one exact program.
    [DllImport(LibName, EntryPoint = "bpf_prog_detach2")]
    internal static extern int ProgDetach2(int prog_fd, int cgroup_fd, BpfAttachType type);

    // Query BPF programs attached to a cgroup.
    // target_fd:    open() fd of the cgroup directory
    // type:         attach type to query (e.g. CgroupSkb = egress)
    // query_flags:  0 for default
    // attach_flags: output — current BPF_F_ALLOW_* flags on the cgroup
    // prog_ids:     output array; pass IntPtr.Zero to query count only
    // prog_cnt:     input: capacity of prog_ids; output: actual number of programs
    // Returns 0 on success, negative errno on failure.
    [DllImport(LibName, EntryPoint = "bpf_prog_query")]
    internal static extern int ProgQuery(int target_fd, BpfAttachType type, uint query_flags,
                                         ref uint attach_flags, IntPtr prog_ids, ref uint prog_cnt);

    // ── Map operations ──────────────────────────────────────────────────────

    // Find a BPF map by name within an object
    [DllImport(LibName, EntryPoint = "bpf_object__find_map_by_name")]
    internal static extern IntPtr FindMapByName(IntPtr obj, string name);

    // Get the file descriptor of a loaded map
    [DllImport(LibName, EntryPoint = "bpf_map__fd")]
    internal static extern int MapFd(IntPtr map);

    // Look up a value in a BPF map
    // Returns: 0 on success (value written to valuePtr), negative errno if not found
    [DllImport(LibName, EntryPoint = "bpf_map_lookup_elem")]
    internal static extern int MapLookup(int map_fd, IntPtr key, IntPtr value);

    // Write/update a value in a BPF map
    // flags: BPF_ANY = 0 (insert or update)
    [DllImport(LibName, EntryPoint = "bpf_map_update_elem")]
    internal static extern int MapUpdate(int map_fd, IntPtr key, IntPtr value, ulong flags);

    // Delete a value from a BPF map
    [DllImport(LibName, EntryPoint = "bpf_map_delete_elem")]
    internal static extern int MapDelete(int map_fd, IntPtr key);

    // ── Ring buffer ─────────────────────────────────────────────────────────

    // Create a ring buffer consumer
    // map_fd: fd of the BPF_MAP_TYPE_RINGBUF map
    // sample_cb: callback invoked for each event (delegate pointer)
    // ctx: context pointer passed to callback (can be IntPtr.Zero)
    // flags: must be 0
    [DllImport(LibName, EntryPoint = "ring_buffer__new")]
    internal static extern IntPtr RingBufferNew(int map_fd,
                                                 RingBufferCallback sample_cb,
                                                 IntPtr ctx,
                                                 uint flags);

    // Poll ring buffer for new events. Blocks for timeout_ms milliseconds.
    // Returns: number of events consumed, or negative errno on error
    [DllImport(LibName, EntryPoint = "ring_buffer__poll")]
    internal static extern int RingBufferPoll(IntPtr rb, int timeout_ms);

    // Free ring buffer consumer
    [DllImport(LibName, EntryPoint = "ring_buffer__free")]
    internal static extern void RingBufferFree(IntPtr rb);

    // ── Pin / Unpin ─────────────────────────────────────────────────────────

    // Pin a BPF object to the BPF filesystem (makes it survive service restarts)
    [DllImport(LibName, EntryPoint = "bpf_object__pin")]
    internal static extern int ObjectPin(IntPtr obj, string path);

    // Unpin all maps and programs from the filesystem
    [DllImport(LibName, EntryPoint = "bpf_object__unpin")]
    internal static extern int ObjectUnpin(IntPtr obj, string path);

    // Open a pinned BPF object from the BPF filesystem by path.
    // Returns an fd (≥ 0) on success, negative on failure.
    [DllImport(LibName, EntryPoint = "bpf_obj_get")]
    internal static extern int ObjGet(string pathname);
}

// ── bpf_object_open_opts — mirrors the C struct from libbpf.h ────────────────
//
// Layout on 64-bit Linux (verified against libbpf ≥ 1.0):
//
//   offset  0 : size_t              sz                 (8 bytes)
//   offset  8 : const char *        object_name        (8 bytes, NULL = auto)
//   offset 16 : bool                relaxed_maps       (1 byte)
//   offset 17 : bool                relaxed_core_relocs(1 byte)
//   offset 18 : [6 bytes padding to 8-byte-align the next pointer]
//   offset 24 : const char *        pin_root_path      (8 bytes, NULL = /sys/fs/bpf)
//   offset 32 : const char *        kconfig            (8 bytes, NULL = auto)
//   offset 40 : const char *        btf_custom_path    (8 bytes, NULL)
//   offset 48 : char *              kernel_log_buf     (8 bytes, NULL = libbpf manages)
//   offset 56 : size_t              kernel_log_size    (8 bytes)
//   offset 64 : __u32               kernel_log_level   (4 bytes)
//   offset 68 : [4 bytes trailing pad — __u32 :32 in C]
//   total     : 72 bytes
//
// libbpf uses opts->sz to determine which fields are present; always set it to
// Marshal.SizeOf<BpfObjectOpenOpts>().
[StructLayout(LayoutKind.Sequential)]
internal struct BpfObjectOpenOpts
{
    public  UIntPtr sz;                // size_t: must be Marshal.SizeOf<BpfObjectOpenOpts>()
    public  IntPtr  ObjectName;        // const char *: NULL = auto-generated name
    public  byte    RelaxedMaps;       // bool: 0 = strict map parsing
    public  byte    RelaxedCoreRelocs; // bool: 0 = strict CO-RE
    private byte    _pad0;             // \
    private byte    _pad1;             //  |
    private byte    _pad2;             //  | 6 bytes explicit padding to 8-byte-align PinRootPath
    private byte    _pad3;             //  |
    private byte    _pad4;             //  |
    private byte    _pad5;             // /
    public  IntPtr  PinRootPath;       // const char *: NULL = /sys/fs/bpf
    public  IntPtr  KConfig;           // const char *: NULL = auto
    public  IntPtr  BtfCustomPath;     // const char *: NULL
    public  IntPtr  KernelLogBuf;      // char *: NULL = libbpf allocates its own
    public  UIntPtr KernelLogSize;     // size_t: verifier log buffer size in bytes
    public  uint    KernelLogLevel;    // __u32: verifier log verbosity (0 = errors only)
    private uint    _pad6;             // __u32 :32 trailing pad
}

// ── bpf_prog_info — mirrors the kernel struct used by BPF_OBJ_GET_INFO_BY_FD ─
//
// Only the fields up to and including `name` are declared.  The kernel fills
// min(our info_len, its own struct size) bytes, so it is safe to pass a struct
// smaller than the kernel's version.
//
// Layout on 64-bit Linux (linux/bpf.h):
//   offset  0 : __u32  type              (4 bytes)
//   offset  4 : __u32  id                (4 bytes)
//   offset  8 : __u8   tag[8]            (8 bytes — BPF_TAG_SIZE)
//   offset 16 : __u32  jited_prog_len    (4 bytes)
//   offset 20 : __u32  xlated_prog_len   (4 bytes)
//   offset 24 : __u64  jited_prog_insns  (8 bytes)
//   offset 32 : __u64  xlated_prog_insns (8 bytes)
//   offset 40 : __u64  load_time         (8 bytes)
//   offset 48 : __u32  created_by_uid    (4 bytes)
//   offset 52 : __u32  nr_map_ids        (4 bytes)
//   offset 56 : __u64  map_ids           (8 bytes)
//   offset 64 : char   name[16]          (16 bytes — BPF_OBJ_NAME_LEN)
//   total     : 80 bytes
[StructLayout(LayoutKind.Sequential)]
internal unsafe struct BpfProgInfo
{
    public  uint       Type;             // __u32, offset  0
    public  uint       Id;              // __u32, offset  4
    public  fixed byte Tag[8];          // __u8[8], offset  8  (BPF_TAG_SIZE)
    public  uint       JitedProgLen;    // __u32, offset 16
    public  uint       XlatedProgLen;   // __u32, offset 20
    public  ulong      JitedProgInsns;  // __u64, offset 24
    public  ulong      XlatedProgInsns; // __u64, offset 32
    public  ulong      LoadTime;        // __u64, offset 40
    public  uint       CreatedByUid;    // __u32, offset 48
    public  uint       NrMapIds;        // __u32, offset 52
    public  ulong      MapIds;          // __u64, offset 56
    public  fixed byte Name[16];        // char[16], offset 64  (BPF_OBJ_NAME_LEN)
}

// ── bpf_map_info — mirrors the kernel struct used by BPF_OBJ_GET_INFO_BY_FD ──
//
// Layout on 64-bit Linux (linux/bpf.h):
//   offset  0 : __u32  type         (4 bytes)
//   offset  4 : __u32  id           (4 bytes)
//   offset  8 : __u32  key_size     (4 bytes)
//   offset 12 : __u32  value_size   (4 bytes)
//   offset 16 : __u32  max_entries  (4 bytes)
//   offset 20 : __u32  map_flags    (4 bytes)
//   offset 24 : char   name[16]     (16 bytes — BPF_OBJ_NAME_LEN)
//   total     : 40 bytes
[StructLayout(LayoutKind.Sequential)]
internal unsafe struct BpfMapInfo
{
    public  uint       Type;        // __u32, offset  0
    public  uint       Id;          // __u32, offset  4
    public  uint       KeySize;     // __u32, offset  8
    public  uint       ValueSize;   // __u32, offset 12
    public  uint       MaxEntries;  // __u32, offset 16
    public  uint       MapFlags;    // __u32, offset 20
    public  fixed byte Name[16];    // char[16], offset 24  (BPF_OBJ_NAME_LEN)
}

// ── BPF program attach flags (bpf_attr.attach_flags) ─────────────────────────
internal static class BpfAttachFlags
{
    internal const uint AllowOverride = 1; // BPF_F_ALLOW_OVERRIDE — replace any existing program
    internal const uint AllowMulti    = 2; // BPF_F_ALLOW_MULTI    — co-exist with other programs in the slot
}

// ── Enums matching kernel BPF attach type constants ──────────────────────────
internal enum BpfAttachType : int
{
    CgroupInetIngress = 0,
    CgroupInetEgress = 1,
    CgroupInetSockCreate = 2,
    CgroupSockOps = 3,
    SkSkbStreamParser = 4,
    SkSkbStreamVerdict = 5,
    CgroupDevice = 6,
    SkMsgVerdict = 7,
    CgroupInet4Bind = 8,
    CgroupInet6Bind = 9,
    CgroupInet4Connect = 10,
    CgroupInet6Connect = 11,
    // Use CgroupSkb for our socket buffer hook
    CgroupSkb = 1,
}

// Delegate matching libbpf ring_buffer_sample_fn signature
// data: pointer to the event struct in the ring buffer
// size: size of the event
// Returns: 0 to continue, non-zero to stop polling
[UnmanagedFunctionPointer(CallingConvention.Cdecl)]
internal delegate int RingBufferCallback(IntPtr ctx, IntPtr data, ulong size);
