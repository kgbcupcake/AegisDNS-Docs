namespace AegisDNS.XdpLoader;

/// <summary>
/// XDP ingress shield operating modes.
/// </summary>
public enum XdpMode
{
    /// <summary>XDP hook disabled — no ingress filtering.</summary>
    Off = 0,
    /// <summary>Monitor only — events are emitted but packets are not dropped.</summary>
    Monitor = 1,
    /// <summary>Active blocking — spoofed and malformed responses are dropped.</summary>
    Block = 2
}
