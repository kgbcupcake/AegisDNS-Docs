// AegisDNS.XdpLoader/LibXdp.cs
// P/Invoke bindings for libbpf + XDP-specific operations

using System;
using System.Runtime.InteropServices;

namespace AegisDNS.XdpLoader;

/// <summary>
/// P/Invoke declarations for libbpf and libc functions needed by the XDP loader.
/// Mirrors LibBpf.cs from AegisDNS.BpfLoader with XDP-specific additions.
/// </summary>
internal static class LibXdp
{
    private const string LibBpfName = "libbpf";
    private const string LibcName = "libc";

    // ── Object loading ──────────────────────────────────────────────────────

    /// <summary>Load a BPF object file (.o) into memory.</summary>
    /// <returns>bpf_object* pointer (opaque handle) or IntPtr.Zero on failure.</returns>
    [DllImport(LibBpfName, EntryPoint = "bpf_object__open")]
    internal static extern IntPtr ObjectOpen(string path);

    /// <summary>Load the object into the kernel (creates all maps, verifies program).</summary>
    /// <returns>0 on success, negative errno on failure.</returns>
    [DllImport(LibBpfName, EntryPoint = "bpf_object__load")]
    internal static extern int ObjectLoad(IntPtr obj);

    /// <summary>Close and free the BPF object.</summary>
    [DllImport(LibBpfName, EntryPoint = "bpf_object__close")]
    internal static extern void ObjectClose(IntPtr obj);

    // ── Program operations ──────────────────────────────────────────────────

    /// <summary>Find a BPF program by its function name.</summary>
    [DllImport(LibBpfName, EntryPoint = "bpf_object__find_program_by_name")]
    internal static extern IntPtr FindProgramByName(IntPtr obj, string name);

    /// <summary>Get the file descriptor of a loaded program.</summary>
    [DllImport(LibBpfName, EntryPoint = "bpf_program__fd")]
    internal static extern int ProgramFd(IntPtr prog);

    // ── Map operations ──────────────────────────────────────────────────────

    /// <summary>Find a BPF map by name within an object.</summary>
    [DllImport(LibBpfName, EntryPoint = "bpf_object__find_map_by_name")]
    internal static extern IntPtr FindMapByName(IntPtr obj, string name);

    /// <summary>Get the file descriptor of a loaded map.</summary>
    [DllImport(LibBpfName, EntryPoint = "bpf_map__fd")]
    internal static extern int MapFd(IntPtr map);

    /// <summary>Look up a value in a BPF map.</summary>
    /// <returns>0 on success, negative errno if not found.</returns>
    [DllImport(LibBpfName, EntryPoint = "bpf_map_lookup_elem")]
    internal static extern int MapLookup(int map_fd, IntPtr key, IntPtr value);

    /// <summary>Write/update a value in a BPF map.</summary>
    /// <param name="flags">BPF_ANY = 0 (insert or update).</param>
    [DllImport(LibBpfName, EntryPoint = "bpf_map_update_elem")]
    internal static extern int MapUpdate(int map_fd, IntPtr key, IntPtr value, ulong flags);

    /// <summary>Delete a value from a BPF map.</summary>
    [DllImport(LibBpfName, EntryPoint = "bpf_map_delete_elem")]
    internal static extern int MapDelete(int map_fd, IntPtr key);

    // ── Ring buffer ─────────────────────────────────────────────────────────

    /// <summary>Create a ring buffer consumer.</summary>
    [DllImport(LibBpfName, EntryPoint = "ring_buffer__new")]
    internal static extern IntPtr RingBufferNew(int map_fd,
                                                 RingBufferCallback sample_cb,
                                                 IntPtr ctx,
                                                 uint flags);

    /// <summary>Poll ring buffer for new events. Blocks for timeout_ms milliseconds.</summary>
    /// <returns>Number of events consumed, or negative errno on error.</returns>
    [DllImport(LibBpfName, EntryPoint = "ring_buffer__poll")]
    internal static extern int RingBufferPoll(IntPtr rb, int timeout_ms);

    /// <summary>Free ring buffer consumer.</summary>
    [DllImport(LibBpfName, EntryPoint = "ring_buffer__free")]
    internal static extern void RingBufferFree(IntPtr rb);

    // ── XDP-specific operations ─────────────────────────────────────────────

    /// <summary>
    /// Attaches or detaches an XDP program from a network interface.
    /// Pass prog_fd = -1 to detach the currently attached program.
    /// </summary>
    /// <returns>0 on success, negative errno on failure.</returns>
    [DllImport(LibBpfName, EntryPoint = "bpf_set_link_xdp_fd", SetLastError = true)]
    internal static extern int SetLinkXdpFd(int ifindex, int prog_fd, uint flags);

    /// <summary>
    /// Resolves a network interface name (e.g. "eth0") to its kernel ifindex.
    /// </summary>
    /// <returns>Non-zero ifindex on success, 0 on failure.</returns>
    [DllImport(LibcName, EntryPoint = "if_nametoindex", SetLastError = true)]
    internal static extern uint IfNameToIndex(string ifname);

    // ── XDP attach flag constants ───────────────────────────────────────────

    /// <summary>Fail if an XDP program is already attached.</summary>
    internal const uint XDP_FLAGS_UPDATE_IF_NOEXIST = 1u << 0;
    /// <summary>Generic/SKB mode — always works but slower (software fallback).</summary>
    internal const uint XDP_FLAGS_SKB_MODE = 1u << 1;
    /// <summary>Native driver mode — fastest, requires NIC driver support.</summary>
    internal const uint XDP_FLAGS_DRV_MODE = 1u << 2;
}

/// <summary>
/// Delegate matching libbpf ring_buffer_sample_fn signature.
/// data: pointer to the event struct in the ring buffer.
/// size: size of the event.
/// Returns: 0 to continue, non-zero to stop polling.
/// </summary>
[UnmanagedFunctionPointer(CallingConvention.Cdecl)]
internal delegate int RingBufferCallback(IntPtr ctx, IntPtr data, ulong size);
