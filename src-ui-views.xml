<file path="src/AegisDNS.UI/InterFaces/XdpSettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.XdpSettingsWindow"
        x:DataType="vm:XdpSettingsViewModel"
        Title="XDP INGRESS SHIELD"
        Width="750" Height="560"
        MinWidth="600" MinHeight="440"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="CheckBox.SettingToggle">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="CheckBox.SettingToggle:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="RadioButton.ModeRadio">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="RadioButton.ModeRadio:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border BorderBrush="Transparent" x:Name="titleBarBorder" BorderThickness="0,0,0,1">
            <Grid Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56" PointerPressed="CloseDot_PointerPressed" />
                    <Border Classes="TrafficDot" Background="#FFBD2E" PointerPressed="MinDot_PointerPressed" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="titleLabel" Text="⚡ XDP INGRESS SHIELD" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" IsHitTestVisible="False"/>
                    <!-- Enterprise Badge -->
                    <Border x:Name="enterpriseBadge" Background="#FF8C00" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="ENTERPRISE" Foreground="Black" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <DockPanel Grid.Row="1" Margin="25,8,25,15">
            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <TextBlock x:Name="contentTitle" Text="XDP INGRESS SHIELD" FontSize="20" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Footer (Save + Detach) -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                <Button x:Name="detachBtn" Content="⚠ Detach XDP" Padding="12,6" Background="#331111" Foreground="#FF5555" FontWeight="SemiBold" FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="#882222" BorderThickness="1" Command="{Binding DetachXdp}"/>
                <Button x:Name="saveBtn" Content="Save" Padding="16,6" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1"/>
            </StackPanel>

            <!-- Columns -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Spacing="6">
                    <!-- XDP Mode Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="modeHeader" Text="PROTECTION MODE" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <RadioButton x:Name="radioOff" Classes="ModeRadio" Content="⬤  OFF — XDP disabled" GroupName="XdpMode" IsChecked="{Binding IsOff}"/>
                    <RadioButton x:Name="radioMonitor" Classes="ModeRadio" Content="🟡  MONITOR — log only" GroupName="XdpMode" IsChecked="{Binding IsMonitor}"/>
                    <RadioButton x:Name="radioBlock" Classes="ModeRadio" Content="🟢  BLOCK — active filtering" GroupName="XdpMode" IsChecked="{Binding IsBlock}"/>

                    <!-- Rules Header -->
                    <StackPanel Margin="0,12,0,8">
                        <TextBlock x:Name="rulesHeader" Text="PROTECTION RULES" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <CheckBox x:Name="chkRfc1918" Classes="SettingToggle" Content="Block RFC1918 DNS Rebinding" IsChecked="{Binding XdpRfc1918Protection}"/>
                    <TextBlock Text="Drops responses resolving public domains to 10.x, 172.16-31.x, 192.168.x private ranges" Foreground="Gray" FontSize="10" TextWrapping="Wrap" Margin="24,0,0,4"/>

                    <CheckBox x:Name="chkAlertDrop" Classes="SettingToggle" Content="Alert on Every Drop" IsChecked="{Binding XdpAlertOnDrop}"/>
                    <TextBlock Text="Broadcast drop events to UI log in real-time" Foreground="Gray" FontSize="10" Margin="24,0,0,4"/>
                </StackPanel>

                <!-- Separator -->
                <Border x:Name="vLine" Grid.Column="1" Width="1" Background="Cyan" Opacity="0.3" Margin="15,0,15,0"/>

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Spacing="8">
                    <!-- Kernel Status Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="statusHeader" Text="KERNEL STATUS" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <!-- Kernel Mode Badge -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="Mode:" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                        <Border x:Name="kernelModeBadge" Background="#333333" CornerRadius="4" Padding="8,3">
                            <TextBlock x:Name="kernelModeText" Text="{Binding KernelModeLabel}" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Interface Display -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Attached Interface:" Foreground="Gray" FontSize="11"/>
                        <TextBlock x:Name="ifaceText" Text="{Binding ResolvedInterface}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Interface Override -->
                    <StackPanel Spacing="2" Margin="0,4,0,0">
                        <TextBlock Text="Interface Override:" Foreground="Gray" FontSize="11"/>
                        <TextBox x:Name="ifaceBox" Text="{Binding XdpInterface}" Watermark="auto (detects default route)" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" CaretBrush="Cyan"/>
                    </StackPanel>

                    <!-- Live Stats Header -->
                    <StackPanel Margin="0,12,0,8">
                        <TextBlock x:Name="statsHeader" Text="LIVE STATISTICS" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <!-- Live Drop Counter -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="Packets Dropped:" Foreground="Gray" FontSize="11"/>
                        <TextBlock x:Name="dropCountText" Text="{Binding DropCount}" Foreground="Cyan" FontSize="28" FontWeight="Light"/>
                    </StackPanel>

                </StackPanel>
                </Grid>
            </ScrollViewer>
        </DockPanel>

    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/AllowlistWindow.axaml.cs">
using AegisDNS.Core.Utilities;
using AegisDNS.UI.Linux;

using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Interactivity;

namespace AegisDNS;

public partial class AllowlistWindow : AegisLinuxWindow
{
    private readonly ListBox _lstDomains = null!;
    private readonly TextBlock _lblDomainCount = null!;

    public AllowlistWindow()
    {
        Avalonia.Markup.Xaml.AvaloniaXamlLoader.Load(this);


        _lstDomains = this.FindControl<ListBox>("lstDomains")!;
        _lblDomainCount = this.FindControl<TextBlock>("lblDomainCount")!;

        RefreshList();
    }

    private void RefreshList()
    {
        var domains = AllowlistManager.GetAll();
        _lstDomains.ItemsSource = domains;
        _lblDomainCount.Text = $"{domains.Count} domains allowlisted";
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseBtn_Click(object? sender, RoutedEventArgs e)
    {
        new SettingsWindow().Show();
        this.Close();
    }

    private void MinBtn_Click(object? sender, RoutedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private async void Import_Click(object? sender, RoutedEventArgs e)
    {
        var topLevel = TopLevel.GetTopLevel(this);
        if (topLevel == null) return;

        var files = await topLevel.StorageProvider.OpenFilePickerAsync(new Avalonia.Platform.Storage.FilePickerOpenOptions
        {
            Title = "Import Allowlist (Plain Text)",
            AllowMultiple = false,
            FileTypeFilter = new[] { new Avalonia.Platform.Storage.FilePickerFileType("Text Files") { Patterns = new[] { "*.txt" } } }
        });

        if (files.Count > 0)
        {
            using var stream = await files[0].OpenReadAsync();
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            AllowlistManager.ImportFromText(content);
            RefreshList();
        }
    }

    private async void Export_Click(object? sender, RoutedEventArgs e)
    {
        var topLevel = TopLevel.GetTopLevel(this);
        if (topLevel == null) return;

        var file = await topLevel.StorageProvider.SaveFilePickerAsync(new Avalonia.Platform.Storage.FilePickerSaveOptions
        {
            Title = "Export Allowlist",
            SuggestedFileName = "allowlist_export.txt",
            DefaultExtension = "txt",
            FileTypeChoices = new[] { new Avalonia.Platform.Storage.FilePickerFileType("Text Files") { Patterns = new[] { "*.txt" } } }
        });

        if (file != null)
        {
            using var stream = await file.OpenWriteAsync();
            using var writer = new StreamWriter(stream);
            var content = AllowlistManager.ExportToText();
            await writer.WriteAsync(content);
        }
    }

    private void Remove_Click(object? sender, RoutedEventArgs e)
    {
        var selected = _lstDomains.SelectedItem as string;
        if (!string.IsNullOrWhiteSpace(selected))
        {
            AllowlistManager.Remove(selected);
            RefreshList();
        }
    }

    private void Clear_Click(object? sender, RoutedEventArgs e)
    {
        var domains = AllowlistManager.GetAll();
        if (domains.Count == 0) return;

        // Note: Simple MessageBox isn't built into naked Avalonia, normally we'd use DialogHost or similar.
        // For this task per instructions, we just clear it.
        AllowlistManager.Clear();
        RefreshList();
    }
}
</file>

