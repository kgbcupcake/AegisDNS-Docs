using AegisDNS.Core;
using AegisDNS.UI.Linux;

using Avalonia;
using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Media;

namespace AegisDNS;

public partial class SettingsWindow : AegisLinuxWindow
{
    private static readonly Color CyanSolid = Color.Parse("#00FFFF");

    public SettingsWindow()
    {
        InitializeComponent();


        bool useGlow = ConfigManager.Settings.EnableNeonGlow;

        if (useGlow)
        {
            var titleLabel = this.FindControl<TextBlock>("titleLabel");
            if (titleLabel != null) titleLabel.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 12, Opacity = 0.6 };

            var titleBarBorder = this.FindControl<Border>("titleBarBorder");
            if (titleBarBorder != null) titleBarBorder.BorderBrush = new SolidColorBrush(Color.Parse("#1A4040"));

            backBtn.PointerEntered += (s, e) => { backBtn.Foreground = Brushes.White; backBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };
            backBtn.PointerExited += (s, e) => { backBtn.Foreground = Brushes.Cyan; backBtn.Effect = null; };

            ApplyGlowHover(securityCard);
            ApplyGlowHover(aiCard);
            ApplyGlowHover(blocklistCard);
            ApplyGlowHover(allowlistCard);
            ApplyGlowHover(aiLearnedCard);
            ApplyGlowHover(generalCard);
            ApplyGlowHover(appearanceCard);
            ApplyGlowHover(xdpCard);
            ApplyGlowHover(processRulesCard);
            ApplyGlowHover(schedulerCard);
            ApplyGlowHover(routerModeCard);
            ApplyGlowHover(extensionApiCard);
            ApplyGlowHover(dotCard);
            ApplyGlowHover(cloudConnectCard);
            ApplyGlowHover(streamingCard);
            ApplyGlowHover(proxyCard);
        }
        else
        {
            backBtn.PointerEntered += (s, e) => { backBtn.Foreground = Brushes.White; };
            backBtn.PointerExited += (s, e) => { backBtn.Foreground = Brushes.Cyan; };

            ApplyNormalHover(securityCard);
            ApplyNormalHover(aiCard);
            ApplyNormalHover(blocklistCard);
            ApplyNormalHover(allowlistCard);
            ApplyNormalHover(aiLearnedCard);
            ApplyNormalHover(generalCard);
            ApplyNormalHover(appearanceCard);
            ApplyNormalHover(xdpCard);
            ApplyNormalHover(processRulesCard);
            ApplyNormalHover(schedulerCard);
            ApplyNormalHover(routerModeCard);
            ApplyNormalHover(extensionApiCard);
            ApplyNormalHover(dotCard);
            ApplyNormalHover(cloudConnectCard);
            ApplyNormalHover(streamingCard);
            ApplyNormalHover(proxyCard);
        }
    }

    private void ApplyGlowHover(Border? card)
    {
        if (card == null) return;
        card.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.2 };
        card.PointerEntered += (s, e) =>
        {
            card.BorderBrush = Brushes.Cyan;
            var tb = FindFirstTextBlock(card);
            if (tb != null) tb.Foreground = Brushes.Cyan;
            card.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 12, Opacity = 0.5 };
        };
        card.PointerExited += (s, e) =>
        {
            card.BorderBrush = new SolidColorBrush(Color.Parse("#333333"));
            var tb = FindFirstTextBlock(card);
            if (tb != null) tb.Foreground = Brushes.Cyan;
            card.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.2 };
        };
    }

    private TextBlock? FindFirstTextBlock(Visual? parent)
    {
        if (parent is TextBlock tb) return tb;
        if (parent is ContentControl cc && cc.Content is Visual v) return FindFirstTextBlock(v);
        if (parent is Border b) return FindFirstTextBlock(b.Child);
        if (parent is Panel p)
        {
            foreach (var child in p.Children)
            {
                var found = FindFirstTextBlock(child);
                if (found != null) return found;
            }
        }
        return null;
    }

    private void ApplyNormalHover(Border? card)
    {
        if (card == null) return;
        card.PointerEntered += (s, e) =>
        {
            card.BorderBrush = Brushes.Cyan;
        };
        card.PointerExited += (s, e) =>
        {
            card.BorderBrush = new SolidColorBrush(Color.Parse("#333333"));
        };
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        Close();
    }

    private void MinDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void BackBtn_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        Close();
    }

    private void SecurityCard_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        new SecurityNetworkWindow().Show();
    }

    private void AllowlistCard_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
