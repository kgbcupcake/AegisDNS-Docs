<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.ViewModels"
             x:Class="AegisDNS.UI.InterFaces.DashboardView"
             x:DataType="vm:MainViewModel">

    <UserControl.Styles>
        <Style Selector="Border.HubCard">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Fixed status header — never scrolled off screen -->
        <Border Grid.Row="0" Background="#111111" BorderBrush="#1E1E1E"
                BorderThickness="0,0,0,1" Padding="20,10">
            <Grid ColumnDefinitions="1*,Auto,1*">
                <TextBlock x:Name="headerTitle" Grid.Column="0" Text="SYSTEM DASHBOARD"
                           FontSize="10" Foreground="Cyan" LetterSpacing="3"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                <Border x:Name="statusPill" Grid.Column="1" CornerRadius="10" Padding="14,5"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="statusText"
                               FontWeight="Bold" Foreground="White" FontSize="11"/>
                </Border>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="tierLabel"
                               FontSize="9" Foreground="Cyan" LetterSpacing="1"
                               HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis" Margin="10,0,0,0"/>
                    <TextBlock x:Name="latencyChip"
                               FontSize="9" Foreground="Gray"
                               HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scrollable card grid -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <UniformGrid Columns="2" Margin="14,14,14,14">

                <!-- 📊 Live Stats -->
                <Border x:Name="statsCard" Classes="HubCard"
                        PointerPressed="StatsCard_PointerPressed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="📊 Live Stats"
                                   Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Queries · Blocks · Block rate · Cache"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 📈 Traffic History -->
                <Border x:Name="trafficCard" Classes="HubCard"
                        PointerPressed="TrafficCard_PointerPressed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="📈 Traffic History"
                                   Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Query velocity over time"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 🌐 Top Domains -->
                <Border x:Name="topDomainsCard" Classes="HubCard"
                        PointerPressed="TopDomainsCard_PointerPressed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="🌐 Top Domains"
                                   Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Most blocked and allowed domains"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 🤖 AI Sentinel -->
                <Border x:Name="aiCard" Classes="HubCard"
                        PointerPressed="AiCard_PointerPressed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="🤖 AI Sentinel"
                                   Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="aiSubtitle"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                        <TextBlock x:Name="aiBlocklistCount" 
                                   Foreground="White" FontSize="11" />
                        <TextBlock x:Name="aiLastDetection"
                                   Foreground="#AAAAAA" FontSize="11" />
                        <TextBlock x:Name="aiConfidence"
                                   Foreground="#AAAAAA" FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- 🛡️ Shield Control -->
                <Border x:Name="shieldCard" Classes="HubCard"
                        PointerPressed="ShieldCard_PointerPressed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="🛡️ Shield Control"
                                   Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Activate or deactivate protection"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ⚙️ System Settings -->
                <Border x:Name="settingsCard" Classes="HubCard"
                        PointerPressed="SettingsCard_PointerPressed">
                    <StackPanel Spacing="5">
                        <TextBlock Text="⚙️ System Settings"
                                   Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="DNS, AI, blocklists, appearance"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 🌐 Router Mode -->
                <Border x:Name="routerCard" Classes="HubCard"
                        PointerPressed="RouterCard_PointerPressed">
                    <StackPanel Spacing="5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🌐 Router Mode"
                                       Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                            <Border Background="#FF8C00" CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                <TextBlock Text="PRO" Foreground="Black" FontSize="8" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="routerModeSubtitle"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ⚡ Network Latency -->
                <Border x:Name="latencyCard" Classes="HubCard">
                    <StackPanel Spacing="5">
                        <TextBlock Text="⚡ Network Latency"
                                   Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="latencyCardText"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 📺 Streaming Ads Blocked (Phase 17) — visible only when EnableStreamingAdBlock=true -->
                <Border x:Name="streamingAdsCard" Classes="HubCard">
                    <StackPanel Spacing="5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📺 Streaming Ads Blocked"
                                       Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                            <Border Background="#FF8C00" CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                <TextBlock Text="PRO" Foreground="Black" FontSize="8" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="streamingAdsCount"
                                   Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Left"/>
                        <TextBlock Text="streaming ads blocked this session"
                                   Foreground="#777777" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- 🔒 HTTPS Proxy (Phase 18) -->
                <Border x:Name="proxyStatsCard" Classes="HubCard">
                    <StackPanel Spacing="5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🔒 HTTPS Proxy"
                                       Foreground="Cyan" FontSize="13" FontWeight="SemiBold"/>
                            <Border Background="#FF8C00" CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                <TextBlock Text="PRO" Foreground="Black" FontSize="8" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="proxyStatusText" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="proxyBlockedText" Foreground="#AAAAAA" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="URL-level interception &amp; blocking"
                                   Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </UniformGrid>
        </ScrollViewer>

    </Grid>
</UserControl>
