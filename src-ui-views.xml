<file path="src/AegisDNS.UI/InterFaces/LicenseWindow.axaml">
<utils:AegisLinuxWindow
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
    x:Class="AegisDNS.UI.LicenseWindow"
    Title="AegisDNS — Activation"
    Width="420" Height="400"
    MinWidth="380" MinHeight="380"
    Background="Transparent"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    ExtendClientAreaChromeHints="NoChrome"
    TransparencyLevelHint="Transparent"
    SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="38,*">

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                <Border Classes="TrafficDot" Background="#FF5F56"
                        PointerPressed="CloseDot_PointerPressed"/>
            </StackPanel>
            <TextBlock Text="ACTIVATION" Foreground="Cyan" FontWeight="SemiBold"
                       FontSize="12" LetterSpacing="1" VerticalAlignment="Center"
                       HorizontalAlignment="Center" IsHitTestVisible="False"/>
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" Spacing="14" Margin="24,16,24,16"
                    VerticalAlignment="Center">
            <TextBlock Text="Your trial has expired." FontWeight="SemiBold"
                       Foreground="#E0E0E0" HorizontalAlignment="Center" FontSize="14"/>
            <TextBlock Text="Enter a license key to activate AegisDNS."
                       Foreground="#B0B0B0" HorizontalAlignment="Center"
                       FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
            <TextBox x:Name="keyBox" Watermark="PRIME-XXXX-XXXX-XXXX-XXXX"
                     Background="#1E1E1E" Foreground="#E0E0E0"
                     BorderBrush="#333333" CornerRadius="8"/>
            <TextBlock x:Name="messageBlock" HorizontalAlignment="Center"
                       FontSize="11" IsVisible="False"/>
            <Button x:Name="activateButton" Content="ACTIVATE"
                    HorizontalAlignment="Center"
                    Background="Cyan" Foreground="#121212"
                    FontWeight="SemiBold" FontSize="12"
                    Padding="24,8" CornerRadius="8"
                    Click="ActivateButton_Click"/>
                    
            <!-- Beta Access / HWID Panel -->
            <StackPanel Spacing="10" Margin="0,16,0,0" IsVisible="{Binding BetaAccess.IsVisible}">
                <Separator Background="#333333" Margin="0,0,0,5"/>
                
                <TextBlock Text="BETA ACCESS" Foreground="Cyan" FontWeight="SemiBold"
                           FontSize="12" LetterSpacing="1" HorizontalAlignment="Center"/>
                           
                <TextBlock Text="To receive a beta or Early Access key, please provide your unique Hardware ID to the developer."
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"/>
                           
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                    <TextBox Grid.Column="0" Text="{Binding BetaAccess.MachineId}"
                             IsReadOnly="True" Background="#1E1E1E" Foreground="#E0E0E0"
                             BorderBrush="#333333" CornerRadius="8,0,0,8" VerticalContentAlignment="Center"
                             FontSize="11"/>
                    <Button Grid.Column="1" Content="COPY" Click="CopyHwid_Click"
                            Background="#333333" Foreground="#E0E0E0" FontSize="11" FontWeight="Bold"
                            CornerRadius="0,8,8,0" Padding="12,0"/>
                </Grid>
                
                <!-- Feedback message (Copied!) -->
                <TextBlock Text="{Binding BetaAccess.CopyFeedbackText}" 
                           Foreground="LimeGreen" FontSize="11" 
                           HorizontalAlignment="Center" Height="14"/>
            </StackPanel>
        </StackPanel>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/LogWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNSUI.Linux"
        xmlns:local="clr-namespace:AegisDNS;assembly=AegisDNSUI"
        x:Class="AegisDNS.LogWindow"
        x:DataType="vm:MainViewModel"
        Title="AegisDNS - Live Traffic Log"
        Width="800" Height="500"
        MinWidth="600" MinHeight="400"
        Background="Transparent"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <Window.Resources>
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter"/>
    </Window.Resources>

    <Border Background="#050505" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="40,Auto,*">
        <!-- Custom Title Bar -->
        <Grid x:Name="titleBar" Grid.Row="0" Background="#111111" PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0" Spacing="8">
                <Button Width="14" Height="14" CornerRadius="7" Background="#FF5F56" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click"/>
                <Button Width="14" Height="14" CornerRadius="7" Background="#FFBD2E" BorderThickness="0" Cursor="Hand" Click="MinBtn_Click"/>
                <Button Width="14" Height="14" CornerRadius="7" Background="#27C93F" BorderThickness="0" Cursor="Hand" Click="MaxBtn_Click"/>
            </StackPanel>

            <TextBlock Text="LIVE TRAFFIC FEED" Foreground="Cyan" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" LetterSpacing="2">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="15" Opacity="0.6" />
                </TextBlock.Effect>
            </TextBlock>
        </Grid>

        <!-- Toolbar / Filters -->
        <Border Grid.Row="1" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                <TextBox x:Name="txtSearch" Watermark="🔍 Search domains..." Width="200" Background="#222222" Foreground="Cyan" BorderBrush="#444444" FontSize="12" CornerRadius="4" TextChanged="TxtSearch_TextChanged"/>
                
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Filters:" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <RadioButton x:Name="radAll" Content="All" GroupName="LogFilter" IsChecked="True" Foreground="LightGray" FontSize="12" Checked="Filter_Checked"/>
                    <RadioButton x:Name="radBlocked" Content="Blocked" GroupName="LogFilter" Foreground="#FF4444" FontSize="12" Checked="Filter_Checked"/>
                    <RadioButton x:Name="radAllowed" Content="Allowed" GroupName="LogFilter" Foreground="LimeGreen" FontSize="12" Checked="Filter_Checked"/>
                    <RadioButton x:Name="radAi" Content="AI Threats" GroupName="LogFilter" Foreground="Orange" FontSize="12" Checked="Filter_Checked"/>
                </StackPanel>

                <ComboBox x:Name="cmbTimeFilter" Width="120" Background="#222222" Foreground="Cyan" BorderBrush="#444444" FontSize="12" CornerRadius="4" SelectionChanged="TimeFilter_SelectionChanged">
                    <ComboBoxItem Content="All Time" IsSelected="True"/>
                    <ComboBoxItem Content="Last 15 Mins"/>
                    <ComboBoxItem Content="Last Hour"/>
                    <ComboBoxItem Content="Last 24 Hours"/>
                </ComboBox>

                <Button x:Name="btnExport" Content="💾 Export CSV" Background="#222222" Foreground="Cyan" BorderBrush="Cyan" BorderThickness="1" CornerRadius="4" Padding="8,4" FontSize="11" Cursor="Hand" Click="Export_Click" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Log List -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="140,80,200,*" Background="#111111" Margin="10,5,10,0">
                <Button Content="Timestamp" Background="Transparent" Foreground="Cyan" BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="Sort_Timestamp" Grid.Column="0"/>
                <Button Content="Level" Background="Transparent" Foreground="Cyan" BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="Sort_Level" Grid.Column="1"/>
                <Button Content="Domain" Background="Transparent" Foreground="Cyan" BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="Sort_Domain" Grid.Column="2"/>
                <Button Content="Message" Background="Transparent" Foreground="Cyan" BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="Sort_Message" Grid.Column="3"/>
            </Grid>

            <ListBox x:Name="logList" Grid.Row="1" ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0" Padding="10,0,10,10">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✅ Add to Allowlist" Click="AddToAllowlist_Click"/>
                        <MenuItem Header="🛡️ Report as Safe (Not a Threat)" Click="ReportSafe_Click"/>
                        <MenuItem Header="📋 Copy Domain" Click="CopyDomain_Click"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="140,80,200,*">
                            <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" Foreground="White" FontFamily="Consolas" FontSize="13" Grid.Column="0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Level}" Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}" FontWeight="Bold" FontSize="12" Grid.Column="1" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Domain}" Foreground="LightGray" FontFamily="Consolas" FontSize="13" TextTrimming="CharacterEllipsis" Grid.Column="2" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Message}" Foreground="Gray" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Grid.Column="3" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/ProcessRulesWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.ProcessRulesWindow"
        x:DataType="vm:ProcessRulesViewModel"
        Title="PER-PROCESS DNS RULES"
        Width="680" Height="520"
        MinWidth="560" MinHeight="400"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border BorderBrush="Transparent" x:Name="titleBarBorder" BorderThickness="0,0,0,1">
            <Grid Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56" PointerPressed="CloseDot_PointerPressed" />
                    <Border Classes="TrafficDot" Background="#FFBD2E" PointerPressed="MinDot_PointerPressed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="titleLabel" Text="🔒 PER-PROCESS DNS RULES" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" IsHitTestVisible="False"/>
                    <Border Background="#FF8C00" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="PRO" Foreground="Black" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <DockPanel Grid.Row="1" Margin="24,8,24,14">
            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <StackPanel HorizontalAlignment="Center" Spacing="3">
                    <TextBlock x:Name="contentTitle" Text="PER-PROCESS DNS RULES" FontSize="18" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center"/>
                    <TextBlock Text="Block or allow all DNS per application" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
                <Button x:Name="refreshBtn" Content="↺ Refresh Processes" Padding="10,5" Background="#1E1E1E" Foreground="#AAAAAA" FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="#444444" BorderThickness="1" Click="RefreshProcesses_Click"/>
                <Button x:Name="saveBtn" Content="Save Rules" Padding="16,5" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1" Command="{Binding Save}"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                <StackPanel Spacing="12">

                    <!-- Add New Rule -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="ADD RULE" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <ComboBox Grid.Column="0" x:Name="processCombo"
                                      SelectedItem="{Binding NewProcessName}"
                                      ItemsSource="{Binding RunningProcesses}"
                                      PlaceholderText="Select or type process name..."
                                      Background="#1E1E1E" Foreground="White" BorderBrush="#333333"
                                      IsEditable="True" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="+ Add" Padding="12,5" Background="#003333" Foreground="Cyan"
                                    FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="#00AAAA" BorderThickness="1"
                                    Command="{Binding AddRule}" Margin="0,0,8,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Rules List -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="ACTIVE RULES" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>
                        <ListBox x:Name="rulesList" ItemsSource="{Binding Rules}"
                                 Background="Transparent" BorderThickness="0"
                                 MinHeight="160" MaxHeight="260">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A1A" CornerRadius="6" Padding="12,8" Margin="0,2">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding ProcessName}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="1" Content="Block All" IsChecked="{Binding BlockAll}" Foreground="#AAAAAA" FontSize="10" Margin="8,0" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="2" Content="Allow All" IsChecked="{Binding AllowAll}" Foreground="#AAAAAA" FontSize="10" Margin="8,0" VerticalAlignment="Center"/>
                                            <Button Grid.Column="3" Content="✕" Padding="6,3" Background="#220000" Foreground="#FF5555"
                                                    FontSize="11" CornerRadius="4" Cursor="Hand" BorderBrush="#882222" BorderThickness="1"
                                                    Command="{Binding $parent[ListBox].DataContext.RemoveRule}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Help Text -->
                    <Border Background="#0D1A1A" CornerRadius="6" Padding="12,8">
                        <StackPanel Spacing="3">
                            <TextBlock Text="ℹ️  How it works" Foreground="Cyan" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Text="• Block All: Always block DNS for this process, regardless of blocklists" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
                            <TextBlock Text="• Allow All: Always allow DNS for this process, bypassing all blocklists" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
                            <TextBlock Text="• Neither checked: Normal blocklist rules apply" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/RouterModeWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.RouterModeWindow"
        x:DataType="vm:RouterModeViewModel"
        Title="ROUTER MODE"
        Width="700" Height="540"
        MinWidth="580" MinHeight="420"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border BorderBrush="Transparent" x:Name="titleBarBorder" BorderThickness="0,0,0,1">
            <Grid Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56" PointerPressed="CloseDot_PointerPressed" />
                    <Border Classes="TrafficDot" Background="#FFBD2E" PointerPressed="MinDot_PointerPressed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="titleLabel" Text="🌐 ROUTER MODE" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" IsHitTestVisible="False"/>
                    <Border Background="#FF8C00" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="PRO" Foreground="Black" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <DockPanel Grid.Row="1" Margin="24,8,24,14">
            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <StackPanel HorizontalAlignment="Center" Spacing="3">
                    <TextBlock x:Name="contentTitle" Text="ROUTER MODE" FontSize="18" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center"/>
                    <TextBlock Text="Network-wide DNS filtering for all devices" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Content columns -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Config -->
                    <StackPanel Grid.Column="0" Spacing="10">

                        <!-- Status -->
                        <StackPanel Margin="0,4,0,8">
                            <TextBlock x:Name="configHeader" Text="CONFIGURATION" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                            <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                        <GradientStop Color="#00FFFF" Offset="0" />
                                        <GradientStop Color="#1A4040" Offset="0.5" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <!-- Enable toggle row -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                            <TextBlock Text="Status:" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                            <Border x:Name="statusBadge" CornerRadius="4" Padding="8,3">
                                <TextBlock x:Name="statusText" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <!-- Bind Address -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="Bind Address:" Foreground="Gray" FontSize="11"/>
                            <TextBox x:Name="bindBox" Text="{Binding BindAddress}" Watermark="0.0.0.0"
                                     Background="#1E1E1E" Foreground="White" BorderBrush="#333333" CaretBrush="Cyan"
                                     ToolTip.Tip="Use 0.0.0.0 to listen on all interfaces"/>
                        </StackPanel>

                        <!-- Port -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="DNS Port:" Foreground="Gray" FontSize="11"/>
                            <NumericUpDown x:Name="portBox" Value="{Binding Port}" Minimum="1" Maximum="65535"
                                          Background="#1E1E1E" Foreground="White" BorderBrush="#333333"
                                          FormatString="0" Increment="1"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button x:Name="enableBtn" Content="Enable" Padding="14,6"
                                    Background="#003300" Foreground="LimeGreen" FontWeight="SemiBold"
                                    FontSize="11" CornerRadius="5" Cursor="Hand"
                                    BorderBrush="#006600" BorderThickness="1"
                                    Command="{Binding Enable}"/>
                            <Button x:Name="disableBtn" Content="Disable" Padding="14,6"
                                    Background="#220000" Foreground="#FF5555" FontWeight="SemiBold"
                                    FontSize="11" CornerRadius="5" Cursor="Hand"
                                    BorderBrush="#882222" BorderThickness="1"
                                    Command="{Binding Disable}"/>
                        </StackPanel>

                        <!-- Warning -->
                        <Border Background="#1A1200" CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="⚠️  Setup required" Foreground="Orange" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Point your router's DNS to this machine's IP to route all device traffic through AegisDNS." Foreground="#888866" FontSize="10" TextWrapping="Wrap"/>
                                <TextBlock Text="Requires port 53 access (may need sudo or cap_net_bind_service)." Foreground="#888866" FontSize="10" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- Separator -->
                    <Border x:Name="vLine" Grid.Column="1" Width="1" Background="Cyan" Opacity="0.3" Margin="15,0,15,0"/>

                    <!-- Right: Connected Devices -->
                    <StackPanel Grid.Column="2" Spacing="8">
                        <StackPanel Margin="0,4,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="devicesHeader" Text="CONNECTED DEVICES" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                                <Button Content="↺" Padding="4,1" Background="#1E1E1E" Foreground="Cyan"
                                        FontSize="11" CornerRadius="3" Cursor="Hand" BorderBrush="#333333" BorderThickness="1"
                                        Command="{Binding Refresh}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                        <GradientStop Color="#00FFFF" Offset="0" />
                                        <GradientStop Color="#1A4040" Offset="0.5" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <ListBox x:Name="devicesList" ItemsSource="{Binding ConnectedDevices}"
                                 Background="Transparent" BorderThickness="0"
                                 MinHeight="240" MaxHeight="360">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A1A" CornerRadius="5" Padding="10,7" Margin="0,2">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding IpAddress}" Foreground="White" FontSize="12" FontWeight="SemiBold" FontFamily="Monospace"/>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding QueryCount, StringFormat='Queries: {0}'}" Foreground="Gray" FontSize="10"/>
                                                    <TextBlock Text="{Binding BlockedCount, StringFormat='Blocked: {0}'}" Foreground="#FF8888" FontSize="10"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding LastSeen, StringFormat='HH:mm:ss'}"
                                                       Foreground="#555555" FontSize="10" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="No devices seen yet. Enable Router Mode and route traffic through this machine."
                                   Foreground="Gray" FontSize="10" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/SchedulerWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.SchedulerWindow"
        x:DataType="vm:SchedulerViewModel"
        Title="SCHEDULED BLOCKING"
        Width="680" Height="520"
        MinWidth="560" MinHeight="400"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border BorderBrush="Transparent" x:Name="titleBarBorder" BorderThickness="0,0,0,1">
            <Grid Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56" PointerPressed="CloseDot_PointerPressed" />
                    <Border Classes="TrafficDot" Background="#FFBD2E" PointerPressed="MinDot_PointerPressed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="titleLabel" Text="🕐 SCHEDULED BLOCKING" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" IsHitTestVisible="False"/>
                    <Border Background="#FF8C00" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="PRO" Foreground="Black" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <DockPanel Grid.Row="1" Margin="24,8,24,14">
            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <StackPanel HorizontalAlignment="Center" Spacing="3">
                    <TextBlock x:Name="contentTitle" Text="SCHEDULED BLOCKING" FontSize="18" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="pauseStatusLabel" Text="{Binding PausedUntilDisplay}" Foreground="Orange" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
                <Button x:Name="pauseBtn" Content="⏸ Pause 30 min" Padding="10,5" Background="#332200" Foreground="Orange"
                        FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="#664400" BorderThickness="1"
                        Command="{Binding PauseThirtyMinutes}" Click="PauseBtn_Click"/>
                <Button x:Name="addBtn" Content="+ Add Schedule" Padding="10,5" Background="#003333" Foreground="Cyan"
                        FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="#00AAAA" BorderThickness="1"
                        Command="{Binding AddSchedule}"/>
                <Button x:Name="saveBtn" Content="Save" Padding="16,5" Background="#006666" Foreground="Cyan"
                        FontWeight="SemiBold" FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1"
                        Command="{Binding Save}"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                <StackPanel Spacing="12">

                    <!-- Schedule List -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="SCHEDULES" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>

                        <ListBox x:Name="scheduleList" ItemsSource="{Binding Schedules}"
                                 Background="Transparent" BorderThickness="0"
                                 MinHeight="200" MaxHeight="320">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A1A" CornerRadius="6" Padding="12,10" Margin="0,3">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBox Text="{Binding Name}" Background="Transparent" Foreground="White"
                                                         FontSize="12" FontWeight="SemiBold" BorderThickness="0" Padding="0"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="Start:" Foreground="Gray" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding StartTime}" Background="#111111" Foreground="Cyan"
                                                             FontSize="10" Padding="4,2" BorderBrush="#333333" CornerRadius="3" Width="70"/>
                                                    <TextBlock Text="End:" Foreground="Gray" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding EndTime}" Background="#111111" Foreground="Cyan"
                                                             FontSize="10" Padding="4,2" BorderBrush="#333333" CornerRadius="3" Width="70"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="✕" Padding="6,3" Background="#220000" Foreground="#FF5555"
                                                    FontSize="11" CornerRadius="4" Cursor="Hand" BorderBrush="#882222" BorderThickness="1"
                                                    Command="{Binding $parent[ListBox].DataContext.RemoveSchedule}"
                                                    CommandParameter="{Binding}"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Help Text -->
                    <Border Background="#0D1A1A" CornerRadius="6" Padding="12,8">
                        <StackPanel Spacing="3">
                            <TextBlock Text="ℹ️  How it works" Foreground="Cyan" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Text="• Schedules enforce blocking during the specified time window each day" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
                            <TextBlock Text="• Use Pause to temporarily suspend blocking for 30 minutes" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
                            <TextBlock Text="• Time format: hh:mm:ss (e.g. 09:00:00 for 9 AM)" Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/SecurityNetworkWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.SecurityNetworkWindow"
        x:DataType="vm:SettingsViewModel"
        Title="SECURITY &amp; NETWORK"
        Width="750" Height="520"
        MinWidth="600" MinHeight="420"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border x:Name="titleBarBorder" Grid.Row="0" BorderThickness="0,0,0,1">
            <Grid x:Name="titleBar" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Width="12" Height="12" CornerRadius="6" Background="#FF5F56" Cursor="Hand" PointerPressed="CloseDot_PointerPressed"/>
                    <Border Width="12" Height="12" CornerRadius="6" Background="#FFBD2E" Cursor="Hand" PointerPressed="MinDot_PointerPressed"/>
                </StackPanel>
                <TextBlock x:Name="titleLabel" Text="🔒 SECURITY &amp; NETWORK" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <DockPanel Grid.Row="1" Margin="25,8,25,15">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <TextBlock x:Name="contentTitle" Text="SECURITY &amp; NETWORK" FontSize="20" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center" />
            </Grid>

            <Button x:Name="saveBtn" DockPanel.Dock="Bottom" Content="Save" Padding="16,6" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="5" HorizontalAlignment="Right" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1" Margin="0,10,0,0"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Spacing="8">
                    <!-- Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="securityHeader" Text="SECURITY &amp; LOGGING" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5" />
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Offset="0" Color="#00FFFF"/>
                                    <GradientStop Offset="0.5" Color="#1A4040"/>
                                    <GradientStop Offset="1" Color="Transparent"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <CheckBox x:Name="chkAutoUpdate" Content="Auto-Update Blocklists" Foreground="#B0B0B0" Cursor="Hand" Margin="0,0,0,2" FontSize="12" />
                    <CheckBox x:Name="chkLogDns" Content="Log DNS Requests (Local Only)" Foreground="#B0B0B0" Cursor="Hand" Margin="0,0,0,2" FontSize="12" />
                    <CheckBox x:Name="chkBlockMalware" Content="Block Known Malware Domains" Foreground="#B0B0B0" Cursor="Hand" Margin="0,0,0,2" FontSize="12" />
                    <CheckBox x:Name="chkBlockAdult" Content="Block Adult Content (Family Safe)" Foreground="#B0B0B0" Cursor="Hand" Margin="0,0,0,2" FontSize="12" />
                    <CheckBox x:Name="chkBlockTelemetry" Content="Block OS Telemetry" Foreground="#B0B0B0" Cursor="Hand" Margin="0,0,0,2" FontSize="12" />

                    <!-- eBPF DNS Interception (Phase 14) -->
                    <StackPanel Margin="0,8,0,0" Spacing="2">
                        <CheckBox x:Name="chkEnableEbpf" Content="KERNEL-LEVEL DNS INTERCEPTION (Linux)" Foreground="#B0B0B0" Cursor="Hand" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="Requires kernel 5.8+ and install-time compilation" Foreground="Gray" FontSize="10" Margin="24,0,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="24,2,0,0">
                            <TextBlock x:Name="ebpfWarningIcon" Text="⚠️" Foreground="#FFBD2E" FontSize="10" IsVisible="False" Margin="0,0,4,0"/>
                            <TextBlock x:Name="ebpfWarningText" Text="Not available on this platform" Foreground="#FFBD2E" FontSize="10" IsVisible="False" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Separator line -->
                <Border x:Name="vLine" Grid.Column="1" Width="1" Background="Cyan" Opacity="0.3" Margin="15,0,15,0" />

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Spacing="8">
                    <!-- Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="networkHeader" Text="NETWORK &amp; UPSTREAM" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5" />
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Offset="0" Color="#00FFFF"/>
                                    <GradientStop Offset="0.5" Color="#1A4040"/>
                                    <GradientStop Offset="1" Color="Transparent"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Upstream DNS Provider:" FontSize="11" Foreground="Gray" />
                    <TextBox x:Name="dnsBox" Watermark="Primary DNS (e.g. 1.1.1.1)" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" CaretBrush="Cyan" />

                    <TextBlock Text="Network Adapter Name:" FontSize="11" Foreground="Gray" />
                    <TextBox x:Name="adapterBox" Watermark="Adapter Name or 'Auto-Detect'" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" CaretBrush="Cyan" />

                    <!-- Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="performanceHeader" Text="PERFORMANCE TUNING" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5" />
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Offset="0" Color="#00FFFF"/>
                                    <GradientStop Offset="0.5" Color="#1A4040"/>
                                    <GradientStop Offset="1" Color="Transparent"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <TextBlock x:Name="cacheLabel" FontSize="11" Foreground="Gray" />
                    <Slider x:Name="cacheSlider" Minimum="128" Maximum="4096" Foreground="Cyan" />
                </StackPanel>

                </Grid>
            </ScrollViewer>
        </DockPanel>

    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/SecurityNetworkWindow.axaml.cs">
using System;
using System.Reactive.Disposables;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.UI.Linux;
using AegisDNS.ViewModels;

using Avalonia;
using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Media;
using Avalonia.ReactiveUI;

using ReactiveUI;

namespace AegisDNS;

/// <summary>
/// Dedicated window for Security & Logging, Network & Upstream, and Performance Tuning settings.
/// </summary>
public partial class SecurityNetworkWindow : AegisLinuxWindow, IViewFor<SettingsViewModel>
{
    public static readonly StyledProperty<SettingsViewModel?> ViewModelProperty =
        AvaloniaProperty.Register<SecurityNetworkWindow, SettingsViewModel?>(nameof(ViewModel));

    public SettingsViewModel? ViewModel
    {
        get => GetValue(ViewModelProperty);
        set => SetValue(ViewModelProperty, value);
    }

    object? IViewFor.ViewModel
    {
        get => ViewModel;
        set => ViewModel = (SettingsViewModel?)value;
    }

    private static readonly Color CyanSolid = Color.Parse("#00FFFF");

    public SecurityNetworkWindow()
    {
        InitializeComponent();


        ViewModel = new SettingsViewModel();
        DataContext = ViewModel;
        bool useGlow = ConfigManager.Settings.EnableNeonGlow;


        if (useGlow)
        {
            var titleLabel = this.FindControl<TextBlock>("titleLabel");
            if (titleLabel != null) titleLabel.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 12, Opacity = 0.6 };

            var titleBarBorder = this.FindControl<Border>("titleBarBorder");
            if (titleBarBorder != null) titleBarBorder.BorderBrush = new SolidColorBrush(Color.Parse("#1A4040"));

            backBtn.PointerEntered += (s, e) => { backBtn.Foreground = Brushes.White; backBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };
            backBtn.PointerExited += (s, e) => { backBtn.Foreground = Brushes.Cyan; backBtn.Effect = null; };

            contentTitle.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 15, Opacity = 0.5 };
            securityHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            networkHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            performanceHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };

            ApplyTextBoxGlow(dnsBox);
            ApplyTextBoxGlow(adapterBox);
            ApplyCheckBoxGlow(chkAutoUpdate);
            ApplyCheckBoxGlow(chkLogDns);
            ApplyCheckBoxGlow(chkBlockMalware);
            ApplyCheckBoxGlow(chkBlockAdult);
            ApplyCheckBoxGlow(chkBlockTelemetry);
            ApplyCheckBoxGlow(chkEnableEbpf);

            vLine.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.5 };

            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 14, Opacity = 0.6 }; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };

            saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
        }
        else
        {
            backBtn.PointerEntered += (s, e) => backBtn.Foreground = Brushes.White;
            backBtn.PointerExited += (s, e) => backBtn.Foreground = Brushes.Cyan;

            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; };
        }

        // ===== BINDINGS =====
        this.WhenActivated(disposables =>
        {
            this.Bind(ViewModel, vm => vm.AutoUpdateBlocklists, v => v.chkAutoUpdate.IsChecked).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.LogDnsRequests, v => v.chkLogDns.IsChecked).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.BlockMalwareDomains, v => v.chkBlockMalware.IsChecked).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.BlockAdultContent, v => v.chkBlockAdult.IsChecked).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.BlockTelemetry, v => v.chkBlockTelemetry.IsChecked).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.EnableEbpf, v => v.chkEnableEbpf.IsChecked).DisposeWith(disposables);

            if (!OperatingSystem.IsLinux())
            {
                chkEnableEbpf.IsEnabled = false;
                ebpfWarningIcon.IsVisible = true;
                ebpfWarningText.IsVisible = true;
            }

            this.Bind(ViewModel, vm => vm.PrimaryDns, v => v.dnsBox.Text).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.PreferredAdapter, v => v.adapterBox.Text).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.CacheSize, v => v.cacheSlider.Value, v => (double)v, d => (int)d).DisposeWith(disposables);

            this.WhenAnyValue(v => v.ViewModel!.CacheSize)
                .Subscribe(size => cacheLabel.Text = $"DNS Cache Size: {size} MB")
                .DisposeWith(disposables);

            saveBtn.Click += async (s, e) =>
            {
                ViewModel!.SaveSettings.Execute().Subscribe();
                var originalText = saveBtn.Content;
                saveBtn.Content = "✅ Saved";
                saveBtn.Background = new SolidColorBrush(Color.Parse("#004400"));
                saveBtn.Foreground = Brushes.LimeGreen;
                saveBtn.BorderBrush = Brushes.LimeGreen;
                if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = Colors.LimeGreen, BlurRadius = 10, Opacity = 0.5 };
                await Task.Delay(1500);
                saveBtn.Content = originalText;
                saveBtn.Background = new SolidColorBrush(Color.Parse("#006666"));
                saveBtn.Foreground = Brushes.Cyan;
                saveBtn.BorderBrush = Brushes.Cyan;
                if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
            };
        });
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        Close();
    }

    private void MinDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void BackBtn_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var settings = new SettingsWindow();
        settings.Show();
        this.Close();
    }

    private void ApplyTextBoxGlow(TextBox tb)
    {
        tb.GotFocus += (s, e) =>
        {
            tb.BorderBrush = Brushes.Cyan;
            tb.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
        };
        tb.LostFocus += (s, e) =>
        {
            tb.BorderBrush = new SolidColorBrush(Color.Parse("#333333"));
            tb.Effect = null;
        };
    }

    private void ApplyCheckBoxGlow(CheckBox cb)
    {
        cb.PointerEntered += (s, e) =>
        {
            cb.Foreground = Brushes.White;
            cb.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 4, Opacity = 0.2 };
        };
        cb.PointerExited += (s, e) =>
        {
            cb.Foreground = new SolidColorBrush(Color.Parse("#B0B0B0"));
            cb.Effect = null;
        };
    }
}
