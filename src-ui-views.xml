<file path="src/AegisDNS.UI/InterFaces/AiLearnedBlocklistWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.AiLearnedBlocklistWindow"
        Title="AegisDNS — learned threat manager"
        Width="600" Height="600"
        MinWidth="500" MinHeight="500"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <Border Background="#050505" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="40,*">
        <!-- Custom Title Bar -->
        <Grid x:Name="titleBar" Grid.Row="0" Background="#111111" PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0" Spacing="8">
                <Button Width="14" Height="14" CornerRadius="7" Background="#FF5F56" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click"/>
                <Button Width="14" Height="14" CornerRadius="7" Background="#FFBD2E" BorderThickness="0" Cursor="Hand" Click="MinBtn_Click"/>
            </StackPanel>

            <TextBlock Text="AI-LEARNED BLOCKLIST" Foreground="Cyan" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" LetterSpacing="2">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="15" Opacity="0.6" />
                </TextBlock.Effect>
            </TextBlock>
        </Grid>

        <!-- Main Content -->
        <DockPanel Grid.Row="1" Margin="20">
            <!-- Header Text -->
            <StackPanel DockPanel.Dock="Top" Spacing="5" Margin="0,0,0,15">
                <TextBlock Text="THREATS AUTOMATICALLY LEARNED BY AI SENTINEL" Foreground="Cyan" FontSize="12" FontWeight="SemiBold" LetterSpacing="1" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock x:Name="lblDomainCount" Text="0 AI-learned blocks active" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Bottom Buttons -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,15,0,0">
                <Button x:Name="btnExport" Content="Export" Click="Export_Click" Background="#222222" Foreground="Cyan" BorderBrush="Cyan" BorderThickness="1" Padding="12,6" Cursor="Hand" FontSize="12"/>
                <Button x:Name="btnRemove" Content="Remove Selected (Add to Allowlist)" Click="Remove_Click" Background="#222222" Foreground="#FF4444" BorderBrush="#FF4444" BorderThickness="1" Padding="12,6" Cursor="Hand" FontSize="12"/>
            </StackPanel>

            <!-- List Box for Domains -->
            <Border Background="#111111" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="5">
                <ListBox x:Name="lstDomains" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="OrangeRed" FontFamily="Consolas, Courier New, Monospace" FontSize="13" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/AiSettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.AiSettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="AI SENTINEL"
        Width="750" Height="520"
        MinWidth="580" MinHeight="380"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="CheckBox.SettingToggle">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="CheckBox.SettingToggle:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border BorderBrush="Transparent" x:Name="titleBarBorder" BorderThickness="0,0,0,1">
            <Grid Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56" PointerPressed="CloseDot_PointerPressed" />
                    <Border Classes="TrafficDot" Background="#FFBD2E" PointerPressed="MinDot_PointerPressed" />
                </StackPanel>
                
                <TextBlock x:Name="titleLabel" Text="🤖 AI SENTINEL" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <DockPanel Grid.Row="1" Margin="25,8,25,15">
            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <TextBlock x:Name="contentTitle" Text="AI SENTINEL" FontSize="20" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Footer (Save Button) -->
            <Button x:Name="saveBtn" DockPanel.Dock="Bottom" Content="Save" Padding="16,6" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="5" HorizontalAlignment="Right" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1" Margin="0,10,0,0"/>

            <!-- Columns -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Spacing="6">
                    <!-- Sentinel Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="sentinelHeader" Text="SENTINEL CONTROL" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <CheckBox x:Name="chkEnableAi" Classes="SettingToggle" Content="Enable AI Sentinel" />

                    <!-- Sign-In Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="signInHeader" Text="PROVIDER SIGN-IN" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="providerCardsPanel" Spacing="6" />
                </StackPanel>

                <!-- Vertical Line -->
                <Border x:Name="vLine" Grid.Column="1" Width="1" Background="Cyan" Opacity="0.3" Margin="15,0,15,0"/>

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Spacing="8">
                    <!-- Model Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="modelHeader" Text="MODEL &amp; CONNECTION" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Active Provider:" FontSize="11" Foreground="Gray" />
                    <ComboBox x:Name="providerCombo" HorizontalAlignment="Stretch" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" />

                    <!-- Fallback Providers Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock Text="FALLBACK PROVIDERS" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="(Tried in order if primary fails)" FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Fallback 1:" FontSize="11" Foreground="Gray" />
                    <ComboBox x:Name="fallbackCombo1" HorizontalAlignment="Stretch" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" />

                    <TextBlock Text="Fallback 2:" FontSize="11" Foreground="Gray" />
                    <ComboBox x:Name="fallbackCombo2" HorizontalAlignment="Stretch" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" />

                    <TextBlock Text="Fallback 3:" FontSize="11" Foreground="Gray" />
                    <ComboBox x:Name="fallbackCombo3" HorizontalAlignment="Stretch" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" />

                    <TextBlock Text="Endpoint URL:" FontSize="11" Foreground="Gray" />
                    <TextBox x:Name="endpointBox" Watermark="http://localhost:11434" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" CaretBrush="Cyan" />

                    <TextBlock Text="Model Name:" FontSize="11" Foreground="Gray" />
                    <TextBox x:Name="modelBox" Watermark="e.g. llama3" Margin="0,0,0,6" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" CaretBrush="Cyan" />

                    <!-- Scan Interval Header -->
                    <StackPanel Margin="0,4,0,8">
                        <TextBlock x:Name="scanHeader" Text="SCAN INTERVAL" Foreground="Cyan" FontSize="12" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                    <GradientStop Color="#00FFFF" Offset="0" />
                                    <GradientStop Color="#1A4040" Offset="0.5" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <TextBlock x:Name="intervalLabel" FontSize="11" Foreground="Gray" />
                    <Slider x:Name="intervalSlider" Minimum="1" Maximum="30" Foreground="Cyan" />
                </StackPanel>
                </Grid>
            </ScrollViewer>
        </DockPanel>

    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

