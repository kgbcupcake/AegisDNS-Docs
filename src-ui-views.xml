<file path="src/AegisDNS.UI/InterFaces/StatsOverviewWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.UI.InterFaces.StatsOverviewWindow"
        Title="LIVE STATS"
        Width="520" Height="240"
        MinWidth="420" MinHeight="200"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                <Border Classes="TrafficDot" Background="#FF5F56"
                        PointerPressed="CloseDot_PointerPressed"/>
                <Border Classes="TrafficDot" Background="#FFBD2E"
                        PointerPressed="MinDot_PointerPressed"/>
            </StackPanel>
            <TextBlock x:Name="titleLabel"
                       Text="📊 LIVE STATS"
                       Foreground="Cyan" FontWeight="SemiBold" FontSize="12"
                       LetterSpacing="1" VerticalAlignment="Center"
                       HorizontalAlignment="Center" IsHitTestVisible="False"/>
        </Grid>

        <!-- Stats Body -->
        <Border Grid.Row="1" Margin="20,16,20,16"
                Background="#0D0D0D" BorderBrush="#1E1E1E"
                BorderThickness="1" CornerRadius="6" Padding="0,20">
            <Grid ColumnDefinitions="*,1,*,1,*,1,*">

                <!-- Total Queries -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="TOTAL QUERIES"
                               Foreground="#00FFFF" FontSize="9" FontWeight="Medium"
                               LetterSpacing="2" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="totalCounter"
                               Foreground="White" FontSize="32" FontWeight="Thin"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#1E1E1E" Width="1"
                        VerticalAlignment="Stretch" Margin="0,8"/>

                <!-- Threats Blocked -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="THREATS BLOCKED"
                               Foreground="#00FFFF" FontSize="9" FontWeight="Medium"
                               LetterSpacing="2" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="blockedCounter"
                               Foreground="#FF4444" FontSize="32" FontWeight="Thin"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="3" Background="#1E1E1E" Width="1"
                        VerticalAlignment="Stretch" Margin="0,8"/>

                <!-- Block Rate -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="BLOCK RATE"
                               Foreground="#00FFFF" FontSize="9" FontWeight="Medium"
                               LetterSpacing="2" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ratioCounter"
                               Foreground="#FF8800" FontSize="32" FontWeight="Thin"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="5" Background="#1E1E1E" Width="1"
                        VerticalAlignment="Stretch" Margin="0,8"/>

                <!-- Cache Hits -->
                <StackPanel Grid.Column="6" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="CACHE HITS"
                               Foreground="#00FFFF" FontSize="9" FontWeight="Medium"
                               LetterSpacing="2" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="cacheCounter"
                               Foreground="#39FF14" FontSize="32" FontWeight="Thin"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/TelemetryConsentWindow.axaml">
<utils:AegisLinuxWindow
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
    x:Class="AegisDNS.UI.TelemetryConsentWindow"
    Title="Privacy &amp; Telemetry Consent"
    Width="450" Height="320"
    Background="Transparent"
    CanResize="False"
    WindowStartupLocation="CenterScreen"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    ExtendClientAreaChromeHints="NoChrome"
    TransparencyLevelHint="Transparent"
    SystemDecorations="None">

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="45,*">
        <Grid Grid.Row="0" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
            <TextBlock Text="🛡️ Privacy Disclosure" Foreground="Cyan" FontWeight="Bold"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>
        <StackPanel Grid.Row="1" Margin="20" Spacing="15">
            <TextBlock Text="Help Improve AegisDNS" Foreground="Cyan" FontSize="18" FontWeight="Bold"/>
            <TextBlock TextWrapping="Wrap" Foreground="White" Opacity="0.8">
                AegisDNS can collect anonymous usage statistics to help us improve threat detection.
                We ONLY collect query counts, block counts, and version info.
            </TextBlock>
            <Border BorderBrush="#3300FFFF" BorderThickness="1" CornerRadius="8"
                    Padding="10" Background="#1A1A1A">
                <StackPanel Spacing="5">
                    <TextBlock Text="• Total DNS queries (count only)" Foreground="White" FontSize="12"/>
                    <TextBlock Text="• Total domains blocked (count only)" Foreground="White" FontSize="12"/>
                    <TextBlock Text="• Application version &amp; OS platform" Foreground="White" FontSize="12"/>
                    <TextBlock Text="• NO domain names, NO IPs, NO PII"
                               Foreground="#00FF00" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                <Button Grid.Column="0" Content="Allow Anonymous Stats" Click="Allow_Click"
                        Background="#00FFFF" Foreground="Black" FontWeight="Bold" CornerRadius="8"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Margin="0,0,5,0"/>
                <Button Grid.Column="1" Content="No Thanks" Click="Decline_Click"
                        Background="#333333" Foreground="White" CornerRadius="8"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Margin="5,0,0,0"/>
            </Grid>
        </StackPanel>
    </Grid>
    </Border>

</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/TopDomainsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
