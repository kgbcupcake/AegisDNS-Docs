using System;
using System.Linq;
using System.Reactive.Disposables;

using AegisDNS;
using AegisDNS.Core;
using AegisDNS.ViewModels;

using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Media;
using Avalonia.ReactiveUI;

using ReactiveUI;

namespace AegisDNS.UI.InterFaces;

public partial class DashboardView : ReactiveUserControl<MainViewModel>
{
    private static readonly Color CyanSolid = Color.Parse("#00FFFF");

    private readonly DashboardViewModel _dashVm = null!;
    private readonly MainWindow? _parent;

    public DashboardView()
    {
        InitializeComponent();
    }

    public DashboardView(MainWindow parent, MainViewModel viewModel)
    {
        InitializeComponent();

        _parent = parent;
        ViewModel = viewModel;
        _dashVm = new DashboardViewModel(viewModel);

        bool useGlow = ConfigManager.Settings.EnableNeonGlow;

        // Phase 17 — hide streaming card unless enabled
        streamingAdsCard.IsVisible = StreamingConfigManager.Settings.EnableStreamingAdBlock;

        if (useGlow)
        {
            ApplyGlowHover(statsCard);
            ApplyGlowHover(trafficCard);
            ApplyGlowHover(topDomainsCard);
            ApplyGlowHover(aiCard);
            ApplyGlowHover(shieldCard);
            ApplyGlowHover(settingsCard);
            ApplyGlowHover(routerCard);
            ApplyGlowHover(latencyCard);
            if (StreamingConfigManager.Settings.EnableStreamingAdBlock) ApplyGlowHover(streamingAdsCard);
            ApplyGlowHover(proxyStatsCard);

            headerTitle.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.6 };
            tierLabel.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.6 };
        }
        else
        {
            ApplyNormalHover(statsCard);
            ApplyNormalHover(trafficCard);
            ApplyNormalHover(topDomainsCard);
            ApplyNormalHover(aiCard);
            ApplyNormalHover(shieldCard);
            ApplyNormalHover(settingsCard);
            ApplyNormalHover(routerCard);
            ApplyNormalHover(latencyCard);
            if (StreamingConfigManager.Settings.EnableStreamingAdBlock) ApplyNormalHover(streamingAdsCard);
        }

        this.WhenActivated(disposables =>
        {
            // Status pill — same bindings as before, nothing moved
            this.OneWayBind(ViewModel, vm => vm.StatusText, v => v.statusText.Text)
                .DisposeWith(disposables);
            this.OneWayBind(ViewModel, vm => vm.StatusBrush, v => v.statusPill.Background)
                .DisposeWith(disposables);

            this.WhenAnyValue(v => v.ViewModel!.PulseBlur)
                .Subscribe(blur =>
                {
                    if (useGlow)
                        statusPill.BoxShadow = new BoxShadows(
                            new BoxShadow { Blur = blur, Color = Color.Parse("#4D00FFFF") });
                })
                .DisposeWith(disposables);

            _dashVm.WhenAnyValue(d => d.LicenseTier)
                .Subscribe(tier => tierLabel.Text = tier.ToUpper())
                .DisposeWith(disposables);

            // AI subtitle — live provider label on the hub card
            _dashVm.WhenAnyValue(d => d.AiProviderLabel)
                .Subscribe(ai => aiSubtitle.Text = $"Provider: {ai}")
                .DisposeWith(disposables);

            _dashVm.WhenAnyValue(d => d.AiLearnedBlocklistCount)
                .Subscribe(count => aiBlocklistCount.Text = count)
                .DisposeWith(disposables);

            _dashVm.WhenAnyValue(d => d.LastAiDetection)
                .Subscribe(det => aiLastDetection.Text = det)
                .DisposeWith(disposables);

            _dashVm.WhenAnyValue(d => d.AiConfidenceSummary)
                .Subscribe(conf => aiConfidence.Text = conf)
                .DisposeWith(disposables);

            // Phase 11 — Latency chip in header
            _dashVm.WhenAnyValue(d => d.UpstreamLatencyDisplay)
                .Subscribe(display => latencyChip.Text = $"⚡ {display}")
                .DisposeWith(disposables);

            _dashVm.WhenAnyValue(d => d.UpstreamLatencyMs)
                .Subscribe(ms =>
                {
                    if (ms < 0)
                        latencyChip.Foreground = new SolidColorBrush(Color.Parse("#555555"));
                    else if (ms < 100)
                        latencyChip.Foreground = Brushes.LimeGreen;
                    else if (ms < 300)
                        latencyChip.Foreground = Brushes.Orange;
                    else
                        latencyChip.Foreground = Brushes.Red;
                })
                .DisposeWith(disposables);

            // Phase 11 — Router Mode card subtitle
            _dashVm.WhenAnyValue(d => d.RouterModeStatus)
                .Subscribe(status => routerModeSubtitle.Text = $"Status: {status}")
                .DisposeWith(disposables);

            // Phase 11 — Latency card text
            _dashVm.WhenAnyValue(d => d.UpstreamLatencyDisplay)
                .Subscribe(display => latencyCardText.Text = $"Upstream: {display}")
                .DisposeWith(disposables);

            // Phase 17 — Streaming Ads Blocked counter
            _dashVm.WhenAnyValue(d => d.StreamingAdsBlockedToday)
                .Subscribe(count => streamingAdsCount.Text = count)
                .DisposeWith(disposables);

            // Phase 18 — HTTPS Proxy
            _dashVm.WhenAnyValue(d => d.ProxyStatus)
                .Subscribe(status => proxyStatusText.Text = $"Status: {status}")
                .DisposeWith(disposables);

            _dashVm.WhenAnyValue(d => d.ProxyAdsBlocked)
                .Subscribe(blocked => proxyBlockedText.Text = $"{blocked} ads blocked")
                .DisposeWith(disposables);
        });
    }

    // ── Card navigation ────────────────────────────────────────────────────────

    private void StatsCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => new StatsOverviewWindow(_dashVm).Show();

    private void TrafficCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => new TrafficHistoryWindow(_dashVm, ViewModel!).Show();

    private void TopDomainsCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => new TopDomainsWindow(_dashVm).Show();

    private void AiCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => new AiSettingsWindow().Show();

    private void ShieldCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => _parent?.NavigateToProtection();

    private void SettingsCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => new SettingsWindow().Show();

    private void RouterCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => new RouterModeWindow().Show();

    private void ProxyStatsCard_PointerPressed(object? sender, PointerPressedEventArgs e)
        => new HttpsProxySettingsWindow().Show();

    // ── Glow hover helpers — verbatim copy of SettingsWindow pattern ───────────

    private void ApplyGlowHover(Border? card)
    {
        if (card == null) return;

        TextBlock? titleText = card.Child switch
        {
            TextBlock textBlock => textBlock,
            StackPanel stackPanel => stackPanel.Children.OfType<TextBlock>().FirstOrDefault(),
            _ => null
        };

        card.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.2 };
        card.PointerEntered += (s, e) =>
        {
            card.BorderBrush = Brushes.Cyan;
            if (titleText != null) titleText.Foreground = Brushes.Cyan;
            card.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 12, Opacity = 0.5 };
        };
        card.PointerExited += (s, e) =>
        {
            card.BorderBrush = new SolidColorBrush(Color.Parse("#333333"));
            if (titleText != null) titleText.Foreground = Brushes.Cyan;
            card.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.2 };
        };
    }

    private void ApplyNormalHover(Border? card)
    {
        if (card == null) return;
        card.PointerEntered += (s, e) => card.BorderBrush = Brushes.Cyan;
        card.PointerExited += (s, e) => card.BorderBrush = new SolidColorBrush(Color.Parse("#333333"));
    }
}
