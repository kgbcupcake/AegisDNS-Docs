using System;
using System.Collections.Generic;
using System.Collections.Specialized;
using System.IO;
using System.Linq;

using AegisDNS.Core.Monitoring;
using AegisDNS.Core.Utilities;
using AegisDNS.UI.Linux;
using AegisDNS.ViewModels;

using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Interactivity;
using Avalonia.Platform.Storage;

namespace AegisDNS;

public partial class LogWindow : AegisLinuxWindow
{
    private readonly ListBox _logList = null!;
    private readonly TextBox _txtSearch = null!;
    private readonly RadioButton _radAll = null!;
    private readonly RadioButton _radBlocked = null!;
    private readonly RadioButton _radAllowed = null!;
    private bool _reallyClosing = false;
    private readonly MainViewModel? _viewModel;
    private string _currentFilter = "All";
    private string _searchText = string.Empty;
    private int _timeFilterIndex = 0;
    private string _sortColumn = "Timestamp";
    private bool _sortAscending = false;

    public LogWindow()
    {
        Avalonia.Markup.Xaml.AvaloniaXamlLoader.Load(this);


    }

    public LogWindow(MainViewModel viewModel)
    {
        Avalonia.Markup.Xaml.AvaloniaXamlLoader.Load(this);


        _viewModel = viewModel;
        DataContext = viewModel;

        _logList = this.FindControl<ListBox>("logList")!;
        _txtSearch = this.FindControl<TextBox>("txtSearch")!;
        _radAll = this.FindControl<RadioButton>("radAll")!;
        _radBlocked = this.FindControl<RadioButton>("radBlocked")!;
        _radAllowed = this.FindControl<RadioButton>("radAllowed")!;

        // Apply initial filter
        ApplyFilters();

        // Auto-scroll logic and filter re-application
        _viewModel.Logs.CollectionChanged += (s, e) =>
        {
            if (e.Action == NotifyCollectionChangedAction.Add)
            {
                // Only scroll if we aren't heavily filtered (simple heuristic)
                if (string.IsNullOrWhiteSpace(_searchText) && _currentFilter == "All")
                {
                    _logList.ScrollIntoView(_viewModel.Logs.Count - 1);
                }
                ApplyFilters(); // Re-evaluate the new item against current filters
            }
        };
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseBtn_Click(object? sender, RoutedEventArgs e)
    {
        this.Hide();
    }

    private void MinBtn_Click(object? sender, RoutedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void MaxBtn_Click(object? sender, RoutedEventArgs e)
    {
        WindowState = WindowState == WindowState.Maximized ? WindowState.Normal : WindowState.Maximized;
    }

    protected override void OnClosing(WindowClosingEventArgs e)
    {
        if (!_reallyClosing)
        {
            e.Cancel = true;
            this.Hide();
        }
        base.OnClosing(e);
    }

    public void ForceClose()
    {
        _reallyClosing = true;
        Close();
    }

    private void TxtSearch_TextChanged(object? sender, TextChangedEventArgs e)
    {
        _searchText = _txtSearch.Text?.ToLower() ?? string.Empty;
        ApplyFilters();
    }

    private void Filter_Checked(object? sender, RoutedEventArgs e)
    {
        if (sender is RadioButton rad && rad.IsChecked == true)
        {
            _currentFilter = rad.Content?.ToString() ?? "All";
            ApplyFilters();
        }
    }

    private void ApplyFilters()
    {
        if (_viewModel == null) return;

        var now = DateTime.Now;

        var filteredItems = _viewModel.Logs.Where(log =>
        {
            // 1. Level Filter
            bool levelMatch = _currentFilter switch
            {
                "Blocked" => log.Level == LogLevel.Block,
                "Allowed" => log.Level == LogLevel.Allow || log.Level == LogLevel.CacheHit || log.Level == LogLevel.Request,
                "AI Threats" => log.Level == LogLevel.AiThreat,
                _ => true
            };

            if (!levelMatch) return false;

            // 2. Time Filter
            if (_timeFilterIndex > 0)
            {
                TimeSpan maxAge = _timeFilterIndex switch
                {
                    1 => TimeSpan.FromMinutes(15),
                    2 => TimeSpan.FromHours(1),
                    3 => TimeSpan.FromHours(24),
                    _ => TimeSpan.MaxValue
                };
                if (now - log.Timestamp > maxAge) return false;
            }

            // 3. Text Search
            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                return log.FullText.ToLower().Contains(_searchText);
            }

            return true;
        });

        // 4. Sorting
        filteredItems = _sortColumn switch
        {
            "Level" => _sortAscending ? filteredItems.OrderBy(l => l.Level) : filteredItems.OrderByDescending(l => l.Level),
            "Domain" => _sortAscending ? filteredItems.OrderBy(l => l.Domain) : filteredItems.OrderByDescending(l => l.Domain),
            "Message" => _sortAscending ? filteredItems.OrderBy(l => l.Message) : filteredItems.OrderByDescending(l => l.Message),
            _ => _sortAscending ? filteredItems.OrderBy(l => l.Timestamp) : filteredItems.OrderByDescending(l => l.Timestamp)
        };

        _logList.ItemsSource = filteredItems.ToList();
    }

    private void TimeFilter_SelectionChanged(object? sender, SelectionChangedEventArgs e)
    {
        if (sender is ComboBox cmb)
        {
            _timeFilterIndex = cmb.SelectedIndex;
            ApplyFilters();
        }
    }

    private void HandleSort(string column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
            if (column == "Timestamp") _sortAscending = false;
        }
        ApplyFilters();
    }

    private void Sort_Timestamp(object? sender, RoutedEventArgs e) => HandleSort("Timestamp");
    private void Sort_Level(object? sender, RoutedEventArgs e) => HandleSort("Level");
    private void Sort_Domain(object? sender, RoutedEventArgs e) => HandleSort("Domain");
    private void Sort_Message(object? sender, RoutedEventArgs e) => HandleSort("Message");

    private async void Export_Click(object? sender, RoutedEventArgs e)
    {
        if (_viewModel == null || _viewModel.Logs.Count == 0) return;

        var topLevel = TopLevel.GetTopLevel(this);
        if (topLevel == null) return;

        try
        {
            var file = await topLevel.StorageProvider.SaveFilePickerAsync(new FilePickerSaveOptions
            {
                Title = "Export DNS Logs",
                SuggestedFileName = $"DNS_Log_{DateTime.Now:yyyyMMdd_HHmmss}.csv",
                DefaultExtension = "csv",
                FileTypeChoices = new[]
                {
                    new FilePickerFileType("CSV Files") { Patterns = new[] { "*.csv" } }
                }
            });

            if (file == null) return; // User cancelled

            using (var stream = await file.OpenWriteAsync())
            using (var writer = new StreamWriter(stream))
            {
                await writer.WriteLineAsync("Timestamp,Level,Domain,FullMessage");

                foreach (var log in _viewModel.Logs)
                {
                    // Escape quotes for CSV
                    var msg = log.Message.Replace("\"", "\"\"");
                    await writer.WriteLineAsync($"{log.Timestamp:o},{log.Level},{log.Domain},\"{msg}\"");
                }
            }

            var successMsg = LogEntry.Parse($"✅ Exported {_viewModel.Logs.Count} logs to {file.Name}");
            _viewModel.Logs.Add(successMsg);
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _viewModel.Logs.Add(LogEntry.Parse($"❌ Export failed: {ex.Message}"));
            ApplyFilters();
        }
    }

    private void AddToAllowlist_Click(object? sender, RoutedEventArgs e)
    {
        if (_logList.SelectedItem is not LogEntry selected) return;

        var domain = selected.Domain;
        if (string.IsNullOrWhiteSpace(domain)) return;

        AllowlistManager.Add(domain);
        _viewModel?.Logs.Add(LogEntry.Parse($"✅ ALLOWLISTED: {domain} — will no longer be blocked"));
        ApplyFilters();
    }

    private void ReportSafe_Click(object? sender, RoutedEventArgs e)
    {
        if (_logList.SelectedItem is not LogEntry selected) return;

        var domain = selected.Domain;
        if (string.IsNullOrWhiteSpace(domain)) return;

        SafeListingManager.Report(domain);
        _viewModel?.Logs.Add(LogEntry.Parse($"🛡️ REPORTED AS SAFE: {domain} — feedback sent to Sentinel"));
        ApplyFilters();
    }

    private async void CopyDomain_Click(object? sender, RoutedEventArgs e)
    {
        if (_logList.SelectedItem is not LogEntry selected) return;
        var domain = selected.Domain;
        if (!string.IsNullOrWhiteSpace(domain) && Clipboard != null)
            await Clipboard.SetTextAsync(domain);
    }

}
