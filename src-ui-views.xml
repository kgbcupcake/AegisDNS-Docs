                    <StackPanel Grid.Column="2" Spacing="6">
                        <!-- Header -->
                        <StackPanel Margin="0,4,0,6">
                            <TextBlock x:Name="updatesHeader" Text="UPDATES" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5" />
                            <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                        <GradientStop Offset="0" Color="#00FFFF"/>
                                        <GradientStop Offset="0.5" Color="#1A4040"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <CheckBox x:Name="chkAutoUpdateBlocklists" Classes="SettingToggle" Content="Auto-Update Blocklists" />
                        <TextBlock x:Name="updateStatusText" Foreground="Gray" FontSize="11" Margin="0,4,0,4" TextWrapping="Wrap" />
                        <Button x:Name="checkUpdatesBtn" Content="Check for App Updates" Padding="10,5" Background="#1E1E1E" Foreground="Cyan" BorderBrush="Cyan" BorderThickness="1" Cursor="Hand" FontSize="11" HorizontalAlignment="Left" />
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </DockPanel>

    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/GlowSettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        xmlns:controls="using:AegisDNS.UI.Controls"
        x:Class="AegisDNS.GlowSettingsWindow"
        x:DataType="vm:AppearanceViewModel"
        Title="NEON GLOW SETTINGS"
        Width="450" Height="400"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="140"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Panel>
        <controls:BackgroundEffectCanvas 
            EffectType="{Binding BackgroundEffect}" 
            IsActive="True" />

        <Grid RowDefinitions="38,*,50">
            <!-- Title Bar -->
            <Border x:Name="titleBarBorder" Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#1A4040">
                <Grid x:Name="titleBar" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#FF5F56" Cursor="Hand" PointerPressed="CloseDot_PointerPressed"/>
                        <Border Width="12" Height="12" CornerRadius="6" Background="#FFBD2E" Cursor="Hand" PointerPressed="MinDot_PointerPressed"/>
                    </StackPanel>
                    <TextBlock Text="NEON GLOW ENGINE" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="30,20" Spacing="20">
                <TextBlock Classes="SectionHeader" Text="GLOW CONFIGURATION"/>
                
                <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="FieldLabel" Text="Glow Color (Hex):" />
                            <TextBox Text="{Binding GlowColor}" Width="120" Background="#222" Foreground="{Binding GlowColor}" BorderBrush="#333" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="FieldLabel" Text="Intensity:" />
                            <Slider Value="{Binding GlowIntensity}" Minimum="0" Maximum="1" Width="200" Foreground="Cyan"/>
                            <TextBlock Text="{Binding GlowIntensity, StringFormat={}{0:F2}}" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center" Width="40"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="FieldLabel" Text="Spread Radius:" />
                            <Slider Value="{Binding GlowRadius}" Minimum="4" Maximum="30" Width="200" Foreground="Cyan"/>
                            <TextBlock Text="{Binding GlowRadius, StringFormat={}{0:F0}px}" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center" Width="40"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="Tip: Use bright neon hex codes like #00FFFF (Cyan) or #FF00FF (Magenta) for best effect." 
                           Foreground="#555" FontSize="10" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#161616" BorderThickness="0,1,0,0" BorderBrush="#222">
                <Grid Margin="20,0">
                    <TextBlock x:Name="backBtn" Text="← BACK TO APPEARANCE" Foreground="Gray" Cursor="Hand" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" PointerPressed="BackBtn_PointerPressed"/>
                    <Button Content="Save &amp; Close" Command="{Binding SaveCommand}" Click="SaveBtn_Click" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Padding="15,6"/>
                </Grid>
            </Border>
        </Grid>
    </Panel>
    </Border>
</utils:AegisLinuxWindow>
</file>

