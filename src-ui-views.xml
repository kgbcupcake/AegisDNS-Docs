        MinWidth="400" MinHeight="200"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">

        <Grid Grid.Row="0" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                <Border Classes="TrafficDot" Background="#FF5F56"
                        PointerPressed="CloseDot_PointerPressed"/>
                <Border Classes="TrafficDot" Background="#FFBD2E"
                        PointerPressed="MinDot_PointerPressed"/>
            </StackPanel>
            <TextBlock x:Name="titleLabel"
                       Text="📈 TRAFFIC HISTORY"
                       Foreground="Cyan" FontWeight="SemiBold" FontSize="12"
                       LetterSpacing="1" VerticalAlignment="Center"
                       HorizontalAlignment="Center" IsHitTestVisible="False"/>
        </Grid>

        <DockPanel Grid.Row="1" Margin="24,16,24,16">

            <TextBlock DockPanel.Dock="Top"
                       Text="QUERY VELOCITY — LAST 5 HOURS"
                       FontSize="9" Foreground="#00FFFF" LetterSpacing="2.5"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <Border Background="#0D0D0D" BorderBrush="#1E1E1E"
                    BorderThickness="1" CornerRadius="6" Padding="14,12">
                <StackPanel Spacing="10">

                    <!-- Sparkline -->
                    <Border Background="#111111" BorderBrush="#222222" BorderThickness="1"
                            CornerRadius="4" Height="80" ClipToBounds="True">
                        <Polyline x:Name="sparkline"
                                  Stroke="#00FFFF" StrokeThickness="1.5"
                                  Stretch="Fill"/>
                    </Border>

                    <!-- Last request -->
                    <TextBlock x:Name="lastRequestLabel"
                               FontSize="11" Foreground="Gray"
                               HorizontalAlignment="Center" FontStyle="Italic"/>
                </StackPanel>
