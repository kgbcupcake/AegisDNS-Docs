<file path="src/AegisDNS.UI/InterFaces/BlocklistSettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.BlocklistSettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="BLOCKLIST SETTINGS"
        Width="800" Height="550"
        MinWidth="600" MinHeight="420"
        MaxWidth="1200" MaxHeight="800"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="CheckBox.SettingToggle">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="CheckBox.SettingToggle:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border x:Name="titleBarBorder" Grid.Row="0" BorderThickness="0,0,0,1">
            <Grid x:Name="titleBar" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Width="12" Height="12" CornerRadius="6" Background="#FF5F56" Cursor="Hand" PointerPressed="CloseDot_PointerPressed"/>
                    <Border Width="12" Height="12" CornerRadius="6" Background="#FFBD2E" Cursor="Hand" PointerPressed="MinDot_PointerPressed"/>
                </StackPanel>
                <TextBlock x:Name="titleLabel" Text="📋 BLOCKLIST SETTINGS" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <DockPanel Grid.Row="1" Margin="20,8,20,12">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <TextBlock x:Name="contentTitle" Text="BLOCKLIST SETTINGS" FontSize="18" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center" />
            </Grid>

            <Button x:Name="saveBtn" DockPanel.Dock="Bottom" Content="Save" Padding="16,6" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="5" HorizontalAlignment="Right" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1" Margin="0,10,0,0"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column -->
                    <StackPanel Grid.Column="0" Spacing="6">
                        <!-- Header -->
                        <StackPanel Margin="0,4,0,6">
                            <TextBlock x:Name="tierHeader" Text="ACTIVE FILTERS" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5" />
                            <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                        <GradientStop Offset="0" Color="#00FFFF"/>
                                        <GradientStop Offset="0.5" Color="#1A4040"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,0,0,6">
                            <TextBlock Text="Current Tier:" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                            <TextBlock x:Name="activeTierText" FontSize="11" Foreground="Cyan" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <CheckBox x:Name="chkThreatIntel" Classes="SettingToggle" Content="Threat Intelligence (Malware/Phishing)" />
                        <CheckBox x:Name="chkPopUpAds" Classes="SettingToggle" Content="Block Aggressive Pop-Up Ads" />
                        <CheckBox x:Name="chkFake" Classes="SettingToggle" Content="Block Scams &amp; Fake Shops" />
                        <CheckBox x:Name="chkAdult" Classes="SettingToggle" Content="Block Adult Content (NSFW)" />
                        <CheckBox x:Name="chkGambling" Classes="SettingToggle" Content="Block Gambling Domains" />
                        <CheckBox x:Name="chkDynamicDns" Classes="SettingToggle" Content="Block Dynamic DNS (Abused by C2)" IsEnabled="{Binding IsEnterprise}" />
                        <CheckBox x:Name="chkNrd" Classes="SettingToggle" Content="Block Newly Registered Domains" IsEnabled="{Binding IsEnterprise}" />
                    </StackPanel>

                    <!-- Separator line -->
                    <Border x:Name="vLine" Grid.Column="1" Width="1" Background="Cyan" Opacity="0.3" Margin="15,0,15,0" />

                    <!-- Right Column -->
                    <StackPanel Grid.Column="2" Spacing="6">
                        <!-- Header -->
                        <StackPanel Margin="0,4,0,6">
                            <TextBlock x:Name="extraHeader" Text="SPECIALIZED &amp; CUSTOM" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5" />
                            <Border Height="1" Opacity="0.6" Margin="0,4,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                        <GradientStop Offset="0" Color="#00FFFF"/>
                                        <GradientStop Offset="0.5" Color="#1A4040"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>

                        <!-- Gaming Launcher Ad Blocking -->
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                            <CheckBox x:Name="chkGamingLauncher" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Text="Block Gaming Launcher Ads" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Removes ads from Epic, EA App, Ubisoft Connect, Battle.net." Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <Button x:Name="updateBlocklistsBtn" Content="Update Blocklists Now" Padding="10,5" Background="#1E1E1E" Foreground="Cyan" BorderBrush="Cyan" BorderThickness="1" Cursor="Hand" FontSize="11" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,5,0,0"/>

                        <Border Height="15" />

                        <!-- Custom Sources Placeholder -->
                        <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Custom Sources" Foreground="Gray" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="Custom URL list imports are configured via settings.json. UI management coming in a future update." Foreground="#777777" FontSize="10" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </DockPanel>

    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

