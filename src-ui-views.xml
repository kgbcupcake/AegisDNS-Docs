<file path="src/AegisDNS.UI/InterFaces/MainWindow.axaml.cs">
using System;
using System.Reflection;

using AegisDNS.Core;
using AegisDNS.Core.Utilities;
using AegisDNS.UI;
using AegisDNS.UI.Audio;
using AegisDNS.UI.Controls;
using AegisDNS.UI.InterFaces;
using AegisDNS.UI.Linux;
using AegisDNS.ViewModels;

using AegisSummaries;
using AegisSummaries.Views;

using Avalonia;
using Avalonia.Controls;
using Avalonia.Controls.ApplicationLifetimes;
using Avalonia.Controls.Notifications;
using Avalonia.Input;
using Avalonia.Interactivity;
using Avalonia.Media;
using Avalonia.ReactiveUI;
using Avalonia.Threading;

using ReactiveUI;

namespace AegisDNS;

public partial class MainWindow : AegisLinuxWindow, IViewFor<MainViewModel>
{
    public static readonly StyledProperty<MainViewModel?> ViewModelProperty =
        AvaloniaProperty.Register<MainWindow, MainViewModel?>(nameof(ViewModel));

    public MainViewModel? ViewModel
    {
        get => GetValue(ViewModelProperty);
        set => SetValue(ViewModelProperty, value);
    }

    object? IViewFor.ViewModel
    {
        get => ViewModel;
        set => ViewModel = (MainViewModel?)value;
    }

    private readonly LogWindow _liveLogWindow;
    private readonly Panel _contentArea;
    private readonly BackgroundEffectCanvas _bgCanvas;
    private readonly DropShadowEffect? _titleShadow;
    private bool _reallyClosing = false;
    private TrayIcon? _trayIcon;
    private WindowIcon? _iconOn;
    private WindowIcon? _iconOff;
    private readonly WindowNotificationManager? _notificationManager;
    private DispatcherTimer? _vfxTimer;

    public MainWindow() : this(false) { }

    public MainWindow(bool isFirstRun)
    {
        Avalonia.Markup.Xaml.AvaloniaXamlLoader.Load(this);


        ViewModel = new MainViewModel();
        DataContext = ViewModel;

        // Create window but DO NOT show it yet
        _liveLogWindow = new LogWindow(ViewModel);

        _contentArea = this.FindControl<Panel>("ContentArea")!;
        _bgCanvas = this.FindControl<BackgroundEffectCanvas>("BgCanvas")!;

        var titleLabel = this.FindControl<TextBlock>("titleLabel");
        if (titleLabel != null && titleLabel.Effect is DropShadowEffect shadowEffect)
        {
            _titleShadow = shadowEffect;
        }

        StartVfxPolling();

        this.WhenActivated(async disposables =>
        {
            NavigateToDashboard();
            disposables.Add(this.WhenAnyValue(x => x.ViewModel!.IsStealthMode)
                .Subscribe(stealth => ShowInTaskbar = !stealth));

            if (isFirstRun)
            {
                var consent = new TelemetryConsentWindow();
                await consent.ShowDialog(this);
            }

            // Phase 10: Show security reports if due
            if (SummaryProvider.IsWeeklySummaryDue())
            {
                var summary = SummaryProvider.GetWeeklySummary();
                // We pass a callback to open the LogWindow since WeeklySummaryWindow no longer has a hard reference to it
                var summaryWindow = new WeeklySummaryWindow(summary, () =>
                {
                    var logWindow = new LogWindow();
                    logWindow.Show();
                });
                await summaryWindow.ShowDialog(this);
            }
            if (SummaryProvider.IsDailySummaryDue())
            {
                var summary = SummaryProvider.GetDailySummary();
                var summaryWindow = new DailySummaryWindow(summary);
                await summaryWindow.ShowDialog(this);
            }

            ViewModel.WindowToggleRequested += (s, e) => ToggleVisibility();
            ViewModel.AppExitRequested += (s, e) => RealExit();

            InitializeTrayIcon();
        });

        // Hook up global UI click sounds for buttons
        this.AddHandler(Button.ClickEvent, OnAnyButtonClicked, RoutingStrategies.Bubble, true);

        // Initialize Notification Manager
        _notificationManager = new WindowNotificationManager(TopLevel.GetTopLevel(this))
        {
            Position = NotificationPosition.BottomRight,
            MaxItems = 3
        };

        ViewModel!.AiThreatDetected += (s, msg) =>
        {
            Dispatcher.UIThread.InvokeAsync(() =>
            {
                AegisDNS.UI.Audio.AudioFeedbackManager.PlayThreatAlert();
                _notificationManager.Show(new Notification("🤖 AI Threat Neutralized", msg, NotificationType.Warning));
            });
        };
    }

    private void StartVfxPolling()
    {
        _vfxTimer = new DispatcherTimer
        {
            Interval = TimeSpan.FromMilliseconds(500)
        };
        _vfxTimer.Tick += (s, args) =>
        {
            ApplyVfxSettings();
        };
        _vfxTimer.Start();

        // Initial apply
        ApplyVfxSettings();
    }

    private void ApplyVfxSettings()
    {
        if (_bgCanvas == null) return;

        var settings = ConfigManager.Settings;

        // Apply Background Effects
        if (_bgCanvas.EffectType != settings.BackgroundEffect)
        {
            _bgCanvas.EffectType = settings.BackgroundEffect ?? "None";
        }

        _bgCanvas.CrtModeEnabled = settings.CrtModeEnabled;

        // Apply Window Backdrop (Mica / Acrylic / Solid)
        var backdrop = settings.WindowBackdrop ?? "Solid";
        if (backdrop == "Acrylic" || backdrop == "Mica") // Fallback Mica to Acrylic on older OS
        {
            TransparencyLevelHint = new[] { WindowTransparencyLevel.AcrylicBlur, WindowTransparencyLevel.None };
        }
        else
        {
            TransparencyLevelHint = new[] { WindowTransparencyLevel.None };
        }

        // Apply Window Opacity
        byte alpha = (byte)(settings.BackgroundOpacity * 255.0);
        this.Background = new SolidColorBrush(Color.FromArgb(alpha, 5, 5, 5)); // Base Dark #050505

        // Apply Glow and Theme
        if (Color.TryParse(settings.GlowColor, out Color glowColor))
        {
            _bgCanvas.EffectColor = new SolidColorBrush(glowColor);

            if (_titleShadow != null)
            {
                _titleShadow.Color = glowColor;
                _titleShadow.Opacity = settings.GlowIntensity;
                _titleShadow.BlurRadius = settings.GlowRadius;
            }
        }

        // Pause VFX when minimized to save CPU (unless the user has a live dashboard open, which we determine by UI state)
        _bgCanvas.IsActive = WindowState != WindowState.Minimized;
    }

    private void InitializeTrayIcon()
    {
        _trayIcon = new TrayIcon
        {
            ToolTipText = "AegisDNS Shield"
        };

        try
        {
            _iconOn = new Avalonia.Controls.WindowIcon(Avalonia.Platform.AssetLoader.Open(new Uri("avares://AegisDNS.UI/Assets/aegis-on.ico")));
            _iconOff = new Avalonia.Controls.WindowIcon(Avalonia.Platform.AssetLoader.Open(new Uri("avares://AegisDNS.UI/Assets/aegis-off.ico")));
            _trayIcon.Icon = _iconOff; // Default state
        }
        catch { /* Fallback */ }

        var menu = new NativeMenu();

        var toggleItem = new NativeMenuItem("Show/Hide Dashboard");
        toggleItem.Command = ViewModel!.ToggleWindow;
        menu.Add(toggleItem);

        menu.Add(new NativeMenuItemSeparator());

        var exitItem = new NativeMenuItem("Exit AegisDNS");
        exitItem.Command = ViewModel!.ExitApp;
        menu.Add(exitItem);

        _trayIcon.Menu = menu;
        _trayIcon.Command = ViewModel!.ToggleWindow;

        var trayIcons = new TrayIcons { _trayIcon };
        TrayIcon.SetIcons(Application.Current!, trayIcons);

        // Subscribe to IsServiceOnline changes to toggle the icon dynamically
        ViewModel.PropertyChanged += (s, e) =>
        {
            if (e.PropertyName == nameof(MainViewModel.IsServiceOnline))
            {
                Dispatcher.UIThread.InvokeAsync(() =>
                {
                    if (_trayIcon != null)
                    {
                        _trayIcon.Icon = ViewModel.IsServiceOnline ? _iconOn : _iconOff;
                        _trayIcon.ToolTipText = ViewModel.IsServiceOnline ? "AegisDNS Shield (🟢 Active)" : "AegisDNS Shield (🔴 Offline)";
                    }
                });
            }
        };
    }

    private void ToggleVisibility()
    {
        if (IsVisible)
        {
            Hide();
        }
        else
        {
            Show();
            Activate();
        }
    }

    private void RealExit()
    {
        _reallyClosing = true;
        _liveLogWindow.ForceClose();
        ViewModel?.Stop();

        // Use Avalonia's Application lifetime if available, otherwise just exit
        if (Application.Current?.ApplicationLifetime is Avalonia.Controls.ApplicationLifetimes.IClassicDesktopStyleApplicationLifetime desktop)
        {
            desktop.Shutdown();
        }
        else
        {
            Environment.Exit(0);
        }
    }

    protected override void OnClosing(WindowClosingEventArgs e)
    {
        if (!_reallyClosing)
        {
            e.Cancel = true;
            Hide();
        }
        base.OnClosing(e);
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void OnAnyButtonClicked(object? sender, RoutedEventArgs e)
    {
        // Don't play click sound for window controls or basic toggles to avoid spam
        if (e.Source is Button btn && btn.Name != "CloseBtn" && btn.Name != "MinBtn" && btn.Name != "MaxBtn")
        {
            AudioFeedbackManager.PlayClick();
        }
    }

    private void CloseBtn_Click(object? sender, RoutedEventArgs e)
    {
        // Fake close - hide to tray
        Hide();
    }

    private void MinBtn_Click(object? sender, RoutedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void MaxBtn_Click(object? sender, RoutedEventArgs e)
    {
        WindowState = WindowState == WindowState.Maximized ? WindowState.Normal : WindowState.Maximized;
    }

    public void NavigateToDashboard()
    {
        _contentArea.Children.Clear();
        _contentArea.Children.Add(new DashboardView(this, ViewModel!));
    }

    public void NavigateToProtection()
    {
        _contentArea.Children.Clear();
        _contentArea.Children.Add(new ProtectionView(this, ViewModel!));
    }

    public void NavigateToSettings()
    {
        var settingsWin = new SettingsWindow();
        settingsWin.Show();
    }

    // --- LOG WINDOW CONTROL ---
    public void ShowLog()
    {
        _liveLogWindow.Show();
        _liveLogWindow.Activate();
    }

    // ADDED: Hide the log window
    public void HideLog()
    {
        _liveLogWindow.Hide();
    }
}
