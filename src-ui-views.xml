<file path="src/AegisDNS.UI/InterFaces/XdpSettingsWindow.axaml.cs">
using System;
using System.Reactive.Disposables;
using System.Runtime.Versioning;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.UI.Linux;
using AegisDNS.ViewModels;

using Avalonia;
using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Media;
using Avalonia.Threading;

using ReactiveUI;

namespace AegisDNS;

/// <summary>
/// Premium XDP Ingress Shield settings window.
/// Full glow treatment, live stats refresh, kernel mode badge, enterprise badge.
/// </summary>
[SupportedOSPlatform("linux")]
public partial class XdpSettingsWindow : AegisLinuxWindow, IViewFor<XdpSettingsViewModel>
{
    public static readonly StyledProperty<XdpSettingsViewModel?> ViewModelProperty =
        AvaloniaProperty.Register<XdpSettingsWindow, XdpSettingsViewModel?>(nameof(ViewModel));

    public XdpSettingsViewModel? ViewModel
    {
        get => GetValue(ViewModelProperty);
        set => SetValue(ViewModelProperty, value);
    }

    object? IViewFor.ViewModel
    {
        get => ViewModel;
        set => ViewModel = (XdpSettingsViewModel?)value;
    }

    private static readonly Color CyanSolid = Color.Parse("#00FFFF");
    private readonly DispatcherTimer? _statsTimer;

    public XdpSettingsWindow()
    {
        InitializeComponent();


        ViewModel = new XdpSettingsViewModel();
        DataContext = ViewModel;
        bool useGlow = ConfigManager.Settings.EnableNeonGlow;

        if (useGlow)
        {
            // Title glow
            titleLabel.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 12, Opacity = 0.6 };
            titleBarBorder.BorderBrush = new SolidColorBrush(Color.Parse("#1A4040"));

            // Content title glow
            contentTitle.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 15, Opacity = 0.5 };

            // Section header glows
            modeHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            rulesHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            statusHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            statsHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };

            // Drop counter glow
            dropCountText.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 14, Opacity = 0.5 };

            // Vertical divider glow
            vLine.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.5 };

            // Back button hover
            backBtn.PointerEntered += (s, e) => { backBtn.Foreground = Brushes.White; backBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };
            backBtn.PointerExited += (s, e) => { backBtn.Foreground = Brushes.Cyan; backBtn.Effect = null; };

            // Save button hover + glow
            saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 14, Opacity = 0.6 }; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };

            // Detach button hover (danger glow)
            var dangerColor = Color.Parse("#FF5555");
            detachBtn.PointerEntered += (s, e) => { detachBtn.Background = new SolidColorBrush(Color.Parse("#550000")); detachBtn.Effect = new DropShadowEffect { Color = dangerColor, BlurRadius = 10, Opacity = 0.5 }; };
            detachBtn.PointerExited += (s, e) => { detachBtn.Background = new SolidColorBrush(Color.Parse("#331111")); detachBtn.Effect = null; };

            // TextBox glow
            ApplyTextBoxGlow(ifaceBox);

            // CheckBox glows
            ApplyCheckBoxGlow(chkRfc1918);
            ApplyCheckBoxGlow(chkAlertDrop);

            // Enterprise badge glow
            enterpriseBadge.Effect = new DropShadowEffect { Color = Color.Parse("#FF8C00"), BlurRadius = 8, Opacity = 0.4 };
        }
        else
        {
            backBtn.PointerEntered += (s, e) => backBtn.Foreground = Brushes.White;
            backBtn.PointerExited += (s, e) => backBtn.Foreground = Brushes.Cyan;

            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; };

            detachBtn.PointerEntered += (s, e) => detachBtn.Background = new SolidColorBrush(Color.Parse("#550000"));
            detachBtn.PointerExited += (s, e) => detachBtn.Background = new SolidColorBrush(Color.Parse("#331111"));
        }

        // Save button click with green flash
        this.WhenActivated(disposables =>
        {
            saveBtn.Click += async (s, e) =>
            {
                ViewModel!.SaveSettings.Execute().Subscribe();
                var originalText = saveBtn.Content;
                saveBtn.Content = "✅ Saved";
                saveBtn.Background = new SolidColorBrush(Color.Parse("#004400"));
                saveBtn.Foreground = Brushes.LimeGreen;
                saveBtn.BorderBrush = Brushes.LimeGreen;
                if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = Colors.LimeGreen, BlurRadius = 10, Opacity = 0.5 };
                await Task.Delay(1500);
                saveBtn.Content = originalText;
                saveBtn.Background = new SolidColorBrush(Color.Parse("#006666"));
                saveBtn.Foreground = Brushes.Cyan;
                saveBtn.BorderBrush = Brushes.Cyan;
                if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
            };
        });

        // Live stats refresh timer (2s)
        _statsTimer = new DispatcherTimer { Interval = TimeSpan.FromSeconds(2) };
        _statsTimer.Tick += (s, e) =>
        {
            ViewModel?.RefreshMetrics();
            UpdateKernelModeBadge();
        };
        _statsTimer.Start();
    }

    private void UpdateKernelModeBadge()
    {
        if (ViewModel == null) return;

        // Determine badge state based on XDP mode and metrics
        int mode = ViewModel.XdpMode;
        if (mode == 0)
        {
            kernelModeText.Text = "NOT LOADED";
            kernelModeText.Foreground = new SolidColorBrush(Color.Parse("#888888"));
            kernelModeBadge.Background = new SolidColorBrush(Color.Parse("#333333"));
        }
        else if (mode == 1)
        {
            kernelModeText.Text = "MONITOR";
            kernelModeText.Foreground = new SolidColorBrush(Color.Parse("#FFBD2E"));
            kernelModeBadge.Background = new SolidColorBrush(Color.Parse("#332B00"));
        }
        else
        {
            kernelModeText.Text = "ACTIVE ⚡";
            kernelModeText.Foreground = new SolidColorBrush(Color.Parse("#00FF88"));
            kernelModeBadge.Background = new SolidColorBrush(Color.Parse("#003318"));
        }
    }

    protected override void OnClosed(EventArgs e)
    {
        _statsTimer?.Stop();
        base.OnClosed(e);
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        Close();
    }

    private void MinDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void BackBtn_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var settings = new SettingsWindow();
        settings.Show();
        this.Close();
    }

    private void ApplyTextBoxGlow(TextBox tb)
    {
        tb.GotFocus += (s, e) =>
        {
            tb.BorderBrush = Brushes.Cyan;
            tb.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
        };
        tb.LostFocus += (s, e) =>
        {
            tb.BorderBrush = new SolidColorBrush(Color.Parse("#333333"));
            tb.Effect = null;
        };
    }

    private void ApplyCheckBoxGlow(CheckBox cb)
    {
        cb.PointerEntered += (s, e) =>
        {
            cb.Foreground = Brushes.White;
            cb.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 4, Opacity = 0.2 };
        };
        cb.PointerExited += (s, e) =>
        {
            cb.Foreground = new SolidColorBrush(Color.Parse("#B0B0B0"));
            cb.Effect = null;
        };
    }
}
</file>

