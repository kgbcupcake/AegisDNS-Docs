using System;
using System.Reactive.Disposables;

using AegisDNS.Core;
using AegisDNS.UI.Audio;
using AegisDNS.UI.Linux;
using AegisDNS.ViewModels;

using Avalonia;
using Avalonia.Controls;
using Avalonia.Controls.Notifications;
using Avalonia.Controls.Primitives;
using Avalonia.Input;
using Avalonia.Interactivity;
using Avalonia.Media;
using Avalonia.Platform.Storage;
using Avalonia.ReactiveUI;
using Avalonia.Threading;

using ReactiveUI;

namespace AegisDNS;

public partial class AppearanceWindow : AegisLinuxWindow, IViewFor<AppearanceViewModel>
{
    public static readonly StyledProperty<AppearanceViewModel?> ViewModelProperty =
        AvaloniaProperty.Register<AppearanceWindow, AppearanceViewModel?>(nameof(ViewModel));

    public AppearanceViewModel? ViewModel
    {
        get => GetValue(ViewModelProperty);
        set => SetValue(ViewModelProperty, value);
    }

    object? IViewFor.ViewModel
    {
        get => ViewModel;
        set => ViewModel = (AppearanceViewModel?)value;
    }

    public AppearanceWindow()
    {
        InitializeComponent();


        ViewModel = new AppearanceViewModel(
            getExportPath: async () =>
            {
                var topLevel = TopLevel.GetTopLevel(this);
                if (topLevel == null) return null;
                var file = await topLevel.StorageProvider.SaveFilePickerAsync(new FilePickerSaveOptions
                {
                    Title = "Export AegisDNS Theme",
                    DefaultExtension = "json",
                    FileTypeChoices = new[] { new FilePickerFileType("JSON Theme") { Patterns = new[] { "*.json" } } }
                });
                return file?.Path.LocalPath;
            },
            getImportPath: async () =>
            {
                var topLevel = TopLevel.GetTopLevel(this);
                if (topLevel == null) return null;
                var files = await topLevel.StorageProvider.OpenFilePickerAsync(new FilePickerOpenOptions
                {
                    Title = "Import AegisDNS Theme",
                    AllowMultiple = false,
                    FileTypeFilter = new[] { new FilePickerFileType("JSON Theme") { Patterns = new[] { "*.json" } } }
                });
                return files.Count > 0 ? files[0].Path.LocalPath : null;
            }
        );
        DataContext = ViewModel;

        // Hook up global UI click sounds for buttons
        this.AddHandler(Button.ClickEvent, OnAnyButtonClicked, RoutingStrategies.Bubble, true);

        ViewModel.ImportFailed += (s, msg) =>
        {
            Dispatcher.UIThread.InvokeAsync(() =>
            {
                var notificationManager = new WindowNotificationManager(TopLevel.GetTopLevel(this))
                {
                    Position = NotificationPosition.BottomRight,
                    MaxItems = 3
                };
                notificationManager.Show(new Notification("Import Failed", msg, NotificationType.Error));
            });
        };

        // Apply dynamic initial rendering (Glow, Colors) driven by the VM
        this.WhenActivated(disposables =>
        {
            // Subscribe to Save command to log and close
            ViewModel.SaveCommand.Subscribe(_ =>
            {
                // Optionally show a "Saved" toast here
                Close();
            }).DisposeWith(disposables);
        });
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    public void GlowCard_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var win = new GlowSettingsWindow { DataContext = this.DataContext };
        win.Show();
        this.Close();
    }

    public void BackgroundCard_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var win = new BackgroundSettingsWindow { DataContext = this.DataContext };
        win.Show();
        this.Close();
    }

    public void MaterialCard_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var win = new WindowMaterialWindow { DataContext = this.DataContext };
        win.Show();
        this.Close();
    }

    public void AudioCard_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var win = new AudioSettingsWindow { DataContext = this.DataContext };
        win.Show();
        this.Close();
    }

    private void BackBtn_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var settings = new SettingsWindow();
        settings.Show();
        this.Close();
    }

    private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e) => Close();
    private void MinDot_PointerPressed(object? sender, PointerPressedEventArgs e) => WindowState = WindowState.Minimized;

    private void OnAnyButtonClicked(object? sender, RoutedEventArgs e)
    {
        if (e.Source is Button btn && btn.Name != "CloseDot" && btn.Name != "MinDot")
        {
            AudioFeedbackManager.PlayClick();
        }
    }
}
