<file path="src/AegisDNS.UI/InterFaces/ProtectionView.axaml.cs">
using System;
using System.Reactive.Disposables;

using AegisDNS.Core;
using AegisDNS.ViewModels;

using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Media;
using Avalonia.ReactiveUI;

using ReactiveUI;

namespace AegisDNS;

public partial class ProtectionView : ReactiveUserControl<MainViewModel>
{

    public ProtectionView()
    {
        InitializeComponent();
    }

    public ProtectionView(MainWindow parent, MainViewModel viewModel)
    {
        InitializeComponent();

        ViewModel = viewModel;

        bool useGlow = ConfigManager.Settings.EnableNeonGlow;
        var cyanGlow = useGlow ? Color.Parse("#4D00FFFF") : Colors.Transparent;
        var limeGlow = useGlow ? Color.Parse("#8000FF00") : Colors.Transparent;


        if (useGlow)
        {
            titleText.Effect = new DropShadowEffect { Color = Colors.Cyan, BlurRadius = 10, Opacity = 0.4 };
        }

        toggleBtn.Click += (s, e) =>
        {
            if (ViewModel.StatusText.StartsWith("OFFLINE") || ViewModel.StatusText.StartsWith("ONLINE"))
            {
                parent.ShowLog();
            }
            else
            {
                parent.HideLog();
            }
        };

        backBtn.Click += (s, e) => parent.NavigateToDashboard();

        // --- BINDINGS ---
        this.WhenActivated(disposables =>
        {
            this.OneWayBind(ViewModel, vm => vm.StatusText, v => v.statusLabel.Text).DisposeWith(disposables);
            this.OneWayBind(ViewModel, vm => vm.StatusBrush, v => v.statusPill.Background).DisposeWith(disposables);
            this.OneWayBind(ViewModel, vm => vm.ToggleBtnText, v => v.toggleBtn.Content).DisposeWith(disposables);
            this.OneWayBind(ViewModel, vm => vm.ToggleBtnBrush, v => v.toggleBtn.Background).DisposeWith(disposables);

            // Protection button only works if service is online
            this.OneWayBind(ViewModel, vm => vm.IsServiceOnline, v => v.toggleBtn.IsEnabled).DisposeWith(disposables);

            // Service button only shows if service is offline
            this.OneWayBind(ViewModel, vm => vm.IsServiceOnline, v => v.startServiceBtn.IsVisible, online => !online).DisposeWith(disposables);
            this.OneWayBind(ViewModel, vm => vm.IsBusy, v => v.startServiceBtn.IsEnabled, busy => !busy).DisposeWith(disposables);

            this.BindCommand(ViewModel, vm => vm.ToggleProtection, v => v.toggleBtn).DisposeWith(disposables);
            this.BindCommand(ViewModel, vm => vm.StartService, v => v.startServiceBtn).DisposeWith(disposables);
            this.BindCommand(ViewModel, vm => vm.ForceStop, v => v.forceStop).DisposeWith(disposables);

            if (useGlow)
            {
                this.WhenAnyValue(v => v.ViewModel!.StatusBrush)
                    .Subscribe(brush =>
                    {
                        if (ViewModel.StatusText.StartsWith("ONLINE"))
                            statusPill.BoxShadow = new BoxShadows(new BoxShadow { Blur = 10, Color = limeGlow });
                        else
                            statusPill.BoxShadow = default;
                    }).DisposeWith(disposables);

                btnContainer.PointerEntered += (s, e) =>
                {
                    if (toggleBtn.IsEnabled)
                        btnContainer.BoxShadow = new BoxShadows(new BoxShadow { Blur = 15, Color = cyanGlow });
                };
                btnContainer.PointerExited += (s, e) =>
                {
                    btnContainer.BoxShadow = default;
                };
            }
        });
    }
}
