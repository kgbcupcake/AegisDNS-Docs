<file path="src/AegisDNS.UI/InterFaces/AppearanceWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        xmlns:controls="using:AegisDNS.UI.Controls"
        x:Class="AegisDNS.AppearanceWindow"
        x:DataType="vm:AppearanceViewModel"
        Title="VFX &amp; APPEARANCE"
        Width="600" Height="650"
        MinWidth="500" MinHeight="500"
        MaxWidth="900" MaxHeight="800"
        Background="#121212"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="140"/>
        </Style>
        <Style Selector="Border.ProBadge">
            <Setter Property="Background" Value="#FF9900"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.ProText">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Panel>
        <!-- BACKGROUND EFFECT CANVAS -->
        <controls:BackgroundEffectCanvas 
            EffectType="{Binding BackgroundEffect}" 
            IsActive="True" />

        <Grid RowDefinitions="38,*,50" Background="Transparent">
            <!-- Title Bar -->
            <Border x:Name="titleBarBorder" Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#1A4040">
            <Grid x:Name="titleBar" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Width="12" Height="12" CornerRadius="6" Background="#FF5F56" Cursor="Hand" PointerPressed="CloseDot_PointerPressed"/>
                    <Border Width="12" Height="12" CornerRadius="6" Background="#FFBD2E" Cursor="Hand" PointerPressed="MinDot_PointerPressed"/>
                </StackPanel>
                <TextBlock x:Name="titleLabel" Text="VFX &amp; APPEARANCE ENGINE" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Margin="20,10,20,10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="10" MaxWidth="520" HorizontalAlignment="Center">
                
                <!-- THEME PROFILES -->
                <Border Background="#1A1A1A" CornerRadius="8" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="THEME PROFILES" Foreground="Cyan" FontSize="13" FontWeight="Bold" LetterSpacing="2" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="FieldLabel" Text="Active Profile:" />
                            <TextBox Text="{Binding ActiveThemeName}" Width="200" Background="#222" Foreground="White" BorderBrush="#333"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                            <Button Content="Reset VFX" Command="{Binding ResetToDefaultCommand}" Background="#331111" Foreground="#FF5555" BorderBrush="#882222" BorderThickness="1" CornerRadius="4" FontSize="11" Padding="10,5" Cursor="Hand"/>
                            <Button Content="Export Theme" Command="{Binding ExportThemeCommand}" IsEnabled="{Binding IsPro}" Background="#222" Foreground="LightGray" BorderBrush="#444" BorderThickness="1" CornerRadius="4" FontSize="11" Padding="10,5" Cursor="Hand"/>
                            <Button Content="Import Theme" Command="{Binding ImportThemeCommand}" IsEnabled="{Binding IsPro}" Background="#222" Foreground="LightGray" BorderBrush="#444" BorderThickness="1" CornerRadius="4" FontSize="11" Padding="10,5" Cursor="Hand"/>
                            <Border Classes="ProBadge" IsVisible="{Binding !IsPro}"><TextBlock Classes="ProText" Text="PRO / PRIME"/></Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Navigation Cards Grid -->
                <UniformGrid Columns="2" Margin="0,8,0,0">
                    <!-- GLOW CARD -->
                    <Border x:Name="glowCard" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" Cursor="Hand" Margin="6"
                            PointerPressed="GlowCard_PointerPressed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="✨ Neon Glow" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Color, intensity, spread radius" Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- BACKGROUND CARD -->
                    <Border x:Name="backgroundCard" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" Cursor="Hand" Margin="6"
                            PointerPressed="BackgroundCard_PointerPressed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="🌌 Background FX" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="DataStream, nodes, CRT overlay" Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- MATERIAL CARD -->
                    <Border x:Name="materialCard" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" Cursor="Hand" Margin="6"
                            PointerPressed="MaterialCard_PointerPressed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="🪟 Window Material" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Backdrop type, opacity" Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- AUDIO CARD -->
                    <Border x:Name="audioCard" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" Cursor="Hand" Margin="6"
                            PointerPressed="AudioCard_PointerPressed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="🔊 Audio Immersion" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Sound pack, threat alerts" Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#161616" BorderThickness="0,1,0,0" BorderBrush="#222" Opacity="0.95">
            <Grid Margin="20,0">
                <TextBlock x:Name="backBtn" Text="← BACK TO SETTINGS" Foreground="Gray" Cursor="Hand" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" PointerPressed="BackBtn_PointerPressed"/>
                <Button x:Name="saveBtn" Content="Apply Changes" Command="{Binding SaveCommand}" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1" Padding="20,8"/>
            </Grid>
        </Border>
    </Grid>
    </Panel>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/AudioSettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        xmlns:controls="using:AegisDNS.UI.Controls"
        x:Class="AegisDNS.AudioSettingsWindow"
        x:DataType="vm:AppearanceViewModel"
        Title="AUDIO IMMERSION SETTINGS"
        Width="450" Height="400"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="140"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Panel>
        <controls:BackgroundEffectCanvas 
            EffectType="{Binding BackgroundEffect}" 
            IsActive="True" />

        <Grid RowDefinitions="38,*,50">
            <!-- Title Bar -->
            <Border x:Name="titleBarBorder" Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#1A4040">
                <Grid x:Name="titleBar" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#FF5F56" Cursor="Hand" PointerPressed="CloseDot_PointerPressed"/>
                        <Border Width="12" Height="12" CornerRadius="6" Background="#FFBD2E" Cursor="Hand" PointerPressed="MinDot_PointerPressed"/>
                    </StackPanel>
                    <TextBlock Text="AUDIO IMMERSION ENGINE" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="30,20" Spacing="20">
                <TextBlock Classes="SectionHeader" Text="SOUNDSCAPE &amp; FEEDBACK"/>
                
                <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="FieldLabel" Text="UI Sound Pack:" />
                            <ComboBox SelectedItem="{Binding AudioPack}" Width="200" Background="#222" Foreground="White" BorderBrush="#333">
                                <sys:String>Muted</sys:String>
                                <sys:String>SciFiTerminal</sys:String>
                                <sys:String>MinimalistClicks</sys:String>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Classes="FieldLabel" Text="Threat Alert Sound:" />
                            <ToggleSwitch IsChecked="{Binding ThreatAlertSound}" OnContent="Active" OffContent="Disabled"/>
                            <Border Classes="ProBadge" IsVisible="{Binding !IsPro}" Background="#FF9900" CornerRadius="3" Padding="4,1" Margin="10,0,0,0">
                                <TextBlock Text="PRO" Foreground="Black" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="Tip: UI sounds provide haptic-like feedback for clicks and actions." 
                           Foreground="#555" FontSize="10" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#161616" BorderThickness="0,1,0,0" BorderBrush="#222">
                <Grid Margin="20,0">
                    <TextBlock x:Name="backBtn" Text="← BACK TO APPEARANCE" Foreground="Gray" Cursor="Hand" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" PointerPressed="BackBtn_PointerPressed"/>
                    <Button Content="Save &amp; Close" Command="{Binding SaveCommand}" Click="SaveBtn_Click" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Padding="15,6"/>
                </Grid>
            </Border>
        </Grid>
    </Panel>
    </Border>
</utils:AegisLinuxWindow>
</file>

