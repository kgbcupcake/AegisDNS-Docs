<file path="src/AegisDNS.UI/InterFaces/CloudConnectWindow.axaml">
<utils:AegisLinuxWindow
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
    x:Class="AegisDNS.UI.CloudConnectWindow"
    Title="AegisDNS — Cloud Connect"
    Width="480" Height="480"
    MinWidth="440" MinHeight="460"
    Background="Transparent"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    ExtendClientAreaChromeHints="NoChrome"
    TransparencyLevelHint="Transparent"
    SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="Cyan"/>
            <Setter Property="Foreground" Value="#121212"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="24,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="18,6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="38,*">

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56"
                            PointerPressed="CloseDot_PointerPressed"/>
                </StackPanel>
                <TextBlock Text="CLOUD CONNECT" Foreground="Cyan" FontWeight="SemiBold"
                           FontSize="12" LetterSpacing="1" VerticalAlignment="Center"
                           HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>

            <!-- Content: 3 Steps as a Panel switcher -->
            <StackPanel Grid.Row="1" Spacing="0" Margin="28,20,28,20">

                <!-- Step indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,16">
                    <Ellipse x:Name="step1Dot" Width="10" Height="10" Fill="Cyan"/>
                    <Ellipse x:Name="step2Dot" Width="10" Height="10" Fill="#444"/>
                    <Ellipse x:Name="step3Dot" Width="10" Height="10" Fill="#444"/>
                </StackPanel>

                <!-- Step 1: Enter License Key -->
                <StackPanel x:Name="step1Panel" Spacing="12">
                    <TextBlock Text="Connect to AegisDNS Cloud" FontWeight="SemiBold"
                               Foreground="#E0E0E0" HorizontalAlignment="Center" FontSize="16"/>
                    <TextBlock Text="Enter your AegisDNS license key to link this device to the cloud fleet."
                               Foreground="#B0B0B0" HorizontalAlignment="Center"
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="License Key" Foreground="#888" FontSize="11" Margin="2,6,0,0"/>
                    <TextBox x:Name="licenseKeyBox" Watermark="PRIME-XXXX-XXXX-XXXX-XXXX"/>
                    <TextBlock Text="API Endpoint" Foreground="#888" FontSize="11" Margin="2,2,0,0"/>
                    <TextBox x:Name="endpointBox" Watermark="https://api.aegisdns.com"/>
                    <TextBlock x:Name="step1Error" Foreground="#FF5F56" FontSize="11"
                               HorizontalAlignment="Center" IsVisible="False"/>
                    <Button x:Name="connectButton" Classes="primary" Content="REGISTER DEVICE"
                            Click="ConnectButton_Click" Margin="0,6,0,0"/>
                    <Button Classes="secondary" Content="Cancel" Click="CancelButton_Click"/>
                </StackPanel>

                <!-- Step 2: Connecting indicator -->
                <StackPanel x:Name="step2Panel" Spacing="12" IsVisible="False">
                    <TextBlock Text="Registering Device..." FontWeight="SemiBold"
                               Foreground="#E0E0E0" HorizontalAlignment="Center" FontSize="16"/>
                    <TextBlock x:Name="connectingStatus"
                               Text="Contacting cloud backend..."
                               Foreground="#B0B0B0" HorizontalAlignment="Center"
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Foreground="Cyan"
                                 Background="#222" CornerRadius="4" Height="6" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Step 3: Success -->
                <StackPanel x:Name="step3Panel" Spacing="12" IsVisible="False">
                    <TextBlock Text="✅ Connected!" FontWeight="SemiBold"
                               Foreground="LimeGreen" HorizontalAlignment="Center" FontSize="18"/>
                    <TextBlock Text="This device is now registered with AegisDNS Cloud."
                               Foreground="#B0B0B0" HorizontalAlignment="Center"
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Device ID:" Foreground="#888" FontSize="11" Width="80"/>
                                <TextBlock x:Name="deviceIdLabel" Foreground="Cyan" FontSize="11"
                                           FontFamily="Consolas,Menlo,Monospace"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="License Tier:" Foreground="#888" FontSize="11" Width="80"/>
                                <TextBlock x:Name="tierLabel" Foreground="LimeGreen" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Policy:" Foreground="#888" FontSize="11" Width="80"/>
                                <TextBlock x:Name="policyLabel" Foreground="#B0B0B0" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Sync:" Foreground="#888" FontSize="11" Width="80"/>
                                <TextBlock Text="Background sync active" Foreground="Cyan" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Classes="primary" Content="DONE" Click="DoneButton_Click" Margin="0,8,0,0"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

<file path="src/AegisDNS.UI/InterFaces/DotSettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.DotSettingsWindow"
        x:DataType="vm:DotSettingsViewModel"
        Title="DNS OVER TLS"
        Width="600" Height="460"
        MinWidth="480" MinHeight="360"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="RadioButton.ModeRadio">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
        <Style Selector="RadioButton.ModeRadio:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">
        <!-- Title Bar -->
        <Border BorderBrush="Transparent" x:Name="titleBarBorder" BorderThickness="0,0,0,1">
            <Grid Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56" PointerPressed="CloseDot_PointerPressed" />
                    <Border Classes="TrafficDot" Background="#FFBD2E" PointerPressed="MinDot_PointerPressed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="titleLabel" Text="🔐 DNS OVER TLS" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" IsHitTestVisible="False"/>
                    <Border Background="#FF8C00" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="PRO" Foreground="Black" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <DockPanel Grid.Row="1" Margin="24,8,24,14">
            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <TextBlock x:Name="contentTitle" Text="DNS OVER TLS" FontSize="18" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="saveBtn" Content="Save" Padding="16,5" Background="#006666" Foreground="Cyan"
                        FontWeight="SemiBold" FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1"
                        Command="{Binding Save}"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,12,0,0">
                <StackPanel Spacing="16">

                    <!-- Upstream Mode -->
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="modeHeader" Text="UPSTREAM MODE" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>
                        <RadioButton Classes="ModeRadio" Content="📡  UDP — Standard DNS (fastest)" GroupName="UpMode" IsChecked="{Binding IsUdpMode}"/>
                        <RadioButton Classes="ModeRadio" Content="🔒  DoH — DNS over HTTPS (encrypted)" GroupName="UpMode" IsChecked="{Binding IsDoHMode}"/>
                        <RadioButton Classes="ModeRadio" Content="🔐  DoT — DNS over TLS (encrypted, RFC 7858)" GroupName="UpMode" IsChecked="{Binding IsDoTMode}"/>
                    </StackPanel>

                    <!-- DoT Upstream Server -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="DoT UPSTREAM SERVER" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>
                        <TextBlock Text="Server IP (used when DoT mode is active):" Foreground="Gray" FontSize="11"/>
                        <TextBox x:Name="upstreamBox" Text="{Binding DoTUpstream}" Watermark="1.1.1.1"
                                 Background="#1E1E1E" Foreground="White" BorderBrush="#333333" CaretBrush="Cyan"/>
                        <TextBlock Text="Common servers: 1.1.1.1 (Cloudflare), 8.8.8.8 (Google), 9.9.9.9 (Quad9)" Foreground="#555555" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Latency Monitor -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="LATENCY MONITOR" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>
                        <CheckBox Content="Enable latency monitoring" IsChecked="{Binding EnableLatencyMonitor}"
                                  Foreground="#CCCCCC" FontSize="12" Cursor="Hand"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                            <TextBlock Text="Alert threshold (ms):" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                            <NumericUpDown Value="{Binding LatencyAlertThresholdMs}" Minimum="50" Maximum="5000"
                                          Background="#1E1E1E" Foreground="White" BorderBrush="#333333"
                                          FormatString="0" Increment="50" Width="120"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

