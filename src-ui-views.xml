<file path="src/AegisDNS.UI/InterFaces/StreamingSettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.StreamingSettingsWindow"
        x:DataType="vm:StreamingSettingsViewModel"
        Title="STREAMING AD BLOCKER"
        Width="600" Height="560"
        MinWidth="480" MinHeight="400"
        Background="Transparent"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="Border.TrafficDot">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Grid RowDefinitions="38,*">

        <!-- Title Bar -->
        <Border BorderBrush="Transparent" x:Name="titleBarBorder" BorderThickness="0,0,0,1">
            <Grid Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                    <Border Classes="TrafficDot" Background="#FF5F56" PointerPressed="CloseDot_PointerPressed" />
                    <Border Classes="TrafficDot" Background="#FFBD2E" PointerPressed="MinDot_PointerPressed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="titleLabel" Text="📺 STREAMING AD BLOCKER" Foreground="Cyan" FontWeight="SemiBold" FontSize="12" LetterSpacing="1" IsHitTestVisible="False"/>
                    <Border Background="#FF8C00" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="PRO" Foreground="Black" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout -->
        <DockPanel Grid.Row="1" Margin="24,8,24,14">

            <!-- Header -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock x:Name="backBtn" Text="← BACK" Foreground="Cyan" Cursor="Hand" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" PointerPressed="BackBtn_PointerPressed"/>
                <TextBlock x:Name="contentTitle" Text="STREAMING AD BLOCKER" FontSize="18" FontWeight="Light" Foreground="Cyan" LetterSpacing="3" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="saveBtn" Content="Save" Padding="16,5" Background="#006666" Foreground="Cyan"
                        FontWeight="SemiBold" FontSize="11" CornerRadius="5" Cursor="Hand" BorderBrush="Cyan" BorderThickness="1"
                        Command="{Binding Save}"/>
            </StackPanel>

            <!-- Upgrade prompt (free tier) -->
            <Border DockPanel.Dock="Top" IsVisible="{Binding !IsProOrHigher}"
                    Background="#1A1A00" BorderBrush="#FFBD2E" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,8,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="⚡ Pro or Enterprise license required" Foreground="#FFBD2E" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Upgrade to unlock per-platform streaming ad blocking." Foreground="#888888" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Content (scrollable) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,12,0,0"
                          IsEnabled="{Binding IsProOrHigher}">
                <StackPanel Spacing="18">

                    <!-- Master Toggle -->
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="masterHeader" Text="MASTER CONTROL" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>
                        <CheckBox Content="Enable Streaming Ad Blocker" IsChecked="{Binding EnableStreamingAdBlock}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="When disabled, all platform toggles below are inactive (settings are preserved)." Foreground="#555555" FontSize="10" TextWrapping="Wrap" Margin="24,0,0,0"/>
                    </StackPanel>

                    <!-- Per-Platform Toggles -->
                    <StackPanel Spacing="6" IsEnabled="{Binding EnableStreamingAdBlock}">
                        <TextBlock x:Name="platformHeader" Text="PLATFORM BLOCKING" Foreground="Cyan" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#1E4040" Margin="0,2,0,4"/>

                        <!-- Spotify -->
                        <StackPanel Spacing="2">
                            <CheckBox Content="🎵  Spotify — Block audio ad domains" IsChecked="{Binding BlockSpotifyAds}"/>
                            <TextBlock Text="Very effective — audio ads load from separate servers" Foreground="#444444" FontSize="10" Margin="24,0,0,0"/>
                        </StackPanel>

                        <!-- Twitch -->
                        <StackPanel Spacing="2">
                            <CheckBox Content="🎮  Twitch — Block ad server domains" IsChecked="{Binding BlockTwitchAds}"/>
                            <TextBlock Text="Partial — blocks many ad servers; some ads use the same CDN as stream content" Foreground="#444444" FontSize="10" Margin="24,0,0,0"/>
                        </StackPanel>

                        <!-- Hulu -->
                        <StackPanel Spacing="2">
                            <CheckBox Content="📺  Hulu — Block tracking and ad domains" IsChecked="{Binding BlockHuluAds}"/>
                            <TextBlock Text="Partial — tracking blocked; server-side ad insertion (SSAI) bypasses DNS" Foreground="#444444" FontSize="10" Margin="24,0,0,0"/>
                        </StackPanel>

                        <!-- Peacock -->
                        <StackPanel Spacing="2">
                            <CheckBox Content="🦚  Peacock — Block tracking and ad domains" IsChecked="{Binding BlockPeacockAds}"/>
                            <TextBlock Text="Partial — tracking blocked; some video ads persist via server-side insertion" Foreground="#444444" FontSize="10" Margin="24,0,0,0"/>
                        </StackPanel>

                        <!-- Paramount+ -->
                        <StackPanel Spacing="2">
                            <CheckBox Content="⭐  Paramount+ — Block tracking and ad domains" IsChecked="{Binding BlockParamountAds}"/>
                            <TextBlock Text="Partial — tracking blocked; ad insertion is mixed" Foreground="#444444" FontSize="10" Margin="24,0,0,0"/>
                        </StackPanel>

                        <!-- YouTube Tracking -->
                        <StackPanel Spacing="2">
                            <CheckBox Content="▶️  YouTube — Block tracking and analytics" IsChecked="{Binding BlockYouTubeTracking}"/>
                            <TextBlock Text="Reduces tracking only — full ad blocking requires HTTPS inspection (coming in Phase 18)" Foreground="#FFBD2E" FontSize="10" TextWrapping="Wrap" Margin="24,0,0,0"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- Coming Soon (greyed out, non-interactive) -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="COMING IN PHASE 18 — HTTPS INSPECTION" Foreground="#333333" FontSize="11" FontWeight="Bold" LetterSpacing="1.5"/>
                        <Border Height="1" Background="#222222" Margin="0,2,0,4"/>
                        <CheckBox Content="🎬  Prime Video — Server-stitched ads (requires HTTPS proxy)" IsEnabled="False" Foreground="#333333"/>
                        <CheckBox Content="🏰  Disney+ — Server-stitched ads (requires HTTPS proxy)" IsEnabled="False" Foreground="#333333"/>
                        <CheckBox Content="🎭  Netflix — Server-side ad insertion (no DNS-blockable domains)" IsEnabled="False" Foreground="#333333"/>
                        <TextBlock Text="These platforms embed ads at the video encoding level. DNS blocking cannot reach them. Phase 18 will add an HTTPS interception proxy to handle these." Foreground="#333333" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

