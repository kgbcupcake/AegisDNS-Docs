<file path="src/AegisDNS.UI/InterFaces/WindowMaterialWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AegisDNS.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        xmlns:controls="using:AegisDNS.UI.Controls"
        x:Class="AegisDNS.WindowMaterialWindow"
        x:DataType="vm:AppearanceViewModel"
        Title="WINDOW MATERIAL SETTINGS"
        Width="450" Height="480"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None">

    <utils:AegisLinuxWindow.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="2"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="140"/>
        </Style>
    </utils:AegisLinuxWindow.Styles>

    <Border Background="#121212" CornerRadius="8" ClipToBounds="True">
    <Panel>
        <controls:BackgroundEffectCanvas 
            EffectType="{Binding BackgroundEffect}" 
            IsActive="True" />

        <Grid RowDefinitions="38,*,50">
            <!-- Title Bar -->
            <Border x:Name="titleBarBorder" Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#1A4040">
                <Grid x:Name="titleBar" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="7">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#FF5F56" Cursor="Hand" PointerPressed="CloseDot_PointerPressed"/>
                        <Border Width="12" Height="12" CornerRadius="6" Background="#FFBD2E" Cursor="Hand" PointerPressed="MinDot_PointerPressed"/>
                    </StackPanel>
                    <TextBlock Text="WINDOW MATERIAL &amp; ACCENTS" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30,20" Spacing="20">
                    <TextBlock Classes="SectionHeader" Text="MATERIAL CONFIGURATION"/>
                    
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="FieldLabel" Text="Backdrop Type:" />
                                <ComboBox SelectedItem="{Binding WindowBackdrop}" Width="160" Background="#222" Foreground="White" BorderBrush="#333">
                                    <sys:String>Solid</sys:String>
                                    <sys:String>Acrylic</sys:String>
                                    <sys:String>Mica</sys:String>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="FieldLabel" Text="Background Opacity:" />
                                <Slider Value="{Binding BackgroundOpacity}" Minimum="0.4" Maximum="1.0" Width="180" Foreground="Gray"/>
                                <TextBlock Text="{Binding BackgroundOpacity, StringFormat={}{0:P0}}" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center" Width="40"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Classes="SectionHeader" Text="COLOR ACCENTS"/>
                    
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="FieldLabel" Text="Primary Accent:" />
                                <TextBox Text="{Binding AccentColorPrimary}" Width="120" Background="#222" Foreground="{Binding AccentColorPrimary}" BorderBrush="#333" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="FieldLabel" Text="Secondary Accent:" />
                                <TextBox Text="{Binding AccentColorSecondary}" Width="120" Background="#222" Foreground="{Binding AccentColorSecondary}" BorderBrush="#333" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="Acrylic and Mica effects are OS-dependent and may require transparency support." 
                               Foreground="#555" FontSize="10" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#161616" BorderThickness="0,1,0,0" BorderBrush="#222">
                <Grid Margin="20,0">
                    <TextBlock x:Name="backBtn" Text="← BACK TO APPEARANCE" Foreground="Gray" Cursor="Hand" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" PointerPressed="BackBtn_PointerPressed"/>
                    <Button Content="Save &amp; Close" Command="{Binding SaveCommand}" Click="SaveBtn_Click" Background="#006666" Foreground="Cyan" FontWeight="SemiBold" FontSize="11" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Padding="15,6"/>
                </Grid>
            </Border>
        </Grid>
    </Panel>
    </Border>
</utils:AegisLinuxWindow>
