<file path="src/AegisDNS.UI/InterFaces/CloudConnectWindow.axaml.cs">
using System;
using System.Net.Http;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.UI.Linux;

using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Interactivity;
using Avalonia.Media;
using Avalonia.Threading;

namespace AegisDNS.UI
{
    public partial class CloudConnectWindow : AegisLinuxWindow
    {
        private readonly HttpClient _http = new() { Timeout = TimeSpan.FromSeconds(15) };

        public CloudConnectWindow()
        {
            InitializeComponent();

            // Pre-fill endpoint from current config
            endpointBox.Text = SecurityConfigManager.Settings.CloudApiEndpoint;
        }

        // ── Drag / Close ──────────────────────────────────────────────────────
        private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
        {
            if (e.GetCurrentPoint(this).Properties.IsLeftButtonPressed)
                BeginMoveDrag(e);
        }

        private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e) => Close();
        private void CancelButton_Click(object? sender, RoutedEventArgs e) => Close();
        private void DoneButton_Click(object? sender, RoutedEventArgs e) => Close();

        // ── Step 1 → Step 2 ───────────────────────────────────────────────────
        private async void ConnectButton_Click(object? sender, RoutedEventArgs e)
        {
            var licenseKey = licenseKeyBox.Text?.Trim() ?? string.Empty;
            var endpoint = endpointBox.Text?.Trim() ?? string.Empty;

            if (string.IsNullOrWhiteSpace(licenseKey) || licenseKey.Length < 16)
            {
                ShowStep1Error("Please enter a valid license key.");
                return;
            }

            if (!Uri.TryCreate(endpoint, UriKind.Absolute, out _) ||
                (!endpoint.StartsWith("https://") && !endpoint.StartsWith("http://")))
            {
                ShowStep1Error("Please enter a valid API endpoint URL.");
                return;
            }

            // Save endpoint
            SecurityConfigManager.Settings.CloudApiEndpoint = endpoint;

            // Move to step 2
            GoToStep(2);
            await RegisterDeviceAsync(licenseKey, endpoint);
        }

        private async Task RegisterDeviceAsync(string licenseKey, string endpoint)
        {
            try
            {
                SetConnectingStatus("Retrieving hardware identity...");
                var hwid = AegisDNS.Licensing.HardwareIdentity.Get();

                SetConnectingStatus("Contacting cloud backend...");

                var payload = JsonSerializer.Serialize(new
                {
                    licenseKey,
                    hardwareId = hwid,
                    platform = "linux",
                    version = "1.0.0"
                });

                using var req = new HttpRequestMessage(HttpMethod.Post, $"{endpoint}/api/device/register");
                req.Content = new StringContent(payload, Encoding.UTF8, "application/json");

                var resp = await _http.SendAsync(req);
                var body = await resp.Content.ReadAsStringAsync();

                if (!resp.IsSuccessStatusCode)
                {
                    string errorMsg = resp.StatusCode switch
                    {
                        System.Net.HttpStatusCode.BadRequest when body.Contains("LicenseExpired") => "License has expired. Please renew.",
                        System.Net.HttpStatusCode.BadRequest when body.Contains("DeviceLimitExceeded") => "Device limit exceeded for this license.",
                        System.Net.HttpStatusCode.BadRequest when body.Contains("InvalidLicense") => "License key not found or invalid.",
                        _ => $"Server error ({(int)resp.StatusCode}). Please try again."
                    };

                    await Dispatcher.UIThread.InvokeAsync(() =>
                    {
                        GoToStep(1);
                        ShowStep1Error(errorMsg);
                    });
                    return;
                }

                // Parse response
                using var doc = JsonDocument.Parse(body);
                var root = doc.RootElement;
                var deviceId = root.GetProperty("deviceId").GetString() ?? "";
                var apiToken = root.GetProperty("apiToken").GetString() ?? "";
                var tier = root.GetProperty("tier").GetString() ?? "Pro";
                var policyVer = root.GetProperty("policyVersion").GetInt32();

                // Persist to config (token in memory; caller should encrypt via AesGcmTokenStore)
                SecurityConfigManager.Settings.DeviceApiToken = apiToken;
                SecurityConfigManager.Settings.CloudDeviceId = deviceId;
                SecurityConfigManager.Settings.CloudPolicyVersion = policyVer;
                SecurityConfigManager.Settings.CloudSyncEnabled = true;
                SecurityConfigManager.Settings.CloudSyncFailureCount = 0;
                SecurityConfigManager.Save();

                await Dispatcher.UIThread.InvokeAsync(() =>
                {
                    deviceIdLabel.Text = deviceId.Length > 18 ? deviceId[..18] + "…" : deviceId;
                    tierLabel.Text = tier.ToUpperInvariant();
                    policyLabel.Text = policyVer > 0 ? $"v{policyVer} synced" : "No policy (defaults apply)";
                    GoToStep(3);
                });
            }
            catch (HttpRequestException ex)
            {
                await Dispatcher.UIThread.InvokeAsync(() =>
                {
                    GoToStep(1);
                    ShowStep1Error($"Network error: {ex.Message}");
                });
            }
            catch (Exception ex)
            {
                await Dispatcher.UIThread.InvokeAsync(() =>
                {
                    GoToStep(1);
                    ShowStep1Error($"Unexpected error: {ex.Message}");
                });
            }
        }

        // ── helpers ───────────────────────────────────────────────────────────
        private void GoToStep(int step)
        {
            step1Panel.IsVisible = step == 1;
            step2Panel.IsVisible = step == 2;
            step3Panel.IsVisible = step == 3;
            step1Dot.Fill = step >= 1 ? Brushes.Cyan : Brushes.Gray;
            step2Dot.Fill = step >= 2 ? Brushes.Cyan : new SolidColorBrush(0xFF444444);
            step3Dot.Fill = step >= 3 ? Brushes.Cyan : new SolidColorBrush(0xFF444444);
        }

        private void ShowStep1Error(string msg)
        {
            step1Error.Text = msg;
            step1Error.IsVisible = true;
        }

        private void SetConnectingStatus(string msg) =>
            Dispatcher.UIThread.Post(() => connectingStatus.Text = msg);
    }
}
