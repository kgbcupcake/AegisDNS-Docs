<file path="src/AegisDNS.UI/InterFaces/AiLearnedBlocklistWindow.axaml.cs">
using System.IO;

using AegisDNS.Core.Utilities;
using AegisDNS.UI.Linux;

using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Interactivity;

namespace AegisDNS;

public partial class AiLearnedBlocklistWindow : AegisLinuxWindow
{
    private readonly ListBox _lstDomains = null!;
    private readonly TextBlock _lblDomainCount = null!;

    public AiLearnedBlocklistWindow()
    {
        Avalonia.Markup.Xaml.AvaloniaXamlLoader.Load(this);


        _lstDomains = this.FindControl<ListBox>("lstDomains")!;
        _lblDomainCount = this.FindControl<TextBlock>("lblDomainCount")!;

        RefreshList();
    }

    private void RefreshList()
    {
        var domains = AiLearnedBlocklist.GetAll();
        _lstDomains.ItemsSource = domains;
        _lblDomainCount.Text = $"{domains.Count} AI-learned blocks active";
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseBtn_Click(object? sender, RoutedEventArgs e)
    {
        new SettingsWindow().Show();
        this.Close();
    }

    private void MinBtn_Click(object? sender, RoutedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private async void Export_Click(object? sender, RoutedEventArgs e)
    {
        var topLevel = TopLevel.GetTopLevel(this);
        if (topLevel == null) return;

        var file = await topLevel.StorageProvider.SaveFilePickerAsync(new Avalonia.Platform.Storage.FilePickerSaveOptions
        {
            Title = "Export AI Learned Blocklist",
            SuggestedFileName = "ai_learned_export.txt",
            DefaultExtension = "txt",
            FileTypeChoices = new[] { new Avalonia.Platform.Storage.FilePickerFileType("Text Files") { Patterns = new[] { "*.txt" } } }
        });

        if (file != null)
        {
            using var stream = await file.OpenWriteAsync();
            using var writer = new StreamWriter(stream);
            var domains = AiLearnedBlocklist.GetAll();
            foreach (var domain in domains)
            {
                await writer.WriteLineAsync(domain);
            }
        }
    }

    private void Remove_Click(object? sender, RoutedEventArgs e)
    {
        var selected = _lstDomains.SelectedItem as string;
        if (!string.IsNullOrWhiteSpace(selected))
        {
            AiLearnedBlocklist.Remove(selected);
            AllowlistManager.Add(selected); // So it's protected from being re-learned
            RefreshList();
        }
    }
}
</file>

<file path="src/AegisDNS.UI/InterFaces/AiSettingsWindow.axaml.cs">
using System;
using System.Reactive.Disposables;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.Core.Ai;
using AegisDNS.Core.Utilities;
using AegisDNS.UI.Linux;
using AegisDNS.ViewModels;

using Avalonia;
using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Layout;
using Avalonia.Media;
using Avalonia.ReactiveUI;

using ReactiveUI;

namespace AegisDNS;

/// <summary>
/// AI Sentinel configuration — provider selection, model/endpoint settings,
/// and per-provider sign-in via API key or browser dashboard.
/// </summary>
public partial class AiSettingsWindow : AegisLinuxWindow, IViewFor<SettingsViewModel>
{
    public static readonly StyledProperty<SettingsViewModel?> ViewModelProperty =
        AvaloniaProperty.Register<AiSettingsWindow, SettingsViewModel?>(nameof(ViewModel));

    public SettingsViewModel? ViewModel
    {
        get => GetValue(ViewModelProperty);
        set => SetValue(ViewModelProperty, value);
    }

    object? IViewFor.ViewModel
    {
        get => ViewModel;
        set => ViewModel = (SettingsViewModel?)value;
    }

    private static readonly Color CyanSolid = Color.Parse("#00FFFF");

    public AiSettingsWindow()
    {
        InitializeComponent();


        ViewModel = new SettingsViewModel();
        DataContext = ViewModel;
        bool useGlow = ConfigManager.Settings.EnableNeonGlow;



        if (useGlow)
        {
            var titleLabel = this.FindControl<TextBlock>("titleLabel");
            if (titleLabel != null) titleLabel.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 12, Opacity = 0.6 };

            var titleBarBorder = this.FindControl<Border>("titleBarBorder");
            if (titleBarBorder != null) titleBarBorder.BorderBrush = new SolidColorBrush(Color.Parse("#1A4040"));

            backBtn.PointerEntered += (s, e) => { backBtn.Foreground = Brushes.White; backBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };
            backBtn.PointerExited += (s, e) => { backBtn.Foreground = Brushes.Cyan; backBtn.Effect = null; };

            contentTitle.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 15, Opacity = 0.5 };
            sentinelHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            signInHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            modelHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            scanHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };

            endpointBox.GotFocus += (s, e) => { endpointBox.BorderBrush = Brushes.Cyan; endpointBox.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };
            endpointBox.LostFocus += (s, e) => { endpointBox.BorderBrush = new SolidColorBrush(Color.Parse("#333333")); endpointBox.Effect = null; };

            modelBox.GotFocus += (s, e) => { modelBox.BorderBrush = Brushes.Cyan; modelBox.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };
            modelBox.LostFocus += (s, e) => { modelBox.BorderBrush = new SolidColorBrush(Color.Parse("#333333")); modelBox.Effect = null; };

            vLine.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.5 };

            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 14, Opacity = 0.6 }; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };

            saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
        }
        else
        {
            backBtn.PointerEntered += (s, e) => backBtn.Foreground = Brushes.White;
            backBtn.PointerExited += (s, e) => backBtn.Foreground = Brushes.Cyan;

            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; };
        }

        foreach (var provider in SecureCredentialStore.SupportedProviders)
        {
            providerCardsPanel.Children.Add(CreateProviderCard(provider, useGlow));
        }

        providerCombo.ItemsSource = SecureCredentialStore.SupportedProviders;

        var fallbackProvidersList = new System.Collections.Generic.List<string> { "None" };
        fallbackProvidersList.AddRange(SecureCredentialStore.SupportedProviders);

        fallbackCombo1.ItemsSource = fallbackProvidersList;
        fallbackCombo2.ItemsSource = fallbackProvidersList;
        fallbackCombo3.ItemsSource = fallbackProvidersList;

        this.WhenActivated(disposables =>
        {
            this.Bind(ViewModel, vm => vm.EnableAiSentinel, v => v.chkEnableAi.IsChecked).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.AiProvider, v => v.providerCombo.SelectedItem).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.FallbackProvider1, v => v.fallbackCombo1.SelectedItem).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.FallbackProvider2, v => v.fallbackCombo2.SelectedItem).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.FallbackProvider3, v => v.fallbackCombo3.SelectedItem).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.AiEndpoint, v => v.endpointBox.Text).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.AiModel, v => v.modelBox.Text).DisposeWith(disposables);
            this.Bind(ViewModel, vm => vm.AiCheckIntervalMinutes, v => v.intervalSlider.Value, v => (double)v, d => (int)d).DisposeWith(disposables);

            this.WhenAnyValue(v => v.ViewModel!.AiCheckIntervalMinutes)
                .Subscribe(mins => intervalLabel.Text = $"Check Interval: {mins} min")
                .DisposeWith(disposables);

            saveBtn.Click += async (s, e) =>
            {
                ViewModel!.SaveSettings.Execute().Subscribe();
                var originalText = saveBtn.Content;
                saveBtn.Content = "✅ Saved";
                saveBtn.Background = new SolidColorBrush(Color.Parse("#004400"));
                saveBtn.Foreground = Brushes.LimeGreen;
                saveBtn.BorderBrush = Brushes.LimeGreen;
                if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = Colors.LimeGreen, BlurRadius = 10, Opacity = 0.5 };
                await Task.Delay(1500);
                saveBtn.Content = originalText;
                saveBtn.Background = new SolidColorBrush(Color.Parse("#006666"));
                saveBtn.Foreground = Brushes.Cyan;
                saveBtn.BorderBrush = Brushes.Cyan;
                if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
            };
        });
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        Close();
    }

    private void MinDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void BackBtn_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var settings = new SettingsWindow();
        settings.Show();
        this.Close();
    }

    // ===== PROVIDER SIGN-IN CARD =====

    private Control CreateProviderCard(string provider, bool useGlow)
    {
        bool signedIn = SecureCredentialStore.IsSignedIn(provider);
        bool supportsBrowser = SecureCredentialStore.BrowserSignInProviders.Contains(provider);
        bool isLocal = string.Equals(provider, "Ollama", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(provider, "LM Studio", StringComparison.OrdinalIgnoreCase);

        var statusDot = new Border
        {
            Width = 8,
            Height = 8,
            CornerRadius = new CornerRadius(4),
            Background = signedIn ? Brushes.LimeGreen : new SolidColorBrush(Color.Parse("#555555")),
            VerticalAlignment = VerticalAlignment.Center,
            Margin = new Thickness(0, 0, 6, 0)
        };

        var providerName = new TextBlock
        {
            Text = provider,
            FontSize = 11,
            FontWeight = FontWeight.SemiBold,
            Foreground = signedIn ? Brushes.White : new SolidColorBrush(Color.Parse("#999999")),
            VerticalAlignment = VerticalAlignment.Center
        };

        var statusLabel = new TextBlock
        {
            Text = signedIn ? "Connected" : (isLocal ? "Local" : "Not connected"),
            FontSize = 9,
            Foreground = signedIn ? Brushes.LimeGreen : Brushes.Gray,
            VerticalAlignment = VerticalAlignment.Center,
            Margin = new Thickness(8, 0, 0, 0)
        };

        var leftInfo = new StackPanel
        {
            Orientation = Orientation.Horizontal,
            Children = { statusDot, providerName, statusLabel }
        };

        var actionsPanel = new StackPanel
        {
            Orientation = Orientation.Horizontal,
            Spacing = 6,
            HorizontalAlignment = HorizontalAlignment.Right,
            VerticalAlignment = VerticalAlignment.Center
        };

        if (signedIn)
        {
            var signOutBtn = CreateMiniButton("Sign Out", "#FF5555", useGlow);
            signOutBtn.PointerPressed += (s, e) =>
            {
                SecureCredentialStore.SignOut(provider);
                var newWindow = new AiSettingsWindow();
                newWindow.Show();
                Close();
            };
            actionsPanel.Children.Add(signOutBtn);
        }
        else if (!isLocal)
        {
            // API Key button
            var apiKeyBtn = CreateMiniButton("API Key", "#00FFFF", useGlow);
            apiKeyBtn.PointerPressed += (s, e) => ShowApiKeyDialog(provider, useGlow);
            actionsPanel.Children.Add(apiKeyBtn);

            // Browser sign-in → opens provider's API key dashboard
            if (supportsBrowser)
            {
                var browserBtn = CreateMiniButton("Sign In →", "#00FF88", useGlow);
                browserBtn.PointerPressed += (s, e) => OAuthBrowserFlow.OpenProviderDashboard(provider);
                actionsPanel.Children.Add(browserBtn);
            }
        }

        var cardGrid = new Grid();
        cardGrid.ColumnDefinitions.Add(new ColumnDefinition(1, GridUnitType.Star));
        cardGrid.ColumnDefinitions.Add(new ColumnDefinition(GridLength.Auto));
        Grid.SetColumn(leftInfo, 0);
        Grid.SetColumn(actionsPanel, 1);
        cardGrid.Children.Add(leftInfo);
        cardGrid.Children.Add(actionsPanel);

        return new Border
        {
            Background = new SolidColorBrush(Color.Parse("#1A1A1A")),
            BorderBrush = signedIn
                ? new SolidColorBrush(Color.Parse("#005500"))
                : new SolidColorBrush(Color.Parse("#2A2A2A")),
            BorderThickness = new Thickness(1),
            CornerRadius = new CornerRadius(5),
            Padding = new Thickness(10, 6),
            Margin = new Thickness(0, 1, 0, 1),
            Child = cardGrid
        };
    }

    private void ShowApiKeyDialog(string provider, bool useGlow)
    {
        var overlay = new Border
        {
            Background = new SolidColorBrush(Color.Parse("#CC000000")),
            HorizontalAlignment = HorizontalAlignment.Stretch,
            VerticalAlignment = VerticalAlignment.Stretch,
            ZIndex = 100
        };

        var dialogTitle = new TextBlock
        {
            Text = $"Enter API Key for {provider}",
            Foreground = Brushes.Cyan,
            FontSize = 14,
            FontWeight = FontWeight.SemiBold,
            HorizontalAlignment = HorizontalAlignment.Center,
            Effect = useGlow ? new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 } : null
        };

        var keyInput = new TextBox
        {
            Watermark = "Paste your API key here...",
            PasswordChar = '•',
            Width = 350,
            Background = new SolidColorBrush(Color.Parse("#1E1E1E")),
            Foreground = Brushes.White,
            BorderBrush = Brushes.Cyan,
            CaretBrush = Brushes.Cyan,
            Margin = new Thickness(0, 15, 0, 15)
        };

        var saveKeyBtn = new Button
        {
            Content = "Save & Connect",
            Padding = new Thickness(16, 6),
            Background = new SolidColorBrush(Color.Parse("#006666")),
            Foreground = Brushes.Cyan,
            FontWeight = FontWeight.SemiBold,
            FontSize = 11,
            CornerRadius = new CornerRadius(5),
            HorizontalAlignment = HorizontalAlignment.Center,
            Cursor = new Cursor(StandardCursorType.Hand),
            BorderBrush = Brushes.Cyan,
            BorderThickness = new Thickness(1)
        };

        var cancelBtn = new TextBlock
        {
            Text = "Cancel",
            Foreground = Brushes.Gray,
            FontSize = 11,
            HorizontalAlignment = HorizontalAlignment.Center,
            Cursor = new Cursor(StandardCursorType.Hand),
            Margin = new Thickness(0, 8, 0, 0)
        };

        var dialogPanel = new StackPanel
        {
            VerticalAlignment = VerticalAlignment.Center,
            HorizontalAlignment = HorizontalAlignment.Center,
            Children = { dialogTitle, keyInput, saveKeyBtn, cancelBtn }
        };

        var dialogBorder = new Border
        {
            Background = new SolidColorBrush(Color.Parse("#1A1A1A")),
            BorderBrush = Brushes.Cyan,
            BorderThickness = new Thickness(1),
            CornerRadius = new CornerRadius(10),
            Padding = new Thickness(30, 25),
            VerticalAlignment = VerticalAlignment.Center,
            HorizontalAlignment = HorizontalAlignment.Center,
            Effect = useGlow ? new DropShadowEffect { Color = CyanSolid, BlurRadius = 20, Opacity = 0.5 } : null,
            Child = dialogPanel
        };

        overlay.Child = dialogBorder;

        if (Content is Grid rootGrid)
        {
            Grid.SetRowSpan(overlay, rootGrid.RowDefinitions.Count);
            rootGrid.Children.Add(overlay);
        }

        saveKeyBtn.Click += (s, e) =>
        {
            string key = keyInput.Text ?? "";
            if (!string.IsNullOrWhiteSpace(key))
            {
                SecureCredentialStore.SetCredential(provider, key);
                var newWindow = new AiSettingsWindow();
                newWindow.Show();
                Close();
            }
        };

        cancelBtn.PointerPressed += (s, e) =>
        {
            if (Content is Grid rg) rg.Children.Remove(overlay);
        };
    }

    private Border CreateMiniButton(string text, string colorHex, bool useGlow)
    {
        var color = Color.Parse(colorHex);
        var textBlock = new TextBlock
        {
            Text = text,
            FontSize = 10,
            Foreground = new SolidColorBrush(color),
            FontWeight = FontWeight.SemiBold
        };

        var border = new Border
        {
            Background = Brushes.Transparent,
            BorderBrush = new SolidColorBrush(color),
            BorderThickness = new Thickness(1),
            CornerRadius = new CornerRadius(4),
            Padding = new Thickness(8, 3),
            Cursor = new Cursor(StandardCursorType.Hand),
            Child = textBlock
        };
        border.PointerEntered += (s, e) =>
        {
            border.Background = new SolidColorBrush(Color.FromArgb(40, color.R, color.G, color.B));
            if (useGlow) border.Effect = new DropShadowEffect { Color = color, BlurRadius = 8, Opacity = 0.4 };
        };
        border.PointerExited += (s, e) =>
        {
            border.Background = Brushes.Transparent;
            border.Effect = null;
        };

        return border;
    }
}
