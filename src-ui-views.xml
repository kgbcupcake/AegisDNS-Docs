<file path="src/AegisDNS.UI/InterFaces/TrafficHistoryWindow.axaml.cs">
using System;
using System.Collections.Generic;
using System.Reactive.Disposables;
using System.Reactive.Linq;

using AegisDNS.Core;
using AegisDNS.UI.Linux;
using AegisDNS.ViewModels;

using Avalonia.Input;
using Avalonia.Media;

using ReactiveUI;

namespace AegisDNS.UI.InterFaces;

public partial class TrafficHistoryWindow : AegisLinuxWindow
{
    private readonly CompositeDisposable _disposables = new();

    public TrafficHistoryWindow()
    {
        InitializeComponent();
    }

    public TrafficHistoryWindow(DashboardViewModel dashVm, MainViewModel mainVm)
    {
        InitializeComponent();


        // Sparkline — SparklinePoints is a space-separated coordinate string e.g. "0,30 45.2,12.1 ..."
        // Avalonia Polyline.Points requires a PointCollection, so we parse on the UI thread.
        dashVm.WhenAnyValue(d => d.SparklinePoints)
            .ObserveOn(RxApp.MainThreadScheduler)
            .Subscribe(pts =>
            {
                try
                {
                    if (string.IsNullOrWhiteSpace(pts)) return;
                    var list = new List<Avalonia.Point>();
                    foreach (var pair in pts.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                    {
                        var coords = pair.Split(',');
                        if (coords.Length == 2 &&
                            double.TryParse(coords[0], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double x) &&
                            double.TryParse(coords[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double y))
                        {
                            list.Add(new Avalonia.Point(x, y));
                        }
                    }
                    sparkline.Points = list;
                }
                catch { /* malformed string during startup — ignore */ }
            })
            .DisposeWith(_disposables);

        mainVm.WhenAnyValue(m => m.LastRequestText)
            .ObserveOn(RxApp.MainThreadScheduler)
            .Subscribe(t => lastRequestLabel.Text = t)
            .DisposeWith(_disposables);

        mainVm.WhenAnyValue(m => m.LastRequestBrush)
            .ObserveOn(RxApp.MainThreadScheduler)
            .Subscribe(b => lastRequestLabel.Foreground = b)
            .DisposeWith(_disposables);

        if (ConfigManager.Settings.EnableNeonGlow)
        {
            var cyan = Color.Parse("#00FFFF");
            if (titleLabel != null)
                titleLabel.Effect = new DropShadowEffect { Color = cyan, BlurRadius = 12, Opacity = 0.6 };
        }

        Closed += (_, _) => _disposables.Dispose();
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
        => HandleTitleBarDrag(e);

    private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e)
        => Close();

    private void MinDot_PointerPressed(object? sender, PointerPressedEventArgs e)
        => WindowState = Avalonia.Controls.WindowState.Minimized;
}
