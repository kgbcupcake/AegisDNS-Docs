<file path="src/AegisDNS.UI/InterFaces/HttpsProxySettingsWindow.axaml">
<utils:AegisLinuxWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AegisDNS.ViewModels"
        xmlns:utils="clr-namespace:AegisDNS.UI.Linux;assembly=AegisDNS.UI.Linux"
        x:Class="AegisDNS.HttpsProxySettingsWindow"
        Title="HTTPS AD BLOCKER"
        Width="550" Height="650"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        CanResize="False"
        SystemDecorations="None">

    <Design.DataContext>
        <vm:HttpsProxySettingsViewModel/>
    </Design.DataContext>

    <Border Background="#121212" CornerRadius="8" BorderBrush="#333333" BorderThickness="1">
        <Grid RowDefinitions="38,*">
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#1A1A1A" PointerPressed="TitleBar_PointerPressed">
                <Grid>
                    <TextBlock Text="🔒 HTTPS AD BLOCKER (PRO)" Foreground="Cyan" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="38" Background="Transparent" BorderThickness="0" Foreground="Gray" Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="20">
                <StackPanel Spacing="15">
                    
                    <Border Background="#1A1A1A" Padding="15" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ToggleSwitch IsChecked="{Binding EnableHttpsProxy}" OnContent="Active" OffContent="Disabled"/>
                                <TextBlock Text="Enable HTTPS Ad Interception" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="This allows AegisDNS to decrypt and inspect HTTPS traffic to block URL-level ads (like YouTube video ads)." Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" Padding="15" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock Text="CA Certificate Status" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding CaStatus}" Foreground="White" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Install Certificate" Command="{Binding InstallCaCert}" IsVisible="{Binding !IsCaInstalled}" Background="#222222" BorderBrush="Cyan" BorderThickness="1"/>
                            </Grid>
                            <TextBlock Text="⚠️ Warning: This feature installs a local CA certificate into your system trust store. This is required for HTTPS inspection. The certificate is local to your machine and removed on uninstall." Foreground="#FF8C00" FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" Padding="15" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Platform Blocking" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                            
                            <CheckBox IsChecked="{Binding ProxyBlockYouTubeAds}" Content="Block YouTube Video Ads" Foreground="White"/>
                            <CheckBox IsChecked="{Binding ProxyBlockSpotifyAds}" Content="Block Spotify Audio Ads" Foreground="White"/>
                            <CheckBox IsChecked="{Binding ProxyBlockPrimeVideoAds}" Content="Block Prime Video Ads" Foreground="White"/>
                            <CheckBox IsChecked="{Binding ProxyBlockDisneyPlusAds}" Content="Block Disney+ Ads" Foreground="White"/>
                            <CheckBox IsChecked="{Binding ProxyBlockGenericAds}" Content="Block Generic Ad Networks" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" Padding="15" CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Proxy Bypass List" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="Domains here will be relayed without decryption (useful for cert-pinned apps)." Foreground="#777777" FontSize="10" TextWrapping="Wrap"/>
                            
                            <ListBox ItemsSource="{Binding ProxyBypassDomains}" Height="120" Background="#121212" BorderBrush="#333333">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="✕" Foreground="Red" Background="Transparent" 
                                                    Command="{Binding $parent[ListBox].DataContext.RemoveBypassDomain}" CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                                <TextBox Text="{Binding NewBypassDomain}" Watermark="Add domain (e.g. *.signal.org)" Background="#121212"/>
                                <Button Grid.Column="1" Content="Add" Command="{Binding AddBypassDomain}" Margin="5,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button Content="SAVE &amp; APPLY" Command="{Binding Save}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#004444" Foreground="Cyan" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</utils:AegisLinuxWindow>
</file>

