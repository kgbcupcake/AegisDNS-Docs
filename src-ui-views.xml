    public StatsOverviewWindow(DashboardViewModel dashVm)
    {
        InitializeComponent();


        // Live bindings — react to every ViewModel change on the UI thread
        dashVm.WhenAnyValue(d => d.MetricsTotal)
            .ObserveOn(RxApp.MainThreadScheduler)
