<file path="src/AegisDNS.UI/InterFaces/GeneralSettingsWindow.axaml.cs">
using System;
using System.Reactive.Disposables;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.UI.Linux;

using Avalonia;
using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Media;
using Avalonia.ReactiveUI;

using ReactiveUI;

namespace AegisDNS;

public partial class GeneralSettingsWindow : AegisLinuxWindow
{
    private static readonly Color CyanSolid = Color.Parse("#00FFFF");

    public GeneralSettingsWindow()
    {
        Avalonia.Markup.Xaml.AvaloniaXamlLoader.Load(this);


        bool useGlow = ConfigManager.Settings.EnableNeonGlow;

        if (useGlow)
        {
            var titleLabel = this.FindControl<TextBlock>("titleLabel");
            if (titleLabel != null) titleLabel.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 12, Opacity = 0.6 };

            var titleBarBorder = this.FindControl<Border>("titleBarBorder");
            if (titleBarBorder != null) titleBarBorder.BorderBrush = new SolidColorBrush(Color.Parse("#1A4040"));

            backBtn.PointerEntered += (s, e) => { backBtn.Foreground = Brushes.White; backBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };
            backBtn.PointerExited += (s, e) => { backBtn.Foreground = Brushes.Cyan; backBtn.Effect = null; };

            contentTitle.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 15, Opacity = 0.5 };
            startupHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };
            updatesHeader.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.4 };

            ApplyCheckBoxGlow(chkStartOnBoot);
            ApplyCheckBoxGlow(chkStartMinimized);
            ApplyCheckBoxGlow(chkMinimizeToTray);
            ApplyCheckBoxGlow(chkStealthMode);
            ApplyCheckBoxGlow(chkWeeklySummary);
            ApplyCheckBoxGlow(chkDailySummary);
            ApplyCheckBoxGlow(chkAutoUpdateBlocklists);

            checkUpdatesBtn.PointerEntered += (s, e) => checkUpdatesBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.5 };
            checkUpdatesBtn.PointerExited += (s, e) => checkUpdatesBtn.Effect = null;

            vLine.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 8, Opacity = 0.5 };

            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 14, Opacity = 0.6 }; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 }; };

            saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
        }
        else
        {
            backBtn.PointerEntered += (s, e) => backBtn.Foreground = Brushes.White;
            backBtn.PointerExited += (s, e) => backBtn.Foreground = Brushes.Cyan;

            saveBtn.PointerEntered += (s, e) => { saveBtn.Background = Brushes.Cyan; saveBtn.Foreground = Brushes.Black; };
            saveBtn.PointerExited += (s, e) => { saveBtn.Background = new SolidColorBrush(Color.Parse("#006666")); saveBtn.Foreground = Brushes.Cyan; };
        }

        saveBtn.Click += async (s, e) =>
        {
            if (DataContext != null)
            {
                var pi = DataContext.GetType().GetProperty("SaveSettings");
                if (pi != null)
                {
                    var cmd = pi.GetValue(DataContext) as global::System.Windows.Input.ICommand;
                    if (cmd != null && cmd.CanExecute(null))
                    {
                        cmd.Execute(null);
                    }
                }
            }

            var originalText = saveBtn.Content;
            saveBtn.Content = "✅ Saved";
            saveBtn.Background = new SolidColorBrush(Color.Parse("#004400"));
            saveBtn.Foreground = Brushes.LimeGreen;
            saveBtn.BorderBrush = Brushes.LimeGreen;
            if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = Colors.LimeGreen, BlurRadius = 10, Opacity = 0.5 };
            await Task.Delay(1500);
            saveBtn.Content = originalText;
            saveBtn.Background = new SolidColorBrush(Color.Parse("#006666"));
            saveBtn.Foreground = Brushes.Cyan;
            saveBtn.BorderBrush = Brushes.Cyan;
            if (useGlow) saveBtn.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 6, Opacity = 0.3 };
        };
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        HandleTitleBarDrag(e);
    }

    private void CloseDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        Close();
    }

    private void MinDot_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        WindowState = WindowState.Minimized;
    }

    private void BackBtn_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        var settings = new SettingsWindow();
        settings.Show();
        this.Close();
    }

    private void ApplyCheckBoxGlow(CheckBox cb)
    {
        cb.PointerEntered += (s, e) =>
        {
            cb.Foreground = Brushes.White;
            cb.Effect = new DropShadowEffect { Color = CyanSolid, BlurRadius = 4, Opacity = 0.2 };
        };
        cb.PointerExited += (s, e) =>
        {
            cb.Foreground = new SolidColorBrush(Color.Parse("#B0B0B0"));
            cb.Effect = null;
        };
    }
}
</file>

