using System;
using System.IO;
using System.Security.Cryptography;
using System.Text;
using System.Text.Json;

using AegisDNS.Licensing;

using Xunit;

namespace AegisDNS.Licensing.Tests;

public class LicenseManagerTests : IDisposable
{
    private readonly RSA _rsa;
    private readonly string _testDir;
    private readonly string _originalPublicKey;
    private readonly string _originalBaseDir;

    public LicenseManagerTests()
    {
        _testDir = Path.Combine(Path.GetTempPath(), "AegisDNS_LicenseTests_" + Guid.NewGuid());
        Directory.CreateDirectory(_testDir);

        _originalBaseDir = LicenseManager.BaseDir;
        _originalPublicKey = LicenseManager.PublicKeyPem;

        LicenseManager.BaseDir = _testDir;

        _rsa = RSA.Create(2048);
        string newPubKey = "-----BEGIN PUBLIC KEY-----\n" + Convert.ToBase64String(_rsa.ExportSubjectPublicKeyInfo(), Base64FormattingOptions.InsertLineBreaks) + "\n-----END PUBLIC KEY-----";
        LicenseManager.PublicKeyPem = newPubKey;

        LicenseManager.Deactivate();
    }

    public void Dispose()
    {
        LicenseManager.BaseDir = _originalBaseDir;
        LicenseManager.PublicKeyPem = _originalPublicKey;
        _rsa.Dispose();

        if (Directory.Exists(_testDir))
            Directory.Delete(_testDir, true);
    }

    private string GenerateLicense(string product, string edition, DateTime? expiryDate = null)
    {
        var payload = new LicenseManager.LicensePayload
        {
            Product = product,
            Edition = edition,
            Type = "Perpetual",
            IssueDate = DateTime.UtcNow,
            ExpiryDate = expiryDate
        };

        var json = JsonSerializer.Serialize(payload);
        var payloadBytes = Encoding.UTF8.GetBytes(json);
        var payloadB64 = Convert.ToBase64String(payloadBytes);

        var signatureBytes = _rsa.SignData(payloadBytes, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1);
        var signatureB64 = Convert.ToBase64String(signatureBytes);

        return $"{payloadB64}.{signatureB64}";
    }

    [Fact]
    public void ValidLicense_ActivatesSuccessfully()
    {
        string lic = GenerateLicense("AegisDNS", "Pro");
        bool result = LicenseManager.EnsureActivated(lic);

        Assert.True(result);
        Assert.True(LicenseManager.IsLicenseValid());
        Assert.Equal(LicenseManager.LicenseTier.Pro, LicenseManager.CurrentTier);
    }

    [Fact]
    public void InvalidSignature_RejectsActivation()
    {
        string validLic = GenerateLicense("AegisDNS", "Pro");
        var parts = validLic.Split('.');

        // Tamper with signature
        byte[] sigBytes = Convert.FromBase64String(parts[1]);
        sigBytes[0] ^= 0xFF;
        string tamperedSig = Convert.ToBase64String(sigBytes);

        string tamperedLic = $"{parts[0]}.{tamperedSig}";

        bool result = LicenseManager.EnsureActivated(tamperedLic);
        Assert.False(result);
        Assert.False(LicenseManager.IsLicenseValid());
    }

    [Fact]
    public void HwidMismatch_RejectsValidation()
    {
        string lic = GenerateLicense("AegisDNS", "Pro");
        bool activated = LicenseManager.EnsureActivated(lic);
        Assert.True(activated);

        // Manually tamper token path to simulate changing HWID
        string tokenData = AesGcmTokenStore.Decrypt(LicenseManager.TokenPath)!;
        var parts = tokenData.Split('|');
        if (parts.Length >= 2)
        {
            parts[1] = "FAKE-HWID-0000";
        }
        AesGcmTokenStore.Encrypt(string.Join('|', parts), LicenseManager.TokenPath);

        Assert.False(LicenseManager.IsLicenseValid());
    }

    [Fact]
    public void ExpiredKey_RejectsValidation()
    {
        // Set expiry to 10 days ago (GraceDays is 7)
        string lic = GenerateLicense("AegisDNS", "Pro", DateTime.UtcNow.AddDays(-10));

        // EnsureActivated might accept and save it
        LicenseManager.EnsureActivated(lic);

        // But IsLicenseValid must return false due to expiration
        Assert.False(LicenseManager.IsLicenseValid());
    }
}
