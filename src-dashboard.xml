using System;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Linq;
using System.Net.WebSockets;
using System.Text;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.Core.PolicyEngine;

using Microsoft.AspNetCore.Builder;
using Microsoft.AspNetCore.Http;
using Microsoft.AspNetCore.WebSockets;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Logging;

namespace AegisDNS.WebDashboard;

/// <summary>
/// AegisDNS Web Management Dashboard — serves on :8080 by default.
/// REST API + WebSocket live DNS feed + embedded SPA frontend.
/// Pro+ tier only — checked by caller before starting.
/// </summary>
public class WebDashboardHost
{
    private WebApplication? _app;
    private readonly AegisEngine _engine;
    private readonly ILogger<WebDashboardHost> _logger;
    private readonly DevicePolicyEngine _policyEngine;
    private readonly ConcurrentBag<WebSocket> _liveClients = new();

    public WebDashboardHost(AegisEngine engine, DevicePolicyEngine policyEngine, ILogger<WebDashboardHost> logger)
    {
        _engine = engine;
        _policyEngine = policyEngine;
        _logger = logger;
        _engine.LogReceived += OnLogReceived;
    }

    public async Task StartAsync(int port = 8080, CancellationToken ct = default)
    {
        var builder = WebApplication.CreateBuilder();
        builder.Services.AddSingleton(_engine);
        builder.Services.AddSingleton(_policyEngine);
        builder.Services.AddWebSockets(opts => opts.KeepAliveInterval = TimeSpan.FromSeconds(30));
        builder.Services.AddCors(opts =>
            opts.AddDefaultPolicy(p => p.AllowAnyOrigin().AllowAnyMethod().AllowAnyHeader()));
        builder.WebHost.UseUrls($"http://0.0.0.0:{port}");

        _app = builder.Build();
        _app.UseCors();
        _app.UseWebSockets();
        _app.UseDefaultFiles();
        _app.UseStaticFiles();
        MapEndpoints(_app);
        await _app.StartAsync(ct);
    }

    public async Task StopAsync() => await (_app?.StopAsync() ?? Task.CompletedTask);

    private void MapEndpoints(WebApplication app)
    {
        app.MapGet("/api/status", () => Results.Json(new
        {
            total = MetricsManager.Current.TotalQueries,
            blocked = MetricsManager.Current.BlockedQueries,
            cacheHits = MetricsManager.Current.CacheHits,
            uptime = (DateTime.UtcNow - System.Diagnostics.Process.GetCurrentProcess().StartTime.ToUniversalTime()).ToString(@"d\.hh\:mm\:ss"),
            version = "0.0.2",
            tier = AegisDNS.Licensing.LicenseManager.CurrentTier.ToString()
        }));

        app.MapGet("/api/history", (int limit = 100) =>
            Results.Json(_engine.GetHistory().Take(limit)));

        app.MapGet("/api/policies", () =>
            Results.Json(_policyEngine.GetAllPolicies()));

        app.MapPost("/api/policies", async (HttpRequest req) =>
        {
            try
            {
                DevicePolicy? policy;
                try
                {
                    policy = await JsonSerializer.DeserializeAsync<DevicePolicy>(req.Body);
                }
                catch (JsonException ex)
                {
                    _logger.LogWarning(ex, "JSON invalid.");
                    return Results.BadRequest("Invalid request body");
                }
                if (policy == null) return Results.BadRequest("Invalid policy JSON");
                _policyEngine.SaveDevicePolicy(policy);
                return Results.Ok(new { saved = true });
            }
            catch (Exception ex) { return Results.BadRequest(ex.Message); }
        });

        app.MapGet("/api/groups", () =>
            Results.Json(_policyEngine.GetAllGroups()));

        app.MapPost("/api/groups", async (HttpRequest req) =>
        {
            try
            {
                DeviceGroup? group;
                try
                {
                    group = await JsonSerializer.DeserializeAsync<DeviceGroup>(req.Body);
                }
                catch (JsonException ex)
                {
                    _logger.LogWarning(ex, "JSON invalid.");
                    return Results.BadRequest("Invalid request body");
                }
                if (group == null) return Results.BadRequest("Invalid group JSON");
                _policyEngine.SaveGroup(group);
                return Results.Ok(new { saved = true });
            }
            catch (Exception ex) { return Results.BadRequest(ex.Message); }
        });

        app.MapPost("/api/blocklist/add", async (HttpRequest req) =>
        {
            try
            {
                var body = await new System.IO.StreamReader(req.Body).ReadToEndAsync();
                Dictionary<string, string>? data;
                try
                {
                    data = JsonSerializer.Deserialize<Dictionary<string, string>>(body);
                }
                catch (JsonException ex)
                {
                    _logger.LogWarning(ex, "JSON invalid.");
                    return Results.BadRequest("Invalid request body");
                }
                if (data?.TryGetValue("domain", out string? domain) == true && !string.IsNullOrWhiteSpace(domain))
                {
                    _engine.AddToBlocklist(domain);
                    return Results.Ok(new { added = domain });
                }
                return Results.BadRequest("domain required");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Request handler error.");
                return Results.BadRequest("Invalid request");
            }
        });

        app.MapPost("/api/allowlist/add", async (HttpRequest req) =>
        {
            try
            {
                var body = await new System.IO.StreamReader(req.Body).ReadToEndAsync();
                Dictionary<string, string>? data;
                try
                {
                    data = JsonSerializer.Deserialize<Dictionary<string, string>>(body);
                }
                catch (JsonException ex)
                {
                    _logger.LogWarning(ex, "JSON invalid.");
                    return Results.BadRequest("Invalid request body");
                }
                if (data?.TryGetValue("domain", out string? domain) == true && !string.IsNullOrWhiteSpace(domain))
                {
                    AegisDNS.Core.Utilities.AllowlistManager.Add(domain);
                    return Results.Ok(new { added = domain });
                }
                return Results.BadRequest("domain required");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Request handler error.");
                return Results.BadRequest("Invalid request");
            }
        });

        app.MapGet("/api/metrics/top-blocked", () =>
            Results.Json(AegisDNS.Core.Utilities.TopDomainsTracker.GetTopBlocked(20)));

        app.MapGet("/ws/live", async (HttpContext ctx) =>
        {
            if (!ctx.WebSockets.IsWebSocketRequest) { ctx.Response.StatusCode = 400; return; }
            using var ws = await ctx.WebSockets.AcceptWebSocketAsync();
            _liveClients.Add(ws);
            var buf = new byte[1024];
            while (ws.State == WebSocketState.Open)
            {
                var result = await ws.ReceiveAsync(new ArraySegment<byte>(buf), ctx.RequestAborted);
                if (result.MessageType == WebSocketMessageType.Close) break;
            }
        });
    }

    private void OnLogReceived(string message)
    {
        if (_liveClients.IsEmpty) return;
        var bytes = Encoding.UTF8.GetBytes(JsonSerializer.Serialize(new
        {
            ts = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
            msg = message
        }));
        var segment = new ArraySegment<byte>(bytes);
        foreach (var ws in _liveClients)
            if (ws.State == WebSocketState.Open)
                ws.SendAsync(segment, WebSocketMessageType.Text, true, CancellationToken.None)
                  .ConfigureAwait(false);
    }
}
