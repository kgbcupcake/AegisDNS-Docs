<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AegisDNS — Network Protection Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --bg: #070d18;
      --bg2: #0d1626;
      --bg3: #111e34;
      --panel: #0f1c2e;
      --border: #1a2d4a;
      --cyan: #00e5ff;
      --cyan-dim: #0097a7;
      --blue: #0288d1;
      --text: #c8ddf0;
      --muted: #4a6a8a;
      --green: #00e676;
      --red: #ff1744;
      --orange: #ff9100;
      --font-mono: 'Share Tech Mono', monospace;
      --font-ui: 'Exo 2', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-ui);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── ANIMATED BACKGROUND ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 20% 20%, rgba(0, 133, 209, 0.06) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(0, 229, 255, 0.04) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── GRID OVERLAY ── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    /* ── TOPBAR ── */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 28px;
      height: 58px;
      background: rgba(7, 13, 24, 0.95);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(12px);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-shield {
      width: 32px;
      height: 32px;
    }

    .logo-text {
      font-family: var(--font-ui);
      font-weight: 700;
      font-size: 18px;
      letter-spacing: 3px;
    }

    .logo-text span {
      color: var(--cyan);
    }

    .status-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 14px;
      border-radius: 20px;
      background: rgba(0, 230, 118, 0.08);
      border: 1px solid rgba(0, 230, 118, 0.25);
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 1px;
      color: var(--green);
    }

    .status-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 8px var(--green);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.5;
        transform: scale(0.8);
      }
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .tier-badge {
      padding: 3px 10px;
      border-radius: 4px;
      background: rgba(2, 136, 209, 0.2);
      border: 1px solid rgba(2, 136, 209, 0.4);
      font-size: 10px;
      letter-spacing: 2px;
      color: var(--blue);
      font-family: var(--font-mono);
    }

    .uptime-text {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--muted);
    }

    /* ── NAV ── */
    .nav {
      display: flex;
      gap: 2px;
      padding: 0 28px;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      position: relative;
      z-index: 10;
    }

    .nav-btn {
      padding: 10px 18px;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      color: var(--muted);
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 2px;
      cursor: pointer;
      transition: all 0.2s;
      text-transform: uppercase;
    }

    .nav-btn:hover {
      color: var(--text);
    }

    .nav-btn.active {
      color: var(--cyan);
      border-bottom-color: var(--cyan);
    }

    /* ── LAYOUT ── */
    .main {
      position: relative;
      z-index: 1;
      padding: 24px 28px;
      max-width: 1600px;
      margin: 0 auto;
    }

    /* ── STAT CARDS ── */
    .stat-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .stat-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 20px 22px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.2s;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
    }

    .stat-card.cyan::before {
      background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    }

    .stat-card.green::before {
      background: linear-gradient(90deg, transparent, var(--green), transparent);
    }

    .stat-card.blue::before {
      background: linear-gradient(90deg, transparent, var(--blue), transparent);
    }

    .stat-card.orange::before {
      background: linear-gradient(90deg, transparent, var(--orange), transparent);
    }

    .stat-card:hover {
      border-color: rgba(0, 229, 255, 0.3);
    }

    .stat-label {
      font-size: 10px;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .stat-value {
      font-family: var(--font-mono);
      font-size: 32px;
      font-weight: 400;
      color: var(--text);
      line-height: 1;
    }

    .stat-value.cyan {
      color: var(--cyan);
    }

    .stat-value.green {
      color: var(--green);
    }

    .stat-value.blue {
      color: var(--blue);
    }

    .stat-sub {
      font-size: 11px;
      color: var(--muted);
      margin-top: 6px;
    }

    /* ── GRID PANELS ── */
    .panel-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }

    .panel-grid-3 {
      grid-template-columns: 1.6fr 1fr 1fr;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }

    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      background: rgba(0, 0, 0, 0.2);
    }

    .panel-title {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--cyan);
    }

    .panel-action {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 1px;
      cursor: pointer;
      background: none;
      border: none;
      font-family: var(--font-ui);
    }

    .panel-action:hover {
      color: var(--cyan);
    }

    .panel-body {
      padding: 16px 20px;
    }

    /* ── LIVE LOG ── */
    .live-log {
      font-family: var(--font-mono);
      font-size: 11px;
      height: 260px;
      overflow-y: auto;
      display: flex;
      flex-direction: column-reverse;
      gap: 3px;
    }

    .live-log::-webkit-scrollbar {
      width: 4px;
    }

    .live-log::-webkit-scrollbar-track {
      background: transparent;
    }

    .live-log::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 2px;
    }

    .log-entry {
      display: flex;
      gap: 10px;
      padding: 3px 0;
      border-bottom: 1px solid rgba(26, 45, 74, 0.5);
      animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .log-ts {
      color: var(--muted);
      min-width: 80px;
    }

    .log-msg {
      color: var(--text);
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .log-msg.blocked {
      color: var(--red);
    }

    .log-msg.allowed {
      color: var(--green);
    }

    .log-msg.cached {
      color: var(--cyan-dim);
    }

    /* ── BAR CHART (top blocked) ── */
    .domain-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .domain-row {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .domain-name {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text);
      min-width: 0;
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .domain-bar-wrap {
      width: 100px;
      height: 6px;
      background: var(--bg3);
      border-radius: 3px;
      overflow: hidden;
    }

    .domain-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--cyan-dim), var(--cyan));
      border-radius: 3px;
      transition: width 0.6s ease;
    }

    .domain-count {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--muted);
      min-width: 32px;
      text-align: right;
    }

    /* ── BLOCK RATE DONUT ── */
    .donut-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px 0 10px;
    }

    .donut-svg {
      transform: rotate(-90deg);
    }

    .donut-center {
      position: absolute;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .donut-pct {
      font-family: var(--font-mono);
      font-size: 28px;
      color: var(--cyan);
    }

    .donut-lbl {
      font-size: 9px;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
    }

    /* ── QUERY INPUT ── */
    .input-row {
      display: flex;
      gap: 8px;
    }

    .dns-input {
      flex: 1;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 9px 14px;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s;
    }

    .dns-input:focus {
      border-color: var(--cyan);
    }

    .dns-input::placeholder {
      color: var(--muted);
    }

    .btn {
      padding: 9px 16px;
      border-radius: 6px;
      border: none;
      font-family: var(--font-ui);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-cyan {
      background: rgba(0, 229, 255, 0.12);
      border: 1px solid rgba(0, 229, 255, 0.35);
      color: var(--cyan);
    }

    .btn-cyan:hover {
      background: rgba(0, 229, 255, 0.2);
      box-shadow: 0 0 12px rgba(0, 229, 255, 0.2);
    }

    .btn-red {
      background: rgba(255, 23, 68, 0.12);
      border: 1px solid rgba(255, 23, 68, 0.35);
      color: var(--red);
    }

    .btn-red:hover {
      background: rgba(255, 23, 68, 0.2);
    }

    /* ── POLICY TABLE ── */
    .policy-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }

    .policy-table th {
      text-align: left;
      padding: 8px 12px;
      font-size: 10px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }

    .policy-table td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(26, 45, 74, 0.5);
      font-family: var(--font-mono);
      font-size: 11px;
    }

    .policy-table tr:hover td {
      background: rgba(0, 229, 255, 0.03);
    }

    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 10px;
      letter-spacing: 1px;
    }

    .badge-allow {
      background: rgba(0, 230, 118, 0.12);
      color: var(--green);
      border: 1px solid rgba(0, 230, 118, 0.25);
    }

    .badge-block {
      background: rgba(255, 23, 68, 0.12);
      color: var(--red);
      border: 1px solid rgba(255, 23, 68, 0.25);
    }

    /* ── TABS ── */
    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    /* ── EMPTY STATE ── */
    .empty {
      text-align: center;
      padding: 40px;
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 1px;
    }

    /* ── TOAST ── */
    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      padding: 12px 20px;
      border-radius: 6px;
      background: var(--panel);
      border: 1px solid var(--cyan);
      color: var(--cyan);
      font-family: var(--font-mono);
      font-size: 12px;
      z-index: 999;
      transform: translateY(80px);
      opacity: 0;
      transition: all 0.3s ease;
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    /* ── LOADING ── */
    .loading {
      display: inline-block;
      width: 12px;
      height: 12px;
      border: 2px solid var(--border);
      border-top-color: var(--cyan);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
      .stat-row {
        grid-template-columns: repeat(2, 1fr);
      }

      .panel-grid,
      .panel-grid-3 {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

