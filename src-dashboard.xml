              <div class="donut-center" style="position:absolute">
                <div class="donut-pct" id="donutPct">0%</div>
                <div class="donut-lbl">blocked</div>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%">
              <div style="text-align:center">
                <div style="font-size:10px;letter-spacing:2px;color:var(--muted)">ALLOWED</div>
                <div style="font-family:var(--font-mono);color:var(--green)" id="allowedCount">–</div>
              </div>
              <div style="text-align:center">
                <div style="font-size:10px;letter-spacing:2px;color:var(--muted)">BLOCKED</div>
                <div style="font-family:var(--font-mono);color:var(--red)" id="blockedCount">–</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ── TRAFFIC TAB ── -->
    <div id="tab-traffic" class="tab-content">
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">Live DNS Traffic — WebSocket Feed</span>
          <div style="display:flex;gap:8px">
            <span id="wsStatus" style="font-size:10px;color:var(--muted)">CONNECTING</span>
            <button class="panel-action" onclick="clearLog()">Clear</button>
          </div>
        </div>
        <div class="panel-body">
          <div class="live-log" id="fullLog" style="height:500px;flex-direction:column"></div>
        </div>
      </div>
    </div>

    <!-- ── BLOCKLIST TAB ── -->
    <div id="tab-blocklist" class="tab-content">
      <div class="panel-grid">
        <div class="panel">
          <div class="panel-header"><span class="panel-title">Block a Domain</span></div>
          <div class="panel-body">
            <div style="margin-bottom:12px;font-size:12px;color:var(--muted)">
              Add a domain to the live blocklist. Takes effect immediately — no restart required.
            </div>
            <div class="input-row">
              <input class="dns-input" id="blockInput" placeholder="ads.example.com" type="text" />
              <button class="btn btn-red" onclick="blockDomain()">BLOCK</button>
            </div>
          </div>
        </div>
        <div class="panel">
          <div class="panel-header"><span class="panel-title">Allow a Domain</span></div>
          <div class="panel-body">
            <div style="margin-bottom:12px;font-size:12px;color:var(--muted)">
              Add a domain to the allowlist. Always resolves regardless of blocklist rules.
            </div>
            <div class="input-row">
              <input class="dns-input" id="allowInput" placeholder="my.domain.com" type="text" />
              <button class="btn btn-cyan" onclick="allowDomain()">ALLOW</button>
            </div>
          </div>
        </div>
      </div>
      <div class="panel" style="margin-top:16px">
        <div class="panel-header"><span class="panel-title">Top Blocked Domains</span></div>
        <div class="panel-body">
          <table class="policy-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Domain</th>
                <th>Block Count</th>
                <th>Bar</th>
              </tr>
            </thead>
            <tbody id="topBlockedTable"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ── POLICIES TAB ── -->
    <div id="tab-policies" class="tab-content">
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">Device Policies</span>
          <button class="panel-action" onclick="loadPolicies()">↺ Refresh</button>
        </div>
        <div class="panel-body">
          <div id="policyList"></div>
        </div>
      </div>
    </div>

  </div><!-- /main -->

  <div class="toast" id="toast"></div>

  <script>
    const API = '';  // same origin

    // ── STATE ──
    let ws = null;
    let logEntries = [];
    let statsData = null;

    // ── INIT ──
    document.addEventListener('DOMContentLoaded', () => {
      fetchStats();
      fetchTopBlocked();
      connectWebSocket();
      setInterval(fetchStats, 5000);
      setInterval(fetchTopBlocked, 15000);
    });

    // ── TAB SWITCHING ──
    function switchTab(name) {
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      event.target.classList.add('active');
      if (name === 'policies') loadPolicies();
      if (name === 'blocklist') renderTopBlockedTable();
    }

    // ── STATS ──
    async function fetchStats() {
      try {
        const r = await fetch(API + '/api/status');
        const d = await r.json();
        statsData = d;

        document.getElementById('totalQ').textContent = fmt(d.total);
        document.getElementById('blockedQ').textContent = fmt(d.blocked);
        document.getElementById('cacheHits').textContent = fmt(d.cacheHits);
        document.getElementById('uptimeStat').textContent = d.uptime;
        document.getElementById('uptimeText').textContent = d.uptime;
        document.getElementById('tierBadge').textContent = d.tier.toUpperCase();

        const pct = d.total > 0 ? Math.round((d.blocked / d.total) * 100) : 0;
        document.getElementById('blockPct').textContent = pct + '% block rate';
        document.getElementById('blockPct').textContent = pct + '% block rate';

        const cpct = d.total > 0 ? Math.round((d.cacheHits / d.total) * 100) : 0;
        document.getElementById('cachePct').textContent = cpct + '% cache rate';

        // Donut
        const circ = 339.3;
        const offset = circ - (pct / 100) * circ;
        document.getElementById('donutArc').style.strokeDashoffset = offset;
        document.getElementById('donutPct').textContent = pct + '%';
        document.getElementById('allowedCount').textContent = fmt(d.total - d.blocked);
        document.getElementById('blockedCount').textContent = fmt(d.blocked);

        // Status
        document.getElementById('statusDot').style.background = '#00e676';
        document.getElementById('statusDot').style.boxShadow = '0 0 8px #00e676';
        document.getElementById('statusText').textContent = 'PROTECTED';

      } catch (e) {
        document.getElementById('statusDot').style.background = '#ff1744';
        document.getElementById('statusDot').style.boxShadow = '0 0 8px #ff1744';
        document.getElementById('statusText').textContent = 'OFFLINE';
      }
    }

    // ── TOP BLOCKED ──
    let topData = [];
    async function fetchTopBlocked() {
      try {
        const r = await fetch(API + '/api/metrics/top-blocked');
        topData = await r.json();
        renderTopBlocked();
        renderTopBlockedTable();
      } catch (e) { }
    }

    function renderTopBlocked() {
      const el = document.getElementById('topBlocked');
      if (!topData.length) { el.innerHTML = '<div class="empty">No blocked domains yet</div>'; return; }
      const max = topData[0].count || 1;
      el.innerHTML = topData.slice(0, 8).map(d => `
      <div class="domain-row">
        <div class="domain-name">${esc(d.domain)}</div>
        <div class="domain-bar-wrap">
          <div class="domain-bar" style="width:${Math.round((d.count / max) * 100)}%"></div>
        </div>
        <div class="domain-count">${d.count}</div>
      </div>`).join('');
    }

    function renderTopBlockedTable() {
      const el = document.getElementById('topBlockedTable');
      if (!el) return;
      if (!topData.length) { el.innerHTML = '<tr><td colspan="4" class="empty">No data</td></tr>'; return; }
      const max = topData[0].count || 1;
      el.innerHTML = topData.map((d, i) => `
      <tr>
        <td style="color:var(--muted)">${i + 1}</td>
        <td>${esc(d.domain)}</td>
        <td style="color:var(--red)">${d.count}</td>
        <td><div class="domain-bar-wrap" style="width:120px">
          <div class="domain-bar" style="width:${Math.round((d.count / max) * 100)}%"></div>
        </div></td>
      </tr>`).join('');
    }

    // ── WEBSOCKET LIVE FEED ──
    function connectWebSocket() {
      const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
      ws = new WebSocket(`${proto}//${location.host}/ws/live`);

      ws.onopen = () => {
        document.getElementById('wsStatus').textContent = 'LIVE';
        document.getElementById('wsStatus').style.color = 'var(--green)';
      };

      ws.onclose = () => {
        document.getElementById('wsStatus').textContent = 'RECONNECTING';
        document.getElementById('wsStatus').style.color = 'var(--orange)';
        setTimeout(connectWebSocket, 3000);
      };

      ws.onmessage = (ev) => {
        try {
          const d = JSON.parse(ev.data);
          addLogEntry(d.ts, d.msg);
        } catch (e) { }
      };
    }

    function addLogEntry(ts, msg) {
      const time = new Date(ts).toLocaleTimeString('en-US', { hour12: false });
      const isBlocked = msg.includes('BLOCKED') || msg.includes('blocked');
      const isCached = msg.includes('CACHE') || msg.includes('cached');
      const cls = isBlocked ? 'blocked' : isCached ? 'cached' : 'allowed';

      logEntries.unshift({ time, msg, cls });
      if (logEntries.length > 500) logEntries.pop();

      renderLog('dashLog', logEntries.slice(0, 20));
      renderLog('fullLog', logEntries, false);
    }

    function renderLog(id, entries, reverse = true) {
      const el = document.getElementById(id);
      if (!el) return;
      const html = entries.map(e => `
      <div class="log-entry">
        <span class="log-ts">${e.time}</span>
        <span class="log-msg ${e.cls}">${esc(e.msg)}</span>
      </div>`).join('');
      el.innerHTML = html || '<div class="empty">Waiting for DNS queries...</div>';
    }

    function clearLog() {
      logEntries = [];
      renderLog('fullLog', []);
    }

    // ── BLOCKLIST ACTIONS ──
    async function blockDomain() {
      const domain = document.getElementById('blockInput').value.trim();
      if (!domain) return;
      try {
        await fetch(API + '/api/blocklist/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ domain })
        });
        toast(`Blocked: ${domain}`);
        document.getElementById('blockInput').value = '';
      } catch (e) { toast('Error — is AegisDNS running?', true); }
    }

    async function allowDomain() {
      const domain = document.getElementById('allowInput').value.trim();
      if (!domain) return;
      try {
        await fetch(API + '/api/allowlist/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ domain })
        });
        toast(`Allowed: ${domain}`);
        document.getElementById('allowInput').value = '';
      } catch (e) { toast('Error — is AegisDNS running?', true); }
    }

    // ── POLICIES ──
    async function loadPolicies() {
      const el = document.getElementById('policyList');
      el.innerHTML = '<div class="empty"><span class="loading"></span></div>';
      try {
        const r = await fetch(API + '/api/policies');
        const policies = await r.json();
        if (!policies.length) {
          el.innerHTML = '<div class="empty">No device policies configured</div>';
          return;
        }
        el.innerHTML = `
        <table class="policy-table">
          <thead>
            <tr><th>Device</th><th>MAC</th><th>Group</th><th>SafeSearch</th><th>Default</th></tr>
          </thead>
          <tbody>
            ${policies.map(p => `
              <tr>
                <td>${esc(p.deviceName)}</td>
                <td>${esc(p.mac)}</td>
                <td>${esc(p.groupId || '—')}</td>
                <td><span class="badge ${p.safeSearchEnabled ? 'badge-allow' : 'badge-block'}">${p.safeSearchEnabled ? 'ON' : 'OFF'}</span></td>
                <td><span class="badge ${p.blockAllByDefault ? 'badge-block' : 'badge-allow'}">${p.blockAllByDefault ? 'BLOCK' : 'ALLOW'}</span></td>
              </tr>`).join('')}
          </tbody>
        </table>`;
      } catch (e) {
        el.innerHTML = '<div class="empty">Failed to load policies</div>';
      }
    }

    // ── HELPERS ──
    function fmt(n) {
      if (n === undefined || n === null) return '–';
      return n.toLocaleString();
    }

    function esc(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function toast(msg, isErr = false) {
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.style.borderColor = isErr ? 'var(--red)' : 'var(--cyan)';
      el.style.color = isErr ? 'var(--red)' : 'var(--cyan)';
      el.classList.add('show');
      setTimeout(() => el.classList.remove('show'), 3000);
    }

    // Load history on boot for the log
    (async () => {
      try {
        const r = await fetch(API + '/api/history?limit=50');
        const hist = await r.json();
        hist.reverse().forEach(h => {
          logEntries.unshift({ time: new Date(h.timestamp || Date.now()).toLocaleTimeString('en-US', { hour12: false }), msg: h.domain || JSON.stringify(h), cls: h.blocked ? 'blocked' : 'allowed' });
        });
        renderLog('dashLog', logEntries.slice(0, 20));
        renderLog('fullLog', logEntries, false);
      } catch (e) { }
    })();
  </script>
</body>

</html>
