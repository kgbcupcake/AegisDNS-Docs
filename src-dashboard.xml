        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">Block Rate</span>
          </div>
          <div class="panel-body" style="display:flex;flex-direction:column;align-items:center;gap:16px">
            <div style="position:relative;display:flex;align-items:center;justify-content:center">
              <svg class="donut-svg" width="140" height="140" viewBox="0 0 140 140">
                <circle cx="70" cy="70" r="54" fill="none" stroke="#1a2d4a" stroke-width="14" />
                <circle cx="70" cy="70" r="54" fill="none" stroke="#00e5ff" stroke-width="14" stroke-dasharray="339.3"
