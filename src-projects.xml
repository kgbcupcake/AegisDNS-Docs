<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
	  <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.3" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Systemd" Version="10.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AegisDNS.Core\AegisDNS.Core.csproj" />
    <ProjectReference Include="..\AegisDNS.ArchitectureAnalyzer\AegisDNS.ArchitectureAnalyzer.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\AegisDNS.Licensing\AegisDNS.Licensing.csproj" />
    <ProjectReference Include="..\AegisDNS.BpfLoader\AegisDNS.BpfLoader.csproj" />
    <ProjectReference Include="..\AegisDNS.XdpLoader\AegisDNS.XdpLoader.csproj" />
    <ProjectReference Include="..\AegisDNS.WebDashboard\AegisDNS.WebDashboard.csproj" />
  </ItemGroup>



  <Target Name="CopyBpfObject" AfterTargets="Publish" Condition="'$(OS)' == 'Unix'">
    <Message Text="[AegisDNS] Copying eBPF kernel object to publish output..." Importance="high" />
    <Copy SourceFiles="$(MSBuildThisFileDirectory)../../kernel/aegisdns.bpf.o"
          DestinationFolder="$(PublishDir)kernel/"
          Condition="Exists('$(MSBuildThisFileDirectory)../../kernel/aegisdns.bpf.o')" />
  </Target>

  <Target Name="CopyXdpObject" AfterTargets="Publish" Condition="'$(OS)' == 'Unix'">
    <Message Text="[AegisDNS] Copying XDP kernel object to publish output..." Importance="high" />
    <Copy SourceFiles="$(MSBuildThisFileDirectory)../AegisDNS.XdpLoader/xdp/aegis_xdp.o"
          DestinationFolder="$(PublishDir)xdp/"
          Condition="Exists('$(MSBuildThisFileDirectory)../AegisDNS.XdpLoader/xdp/aegis_xdp.o')" />
  </Target>
</Project>
