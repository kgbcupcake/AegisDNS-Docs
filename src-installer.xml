    // ── Constructor ───────────────────────────────────────────────────────────

    public InstallerViewModel()
    {
        BackCommand = ReactiveCommand.Create(GoBack);
        NextCommand = ReactiveCommand.Create(GoNext);
        ExpressCommand = ReactiveCommand.Create(() =>
        {
            RecommendedSelected = true;
            CurrentPage = InstallerPage.SystemAudit;
            RunAuditAsync();
        });
        AdvancedCommand = ReactiveCommand.Create(() =>
        {
            CustomSelected = true;
            CurrentPage = InstallerPage.SystemAudit;
            RunAuditAsync();
        });
        HeadlessCommand = ReactiveCommand.Create(() =>
        {
            HeadlessSelected = true;
            CurrentPage = InstallerPage.SystemAudit;
            RunAuditAsync();
        });
        ActivateCommand = ReactiveCommand.CreateFromTask(ActivateAsync);
        SkipLicenseCommand = ReactiveCommand.Create(() =>
        {
            LicenseActivated = true;
            ActivatedEdition = "Community";
            GoNext();
        });
        TestLatencyCommand = ReactiveCommand.CreateFromTask(TestLatencyAsync);
        TestAiCommand = ReactiveCommand.CreateFromTask(TestAiAsync);
        StartInstallCommand = ReactiveCommand.CreateFromTask(StartInstallAsync);
        LaunchCommand = ReactiveCommand.Create(() =>
        {
            try
            {
                var psi = new ProcessStartInfo("/opt/AegisDNS/AegisDNSUI");
                psi.UseShellExecute = false;
                Process.Start(psi);
            }
            catch { /* will run from app launcher */ }
            Environment.Exit(0);
        });

        DetectSystemInfo();
        BuildInstallSteps();

        // Check if already activated (e.g. on reinstall)
        using (LicenseTokenScope.ForRealUserIfElevated())
        {
            if (LicenseManager.IsLicenseValid())
            {
                // Force a rewrite of the token to ensure the timestamp is updated
                // and it is bound to the current machine's HWID (safety measure).
                string? raw = LicenseManager.GetRawLicenseFromToken();
                if (raw != null)
                {
                    LicenseManager.EnsureActivated(raw);
                }

                LicenseActivated = true;
                ActivatedEdition = LicenseManager.CurrentTier.ToString();
                ActivationStatus = $"✅ Activated — {ActivatedEdition} Edition";
                ActivationColor = "#00FF88";
                SummaryEdition = ActivatedEdition;
            }
        }
    }

    // ── Navigation ────────────────────────────────────────────────────────────

    private void GoBack()
    {
        if (CurrentPage == InstallerPage.SystemAudit)
        {
            // Back from audit goes to InstallType, not previous enum value
            CurrentPage = InstallerPage.InstallType;
            return;
        }
        if ((int)CurrentPage > 0)
            CurrentPage = (InstallerPage)((int)CurrentPage - 1);
    }

    private void GoNext()
    {
        // Express mode skips DnsConfig + AiConfig
        if (RecommendedSelected && CurrentPage == InstallerPage.LicenseActivation)
        {
            CurrentPage = InstallerPage.InstallProgress;
            return;
        }
        if ((int)CurrentPage < (int)InstallerPage.Complete)
            CurrentPage = (InstallerPage)((int)CurrentPage + 1);
    }

    // ── System Detection ──────────────────────────────────────────────────────

    private void DetectSystemInfo()
    {
        Task.Run(() =>
        {
            try
            {
                // Distro
                if (File.Exists("/etc/os-release"))
                {
                    foreach (var line in File.ReadAllLines("/etc/os-release"))
                        if (line.StartsWith("PRETTY_NAME="))
                        { DetectedDistro = line.Split('=')[1].Trim('"'); break; }
                }

                // Kernel
                KernelVersion = RunCmd("uname", "-r").Trim();

                // RAM
                if (File.Exists("/proc/meminfo"))
                {
                    foreach (var line in File.ReadAllLines("/proc/meminfo"))
                        if (line.StartsWith("MemTotal:"))
                        {
                            var kb = long.Parse(line.Split(new[] { ' ' },
                                StringSplitOptions.RemoveEmptyEntries)[1]);
                            RamInfo = $"{kb / 1024 / 1024} GB";
                            break;
                        }
                }

                // CPU
                if (File.Exists("/proc/cpuinfo"))
                {
                    foreach (var line in File.ReadAllLines("/proc/cpuinfo"))
                        if (line.StartsWith("model name"))
                        {
                            CpuInfo = line.Split(':')[1].Trim();
                            break;
                        }
                }

                // Installer hash (self)
                var self = Environment.ProcessPath ?? "";
                if (File.Exists(self))
                {
                    using var sha = System.Security.Cryptography.SHA256.Create();
                    using var stream = File.OpenRead(self);
                    var hash = Convert.ToHexString(sha.ComputeHash(stream));
                    InstallerHash = $"SHA256: {hash[..8]}...{hash[^8..]}";
                }
                else InstallerHash = "SHA256: N/A";
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[InstallerViewModel] DetectSystemInfo: {ex.Message}");
            }
        });
    }

    // ── Audit ─────────────────────────────────────────────────────────────────

    private async void RunAuditAsync()
    {
        AuditItems.Clear();
        AuditPassed = false;
        EbpfAvailable = false;

        var checks = new (string Name, Func<(bool Ok, bool Critical, string Msg)> Check)[]
        {
            ("Root Privileges", () => {
                bool ok = Environment.IsPrivilegedProcess
                          || RunCmd("id", "-u").Trim() == "0"
                          || Environment.GetEnvironmentVariable("EUID") == "0"
                          || Environment.GetEnvironmentVariable("USER") == "root";
                return (ok, true, ok ? "Running with elevated permissions" : "Not running as root — pkexec required"); }),
            (".NET 10 Runtime",     () => {
                var v = RunCmd("dotnet", "--list-runtimes");
                bool ok = v.Contains("Microsoft.NETCore.App 10.");
                return (ok, true, ok ? ".NET 10 runtime confirmed" : ".NET 10 not found — installer will offer to install"); }),
            ("systemd",             () => {
                bool ok = RunCmd("systemctl", "--version").Contains("systemd");
                return (ok, true, ok ? "systemd is present" : "systemd not found — required for service management"); }),
            ("Kernel 5.8+",         () => {
                var k = RunCmd("uname", "-r").Trim();
                var parts = k.Split('.');
                bool ok = parts.Length >= 2
                       && int.TryParse(parts[0], out int maj)
                       && int.TryParse(parts[1].Split('-')[0], out int min)
                       && (maj > 5 || (maj == 5 && min >= 8));
                return (ok, false, ok ? $"Kernel {k} — eBPF supported" : $"Kernel {k} — below 5.8, eBPF unavailable"); }),
            ("Kernel BTF (vmlinux)", () => {
                bool ok = File.Exists("/sys/kernel/btf/vmlinux");
                return (ok, false, ok ? "BTF data available" : "BTF not found — eBPF compilation will be skipped"); }),
            ("cgroup v2",           () => {
                var mounts = File.Exists("/proc/mounts") ? File.ReadAllText("/proc/mounts") : "";
                bool ok = mounts.Contains("cgroup2");
                return (ok, false, ok ? "cgroup v2 mounted" : "cgroup v2 not detected"); }),
            ("clang",               () => {
                bool ok = CommandExists("clang");
                return (ok, false, ok ? "clang compiler found" : "clang not found — eBPF compilation unavailable"); }),
            ("Disk Space (200MB+)", () => {
                try {
                    var info = new DriveInfo("/");
                    bool ok = info.AvailableFreeSpace > 200L * 1024 * 1024;
                    return (ok, true, ok ? $"{info.AvailableFreeSpace / 1024 / 1024} MB free" : "Less than 200 MB free"); }
                catch { return (true, false, "Could not check disk space"); } }),
        };

        bool allCriticalPassed = true;
        bool ebpfChecks = true;

        foreach (var (name, check) in checks)
        {
            var item = new AuditItem { Name = name, Status = "⏳", Message = "Checking...", StatusColor = "#555555" };
            AuditItems.Add(item);

            await Task.Delay(120); // brief visual stagger
            var (ok, critical, msg) = check();

            item.Status = ok ? "✅" : (critical ? "❌" : "⚠️");
            item.Message = msg;
            item.StatusColor = ok ? "#00FF88" : (critical ? "#FF453A" : "#FFBD2E");

            if (critical && !ok) allCriticalPassed = false;
            if (!ok && (name.Contains("BTF") || name.Contains("clang") || name.Contains("cgroup") || name.Contains("Kernel 5")))
                ebpfChecks = false;
        }

        AuditPassed = allCriticalPassed;
        EbpfAvailable = ebpfChecks && allCriticalPassed;
        SummaryEbpf = EbpfAvailable ? "Active (eBPF)" : "Fallback (iptables)";
    }

