                  VerticalAlignment="Center" Margin="15,0,0,0" Spacing="8">
        <Button Classes="TrafficLight" Background="#FF5F56" Click="CloseBtn_Click"/>
        <Button Classes="TrafficLight" Background="#FFBD2E" Click="MinBtn_Click"/>
