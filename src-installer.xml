<file path="src/AegisDNS.Installer/MainWindow.axaml.cs">
using AegisDNS.Installer.Pages;
using AegisDNS.Installer.ViewModels;

using Avalonia.Controls;
using Avalonia.Input;

namespace AegisDNS.Installer;

public partial class MainWindow : Window
{
    public MainWindow()
    {
        InitializeComponent();
        DataContext = new InstallerViewModel();

        if (DataContext is InstallerViewModel vm)
        {
            vm.PropertyChanged += (_, e) =>
            {
                if (e.PropertyName == nameof(InstallerViewModel.CurrentPage))
                {
                    UpdatePageContent(vm.CurrentPage);
                    UpdatePageDots(vm);
                }
            };
            UpdatePageContent(vm.CurrentPage);
            UpdatePageDots(vm);
        }
    }

    private void UpdatePageContent(InstallerPage page)
    {
        var host = this.FindControl<TransitioningContentControl>("PageHost");
        if (host == null) return;

        host.Content = page switch
        {
            InstallerPage.Welcome => (Control)new WelcomePage { DataContext = DataContext },
            InstallerPage.LicenseAgreement => new LicenseAgreementPage { DataContext = DataContext },
            InstallerPage.InstallType => new InstallTypePage { DataContext = DataContext },
            InstallerPage.SystemAudit => new SystemAuditPage { DataContext = DataContext },
            InstallerPage.LicenseActivation => new LicenseActivationPage { DataContext = DataContext },
            InstallerPage.DnsConfig => new DnsConfigPage { DataContext = DataContext },
            InstallerPage.AiConfig => new AiConfigPage { DataContext = DataContext },
            InstallerPage.InstallProgress => new InstallProgressPage { DataContext = DataContext },
            InstallerPage.Complete => new CompletePage { DataContext = DataContext },
            _ => new WelcomePage { DataContext = DataContext }
        };
    }

    private void UpdatePageDots(InstallerViewModel vm)
    {
        var dots = this.FindControl<StackPanel>("PageDots");
        if (dots == null) return;
        dots.Children.Clear();
        for (int i = 0; i < 9; i++)
        {
            dots.Children.Add(new Avalonia.Controls.Shapes.Ellipse
            {
                Width = 6,
                Height = 6,
                Fill = new Avalonia.Media.SolidColorBrush(
                    i == vm.CurrentPageIndex
                        ? Avalonia.Media.Color.Parse("#00FFFF")
                        : Avalonia.Media.Color.Parse("#333333"))
            });
        }
    }

    private void TitleBar_PointerPressed(object? sender, PointerPressedEventArgs e)
    {
        if (e.GetCurrentPoint(this).Properties.IsLeftButtonPressed)
            BeginMoveDrag(e);
    }

    private void CloseBtn_Click(object? sender, Avalonia.Interactivity.RoutedEventArgs e) => Close();
    private void MinBtn_Click(object? sender, Avalonia.Interactivity.RoutedEventArgs e)
        => WindowState = WindowState.Minimized;
}
