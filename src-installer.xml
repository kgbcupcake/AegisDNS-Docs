using System;
using System.Collections.Generic;
using System.Collections.ObjectModel;
using System.Diagnostics;
using System.IO;
using System.Net.NetworkInformation;
using System.Reactive;
using System.Runtime.InteropServices;
using System.Threading.Tasks;

using AegisDNS.Licensing;

using ReactiveUI;

namespace AegisDNS.Installer.ViewModels;

public enum InstallerPage
{
    Welcome = 0,
    LicenseAgreement = 1,
    InstallType = 2,
    SystemAudit = 3,
    LicenseActivation = 4,
    DnsConfig = 5,
    AiConfig = 6,
    InstallProgress = 7,
    Complete = 8
}

public class AuditItem : ReactiveObject
{
    private string _name = "";
    public string Name { get => _name; set => this.RaiseAndSetIfChanged(ref _name, value); }

    private string _status = "⏳";
    public string Status { get => _status; set => this.RaiseAndSetIfChanged(ref _status, value); }

    private string _message = "";
    public string Message { get => _message; set => this.RaiseAndSetIfChanged(ref _message, value); }

    private string _statusColor = "Gray";
    public string StatusColor { get => _statusColor; set => this.RaiseAndSetIfChanged(ref _statusColor, value); }
}

public class InstallStep : ReactiveObject
{
    private string _name = "";
    public string Name { get => _name; set => this.RaiseAndSetIfChanged(ref _name, value); }

    private string _icon = "⚪";
    public string Icon { get => _icon; set => this.RaiseAndSetIfChanged(ref _icon, value); }

    private string _status = "Waiting...";
    public string Status { get => _status; set => this.RaiseAndSetIfChanged(ref _status, value); }

    private string _elapsed = "0s";
    public string Elapsed { get => _elapsed; set => this.RaiseAndSetIfChanged(ref _elapsed, value); }
}

// UI ViewModel: logger injection deferred — Installer ViewModels are not DI-constructed; Debug.WriteLine retained.
public class InstallerViewModel : ReactiveObject
{
    // ── Page Navigation ───────────────────────────────────────────────────────

    private InstallerPage _currentPage = InstallerPage.Welcome;
    public InstallerPage CurrentPage
    {
        get => _currentPage;
        set
        {
            this.RaiseAndSetIfChanged(ref _currentPage, value);
            this.RaisePropertyChanged(nameof(CurrentPageIndex));
            this.RaisePropertyChanged(nameof(CanGoBack));
            this.RaisePropertyChanged(nameof(CanGoNext));
        }
    }

    public int CurrentPageIndex => (int)CurrentPage;

    public bool CanGoBack => CurrentPage != InstallerPage.Welcome
                          && CurrentPage != InstallerPage.InstallProgress
                          && CurrentPage != InstallerPage.Complete;

    public bool CanGoNext => CurrentPage != InstallerPage.InstallProgress
                          && CurrentPage != InstallerPage.Complete
                          && (CurrentPage != InstallerPage.LicenseAgreement || LicenseAccepted)
                          && CurrentPage != InstallerPage.Welcome; // Welcome uses card buttons

    // ── Welcome Page ──────────────────────────────────────────────────────────

    private string _detectedDistro = "Detecting...";
    public string DetectedDistro { get => _detectedDistro; set => this.RaiseAndSetIfChanged(ref _detectedDistro, value); }

    private string _kernelVersion = "Detecting...";
    public string KernelVersion { get => _kernelVersion; set => this.RaiseAndSetIfChanged(ref _kernelVersion, value); }

    private string _ramInfo = "Detecting...";
