<file path="src/AegisDNS.Installer/Pages/AiConfigPage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.AiConfigPage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">
    <ScrollViewer Padding="50,30,50,20">
        <StackPanel Spacing="16">
            <TextBlock Text="AI SENTINEL" Classes="SectionHeader"/>
            <TextBlock Text="Optional. Configure an AI provider for real-time threat detection." Foreground="#555555" FontSize="12"/>

            <TextBlock Text="PROVIDER" Classes="SectionHeader"/>
            <ComboBox SelectedItem="{Binding AiProvider}" Background="#0A0A0A"
                      BorderBrush="#333333" Foreground="Cyan" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="None"/>
                <ComboBoxItem Content="OpenAI"/>
                <ComboBoxItem Content="Anthropic"/>
                <ComboBoxItem Content="OpenRouter"/>
                <ComboBoxItem Content="Ollama (Local)"/>
            </ComboBox>

            <TextBox Text="{Binding AiApiKey}" Watermark="API Key..."
                     PasswordChar="•" Background="#0A0A0A" Foreground="Cyan" BorderBrush="#333333" CornerRadius="4"/>

            <TextBox Text="{Binding AiModel}" Watermark="Model (e.g. gpt-4o-mini, claude-3-haiku-20240307)"
                     Background="#0A0A0A" Foreground="Cyan" BorderBrush="#333333" CornerRadius="4"/>

            <Button Classes="Secondary" Content="Test Connection" Command="{Binding TestAiCommand}"/>
            <TextBlock Text="{Binding AiTestResult}" Foreground="#00FF88" FontSize="11"/>

            <TextBlock Text="AI can be configured later in Settings → AI Sentinel." Foreground="#444444" FontSize="10" FontStyle="Italic"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
</file>

<file path="src/AegisDNS.Installer/Pages/CompletePage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.CompletePage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">
    <ScrollViewer Padding="50,30,50,20">
        <StackPanel Spacing="0" HorizontalAlignment="Center">
            <TextBlock Text="✅" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="Installation Complete" FontSize="28" FontWeight="Bold"
                       Foreground="Cyan" HorizontalAlignment="Center" LetterSpacing="1">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="12" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="AegisDNS is ready to protect your network."
                       Foreground="#777777" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,32"/>

            <!-- Summary card -->
            <Border Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1"
                    CornerRadius="8" Padding="24,18" Width="420">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,*">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Edition" Foreground="#555555" FontSize="11"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SummaryEdition}" Foreground="Cyan" FontSize="11" HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="DNS Upstream" Foreground="#555555" FontSize="11" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryDns}" Foreground="#CCCCCC" FontSize="11" HorizontalAlignment="Right" Margin="0,8,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="AI Sentinel" Foreground="#555555" FontSize="11" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryAi}" Foreground="#CCCCCC" FontSize="11" HorizontalAlignment="Right" Margin="0,8,0,0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Kernel Protection" Foreground="#555555" FontSize="11" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SummaryEbpf}" Foreground="#00FF88" FontSize="11" HorizontalAlignment="Right" Margin="0,8,0,0"/>
                </Grid>
            </Border>

            <!-- Autostart toggle -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,20,0,0">
                <ToggleSwitch IsChecked="{Binding AutoStartEnabled}"
                              OnContent="Start on boot" OffContent="Manual start"/>
            </StackPanel>

            <!-- Launch button -->
            <Button Classes="Primary" Content="🛡️  Launch AegisDNS"
                    Command="{Binding LaunchCommand}"
                    HorizontalAlignment="Center" FontSize="14"
                    Padding="36,12" Margin="0,24,0,0">
                <Button.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="12" Opacity="0.4"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
</file>

<file path="src/AegisDNS.Installer/Pages/DnsConfigPage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.DnsConfigPage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">
    <ScrollViewer Padding="40,30,40,20">
        <StackPanel Spacing="16">
            <TextBlock Text="DNS CONFIGURATION" Classes="SectionHeader"/>

            <!-- Provider grid -->
            <UniformGrid Columns="2" Margin="0,0,0,12">
                <!-- Cloudflare -->
                <Border Background="#0D0D0D" BorderBrush="#222222" BorderThickness="1" CornerRadius="6" Padding="14,10" Cursor="Hand" Margin="4">
                    <StackPanel Spacing="4">
                        <TextBlock Text="☁️ Cloudflare" Foreground="Cyan" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="1.1.1.1" Foreground="#555555" FontSize="11"/>
                        <TextBlock Text="{Binding CloudflareLatency}" Foreground="#00FF88" FontSize="11"/>
                    </StackPanel>
                </Border>
                <!-- Add other providers here if needed, following same pattern -->
            </UniformGrid>

            <Button Classes="Secondary" Content="Test Latency" Command="{Binding TestLatencyCommand}"/>

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <TextBlock Text="Encrypted DNS (DoH):" Foreground="#B0B0B0" FontSize="12" VerticalAlignment="Center"/>
                <ToggleSwitch IsChecked="{Binding DohEnabled}"
                              OnContent="Enabled" OffContent="Plain UDP"/>
            </StackPanel>

            <!-- Custom fields -->
            <StackPanel Spacing="8" IsVisible="{Binding ShowCustomFields}">
                <TextBlock Text="CUSTOM DNS" Classes="SectionHeader"/>
                <TextBox Text="{Binding CustomPrimary}" Watermark="Primary DNS (e.g. 1.1.1.1)"
                         Background="#0A0A0A" Foreground="Cyan" BorderBrush="#333333" CornerRadius="4"/>
                <TextBox Text="{Binding CustomSecondary}" Watermark="Secondary DNS (optional)"
                         Background="#0A0A0A" Foreground="Cyan" BorderBrush="#333333" CornerRadius="4"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
</file>

<file path="src/AegisDNS.Installer/Pages/InstallProgressPage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.InstallProgressPage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">
    <Grid RowDefinitions="Auto,*,Auto" Margin="40,30,40,20">
        <!-- Row 0 -->
        <StackPanel Grid.Row="0">
            <Grid>
                <TextBlock Text="INSTALLING" Classes="SectionHeader"/>
                <TextBlock Text="{Binding TimeRemaining}" Foreground="#555555" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <ProgressBar Value="{Binding InstallProgress}" Maximum="100"
                         Height="4" Background="#111111" Foreground="Cyan" CornerRadius="2" Margin="0,10,0,2"/>
            <TextBlock Text="{Binding InstallProgress, StringFormat='{}{0:F0}%'}"
                       Foreground="Cyan" FontSize="11" HorizontalAlignment="Right"/>
        </StackPanel>

        <!-- Row 1 — step list -->
        <ScrollViewer Grid.Row="1" Margin="0,10">
            <ItemsControl ItemsSource="{Binding InstallSteps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:InstallStep">
                        <Border Margin="0,0,0,4" Padding="14,10" Background="#0D0D0D" CornerRadius="5">
                            <Grid ColumnDefinitions="28,*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="15" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding Name}" Foreground="#CCCCCC" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Status}" Foreground="#555555" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Elapsed}"
                                           Foreground="#333333" FontSize="11"
                                           FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 2 -->
        <StackPanel Grid.Row="2" Spacing="10" Margin="0,14,0,0">
            <Button Classes="Primary" Content="Begin Installation"
                    Command="{Binding StartInstallCommand}"
                    HorizontalAlignment="Center"
                    IsVisible="{Binding !InstallComplete}"/>
            <TextBlock Text="✅ Installation complete — click Continue"
                       Foreground="#00FF88" FontSize="13" FontWeight="SemiBold"
                       HorizontalAlignment="Center" IsVisible="{Binding InstallComplete}"/>
            <TextBlock Text="❌ Installation failed — check step details above"
                       Foreground="#FF453A" FontSize="13"
                       HorizontalAlignment="Center" IsVisible="{Binding InstallFailed}"/>
        </StackPanel>
    </Grid>
</UserControl>
</file>

<file path="src/AegisDNS.Installer/Pages/InstallTypePage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.InstallTypePage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">

  <ScrollViewer Padding="50,36,50,20">
    <StackPanel Spacing="0">

      <!-- Header -->
      <TextBlock Text="INSTALLATION TYPE" Foreground="Cyan" FontSize="11"
                 FontWeight="Bold" LetterSpacing="2" Margin="0,0,0,6"/>
      <TextBlock Text="Choose how you want AegisDNS installed."
                 Foreground="#555555" FontSize="12" Margin="0,0,0,28"/>

      <!-- Option cards -->
      <StackPanel Spacing="10">

        <!-- Card 1 — Recommended -->
        <Border Background="#071A07" BorderBrush="#1A4A1A"
                BorderThickness="1" CornerRadius="7" Padding="18,14">
          <Grid ColumnDefinitions="Auto,*">
            <RadioButton Grid.Column="0" IsChecked="{Binding RecommendedSelected}"
                         GroupName="InstallType" VerticalAlignment="Top" Margin="0,2,14,0"/>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="⚡  RECOMMENDED" Foreground="#00FF88"
                         FontSize="13" FontWeight="Bold" LetterSpacing="1"/>
              <TextBlock Text="Install with optimised defaults for most users."
                         Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
              <TextBlock Text="Installs to /opt/aegisdns — starts on boot — enables eBPF if available"
                         Foreground="#444444" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Card 2 — Custom -->
        <Border Background="#0A0A0A" BorderBrush="#222222" BorderThickness="1"
                CornerRadius="7" Padding="18,14">
          <Grid ColumnDefinitions="Auto,*">
            <RadioButton Grid.Column="0" IsChecked="{Binding CustomSelected}"
                         GroupName="InstallType" VerticalAlignment="Top" Margin="0,2,14,0"/>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="🔧  CUSTOM" Foreground="Cyan"
                         FontSize="13" FontWeight="Bold" LetterSpacing="1"/>
              <TextBlock Text="Configure DNS, AI Sentinel, eBPF, and install path manually."
                         Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
              <TextBlock Text="Advanced users only"
                         Foreground="#444444" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Card 3 — Headless/Server -->
        <Border Background="#0A0A0A" BorderBrush="#222222" BorderThickness="1"
                CornerRadius="7" Padding="18,14">
          <Grid ColumnDefinitions="Auto,*">
            <RadioButton Grid.Column="0" IsChecked="{Binding HeadlessSelected}"
                         GroupName="InstallType" VerticalAlignment="Top" Margin="0,2,14,0"/>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="🖥️  SERVER / HEADLESS" Foreground="#FFBD2E"
                         FontSize="13" FontWeight="Bold" LetterSpacing="1"/>
              <TextBlock Text="No UI — DNS service and web dashboard only. Ideal for router mode."
                         Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
              <TextBlock Text="Requires router mode to be enabled post-install"
                         Foreground="#444444" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
          </Grid>
        </Border>

      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
</file>

<file path="src/AegisDNS.Installer/Pages/LicenseActivationPage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.LicenseActivationPage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">
    <ScrollViewer Padding="50,30,50,20">
        <StackPanel Spacing="16">
            <TextBlock Text="LICENSE ACTIVATION" Classes="SectionHeader"/>

            <!-- Machine ID card -->
            <Border Background="#0D0D0D" CornerRadius="6" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="MACHINE ID" Classes="SectionHeader" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding MachineHwid}" Foreground="Cyan"
                               FontFamily="Consolas,Courier New,monospace" FontSize="11"/>
                    <TextBlock Text="Your license key will be bound to this hardware."
                               Foreground="#444444" FontSize="10" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- License entry card -->
            <Border Background="#0D0D0D" CornerRadius="6" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="LICENSE KEY" Classes="SectionHeader" Margin="0,0,0,10"/>
                    <TextBox Text="{Binding LicenseKey}"
                             Watermark="Paste your license key here..."
                             Background="#0A0A0A" Foreground="Cyan" BorderBrush="#333333"
                             CornerRadius="4" FontFamily="Consolas,Courier New,monospace" FontSize="12"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ActivationStatus}"
                               Foreground="{Binding ActivationColor}" FontSize="11" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Classes="Primary" Content="Activate License"
                                Command="{Binding ActivateCommand}" IsEnabled="{Binding KeyFormatValid}"/>
                        <Button Classes="Secondary" Content="Skip (Community Edition)"
                                Command="{Binding SkipLicenseCommand}" Foreground="#555555"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Activated state -->
            <Border Background="#071A07" BorderBrush="#1A4A1A" BorderThickness="1"
                    CornerRadius="6" Padding="16,12"
                    IsVisible="{Binding LicenseActivated}">
                <TextBlock Foreground="#00FF88" FontSize="14" FontWeight="SemiBold"
                           Text="{Binding ActivatedEdition, StringFormat='✅ ACTIVATED — {0} Edition'}"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
</file>

<file path="src/AegisDNS.Installer/Pages/LicenseAgreementPage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
