            <TextBlock Text="Alpha Test 0.0.2  ·  Linux-First Build" Foreground="#2A2A2A" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
