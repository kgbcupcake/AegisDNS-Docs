<file path="src/AegisDNS.Installer/Pages/SystemAuditPage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.SystemAuditPage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">
    <Grid RowDefinitions="Auto,*,Auto" Margin="40,30,40,20">
        <!-- Row 0 header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="SYSTEM AUDIT" Classes="SectionHeader"/>
            <TextBlock Text="Verifying prerequisites..." Foreground="#555555" FontSize="11"/>
        </StackPanel>

        <!-- Row 1 — audit list -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding AuditItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AuditItem">
                        <Border Margin="0,0,0,6" Padding="14,10" Background="#0D0D0D" CornerRadius="5">
                            <Grid ColumnDefinitions="28,*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Status}" FontSize="15" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{Binding Name}" Foreground="#CCCCCC" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Message}" Foreground="#555555" FontSize="11"/>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="8" Height="8" Fill="{Binding StatusColor}"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 2 — status -->
        <StackPanel Grid.Row="2" Spacing="6" Margin="0,10,0,0">
            <TextBlock Text="✅ All checks passed — you're good to go"
                       Foreground="#00FF88" FontSize="12" HorizontalAlignment="Center"
                       IsVisible="{Binding AuditPassed}"/>
            <TextBlock Text="⚡ eBPF available — kernel protection will be enabled"
                       Foreground="Cyan" FontSize="11" HorizontalAlignment="Center"
                       IsVisible="{Binding EbpfAvailable}"/>
        </StackPanel>
    </Grid>
</UserControl>
</file>

<file path="src/AegisDNS.Installer/Pages/WelcomePage.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AegisDNS.Installer.ViewModels"
             x:Class="AegisDNS.Installer.Pages.WelcomePage"
             x:DataType="vm:InstallerViewModel"
             Background="#050505">
    <ScrollViewer Padding="50,40,50,20">
        <StackPanel Spacing="0">
            <!-- Logo block -->
            <TextBlock Text="⬡" FontSize="52" Foreground="Cyan" HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="24" Opacity="0.6"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="AegisDNS" FontSize="36" FontWeight="Bold" Foreground="Cyan"
                       HorizontalAlignment="Center" LetterSpacing="4" Margin="0,8,0,4">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Cyan" BlurRadius="16" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="AI-Powered DNS Privacy Shield" Foreground="#555555" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>

            <!-- Hardware info card -->
            <Border Background="#111111" BorderBrush="#1E1E1E" BorderThickness="1"
                    CornerRadius="8" Padding="20,14" Margin="0,0,0,28">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*">
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                        <TextBlock Text="{Binding DetectedDistro, StringFormat='🐧 {0}'}" Foreground="#CCCCCC" FontSize="12"/>
                        <TextBlock Text="{Binding KernelVersion, StringFormat='⚙️ {0}'}" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding RamInfo, StringFormat='💾 {0}'}" Foreground="#CCCCCC" FontSize="12"/>
                        <TextBlock Text="{Binding CpuInfo, StringFormat='🖥️ {0}'}" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding InstallerHash}"
                               Foreground="#333333" FontSize="10" FontFamily="Consolas,Courier New,monospace"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
