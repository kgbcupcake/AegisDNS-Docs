            </Border>

            <!-- Mode selection -->
            <Grid ColumnDefinitions="*,16,*">
                <!-- Express card -->
                <Border Grid.Column="0" Background="#071A07" BorderBrush="#1A4A1A" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="⚡ EXPRESS" Foreground="#00FF88" FontSize="14" FontWeight="Bold" LetterSpacing="1"/>
                        <TextBlock Text="Recommended defaults. Done in 3 minutes." Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                        <Button Classes="Primary" Content="Express Install"
                                Command="{Binding ExpressCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Advanced card -->
                <Border Grid.Column="2" Background="#0A0A0A" BorderBrush="#222222" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="🔧 ADVANCED" Foreground="Cyan" FontSize="14" FontWeight="Bold" LetterSpacing="1"/>
                        <TextBlock Text="Configure every option: DNS, AI, eBPF and more." Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>
                        <Button Classes="Secondary" Content="Advanced Setup"
                                Command="{Binding AdvancedCommand}" HorizontalAlignment="Stretch"
                                Foreground="Cyan" BorderBrush="#003333"/>
                    </StackPanel>
                </Border>
