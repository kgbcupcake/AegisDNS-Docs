    private async Task StartInstallAsync()
    {
        InstallProgress = 0;
        InstallFailed = false;
        InstallComplete = false;
        TimeRemaining = "Estimating...";

        try
        {
            var svc = new Services.InstallService(this);
            await svc.RunAsync();
            InstallComplete = true;
            CurrentPage = InstallerPage.Complete;
            SummaryDns = DohEnabled ? $"{SelectedUpstream} (DoH)" : SelectedUpstream;
            SummaryAi = AiProvider == "None" ? "Disabled" : AiProvider;
        }
        catch (Exception ex)
        {
            InstallFailed = true;
            System.Diagnostics.Debug.WriteLine($"[Installer] Install failed: {ex}");
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    internal void ReportStep(int stepIndex, string status, string elapsed)
    {
        if (stepIndex < InstallSteps.Count)
        {
            InstallSteps[stepIndex].Icon = "✅";
            InstallSteps[stepIndex].Status = status;
            InstallSteps[stepIndex].Elapsed = elapsed;
        }
        InstallProgress = (double)(stepIndex + 1) / InstallSteps.Count * 100.0;
        int remaining = InstallSteps.Count - stepIndex - 1;
        TimeRemaining = remaining > 0 ? $"~{remaining * 5}s remaining" : "Finishing...";
    }

    internal void FailStep(int stepIndex, string error)
    {
        if (stepIndex < InstallSteps.Count)
        {
            InstallSteps[stepIndex].Icon = "❌";
            InstallSteps[stepIndex].Status = error;
        }
    }

    private static string RunCmd(string cmd, string args)
    {
        try
        {
            var psi = new ProcessStartInfo(cmd)
            {
                RedirectStandardOutput = true,
                UseShellExecute = false
            };
            if (!string.IsNullOrWhiteSpace(args))
            {
                foreach (var arg in args.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                {
                    psi.ArgumentList.Add(arg);
                }
            }
            using var p = Process.Start(psi);
            return p?.StandardOutput.ReadToEnd() ?? "";
        }
        catch { return ""; }
    }

    private static bool CommandExists(string cmd)
        => !string.IsNullOrEmpty(RunCmd("which", cmd));
}
