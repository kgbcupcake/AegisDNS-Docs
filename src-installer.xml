    /// <summary>
    /// If the process is elevated (pkexec / sudo), copies the activation token
    /// from the root-owned path to the real user's home directory and chowns it.
    /// No-ops when not elevated or when the token file does not exist.
    /// </summary>
    private static void CopyTokenToRealUser()
    {
        try
        {
            // Resolve elevated user context once and no-op if not elevated.
            if (!TryGetRealUserContext(out string? realUser, out string? realHome)
                || string.IsNullOrWhiteSpace(realUser)
                || string.IsNullOrWhiteSpace(realHome))
                return;

            string resolvedUser = realUser;
            string resolvedHome = realHome;

            // ── 2. Locate the source token via AesGcmTokenStore ───────────────
            // GetTokenPath resolves to the path AesGcmTokenStore just wrote;
            // when running as root this is under /root/.local/share/AegisDNS/.
            string sourceToken = AesGcmTokenStore.GetTokenPath("AegisDNS");
            if (!File.Exists(sourceToken))
                return;

            // ── 3. Copy to the real user's path ──────────────────────────────
            string destDir = Path.Combine(resolvedHome, ".local", "share", "AegisDNS");
            Directory.CreateDirectory(destDir);

            string destToken = Path.Combine(destDir, "activation.token");
            if (sourceToken != destToken)
            {
                File.Copy(sourceToken, destToken, overwrite: true);
            }

            // ── 4. chown to real user (ArgumentList — never bash -c) ──────────
            var psi = new ProcessStartInfo("chown")
            {
                UseShellExecute = false,
                RedirectStandardOutput = false,
                RedirectStandardError = false
            };
            psi.ArgumentList.Add($"{resolvedUser}:{resolvedUser}");
            psi.ArgumentList.Add(destToken);

            using var p = Process.Start(psi);
            p?.WaitForExit();

            Debug.WriteLine($"[InstallerViewModel] Token copied to {destToken} and chowned to {resolvedUser}");
        }
        catch (Exception ex)
        {
            // Non-fatal — the user can re-activate from the UI if needed.
            Debug.WriteLine($"[InstallerViewModel] CopyTokenToRealUser failed: {ex.Message}");
        }
    }

    private static bool TryGetRealUserContext(out string? username, out string? homeDir)
    {
        username = null;
        homeDir = null;

        string? sudoUser = Environment.GetEnvironmentVariable("SUDO_USER");
        if (!string.IsNullOrEmpty(sudoUser) && sudoUser != "root")
        {
            username = sudoUser;
            homeDir = Path.Combine("/home", sudoUser);
        }

        if (homeDir == null)
        {
            string? pkexecUid = Environment.GetEnvironmentVariable("PKEXEC_UID");
            if (!string.IsNullOrEmpty(pkexecUid) && int.TryParse(pkexecUid, out int uid) && uid != 0 && File.Exists("/etc/passwd"))
            {
                foreach (var line in File.ReadAllLines("/etc/passwd"))
                {
                    var parts = line.Split(':');
                    if (parts.Length >= 7
                        && int.TryParse(parts[2], out int lineUid)
                        && lineUid == uid)
                    {
                        username = parts[0];
                        homeDir = parts[5];
                        break;
                    }
                }
            }
        }

        return !string.IsNullOrEmpty(username) && !string.IsNullOrEmpty(homeDir);
    }

    private readonly struct LicenseTokenScope : IDisposable
    {
        private readonly string? _previousXdgDataHome;
        private readonly bool _changed;

        private LicenseTokenScope(string? previousXdgDataHome, bool changed)
        {
            _previousXdgDataHome = previousXdgDataHome;
            _changed = changed;
        }

        public static LicenseTokenScope ForRealUserIfElevated()
        {
            if (!TryGetRealUserContext(out _, out string? realHome) || string.IsNullOrWhiteSpace(realHome))
                return new LicenseTokenScope(previousXdgDataHome: null, changed: false);

            string targetXdgDataHome = Path.Combine(realHome, ".local", "share");
            string? previous = Environment.GetEnvironmentVariable("XDG_DATA_HOME");

            if (string.Equals(previous, targetXdgDataHome, StringComparison.Ordinal))
                return new LicenseTokenScope(previousXdgDataHome: previous, changed: false);

            Environment.SetEnvironmentVariable("XDG_DATA_HOME", targetXdgDataHome);
            return new LicenseTokenScope(previousXdgDataHome: previous, changed: true);
        }

        public void Dispose()
        {
            if (_changed)
                Environment.SetEnvironmentVariable("XDG_DATA_HOME", _previousXdgDataHome);
        }
    }

    // ── DNS Latency Test ──────────────────────────────────────────────────────

    private async Task TestLatencyAsync()
    {
        CloudflareLatency = "Testing...";
        GoogleLatency = "Testing...";
        Quad9Latency = "Testing...";
        OpenDnsLatency = "Testing...";

        var tests = new (string Prop, string Host)[]
        {
            ("Cloudflare", "1.1.1.1"),
            ("Google",     "8.8.8.8"),
            ("Quad9",      "9.9.9.9"),
            ("OpenDns",    "208.67.222.222"),
        };

        foreach (var (prop, host) in tests)
        {
            var ms = await PingAsync(host);
            var label = ms < 0 ? "Timeout" : $"{ms}ms";
            switch (prop)
            {
                case "Cloudflare": CloudflareLatency = label; break;
                case "Google": GoogleLatency = label; break;
                case "Quad9": Quad9Latency = label; break;
                case "OpenDns": OpenDnsLatency = label; break;
            }
        }
    }

    private static async Task<long> PingAsync(string host)
    {
        try
        {
            using var ping = new Ping();
            var reply = await ping.SendPingAsync(host, 2000);
            return reply.Status == IPStatus.Success ? reply.RoundtripTime : -1;
        }
        catch { return -1; }
    }

