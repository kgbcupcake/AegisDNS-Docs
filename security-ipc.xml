using System;
using System.IO;
using System.Net.Sockets;
using System.Runtime.InteropServices;
using System.Runtime.Versioning;
using System.Text;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;

namespace AegisDNS.Core;

/// <summary>
/// IPC system for Service/UI synchronization.
/// Uses Unix Domain Sockets on Linux.
/// </summary>
public static class IpcSystem
{
    private const string SocketDirectory = "/run/aegisdns";
    private const string CommandSocketPath = "/run/aegisdns/command.sock";
    private const string BroadcastSocketPath = "/run/aegisdns/broadcast.sock";
    private const int MaxMessageSize = 65536; // 64KB limit (Prompt 05)

    [StructLayout(LayoutKind.Sequential)]
    private struct UnixCredentials
    {
        public uint pid;
        public uint uid;
        public uint gid;
    }

    private const int SOL_SOCKET = 1;
    private const int SO_PEERCRED = 17;

    // P/Invoke for getuid() — returns the real UID of the current process.
    // No NativeMethods/Interop class exists in this project; defined here alongside SO_PEERCRED.
    [DllImport("libc", SetLastError = true, EntryPoint = "getuid")]
    private static extern uint Getuid();

    private static uint GetCurrentUid()
    {
        try { return Getuid(); }
        catch { return uint.MaxValue; } // fail-safe: deny all if syscall unavailable
    }

    /// <summary>
    /// Ensures /run/aegisdns/ exists with 0700 permissions. Call once at service startup.
    /// </summary>
    public static void EnsureSocketDirectory()
    {
        if (!Directory.Exists(SocketDirectory))
        {
            Directory.CreateDirectory(SocketDirectory);
        }
        // Set 0750: owner rwx, group r-x, other --- so the desktop user can traverse
        try
        {
            var psi = new System.Diagnostics.ProcessStartInfo("chmod")
            {
                CreateNoWindow = true,
                UseShellExecute = false
            };
            psi.ArgumentList.Add("750");
            psi.ArgumentList.Add(SocketDirectory);
            System.Diagnostics.Process.Start(psi)?.WaitForExit(5000);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[IPC] chmod /run/aegisdns failed: {ex.Message}");
        }
    }

    private static StreamWriter? _broadcastWriter;
    private static readonly SemaphoreSlim _writeLock = new(1, 1);

    public record IpcPacket(string Command, string Payload = "", long Value = 0);

    [SupportedOSPlatform("linux")]
    public static async Task StartBroadcastServerAsync(CancellationToken token)
    {
        try
        {
            await StartLinuxBroadcastServerAsync(token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            // This method runs as a fire-and-forget task in the Worker.
            // Exceptions must never propagate to an unobserved Task — log and swallow.
            System.Diagnostics.Debug.WriteLine($"[BroadcastServer] Fatal: {ex}");
        }
    }

    [SupportedOSPlatform("linux")]
    private static async Task StartLinuxBroadcastServerAsync(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                if (File.Exists(BroadcastSocketPath))
                {
                    File.Delete(BroadcastSocketPath);
                }

                using var endPoint = new Socket(AddressFamily.Unix, SocketType.Stream, ProtocolType.Unspecified);
                endPoint.Bind(new UnixDomainSocketEndPoint(BroadcastSocketPath));

                // Set permissions so the UI can connect
                SetSocketPermissions(BroadcastSocketPath);

                endPoint.Listen(1); // One UI instance broadcast receiver

                using var clientSocket = await endPoint.AcceptAsync(token);
                using var networkStream = new NetworkStream(clientSocket, ownsSocket: true);
                _broadcastWriter = new StreamWriter(networkStream) { AutoFlush = true };

                // Keep connection alive until client disconnects
                while (clientSocket.Connected && !token.IsCancellationRequested)
                {
                    // NetworkStream relies on write exceptions or zero-byte reads to detect disconnects.
                    // We'll trust the BroadcastLogAsync to handle write failures and reset the writer.
                    await Task.Delay(1000, token);
                }
            }
            catch (OperationCanceledException) { }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[Linux Broadcast Server Error] {ex.Message}");
                _broadcastWriter = null;
                await Task.Delay(1000, token);
            }
            finally
            {
                _broadcastWriter = null;
                if (File.Exists(BroadcastSocketPath))
                {
                    File.Delete(BroadcastSocketPath);
                }
            }
        }
    }

    /// <summary>
    /// Broadcasts a log message to the connected UI client.
    /// </summary>
    public static async Task BroadcastLogAsync(string message)
    {
        var writer = _broadcastWriter;
        if (writer == null) return;

        await _writeLock.WaitAsync();
        try
        {
            writer = _broadcastWriter;
            if (writer == null) return;

            var packet = new IpcPacket("Log", message);
            await writer.WriteLineAsync(JsonSerializer.Serialize(packet));
        }
        catch (IOException)
        {
            // Client disconnected, the server loop will detect via IsConnected
            _broadcastWriter = null;
        }
        catch (ObjectDisposedException)
        {
            _broadcastWriter = null;
        }
        finally
        {
            _writeLock.Release();
        }
    }

    /// <summary>
    /// Starts a client to listen for broadcasted logs. The UI calls this.
    /// </summary>
    [SupportedOSPlatform("linux")]
    public static async Task StartBroadcastClientAsync(Action<string> onMessageReceived, CancellationToken token)
    {
        await StartLinuxBroadcastClientAsync(onMessageReceived, token);
    }

    [SupportedOSPlatform("linux")]
    private static async Task StartLinuxBroadcastClientAsync(Action<string> onMessageReceived, CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                using var endPoint = new Socket(AddressFamily.Unix, SocketType.Stream, ProtocolType.Unspecified);
                await endPoint.ConnectAsync(new UnixDomainSocketEndPoint(BroadcastSocketPath), token);

                using var networkStream = new NetworkStream(endPoint, ownsSocket: true);
                using var reader = new StreamReader(networkStream);

                while (!token.IsCancellationRequested)
                {
                    string? json = await ReadLineWithLimitAsync(reader, MaxMessageSize);
                    if (!string.IsNullOrEmpty(json))
                    {
                        IpcPacket? packet = null;
                        try { packet = JsonSerializer.Deserialize<IpcPacket>(json); }
                        catch (JsonException) { }
                        if (packet?.Command == "Log")
                        {
                            onMessageReceived(packet.Payload);
                        }
                    }
                    else
                    {
                        // Socket closed
                        break;
                    }
                }
            }
            catch (OperationCanceledException) { }
            catch (Exception)
            {
                // Server likely offline, wait and retry
                await Task.Delay(2000, token);
            }
        }
    }

    // --- COMMAND CHANNEL (UI -> Service) ---

    /// <summary>
    /// Runs a Server for request/response commands. Used by the background Service/Daemon.
    /// Supports multiple concurrent connections dynamically.
    /// </summary>
    [SupportedOSPlatform("linux")]
    public static async Task StartCommandServerAsync(Func<IpcPacket, Task<IpcPacket>> onCommand, CancellationToken token)
    {
        await StartLinuxCommandServerAsync(onCommand, token);
    }

    [SupportedOSPlatform("linux")]
    private static async Task StartLinuxCommandServerAsync(Func<IpcPacket, Task<IpcPacket>> onCommand, CancellationToken token)
    {
        try
        {
            if (File.Exists(CommandSocketPath))
            {
                File.Delete(CommandSocketPath);
            }

            using var endPoint = new Socket(AddressFamily.Unix, SocketType.Stream, ProtocolType.Unspecified);
            endPoint.Bind(new UnixDomainSocketEndPoint(CommandSocketPath));

            // Setup access permissions for UI side
            SetSocketPermissions(CommandSocketPath);

            endPoint.Listen(20); // 20 concurrent IPC connections supported before backlog

            while (!token.IsCancellationRequested)
            {
                var clientSocket = await endPoint.AcceptAsync(token);
                _ = HandleLinuxCommandConnectionAsync(clientSocket, onCommand, token);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Linux Command Server Error] {ex.Message}");
            await Task.Delay(1000, token);
        }
        finally
        {
            if (File.Exists(CommandSocketPath))
            {
                File.Delete(CommandSocketPath);
            }
        }
    }

    [SupportedOSPlatform("linux")]
    private static async Task HandleLinuxCommandConnectionAsync(Socket clientSocket, Func<IpcPacket, Task<IpcPacket>> onCommand, CancellationToken token)
    {
        using (clientSocket)
        {
            try
            {
                // 1. Verify Peer Credentials — allow root (UID 0) or the real desktop user.
                var cred = GetPeerUid(clientSocket);
                var allowedUid = GetRealUserUid();
                if (cred == null || (cred.Value.uid != 0 && (allowedUid == null || cred.Value.uid != allowedUid.Value)))
                {
                    Console.Error.WriteLine($"[IPC] Rejected UID {cred?.uid ?? 999} (allowed: 0 or {allowedUid?.ToString() ?? "root-only"})");
                    return;
                }

                using var networkStream = new NetworkStream(clientSocket, ownsSocket: true);
                using var reader = new StreamReader(networkStream);
                using var writer = new StreamWriter(networkStream) { AutoFlush = true };

                string? json = await ReadLineWithLimitAsync(reader, MaxMessageSize);
                if (!string.IsNullOrEmpty(json))
                {
                    IpcPacket? command = null;
                    try { command = JsonSerializer.Deserialize<IpcPacket>(json); }
                    catch (JsonException) { }
                    if (command != null)
                    {
                        var response = await onCommand(command);
                        await writer.WriteLineAsync(JsonSerializer.Serialize(response));
                    }
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[Linux IPC Handler Error] {ex.Message}");
            }
        }
    }

    [DllImport("libc", SetLastError = true)]
    private static extern int getsockopt(int sockfd, int level, int optname, ref UnixCredentials optval, ref int optlen);

    [DllImport("libc", SetLastError = true, CharSet = CharSet.Ansi)]
    private static extern int chown(string pathname, uint owner, uint group);

    [DllImport("libc", SetLastError = true, CharSet = CharSet.Ansi)]
    private static extern int chmod(string pathname, uint mode);

    private static UnixCredentials? GetPeerUid(Socket socket)
    {
        try
        {
            var cred = new UnixCredentials();
            int len = Marshal.SizeOf<UnixCredentials>();
            int ret = getsockopt((int)socket.Handle, SOL_SOCKET, SO_PEERCRED, ref cred, ref len);
            if (ret == 0) return cred;
            return null;
        }
        catch { return null; }
    }

    /// <summary>
    /// Sends a command to the Server. Used by the UI.
    /// </summary>
    [SupportedOSPlatform("linux")]
    public static async Task<IpcPacket?> SendCommandAsync(IpcPacket packet, int timeoutMs = 2000)
    {
        return await SendLinuxCommandAsync(packet, timeoutMs);
    }

    [SupportedOSPlatform("linux")]
    private static async Task<IpcPacket?> SendLinuxCommandAsync(IpcPacket packet, int timeoutMs)
    {
        try
        {
            using var endPoint = new Socket(AddressFamily.Unix, SocketType.Stream, ProtocolType.Unspecified);
            using var cts = new CancellationTokenSource(timeoutMs);

            await endPoint.ConnectAsync(new UnixDomainSocketEndPoint(CommandSocketPath), cts.Token);

            using var networkStream = new NetworkStream(endPoint, ownsSocket: true);
            using var reader = new StreamReader(networkStream);
            using var writer = new StreamWriter(networkStream) { AutoFlush = true };

            await writer.WriteLineAsync(JsonSerializer.Serialize(packet));

            string? responseJson = await ReadLineWithLimitAsync(reader, MaxMessageSize);
            try
            {
                return !string.IsNullOrEmpty(responseJson) ? JsonSerializer.Deserialize<IpcPacket>(responseJson) : null;
            }
            catch (JsonException)
            {
                return null;
            }
        }
        catch (Exception)
        {
            return null; // Server likely offline
        }
    }

    // ── Socket permission helpers ─────────────────────────────────────────────

    /// <summary>
    /// Resolves the real desktop user's numeric UID from the environment.
    /// Priority: AEGIS_UI_USER → SUDO_USER (both via /etc/passwd) → PKEXEC_UID.
    /// Returns null if none are set; caller falls back to root-only access.
    /// </summary>
    private static uint? GetRealUserUid()
    {
        // Resolve username from AEGIS_UI_USER or SUDO_USER, then look up UID in /etc/passwd
        string? userName = null;

        var aegisUser = Environment.GetEnvironmentVariable("AEGIS_UI_USER");
        if (!string.IsNullOrWhiteSpace(aegisUser)) userName = aegisUser;

        if (userName == null)
        {
            var sudoUser = Environment.GetEnvironmentVariable("SUDO_USER");
            if (!string.IsNullOrWhiteSpace(sudoUser) && sudoUser != "root") userName = sudoUser;
        }

        if (userName != null)
        {
            try
            {
                foreach (var line in File.ReadLines("/etc/passwd"))
                {
                    var parts = line.Split(':');
                    // Format: username:x:uid:gid:comment:home:shell
                    if (parts.Length >= 3 && parts[0] == userName
                        && uint.TryParse(parts[2], out uint parsedUid))
                        return parsedUid;
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[IPC] GetRealUserUid passwd lookup failed: {ex.Message}");
            }
        }

        // PKEXEC_UID is already a numeric UID — use it directly
        var pkexecUid = Environment.GetEnvironmentVariable("PKEXEC_UID");
        if (!string.IsNullOrWhiteSpace(pkexecUid) && uint.TryParse(pkexecUid, out uint pkUid) && pkUid != 0)
            return pkUid;

        return null; // No desktop user found — caller allows root only
    }

    /// <summary>
    /// Resolves the real (non-root) desktop username when the service is started
    /// via sudo or pkexec, so sockets can be group-owned by that user.
    /// Returns null when neither variable is set (true root session).
    /// </summary>
    private static string? GetRealUserName()
    {
        // Explicit override — set in systemd unit via Environment=AEGIS_UI_USER=<username>
        var aegisUser = Environment.GetEnvironmentVariable("AEGIS_UI_USER");
        if (!string.IsNullOrWhiteSpace(aegisUser)) return aegisUser;

        // Try SUDO_USER (set when launched via sudo)
        var sudoUser = Environment.GetEnvironmentVariable("SUDO_USER");
        if (!string.IsNullOrWhiteSpace(sudoUser) && sudoUser != "root") return sudoUser;

        // Fallback: resolve PKEXEC_UID via /etc/passwd
        var pkexecUid = Environment.GetEnvironmentVariable("PKEXEC_UID");
        if (!string.IsNullOrWhiteSpace(pkexecUid))
        {
            try
            {
                foreach (var line in File.ReadLines("/etc/passwd"))
                {
                    var parts = line.Split(':');
                    if (parts.Length >= 3 && parts[2] == pkexecUid)
                        return parts[0];
                }
            }
            catch { }
        }

        return null;
    }

    /// <summary>
    /// Applies chmod 660 + chown root:{realUser} to a socket file so the
    /// desktop UI process can connect. Falls back gracefully if the real user
    /// cannot be determined (leaves ownership as root:root with mode 660).
    /// All subprocess calls use ArgumentList — no shell interpolation.
    /// </summary>
    private static void SetSocketPermissions(string socketPath)
    {
        // chmod 0777 = 0x1FF — any local user can connect; access is enforced by SO_PEERCRED
        // (only UID 0 or the real desktop user can issue commands), not filesystem permissions.
        // chown is intentionally omitted: SELinux blocks chown on var_run_t socket files from
        // a .NET process, and it is not needed since the socket is world-accessible.
        int chmodResult = chmod(socketPath, 0x1FF);
        if (chmodResult != 0)
            System.Diagnostics.Debug.WriteLine($"[IPC] chmod 777 {socketPath} failed: errno={Marshal.GetLastWin32Error()}");
    }

    private static async Task<string?> ReadLineWithLimitAsync(StreamReader reader, int limit)
    {
        var sb = new StringBuilder();
        char[] buffer = new char[1];
        while (true)
        {
            int read = await reader.ReadAsync(buffer, 0, 1);
            if (read == 0) return sb.Length > 0 ? sb.ToString() : null;

            char c = buffer[0];
            if (c == '\n') return sb.ToString();
            if (c == '\r') continue;

            sb.Append(c);
            if (sb.Length >= limit)
            {
                System.Diagnostics.Debug.WriteLine($"[IPC] Warning: Incoming message exceeded {limit} bytes. Connection closed.");
                throw new InvalidDataException("Message size limit exceeded.");
            }
        }
    }
