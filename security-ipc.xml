<file path="src/AegisDNS.Installer/Services/InstallService.cs">
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;

using AegisDNS.Core.Ai;
using AegisDNS.Installer.ViewModels;

namespace AegisDNS.Installer.Services;

/// <summary>
/// Performs the full AegisDNS installation.
/// Mirrors installer/install.sh step-by-step in managed C#.
/// Must run as root (enforced by Program.cs pkexec elevation).
/// </summary>
public class InstallService
{
    private const string InstallDir = "/opt/AegisDNS";
    private const string ServiceDir = "/opt/AegisDNS/Service";
    private const string ConfigDir = "/etc/aegisdns";
    private const string LogDir = "/var/log/aegisdns";
    private const string BackupDir = "/var/lib/aegisdns/backup";
    private const string ServiceFile = "/etc/systemd/system/aegisdns.service";
    private const string DesktopFile = "/usr/share/applications/aegisdns.desktop";

    // AppImage unpacks next to the installer binary
    private static readonly string AppDir =
        Path.GetDirectoryName(Environment.ProcessPath ?? "/usr/bin/AegisDNS.Installer") ?? throw new InvalidOperationException(
            "RuntimeDirectory is not set. Cannot determine safe install path.");

    private readonly InstallerViewModel _vm;
    private readonly Stopwatch _stepTimer = new();

    public InstallService(InstallerViewModel vm) => _vm = vm;

    public async Task RunAsync()
    {
        await Step(0, "Create directories", CreateDirectoriesAsync);
        await Step(1, "Copy binaries", CopyBinariesAsync);
        await Step(2, "Compile eBPF protection", CompileEbpfAsync);
        await Step(3, "Install systemd service", InstallServiceAsync);
        await Step(4, "Configure DNS upstream", ConfigureDnsAsync);
        await Step(5, "Write AI config", WriteAiConfigAsync);
        await Step(6, "Desktop integration", InstallDesktopAsync);
        await Step(7, "Free port 53", DisableResolvedStubAsync);
        await Step(8, "Start service", StartServiceAsync);
        await Step(9, "Restore license", RestoreLicenseAsync);
    }

    private async Task Step(int index, string name, Func<Task> action)
    {
        _stepTimer.Restart();
        try
        {
            await action();
            _vm.ReportStep(index, "Complete", $"{_stepTimer.Elapsed.TotalSeconds:F1}s");
        }
        catch (Exception ex)
        {
            _vm.FailStep(index, ex.Message);
            throw;
        }
    }

    // ── Step 0: Create directories ────────────────────────────────────────────

    private Task CreateDirectoriesAsync()
    {
        // InstallDir must be world-traversable so any user can execute AegisDNSUI
        Directory.CreateDirectory(InstallDir);
        Chmod(InstallDir, "755");

        foreach (var dir in new[] { ServiceDir, ConfigDir, LogDir, BackupDir,
                                    "/var/lib/aegisdns/policies" })
        {
            Directory.CreateDirectory(dir);
            Chmod(dir, "750");
        }
        return Task.CompletedTask;
    }

    // ── Step 1: Copy binaries ─────────────────────────────────────────────────

    private async Task CopyBinariesAsync()
    {
        // Backup existing DNS config before touching anything
        if (File.Exists("/etc/resolv.conf"))
            File.Copy("/etc/resolv.conf", Path.Combine(BackupDir, "resolv.conf.bak"), overwrite: true);
        if (File.Exists("/etc/hosts"))
            File.Copy("/etc/hosts", Path.Combine(BackupDir, "hosts.bak"), overwrite: true);

        // Stop any existing instance
        await RunAsyncWithArgumentList("systemctl", new[] { "stop", "aegisdns" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("pkill", new[] { "-f", "AegisDNSUI" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("pkill", new[] { "-f", "AegisDNS.Service" }, ignoreErrors: true);
        await Task.Delay(500);

        // ── Copy UI binary ────────────────────────────────────────────────────
        // Canonical install path: /opt/AegisDNS/UI/AegisDNSUI  (AppRun expects this)
        string uiSubDir     = Path.Combine(InstallDir, "UI");
        Directory.CreateDirectory(uiSubDir);
        string uiBinaryDest = Path.Combine(uiSubDir, "AegisDNSUI");

        // Priority 1: single self-contained binary alongside the installer
        string uiBinarySrc  = Path.Combine(AppDir, "AegisDNSUI");
        if (File.Exists(uiBinarySrc))
        {
            File.Copy(uiBinarySrc, uiBinaryDest, overwrite: true);
        }
        else
        {
            // Priority 2: AppImage layout  $APPDIR/usr/bin/AegisDNSUI
            string uiBinSrc2 = Path.Combine(AppDir, "usr", "bin", "AegisDNSUI");
            if (File.Exists(uiBinSrc2))
            {
                File.Copy(uiBinSrc2, uiBinaryDest, overwrite: true);
            }
            else
            {
                // Priority 3: AppImage layout  usr/bin/UI/<files>
                string uiDirSrc = Path.Combine(AppDir, "usr", "bin", "UI");
                if (Directory.Exists(uiDirSrc))
                    CopyDirectory(uiDirSrc, uiSubDir);
                else
                {
                    // Priority 4: dotnet publish output  publish/UI/<files>
                    string publishUi = Path.Combine(AppDir, "publish", "UI");
                    if (Directory.Exists(publishUi))
                        CopyDirectory(publishUi, uiSubDir);
                }
            }
        }

        // Ensure the UI binary has correct permissions immediately after copy
        if (File.Exists(uiBinaryDest))
        {
            Chmod(uiBinaryDest, "755");
            await RunAsyncWithArgumentList("chown", new[] { "root:root", uiBinaryDest }, ignoreErrors: true);
        }

        // ── Copy Service binary ───────────────────────────────────────────────
        // Priority 1: single self-contained binary alongside the installer
        string svcBinarySrc  = Path.Combine(AppDir, "AegisDNS.Service");
        string svcExe        = Path.Combine(ServiceDir, "AegisDNS.Service");
        if (File.Exists(svcBinarySrc))
        {
            File.Copy(svcBinarySrc, svcExe, overwrite: true);
        }
        else
        {
            // Priority 2: AppImage layout  $APPDIR/usr/bin/AegisDNS.Service
            string svcBinSrc2 = Path.Combine(AppDir, "usr", "bin", "AegisDNS.Service");
            if (File.Exists(svcBinSrc2))
            {
                File.Copy(svcBinSrc2, svcExe, overwrite: true);
            }
            else
            {
                // Priority 3: AppImage layout  usr/bin/Service/<files>
                string svcSrc = Path.Combine(AppDir, "usr", "bin", "Service");
                if (Directory.Exists(svcSrc))
                    CopyDirectory(svcSrc, ServiceDir);
                else
                {
                    // Priority 4: dotnet publish output  publish/Service/<files>
                    string publishSvc = Path.Combine(AppDir, "publish", "Service");
                    if (Directory.Exists(publishSvc))
                        CopyDirectory(publishSvc, ServiceDir);
                }
            }
        }

        // Make Service binary executable
        if (File.Exists(svcExe))
        {
            Chmod(svcExe, "755");
            await RunAsyncWithArgumentList("chown", new[] { "root:root", svcExe }, ignoreErrors: true);
        }

        Chmod(ServiceDir, "750");
        await RunAsyncWithArgumentList("chown", new[] { "-R", "root:root", ServiceDir }, ignoreErrors: true);

        // ── Fix activation.token ownership ────────────────────────────────────
        // The token lives in the REAL user's XDG_DATA_HOME, but the installer
        // runs as root (via pkexec/sudo). If the token file was written under
        // the root context it will be owned by root and unreadable by the UI
        // process (which runs as the normal user). Re-chown it here.
        string? realUser = GetRealUserName();
        if (realUser != null)
        {
            // Resolve the user's home directory from /etc/passwd so we don't
            // rely on HOME (which may still point to /root when under pkexec).
            string userHome = GetHomeForUser(realUser);
            string xdgData  = Path.Combine(userHome, ".local", "share");
            string tokenPath = Path.Combine(xdgData, "AegisDNS", "activation.token");

            // Ensure the directory exists
            Directory.CreateDirectory(Path.GetDirectoryName(tokenPath)!);

            if (File.Exists(tokenPath))
            {
                await RunAsyncWithArgumentList("chown", new[] { $"{realUser}:{realUser}", tokenPath }, ignoreErrors: true);
                Chmod(tokenPath, "600");
            }
        }
    }

    // ── Step 2: Compile eBPF ──────────────────────────────────────────────────

    private async Task CompileEbpfAsync()
    {
        if (!_vm.EbpfAvailable)
        {
            await InstallIptablesFallbackAsync();
            return;
        }

        string kernelDir = Path.Combine(AppDir, "kernel");
        if (!Directory.Exists(kernelDir))
        {
            await InstallIptablesFallbackAsync();
            return;
        }

        // Generate vmlinux.h from running kernel BTF
        var (btfExit, btfOutput, _) = await RunCapture("bpftool", new[] { "btf", "dump", "file", "/sys/kernel/btf/vmlinux", "format", "c" });
        if (btfExit == 0 && !string.IsNullOrEmpty(btfOutput))
            await File.WriteAllTextAsync(Path.Combine(kernelDir, "vmlinux.h"), btfOutput);

        if (!File.Exists(Path.Combine(kernelDir, "vmlinux.h")))
        {
            await InstallIptablesFallbackAsync();
            return;
        }

        // Compile eBPF program
        var (exitCode, _, _) = await RunCapture("make", new[] { "-C", kernelDir, "aegisdns.bpf.o" });
        if (exitCode != 0)
        {
            await InstallIptablesFallbackAsync();
            return;
        }

        string objPath = Path.Combine(kernelDir, "aegisdns.bpf.o");
        if (!File.Exists(objPath))
        {
            await InstallIptablesFallbackAsync();
            return;
        }

        // Deploy compiled object
        Directory.CreateDirectory(Path.Combine(ServiceDir, "kernel"));
        File.Copy(objPath, Path.Combine(ServiceDir, "kernel", "aegisdns.bpf.o"), overwrite: true);
        Chmod(Path.Combine(ServiceDir, "kernel", "aegisdns.bpf.o"), "644");

        // BPF pin directory
        Directory.CreateDirectory("/sys/fs/bpf/aegisdns");

        // Mount BPF filesystem on boot
        const string bpfFstab = "bpf    /sys/fs/bpf    bpf    defaults    0 0";
        string fstab = File.ReadAllText("/etc/fstab");
        if (!fstab.Contains("/sys/fs/bpf"))
            File.AppendAllText("/etc/fstab", "\n" + bpfFstab + "\n");

        // Try XDP ingress shield
        string xdpDir = Path.Combine(AppDir, "xdp");
        if (Directory.Exists(xdpDir) && File.Exists(Path.Combine(xdpDir, "aegis_xdp.c")))
        {
            var (xdpExit, _, _) = await RunCapture("make", new[] { "-C", xdpDir, "aegis_xdp.o" });
            if (xdpExit == 0 && File.Exists(Path.Combine(xdpDir, "aegis_xdp.o")))
            {
                Directory.CreateDirectory(Path.Combine(ServiceDir, "xdp"));
                File.Copy(Path.Combine(xdpDir, "aegis_xdp.o"),
                          Path.Combine(ServiceDir, "xdp", "aegis_xdp.o"), overwrite: true);
                Chmod(Path.Combine(ServiceDir, "xdp", "aegis_xdp.o"), "644");
            }
        }

        // Clean up any old iptables rules
        await CleanupOldIptablesAsync();
    }

    private async Task InstallIptablesFallbackAsync()
    {
        // iptables redirect — same as install.sh fallback
        await RunAsyncWithArgumentList("iptables", new[] { "-t", "nat", "-A", "OUTPUT", "-p", "udp", "--dport", "53", "-m", "owner", "--uid-owner", "0", "-j", "RETURN" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("iptables", new[] { "-t", "nat", "-A", "OUTPUT", "-p", "tcp", "--dport", "53", "-m", "owner", "--uid-owner", "0", "-j", "RETURN" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("iptables", new[] { "-t", "nat", "-A", "OUTPUT", "-p", "udp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("iptables", new[] { "-t", "nat", "-A", "OUTPUT", "-p", "tcp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("ip6tables", new[] { "-t", "nat", "-A", "OUTPUT", "-p", "udp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("ip6tables", new[] { "-t", "nat", "-A", "OUTPUT", "-p", "tcp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("iptables", new[] { "-A", "INPUT", "-p", "udp", "--dport", "53", "-j", "ACCEPT" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("iptables", new[] { "-A", "INPUT", "-p", "tcp", "--dport", "53", "-j", "ACCEPT" }, ignoreErrors: true);

        // Persist rules using the distro-appropriate tool
        if (File.Exists("/etc/debian_version"))
            await RunAsyncWithArgumentList("netfilter-persistent", new[] { "save" }, ignoreErrors: true);
        else
            await RunAsyncWithArgumentList("service", new[] { "iptables", "save" }, ignoreErrors: true);
    }

    private async Task CleanupOldIptablesAsync()
    {
        await RunAsyncWithArgumentList("iptables", new[] { "-t", "nat", "-D", "OUTPUT", "-p", "udp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("iptables", new[] { "-t", "nat", "-D", "OUTPUT", "-p", "tcp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("ip6tables", new[] { "-t", "nat", "-D", "OUTPUT", "-p", "udp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("ip6tables", new[] { "-t", "nat", "-D", "OUTPUT", "-p", "tcp", "--dport", "53", "-j", "REDIRECT", "--to-ports", "53" }, ignoreErrors: true);
        await RunAsyncWithArgumentList("nft", new[] { "delete", "table", "inet", "aegisdns" }, ignoreErrors: true);
    }

    // ── Step 3: Install systemd service ──────────────────────────────────────

    private async Task InstallServiceAsync()
    {
        var unit = $"""
[Unit]
Description=AegisDNS AI-Powered DNS Interceptor Service
Documentation=https://aegisdns.com
After=network-online.target sys-fs-bpf.mount
Wants=network-online.target sys-fs-bpf.mount
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
ExecStart=/opt/AegisDNS/Service/AegisDNS.Service
WorkingDirectory=/opt/AegisDNS/Service
Restart=on-failure
RestartSec=5
StandardOutput=append:/var/log/aegisdns/service.log
StandardError=append:/var/log/aegisdns/service.error.log
User=root
Group=only
Environment=AEGIS_UI_USER=only
RuntimeDirectory=aegisdns
RuntimeDirectoryMode=0750
LimitNOFILE=65536
LimitNPROC=4096
CapabilityBoundingSet=CAP_NET_BIND_SERVICE CAP_NET_ADMIN CAP_NET_RAW CAP_BPF
AmbientCapabilities=CAP_NET_BIND_SERVICE CAP_NET_ADMIN CAP_BPF
ExecStopPost=/bin/sh -c 'resolvectl dns enp4s0 8.8.8.8 8.8.4.4 && resolvectl domain enp4s0 "~." && resolvectl flush-caches'

[Install]
WantedBy=multi-user.target
""";
        await File.WriteAllTextAsync(ServiceFile, unit);
        await RunAsyncWithArgumentList("systemctl", new[] { "daemon-reload" });
        // Do NOT enable or start the service here.
        // The UI's Activate/Deactivate button controls start/stop/enable/disable.
    }

    // ── Step 4: Configure DNS upstream ───────────────────────────────────────

    private async Task ConfigureDnsAsync()
    {
        string upstreamIp = _vm.SelectedUpstream switch
        {
            "Google" => "8.8.8.8",
            "Quad9" => "9.9.9.9",
            "OpenDNS" => "208.67.222.222",
            "Custom" => _vm.CustomPrimary,
            _ => "1.1.1.1"   // Cloudflare default
        };

        // Write AegisDNS upstream config only.
        // System DNS is NOT touched here — it is switched to 127.0.0.1
        // in StartServiceAsync() only after the service is confirmed healthy.
        Directory.CreateDirectory(ConfigDir);
        await File.WriteAllTextAsync(Path.Combine(ConfigDir, "upstream.conf"),
            $"UPSTREAM_DNS={upstreamIp}\nDOH_ENABLED={(_vm.DohEnabled ? "1" : "0")}\n");
    }

    // ── Step 5: Write AI config ───────────────────────────────────────────────

    private async Task WriteAiConfigAsync()
    {
        string aiConfigDir = Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
            ".config", "AegisDNS");
        Directory.CreateDirectory(aiConfigDir);
        string aiConfigFile = Path.Combine(aiConfigDir, "Ai.config");

        if (!File.Exists(aiConfigFile))
        {
            var config = new AiConfig
            {
                EnableAiSentinel = _vm.AiProvider != "None",
                AiProvider = _vm.AiProvider == "None" ? "Ollama" : _vm.AiProvider,
                AiEndpoint = "http://localhost:11434",
                AiModel = string.IsNullOrWhiteSpace(_vm.AiModel) ? "llama3" : _vm.AiModel,
                AiApiKey = _vm.AiApiKey,
                AiCheckIntervalMinutes = 2,
                FallbackProviders = new List<string>()
            };

            var options = new JsonSerializerOptions { WriteIndented = true };
            string json = JsonSerializer.Serialize(config, options);
            await File.WriteAllTextAsync(aiConfigFile, json);
        }
    }

    // ── Step 6: Desktop integration ───────────────────────────────────────────

    private async Task InstallDesktopAsync()
    {
        var desktop = $"""
[Desktop Entry]
Version=1.0
Name=AegisDNS
GenericName=DNS Security Shield
Comment=AI-Powered DNS Interceptor and Threat Shield
Exec={InstallDir}/UI/AegisDNSUI
Icon=network-wired
Type=Application
Terminal=false
Categories=Network;Security;Settings;System;
Keywords=DNS;Security;Firewall;Privacy;AI;Blocker;
StartupNotify=true
""";
        await File.WriteAllTextAsync(DesktopFile, desktop);
        await RunAsyncWithArgumentList("update-desktop-database", new[] { "/usr/share/applications" }, ignoreErrors: true);

        // CLI symlink
        string symlink = "/usr/local/bin/aegisdns-ui";
        if (File.Exists(symlink)) File.Delete(symlink);
        await RunAsyncWithArgumentList("ln", new[] { "-sf", $"{InstallDir}/UI/AegisDNSUI", symlink }, ignoreErrors: true);
    }

    // ── Step 7: Start service ─────────────────────────────────────────────────

    private async Task StartServiceAsync()
    {
        // Detect the primary interface for resolvectl
        string iface = "enp4s0"; // safe fallback

        await RunAsyncWithArgumentList("systemctl", new[] { "start", "aegisdns" });

        // Wait for service to be healthy before touching DNS
        bool healthy = false;
        for (int i = 0; i < 10; i++)
        {
            await Task.Delay(1000);
            var (rc, stdout, _) = await RunCapture("systemctl", new[] { "is-active", "aegisdns" });
            if (rc == 0 && stdout.Trim() == "active")
            {
                healthy = true;
                break;
            }
        }

        if (!healthy)
        {
            // Service failed to start — do NOT touch DNS
            throw new Exception("AegisDNS service failed to start. DNS was not modified.");
        }

        // Service confirmed healthy — now safe to switch DNS
        var (resolvectlRc, _, _) = await RunCapture("resolvectl", new[] { "status" });
        if (resolvectlRc == 0)
        {
            await RunAsyncWithArgumentList("resolvectl",
                new[] { "dns", iface, "127.0.0.1" }, ignoreErrors: false);
        }
    }

    // ── Step 8: Restore license token ────────────────────────────────────────

    private async Task RestoreLicenseAsync()
    {
        // Resolve the real (non-root) user's home directory.
        // The installer runs as root via pkexec/sudo, so HOME may point to /root.
        string? realUser = GetRealUserName();
        if (realUser == null) return;

        string userHome  = GetHomeForUser(realUser);
        string tokenPath = Path.Combine(userHome, ".local", "share", "AegisDNS", "activation.token");

        // Silent — nothing to restore on fresh installs without a prior activation.
        if (!File.Exists(tokenPath)) return;

        string token = await File.ReadAllTextAsync(tokenPath);

        // Destination 1: /etc/aegisdns/license.key (ConfigDir created in step 0)
        string etcKey = Path.Combine(ConfigDir, "license.key");
        await File.WriteAllTextAsync(etcKey, token);
        Chmod(etcKey, "600");

        // Destination 2: /root/.config/aegisdns/license.key
        string rootConfigDir = Path.Combine("/root", ".config", "aegisdns");
        Directory.CreateDirectory(rootConfigDir);
        Chmod(rootConfigDir, "700");
        string rootKey = Path.Combine(rootConfigDir, "license.key");
        await File.WriteAllTextAsync(rootKey, token);
        Chmod(rootKey, "600");
    }

    // ── Step 7: Free port 53 ─────────────────────────────────────────────────

    private const string ResolvedConf = "/etc/systemd/resolved.conf";

    // Install: set DNSStubListener=no so systemd-resolved stops binding :53.
    // Backs up the original file to BackupDir/resolved.conf.bak for uninstall.
    private async Task DisableResolvedStubAsync()
    {
        if (File.Exists(ResolvedConf))
            File.Copy(ResolvedConf, Path.Combine(BackupDir, "resolved.conf.bak"), overwrite: true);

        string content = File.Exists(ResolvedConf)
            ? await File.ReadAllTextAsync(ResolvedConf)
            : "[Resolve]\n";

        // Walk every line: replace existing DNSStubListener entries (even if
        // commented out) with the authoritative no-stub line.
        var lines = new List<string>(content.Split('\n'));
        bool found = false;
        for (int i = 0; i < lines.Count; i++)
        {
            string trimmed = lines[i].TrimStart('#', ' ', '\t');
            if (trimmed.StartsWith("DNSStubListener", StringComparison.OrdinalIgnoreCase))
            {
                lines[i] = "DNSStubListener=no";
                found = true;
            }
        }
        if (!found)
            lines.Add("DNSStubListener=no");

        await File.WriteAllTextAsync(ResolvedConf, string.Join('\n', lines));
        await RunAsyncWithArgumentList("systemctl", new[] { "restart", "systemd-resolved" });
    }

    // Uninstall: restore DNSStubListener=yes so the system stub resolver comes back.
    // Called by uninstall logic; static so it can be invoked without an instance.
    public static async Task RestoreResolvedStubAsync()
    {
        string backup = Path.Combine(BackupDir, "resolved.conf.bak");
        if (File.Exists(backup))
        {
            File.Copy(backup, ResolvedConf, overwrite: true);
        }
        else if (File.Exists(ResolvedConf))
        {
            var lines = new List<string>((await File.ReadAllTextAsync(ResolvedConf)).Split('\n'));
            for (int i = 0; i < lines.Count; i++)
            {
                if (string.Equals(lines[i].Trim(), "DNSStubListener=no",
                                  StringComparison.OrdinalIgnoreCase))
                    lines[i] = "DNSStubListener=yes";
            }
            await File.WriteAllTextAsync(ResolvedConf, string.Join('\n', lines));
        }
        await RunAsyncWithArgumentList("systemctl", new[] { "restart", "systemd-resolved" });
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    /// <summary>
    /// Returns the real (non-root) username when the installer was elevated via
    /// pkexec or sudo. Returns null if we are genuinely running as root with no
    /// underlying user, or if the env vars are absent.
    /// </summary>
    private static string? GetRealUserName()
    {
        // pkexec sets PKEXEC_UID to the invoking user's numeric UID
        string? pkexecUid = Environment.GetEnvironmentVariable("PKEXEC_UID");
        if (!string.IsNullOrEmpty(pkexecUid))
            return GetUsernameForUid(pkexecUid);

        // sudo sets SUDO_USER to the invoking username
        string? sudoUser = Environment.GetEnvironmentVariable("SUDO_USER");
        if (!string.IsNullOrEmpty(sudoUser))
            return sudoUser;

        return null;
    }

    /// <summary>
    /// Looks up a username by numeric UID from /etc/passwd.
    /// Returns null if not found or on parse error.
    /// </summary>
    private static string? GetUsernameForUid(string uid)
    {
        try
        {
            foreach (var line in File.ReadLines("/etc/passwd"))
            {
                var f = line.Split(':');
                if (f.Length >= 3 && f[2] == uid)
                    return f[0];
            }
        }
        catch { }
        return null;
    }

    /// <summary>
    /// Returns the home directory for the given username from /etc/passwd.
    /// Falls back to /home/{username} if the lookup fails.
    /// </summary>
    private static string GetHomeForUser(string username)
    {
        try
        {
            foreach (var line in File.ReadLines("/etc/passwd"))
            {
                var f = line.Split(':');
                if (f.Length >= 6 && f[0] == username)
                    return f[5]; // home dir is field index 5
            }
        }
        catch { }
        return Path.Combine("/home", username);
    }

    private static void Chmod(string path, string mode)
    {
        var psi = new ProcessStartInfo("chmod") { UseShellExecute = false };
        psi.ArgumentList.Add(mode);
        psi.ArgumentList.Add(path);
        using var p = Process.Start(psi);
        p?.WaitForExit();
    }

    private static void CopyDirectory(string src, string dst)
    {
        Directory.CreateDirectory(dst);
        foreach (var file in Directory.GetFiles(src, "*", SearchOption.AllDirectories))
        {
            string rel = Path.GetRelativePath(src, file);
            string target = Path.Combine(dst, rel);
            Directory.CreateDirectory(Path.GetDirectoryName(target)!);
            File.Copy(file, target, overwrite: true);
        }
    }

    private static async Task RunAsyncWithArgumentList(string cmd, string[] args,
        bool ignoreErrors = false)
    {
        var psi = new ProcessStartInfo(cmd)
        {
            UseShellExecute = false,
            RedirectStandardOutput = true,
            RedirectStandardError = true,
            CreateNoWindow = true,
        };

        foreach (var arg in args)
            psi.ArgumentList.Add(arg);

        using var p = Process.Start(psi);
        if (p == null) return;
        await p.WaitForExitAsync();
        if (!ignoreErrors && p.ExitCode != 0)
            throw new Exception($"{cmd} {string.Join(" ", args)} exited with code {p.ExitCode}");
    }



    private static async Task<(int ExitCode, string StdOut, string StdErr)>
        RunCapture(string cmd, string[] args)
    {
        var psi = new ProcessStartInfo(cmd)
        {
            UseShellExecute = false,
            RedirectStandardOutput = true,
            RedirectStandardError = true
        };
        foreach (var arg in args)
            psi.ArgumentList.Add(arg);
        using var p = Process.Start(psi);
        if (p == null) return (-1, "", "");
        string stdout = await p.StandardOutput.ReadToEndAsync();
        string stderr = await p.StandardError.ReadToEndAsync();
        await p.WaitForExitAsync();
        return (p.ExitCode, stdout, stderr);
    }
}
