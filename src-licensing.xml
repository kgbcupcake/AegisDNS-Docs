using System;
using System.IO;
using System.Security.Cryptography;
using System.Text;

namespace AegisDNS.Licensing;

public static class HardwareIdentity
{
    private static readonly Lazy<string> Cached = new(Compute);

    /// <summary>
    /// Returns a stable, machine-scoped identity that is identical for
    /// root/non-root callers on the same Linux host.
    /// </summary>
    public static string Get() => Cached.Value;

    private static string Compute()
    {
        string rawId = GetLinuxHwid();

        using var sha256 = SHA256.Create();
        var hash = sha256.ComputeHash(Encoding.UTF8.GetBytes(rawId));
        return BitConverter.ToString(hash).Replace("-", "").ToUpperInvariant();
    }

    private static string GetLinuxHwid()
    {
        // Use machine-id only. DMI UUID fallback was removed because it can be
        // permission-dependent across root/non-root contexts.
        string? machineId = TryReadMachineId("/etc/machine-id");
        if (!string.IsNullOrEmpty(machineId))
            return machineId;

        machineId = TryReadMachineId("/var/lib/dbus/machine-id");
        if (!string.IsNullOrEmpty(machineId))
            return machineId;

        throw new PlatformNotSupportedException("Linux hardware identity could not be determined from standard paths (/etc/machine-id, /var/lib/dbus/machine-id).");
    }

    private static string? TryReadMachineId(string path)
    {
        if (!File.Exists(path))
            return null;

        string value = File.ReadAllText(path).Trim().ToLowerInvariant();
        return string.IsNullOrEmpty(value) ? null : value;
    }

}
