<file path="src/AegisDNS.Licensing/LicenseManager.cs">
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Security.Cryptography;
using System.Text;
using System.Text.Json;

namespace AegisDNS.Licensing;

public static class LicenseManager
{
    internal static string BaseDir { get; set; } = Path.GetDirectoryName(AesGcmTokenStore.GetTokenPath("AegisDNS"))!;
    internal static string LicensePath => Path.Combine(BaseDir, "license.dat");
    internal static string TokenPath => AesGcmTokenStore.GetTokenPath("AegisDNS");
    internal static string TrialPath => Path.Combine(BaseDir, "trial.info");

    public const int TrialDays = 14;
    public const int GraceDays = 7;

    internal static string PublicKeyPem = @"-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAiCeAIL7ZuanNfeJ5OFfR
VwquEJfIBYRd8ugkM2/w/+Cfgcgkog68A2ApvlXTfykMa+9M2Im3kVnASryAN4wd
mxR9VkXPCB7Ci1poUuY+lI+NDYGArX5GxEScZ4sEqAzdaLLHTAZRS6taQvqCO3HV
uUyG8Y+KlTwpChMDCubqCeD0o9tmoQYQBsQXNDJNYakYRkWt7YX2v2yBb6vVOz2N
TMwJrTx2W44XkkAU6qhLZpzgkeRntxoQ4xrKqkICLfqJ1DWbwDvAvKpDRtdK+w3g
I2fkQ+hs8KtuyWSsUPx0LGgkAcS1T3nV1srSDD0sjQjQFZeCyWv1E9pFfJdpS1MF
/wIDAQAB
-----END PUBLIC KEY-----";

    public enum LicenseTier { Community, Basic, Pro, AegisPrime, Enterprise, Founder, Developer }

    public static bool IsDevMode => CurrentTier == LicenseTier.Developer;

    public class LicensePayload
    {
        public string Product { get; set; } = "";
        public string Edition { get; set; } = "Consumer";
        public string Type { get; set; } = "Perpetual";
        public DateTime IssueDate { get; set; }
        public DateTime? ExpiryDate { get; set; }
        public Dictionary<string, JsonElement>? Metadata { get; set; }
    }

    public static bool ValidateFormat(string key)
    {
        if (string.IsNullOrWhiteSpace(key)) return false;
        var parts = key.Split('.');
        return parts.Length == 2 && IsBase64(parts[0]) && IsBase64(parts[1]);
    }

    private static bool IsBase64(string base64)
    {
        try { Convert.FromBase64String(base64); return true; } catch { return false; }
    }

    public static bool IsLicenseValid()
    {
        try
        {
            string? tokenData = AesGcmTokenStore.Decrypt(TokenPath);
            if (tokenData == null) return false;

            var parts = tokenData.Split('|');
            if (parts.Length < 4) return false;

            string rawLicense = parts[0];
            string savedHwid = parts[1];

            // 1. RSA Signature Re-verification
            var licenseParts = rawLicense.Split('.');
            if (licenseParts.Length != 2) return false;

            byte[] payloadBytes = Convert.FromBase64String(licenseParts[0]);
            byte[] signature = Convert.FromBase64String(licenseParts[1]);

            if (!VerifySignature(payloadBytes, signature)) return false;

            // 2. HWID Check (Fixed Time) - Bypassed for Developer tier
            var json = Encoding.UTF8.GetString(payloadBytes);
            LicensePayload? payload;
            try { payload = JsonSerializer.Deserialize<LicensePayload>(json); }
            catch (JsonException) { return false; }

            if (payload == null || !SafeStringEquals(payload.Product, "AegisDNS")) return false;

            // 4. Revocation Check (Local)
            if (payload.Metadata != null && payload.Metadata.TryGetValue("Id", out var licenseIdElement))
            {
                var licenseId = licenseIdElement.GetString();
                if (licenseId != null && IsKeyRevoked(licenseId)) return false;
            }

            if (payload.Edition != "Developer")
            {
                string currentHwid = HardwareIdentity.Get();
                if (!SafeStringEquals(savedHwid, currentHwid)) return false;
            }

            // 3. Expiry Check
            if (payload.ExpiryDate.HasValue && DateTime.UtcNow > payload.ExpiryDate.Value.AddDays(GraceDays))
            {
                return false;
            }

            return true;
        }
        catch { return false; }
    }

    private static bool IsKeyRevoked(string licenseId)
    {
        try
        {
            string configDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), ".config", "aegisdns");
            string revokedPath = Path.Combine(configDir, "revoked.json");

            if (!File.Exists(revokedPath)) return false;

            string json = File.ReadAllText(revokedPath);
            string[]? revokedIds;
            try
            {
                revokedIds = JsonSerializer.Deserialize<string[]>(json);
            }
            catch (JsonException ex)
            {
                System.Diagnostics.Debug.WriteLine($"[LicenseManager] Failed to deserialize: {ex.Message}");
                return false;
            }
            return revokedIds != null && revokedIds.Contains(licenseId);
        }
        catch { return false; }
    }

    private static bool SafeStringEquals(string? a, string? b)
    {
        byte[] aBytes = Encoding.UTF8.GetBytes(a ?? "");
        byte[] bBytes = Encoding.UTF8.GetBytes(b ?? "");
        int maxLen = Math.Max(aBytes.Length, bBytes.Length);
        byte[] aPadded = new byte[maxLen];
        byte[] bPadded = new byte[maxLen];
        Array.Copy(aBytes, aPadded, aBytes.Length);
        Array.Copy(bBytes, bPadded, bBytes.Length);
        return CryptographicOperations.FixedTimeEquals(aPadded, bPadded);
    }

    public static string? GetRawLicenseFromToken()
    {
        try
        {
            string? tokenData = AesGcmTokenStore.Decrypt(TokenPath);
            if (tokenData == null) return null;

            var parts = tokenData.Split('|');
            return parts.Length > 0 ? parts[0] : null;
        }
        catch { return null; }
    }

    public static bool EnsureActivated(string? rawLicense = null)
    {
        if (string.IsNullOrEmpty(rawLicense))
            return IsLicenseValid();

        try
        {
            var parts = rawLicense.Split('.');
            if (parts.Length != 2) return false;

            byte[] payloadBytes = Convert.FromBase64String(parts[0]);
            byte[] signature = Convert.FromBase64String(parts[1]);

            if (!VerifySignature(payloadBytes, signature)) return false;

            var json = Encoding.UTF8.GetString(payloadBytes);
            LicensePayload? payload;
            try { payload = JsonSerializer.Deserialize<LicensePayload>(json); }
            catch (JsonException) { return false; }
            if (payload == null || !SafeStringEquals(payload.Product, "AegisDNS")) return false;

            string hwid = HardwareIdentity.Get();
            string expiry = payload.ExpiryDate?.ToString("O") ?? "Never";
            string tokenData = $"{rawLicense}|{hwid}|{payload.Edition}|{expiry}";

            AesGcmTokenStore.Encrypt(tokenData, TokenPath);
            return true;
        }
        catch { return false; }
    }

    private static bool VerifySignature(byte[] data, byte[] signature)
    {
        try
        {
            using var rsa = RSA.Create();
            rsa.ImportFromPem(PublicKeyPem);
            return rsa.VerifyData(data, signature, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1);
        }
        catch { return false; }
    }

    public static LicenseTier CurrentTier
    {
        get
        {
            Debug.WriteLine($"[LicenseManager.CurrentTier] Resolving tier from TokenPath='{TokenPath}'");
            string? tokenData = AesGcmTokenStore.Decrypt(TokenPath);
            if (tokenData != null)
            {
                try
                {
                    var parts = tokenData.Split('|');
                    Debug.WriteLine($"[LicenseManager.CurrentTier] Token decrypted. parts.Length={parts.Length}");
                    if (parts.Length >= 4)
                    {
                        Debug.WriteLine($"[LicenseManager.CurrentTier] Parsed edition='{parts[2]}', expiryRaw='{parts[3]}'");
                        var tier = parts[2] switch
                        {
                            "Developer" => LicenseTier.Developer,
                            "Founder" => LicenseTier.Founder,
                            "Enterprise" => LicenseTier.Enterprise,
                            "AegisPrime" => LicenseTier.AegisPrime,
                            "Pro" => LicenseTier.Pro,
                            "Basic" => LicenseTier.Basic,
                            _ => LicenseTier.Community
                        };
                        Debug.WriteLine($"[LicenseManager.CurrentTier] Mapped tier={tier}");

                        if (DateTime.TryParse(parts[3], out DateTime expiry))
                        {
                            Debug.WriteLine($"[LicenseManager.CurrentTier] Expiry parsed={expiry:O}, now={DateTime.UtcNow:O}");
                            if (DateTime.UtcNow > expiry.AddDays(GraceDays))
                            {
                                Debug.WriteLine("[LicenseManager.CurrentTier] Expired beyond grace, returning Community.");
                                return LicenseTier.Community;
                            }
                        }
                        else
                        {
                            Debug.WriteLine("[LicenseManager.CurrentTier] Expiry parse failed, using mapped tier.");
                        }

                        Debug.WriteLine($"[LicenseManager.CurrentTier] Returning tier={tier} from token.");
                        return tier;
                    }
                    Debug.WriteLine("[LicenseManager.CurrentTier] Token format invalid (<4 parts).");
                }
                catch (Exception ex)
                {
                    Debug.WriteLine($"[LicenseManager.CurrentTier] Exception while parsing token ({ex.GetType().Name}): {ex.Message}");
                }
            }
            else
            {
                Debug.WriteLine("[LicenseManager.CurrentTier] Token decrypt returned null.");
            }

            if (IsTrialActive())
            {
                Debug.WriteLine("[LicenseManager.CurrentTier] Trial active. Returning Pro.");
                return LicenseTier.Pro;
            }

            Debug.WriteLine("[LicenseManager.CurrentTier] Trial inactive. Returning Community.");
            return LicenseTier.Community;
        }
    }

    private class TrialData
    {
        public DateTime InstallationDate { get; set; }
        public DateTime LastCheckDate { get; set; }
    }

    public static bool IsTrialActive()
    {
        try
        {
            if (!AesGcmTokenStore.Exists(TrialPath))
            {
                InitializeTrial();
                return true;
            }

            string? json = AesGcmTokenStore.Decrypt(TrialPath);
            if (json == null) return false;

            TrialData? data;
            try { data = JsonSerializer.Deserialize<TrialData>(json); }
            catch (JsonException) { return false; }
            if (data == null) return false;

            if (DateTime.UtcNow < data.LastCheckDate) return false;

            data.LastCheckDate = DateTime.UtcNow;
            SaveTrial(data);

            return (DateTime.UtcNow - data.InstallationDate).TotalDays <= TrialDays;
        }
        catch { return false; }
    }

    private static void InitializeTrial()
    {
        var data = new TrialData { InstallationDate = DateTime.UtcNow, LastCheckDate = DateTime.UtcNow };
        SaveTrial(data);
    }

    private static void SaveTrial(TrialData data)
    {
        string json = JsonSerializer.Serialize(data);
        AesGcmTokenStore.Encrypt(json, TrialPath);
    }

    public static bool IsTrialExpired => !IsTrialActive() && (DateTime.UtcNow - GetTrialStartDate()).TotalDays > TrialDays;

    private static DateTime GetTrialStartDate()
    {
        try
        {
            string? json = AesGcmTokenStore.Decrypt(TrialPath);
            if (json == null) return DateTime.MaxValue;
            TrialData? data = null;
            try { data = JsonSerializer.Deserialize<TrialData>(json); }
            catch (JsonException) { }
            return data?.InstallationDate ?? DateTime.MaxValue;
        }
        catch { return DateTime.MaxValue; }
    }

    public static void Deactivate()
    {
        AesGcmTokenStore.TryDelete(TokenPath);
    }
}
