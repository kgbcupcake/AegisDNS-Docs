using System;
using System.Collections.ObjectModel;
using System.Reactive;
using System.Reactive.Linq;

using AegisDNS.Core;
using AegisDNS.Core.RouterMode;

using ReactiveUI;

namespace AegisDNS.ViewModels;

public class RouterModeViewModel : ReactiveObject
{
    private string _bindAddress = RouterConfigManager.Settings.RouterModeBindAddress;
    public string BindAddress
    {
        get => _bindAddress;
        set => this.RaiseAndSetIfChanged(ref _bindAddress, value);
    }

    private int _port = RouterConfigManager.Settings.RouterModePort;
    public int Port
    {
        get => _port;
        set => this.RaiseAndSetIfChanged(ref _port, value);
    }

    private bool _isEnabled = RouterConfigManager.Settings.EnableRouterMode;
    public bool IsEnabled
    {
        get => _isEnabled;
        set => this.RaiseAndSetIfChanged(ref _isEnabled, value);
    }

    public ObservableCollection<ConnectedDevice> ConnectedDevices { get; } = [];

    public ReactiveCommand<Unit, Unit> Enable { get; }
    public ReactiveCommand<Unit, Unit> Disable { get; }
    public ReactiveCommand<Unit, Unit> Refresh { get; }

    public RouterModeViewModel()
    {
        Enable = ReactiveCommand.Create(ExecuteEnable);
        Disable = ReactiveCommand.Create(ExecuteDisable);
        Refresh = ReactiveCommand.Create(ExecuteRefresh);

        // Auto-refresh connected devices every 5 seconds
        Observable
            .Interval(TimeSpan.FromSeconds(5))
            .ObserveOn(RxApp.MainThreadScheduler)
            .Subscribe(_ => ExecuteRefresh());

        ExecuteRefresh();
    }

    private void ExecuteEnable()
    {
        RouterConfigManager.Settings.EnableRouterMode = true;
        RouterConfigManager.Settings.RouterModeBindAddress = BindAddress;
        RouterConfigManager.Settings.RouterModePort = Port;
        RouterConfigManager.Save();
        IsEnabled = true;
    }

    private void ExecuteDisable()
    {
        RouterConfigManager.Settings.EnableRouterMode = false;
        RouterConfigManager.Save();
        IsEnabled = false;
    }

    private void ExecuteRefresh()
    {
        ConnectedDevices.Clear();
        foreach (var device in ConnectedDeviceTracker.Instance.GetDevices())
            ConnectedDevices.Add(device);
    }
}
