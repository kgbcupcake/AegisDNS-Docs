            BackgroundOpacity = 1.0;
            AccentColorPrimary = "#00FFFF";
            AccentColorSecondary = "#0080FF";
            LogFontFamily = "Consolas";
            StrictMonospaceLog = true;
            AudioPack = "Muted";
            ThreatAlertSound = false;
            ActiveThemeName = "Default";
        });

        ExportThemeCommand = ReactiveCommand.CreateFromTask(async () =>
        {
            if (getExportPath == null) return;
            var path = await getExportPath();
            if (!string.IsNullOrEmpty(path))
            {
                var json = SerializeTheme();
                await File.WriteAllTextAsync(path, json);
            }
        });

        ImportThemeCommand = ReactiveCommand.CreateFromTask(async () =>
        {
            if (getImportPath == null) return;
            var path = await getImportPath();
            if (!string.IsNullOrEmpty(path) && File.Exists(path))
            {
                var json = await File.ReadAllTextAsync(path);
                ApplyTheme(json);
            }
        });
    }

    // --- Tier Gating ---

    public bool IsPro
    {
        get
        {
#if DEBUG
            return true;
#else
#pragma warning disable CA1416
            return false;
#pragma warning restore CA1416
#endif
        }
    }

    // --- Commands ---

    public ReactiveCommand<Unit, Unit> SaveCommand { get; }
    public ReactiveCommand<Unit, Unit> ResetToDefaultCommand { get; }
    public ReactiveCommand<Unit, Unit> ExportThemeCommand { get; }
    public ReactiveCommand<Unit, Unit> ImportThemeCommand { get; }

    public event EventHandler<string>? ImportFailed;

    // --- Glow ---

    public double GlowIntensity
    {
        get => ConfigManager.Settings.GlowIntensity;
        set
        {
            ConfigManager.Settings.GlowIntensity = Math.Clamp(value, 0.0, 1.0);
            this.RaisePropertyChanged();
        }
    }

    public double GlowRadius
    {
        get => ConfigManager.Settings.GlowRadius;
        set
        {
            ConfigManager.Settings.GlowRadius = Math.Clamp(value, 4.0, 30.0);
            this.RaisePropertyChanged();
        }
    }

    public string GlowColor
    {
        get => ConfigManager.Settings.GlowColor;
        set { ConfigManager.Settings.GlowColor = value; this.RaisePropertyChanged(); }
    }

    // --- Background Effects ---

    public string BackgroundEffect
    {
        get => ConfigManager.Settings.BackgroundEffect;
        set { ConfigManager.Settings.BackgroundEffect = value; this.RaisePropertyChanged(); }
    }

    public bool CrtModeEnabled
    {
        get => ConfigManager.Settings.CrtModeEnabled;
        set { ConfigManager.Settings.CrtModeEnabled = value; this.RaisePropertyChanged(); }
    }

    // --- Window & Transparency ---

    public string WindowBackdrop
    {
        get => ConfigManager.Settings.WindowBackdrop;
        set { ConfigManager.Settings.WindowBackdrop = value; this.RaisePropertyChanged(); }
    }

    public double BackgroundOpacity
    {
        get => ConfigManager.Settings.BackgroundOpacity;
        set
        {
            ConfigManager.Settings.BackgroundOpacity = Math.Clamp(value, 0.4, 1.0);
            this.RaisePropertyChanged();
        }
    }

    public string AccentColorPrimary
    {
        get => ConfigManager.Settings.AccentColorPrimary;
        set { ConfigManager.Settings.AccentColorPrimary = value; this.RaisePropertyChanged(); }
    }

    public string AccentColorSecondary
    {
        get => ConfigManager.Settings.AccentColorSecondary;
        set { ConfigManager.Settings.AccentColorSecondary = value; this.RaisePropertyChanged(); }
    }

    // --- Typography ---

    public string LogFontFamily
    {
        get => ConfigManager.Settings.LogFontFamily;
        set { ConfigManager.Settings.LogFontFamily = value; this.RaisePropertyChanged(); }
    }

    public bool StrictMonospaceLog
    {
        get => ConfigManager.Settings.StrictMonospaceLog;
        set { ConfigManager.Settings.StrictMonospaceLog = value; this.RaisePropertyChanged(); }
    }

    // --- Audio ---

    public string AudioPack
    {
        get => ConfigManager.Settings.AudioPack;
        set
        {
            ConfigManager.Settings.AudioPack = value;
            this.RaisePropertyChanged();
            // Trigger 0.5s preview audio when pack changes (unless Muted)
            if (value != "Muted") AegisDNS.UI.Audio.AudioFeedbackManager.PlayActionSuccess();
        }
    }

    public bool ThreatAlertSound
    {
        get => ConfigManager.Settings.ThreatAlertSound;
        set { ConfigManager.Settings.ThreatAlertSound = value; this.RaisePropertyChanged(); }
    }

    // --- Theme Profiles ---

    public string ActiveThemeName
    {
        get => ConfigManager.Settings.ActiveThemeName;
        set { ConfigManager.Settings.ActiveThemeName = value; this.RaisePropertyChanged(); }
    }

    // --- Theme Export/Import Logic ---

    public string SerializeTheme()
    {
        var theme = new ThemeProfile
        {
            Name = ActiveThemeName,
            GlowIntensity = GlowIntensity,
            GlowRadius = GlowRadius,
            GlowColor = GlowColor,
            BackgroundEffect = BackgroundEffect,
            CrtModeEnabled = CrtModeEnabled,
            WindowBackdrop = WindowBackdrop,
            BackgroundOpacity = BackgroundOpacity,
            AccentColorPrimary = AccentColorPrimary,
            AccentColorSecondary = AccentColorSecondary,
            LogFontFamily = LogFontFamily,
            StrictMonospaceLog = StrictMonospaceLog,
            AudioPack = AudioPack,
            ThreatAlertSound = ThreatAlertSound
        };

        return JsonSerializer.Serialize(theme, new JsonSerializerOptions { WriteIndented = true });
    }

    public bool ApplyTheme(string json)
    {
        try
        {
            ThemeProfile? theme;
            try
            {
                theme = JsonSerializer.Deserialize<ThemeProfile>(json);
            }
            catch (JsonException ex)
            {
                System.Diagnostics.Debug.WriteLine($"[AppearanceViewModel] ApplyTheme JSON parse failed: {ex.Message}");
                ImportFailed?.Invoke(this, "Failed to parse theme profile. " + ex.Message);
                return false;
            }
            if (theme == null) return false;

            ActiveThemeName = theme.Name ?? "Imported";
            GlowIntensity = theme.GlowIntensity;
            GlowRadius = theme.GlowRadius;
            GlowColor = theme.GlowColor ?? "#00FFFF";
            BackgroundEffect = theme.BackgroundEffect ?? "None";
            CrtModeEnabled = theme.CrtModeEnabled;
            WindowBackdrop = theme.WindowBackdrop ?? "Solid";
            BackgroundOpacity = theme.BackgroundOpacity;
            AccentColorPrimary = theme.AccentColorPrimary ?? "#00FFFF";
            AccentColorSecondary = theme.AccentColorSecondary ?? "#0080FF";
            LogFontFamily = theme.LogFontFamily ?? "Consolas";
            StrictMonospaceLog = theme.StrictMonospaceLog;
            AudioPack = theme.AudioPack ?? "Muted";
            ThreatAlertSound = theme.ThreatAlertSound;
            return true;
        }
        catch (Exception ex)
        {
            ImportFailed?.Invoke(this, "Failed to parse theme profile. " + ex.Message);
            return false;
        }
    }
}

public class ThemeProfile
{
    public string? Name { get; set; }
    public double GlowIntensity { get; set; }
    public double GlowRadius { get; set; }
    public string? GlowColor { get; set; }
    public string? BackgroundEffect { get; set; }
    public bool CrtModeEnabled { get; set; }
    public string? WindowBackdrop { get; set; }
    public double BackgroundOpacity { get; set; }
    public string? AccentColorPrimary { get; set; }
    public string? AccentColorSecondary { get; set; }
    public string? LogFontFamily { get; set; }
    public bool StrictMonospaceLog { get; set; }
    public string? AudioPack { get; set; }
    public bool ThreatAlertSound { get; set; }
}
