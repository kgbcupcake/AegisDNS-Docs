using System;
using System.Reactive;
using System.Runtime.Versioning;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.Core.Ai;
using AegisDNS.Core.Utilities;
using AegisDNS.Licensing;

using Avalonia.Media;

using Microsoft.Extensions.Logging.Abstractions;

using ReactiveUI;

namespace AegisDNS.ViewModels;

[SupportedOSPlatform("linux")]
public class SettingsViewModel : ViewModelBase
{
    private readonly UpdateManager _updateManager = new(NullLogger<UpdateManager>.Instance);
    private string _updateStatus = "Ready";

    public SettingsViewModel()
    {
        SaveSettings = ReactiveCommand.CreateFromTask(async () =>
        {
            await Task.Run(() =>
            {
                ConfigManager.Save();
                AiConfigManager.Save();
                BlocklistConfigManager.Save();
                DnsConfigManager.Save();
                XdpConfigManager.Save();
            });
            return Unit.Default;
        });

        CheckForUpdates = ReactiveCommand.CreateFromTask(async () =>
        {
            UpdateStatus = "Checking...";
            var update = await _updateManager.CheckForUpdatesAsync();
            if (update != null)
            {
                UpdateStatus = $"Update Found: v{update.Version}. Downloading...";
                bool success = await _updateManager.DownloadAndInstallAsync(update);
                if (success) UpdateStatus = "Update started. App will restart.";
                else UpdateStatus = "Update failed (Check console).";
            }
            else
            {
                UpdateStatus = "You are up to date.";
            }
        });

        UpdateBlocklistsNow = ReactiveCommand.CreateFromTask(async () =>
        {
            UpdateStatus = "Triggering blocklist update...";
            var result = await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("UpdateBlocklists"));
            if (result != null && result.Command == "UpdateResponse")
            {
                UpdateStatus = "Blocklist update initiated in background.";
            }
            else
            {
                UpdateStatus = "Failed to communicate with Aegis service.";
            }
        });
    }

    public string UpdateStatus
    {
        get => _updateStatus;
        set => this.RaiseAndSetIfChanged(ref _updateStatus, value);
    }

    public ReactiveCommand<Unit, Unit> CheckForUpdates { get; }
    public ReactiveCommand<Unit, Unit> UpdateBlocklistsNow { get; }

    public bool StartOnBoot
    {
        get => ConfigManager.Settings.StartOnBoot;
        set
        {
            ConfigManager.Settings.StartOnBoot = value;
            BootManager.SetStartup(value);
            this.RaisePropertyChanged();
        }
    }

    public bool StartMinimized
    {
        get => ConfigManager.Settings.StartMinimized;
        set { ConfigManager.Settings.StartMinimized = value; this.RaisePropertyChanged(); }
    }

    public bool MinimizeToTray
