using System;
using System.Collections.ObjectModel;
using System.Reactive;

using AegisDNS.Core.Scheduling;

using ReactiveUI;

namespace AegisDNS.ViewModels;

public class SchedulerViewModel : ReactiveObject
{
    private readonly ScheduleEngine _engine = new();

    public ObservableCollection<BlockSchedule> Schedules { get; } = [];

    public ReactiveCommand<Unit, Unit> AddSchedule { get; }
    public ReactiveCommand<BlockSchedule, Unit> RemoveSchedule { get; }
    public ReactiveCommand<Unit, Unit> Save { get; }
    public ReactiveCommand<Unit, Unit> PauseThirtyMinutes { get; }

    private bool _isPaused;
    public bool IsPaused
    {
        get => _isPaused;
        private set => this.RaiseAndSetIfChanged(ref _isPaused, value);
    }

    private string _pausedUntilDisplay = "";
    public string PausedUntilDisplay
    {
        get => _pausedUntilDisplay;
        private set => this.RaiseAndSetIfChanged(ref _pausedUntilDisplay, value);
    }

    public SchedulerViewModel()
    {
        foreach (var schedule in _engine.GetAll())
            Schedules.Add(schedule);

        AddSchedule = ReactiveCommand.Create(ExecuteAddSchedule);
        RemoveSchedule = ReactiveCommand.Create<BlockSchedule>(ExecuteRemoveSchedule);
        Save = ReactiveCommand.Create(ExecuteSave);
        PauseThirtyMinutes = ReactiveCommand.Create(ExecutePauseThirtyMinutes);

        RefreshPauseStatus();
    }

    private void ExecuteAddSchedule()
    {
        Schedules.Add(new BlockSchedule
        {
            Name = "New Schedule",
            StartTime = TimeSpan.FromHours(9),
            EndTime = TimeSpan.FromHours(17),
            Enabled = true
        });
    }

    private void ExecuteRemoveSchedule(BlockSchedule schedule)
    {
        Schedules.Remove(schedule);
    }

    private void ExecuteSave()
    {
        _engine.Save(Schedules);
    }

    private void ExecutePauseThirtyMinutes()
    {
        _engine.PauseUntil(DateTime.UtcNow.AddMinutes(30));
        RefreshPauseStatus();
    }

    public void RefreshPauseStatus()
    {
        IsPaused = _engine.IsPaused;
        PausedUntilDisplay = IsPaused
            ? $"Paused until {_engine.PausedUntil:HH:mm}"
            : "";
    }
}
