    public bool EnableHttpsProxy
    {
        get => HttpsProxyConfigManager.Settings.EnableHttpsProxy;
        set
        {
            HttpsProxyConfigManager.Settings.EnableHttpsProxy = value;
            this.RaisePropertyChanged();

            // If enabling for the first time and CA not installed, we should probably warn or auto-trigger status check
            if (value) RefreshCaStatus();
