namespace AegisDNS.ViewModels;

/// <summary>
/// ViewModel for the HTTPS Proxy Ad Blocker settings window.
/// Phase 18 — HTTPS Proxy Ad Blocker.
/// </summary>
public class HttpsProxySettingsViewModel : ViewModelBase
{
    private string _caStatus = "Checking...";
    private string _newBypassDomain = "";

    public HttpsProxySettingsViewModel()
    {
        ProxyBypassDomains = new ObservableCollection<string>(HttpsProxyConfigManager.Settings.ProxyBypassDomains);

        InstallCaCert = ReactiveCommand.CreateFromTask(async () =>
        {
            CaStatus = "Installing...";
            bool success = await CertificateManager.InstallCaCertAsync();
            RefreshCaStatus();
            return success;
        });

        AddBypassDomain = ReactiveCommand.Create(() =>
        {
            if (!string.IsNullOrWhiteSpace(NewBypassDomain) && !ProxyBypassDomains.Contains(NewBypassDomain))
            {
                ProxyBypassDomains.Add(NewBypassDomain);
                HttpsProxyConfigManager.Settings.ProxyBypassDomains.Add(NewBypassDomain);
                NewBypassDomain = "";
                HttpsProxyConfigManager.Save();
            }
        });

        RemoveBypassDomain = ReactiveCommand.Create<string>(domain =>
        {
            ProxyBypassDomains.Remove(domain);
            HttpsProxyConfigManager.Settings.ProxyBypassDomains.Remove(domain);
            HttpsProxyConfigManager.Save();
        });

        Save = ReactiveCommand.Create(() =>
        {
            HttpsProxyConfigManager.Save();
            return Unit.Default;
        });

        RefreshCaStatus();
    }

    public void RefreshCaStatus()
    {
        CaStatus = CertificateManager.IsCaInstalled() ? "Installed ✓" : "Not installed — Click to install";
    }

    public string CaStatus
    {
        get => _caStatus;
        set => this.RaiseAndSetIfChanged(ref _caStatus, value);
    }

    public string NewBypassDomain
    {
        get => _newBypassDomain;
        set => this.RaiseAndSetIfChanged(ref _newBypassDomain, value);
    }

    public ObservableCollection<string> ProxyBypassDomains { get; }

    public ReactiveCommand<Unit, bool> InstallCaCert { get; }
