using System;
using System.Collections.ObjectModel;
using System.Diagnostics;
using System.Reactive.Linq;

using AegisDNS.Core;
using AegisDNS.Core.Ai;
using AegisDNS.Core.Monitoring;
using AegisDNS.Core.Utilities;
using AegisDNS.Licensing;

using ReactiveUI;

namespace AegisDNS.ViewModels;

/// <summary>
/// ViewModel for the Dashboard view.
/// Observes MainViewModel's IPC-received data and exposes
/// aggregate statistics and supplementary dashboard state.
/// </summary>
public class DashboardViewModel : ReactiveObject
{
    private readonly MainViewModel _mainVm;

    private string _activeBlocklistUrl = "";
    public string ActiveBlocklistUrl
    {
        get => _activeBlocklistUrl;
        set => this.RaiseAndSetIfChanged(ref _activeBlocklistUrl, value);
    }

    private string _blockedRatio = "—";
    public string BlockedRatio
    {
        get => _blockedRatio;
        set => this.RaiseAndSetIfChanged(ref _blockedRatio, value);
    }

    private string _licenseTier = "";
    public string LicenseTier
    {
        get => _licenseTier;
        set => this.RaiseAndSetIfChanged(ref _licenseTier, value);
    }

    private string _aiProviderLabel = "Off";
    public string AiProviderLabel
    {
        get => _aiProviderLabel;
        set => this.RaiseAndSetIfChanged(ref _aiProviderLabel, value);
    }

    private string _aiLearnedBlocklistCount = "0 AI-learned blocks";
    public string AiLearnedBlocklistCount
    {
        get => _aiLearnedBlocklistCount;
        set => this.RaiseAndSetIfChanged(ref _aiLearnedBlocklistCount, value);
    }

    private string _lastAiDetection = "None";
    public string LastAiDetection
    {
        get => _lastAiDetection;
        set => this.RaiseAndSetIfChanged(ref _lastAiDetection, value);
    }

    private string _aiConfidenceSummary = "0 High, 0 Critical this session";
    public string AiConfidenceSummary
    {
        get => _aiConfidenceSummary;
        set => this.RaiseAndSetIfChanged(ref _aiConfidenceSummary, value);
    }

    private string _metricsTotal = "0";
    public string MetricsTotal
    {
        get => _metricsTotal;
        set => this.RaiseAndSetIfChanged(ref _metricsTotal, value);
    }

    private string _metricsBlocked = "0";
    public string MetricsBlocked
    {
        get => _metricsBlocked;
        set => this.RaiseAndSetIfChanged(ref _metricsBlocked, value);
    }

    public ObservableCollection<string> TopBlocked { get; } = new();
    public ObservableCollection<string> TopAllowed { get; } = new();

    private string _xdpStatus = "Off";
    public string XdpStatus
    {
        get => _xdpStatus;
        set => this.RaiseAndSetIfChanged(ref _xdpStatus, value);
    }

    private string _xdpDropCount = "0";
    public string XdpDropCount
    {
        get => _xdpDropCount;
        set => this.RaiseAndSetIfChanged(ref _xdpDropCount, value);
    }

    // Phase 11 — Latency Monitor
    private int _upstreamLatencyMs = -1;
    public int UpstreamLatencyMs
    {
        get => _upstreamLatencyMs;
        set => this.RaiseAndSetIfChanged(ref _upstreamLatencyMs, value);
    }

    private string _upstreamLatencyDisplay = "—";
    public string UpstreamLatencyDisplay
    {
        get => _upstreamLatencyDisplay;
        set => this.RaiseAndSetIfChanged(ref _upstreamLatencyDisplay, value);
    }

    // Phase 11 — Router Mode status chip
    private string _routerModeStatus = "Off";
    public string RouterModeStatus
    {
        get => _routerModeStatus;
        set => this.RaiseAndSetIfChanged(ref _routerModeStatus, value);
    }

    // Phase 17 — Streaming Ads Blocked counter
    private string _streamingAdsBlockedToday = "0";
    public string StreamingAdsBlockedToday
    {
        get => _streamingAdsBlockedToday;
        set => this.RaiseAndSetIfChanged(ref _streamingAdsBlockedToday, value);
    }

    // Phase 18 — HTTPS Proxy statistics
    private string _proxyStatus = "Off";
    public string ProxyStatus
    {
        get => _proxyStatus;
        set => this.RaiseAndSetIfChanged(ref _proxyStatus, value);
    }

    private string _proxyAdsBlocked = "0";
    public string ProxyAdsBlocked
    {
        get => _proxyAdsBlocked;
        set => this.RaiseAndSetIfChanged(ref _proxyAdsBlocked, value);
    }

    private int _proxyActiveConnections = 0;
    public int ProxyActiveConnections
    {
        get => _proxyActiveConnections;
        set => this.RaiseAndSetIfChanged(ref _proxyActiveConnections, value);
    }

    public DashboardViewModel(MainViewModel mainVm)
    {
        _mainVm = mainVm;

        // Sync read-only dashboard metadata every 3 seconds
        Observable
            .Interval(TimeSpan.FromSeconds(3))
            .ObserveOn(RxApp.MainThreadScheduler)
            .Subscribe(_ => RefreshDashboardMeta());

        RefreshDashboardMeta(); // Initial sync
    }

    private string _sparklinePoints = "0,30 100,30";
    public string SparklinePoints
    {
        get => _sparklinePoints;
        set => this.RaiseAndSetIfChanged(ref _sparklinePoints, value);
    }

    private string _cacheHitRate = "0.0%";
    public string CacheHitRate
    {
        get => _cacheHitRate;
        set => this.RaiseAndSetIfChanged(ref _cacheHitRate, value);
    }

    private void RefreshDashboardMeta()
    {
        var urls = BlocklistManager.GetActiveBlocklistUrls();
        ActiveBlocklistUrl = urls.Count > 1 ? $"{urls[0]} (+{urls.Count - 1} more)" : (urls.Count > 0 ? urls[0] : "None");

        var tier = LicenseManager.CurrentTier;
        LicenseTier = tier switch
        {
            LicenseManager.LicenseTier.Developer => "Developer (Unlimited)",
            LicenseManager.LicenseTier.Founder => "Founder",
            LicenseManager.LicenseTier.Enterprise => "Enterprise",
            LicenseManager.LicenseTier.AegisPrime => "AegisPrime",
            LicenseManager.LicenseTier.Pro => "Pro",
            LicenseManager.LicenseTier.Basic => "Basic",
            _ => "Community"
        };
        Debug.WriteLine($"[DashboardViewModel] LicenseTier label source=LicenseManager.CurrentTier, tier={tier}, label='{LicenseTier}'.");

        AiProviderLabel = AiConfigManager.Settings.EnableAiSentinel
            ? AiConfigManager.Settings.AiProvider
            : "Off";

        AiLearnedBlocklistCount = $"{AiLearnedBlocklist.Count} AI-learned blocks";

        if (AiWatchdog.LastDetectionTime.HasValue)
        {
            var span = DateTime.UtcNow - AiWatchdog.LastDetectionTime.Value;
            string timeStr = span.TotalMinutes < 1 ? "just now" : $"{(int)span.TotalMinutes} mins ago";
            LastAiDetection = $"🤖 {AiWatchdog.LastDetectionDomain} — {timeStr}";
        }
        else
        {
            LastAiDetection = "No recent detections";
        }

        AiConfidenceSummary = $"{AiWatchdog.HighThreatCount} High, {AiWatchdog.CriticalThreatCount} Critical this session";

        MetricsTotal = _mainVm.CurrentMetrics.Total.ToString("N0");
        MetricsBlocked = _mainVm.CurrentMetrics.Blocked.ToString("N0");

        double total = _mainVm.CurrentMetrics.Total;
        if (total > 0)
        {
            double ratio = ((double)_mainVm.CurrentMetrics.Blocked / total) * 100.0;
            BlockedRatio = $"{ratio:F1}%";

            double cacheRatio = ((double)_mainVm.CurrentMetrics.CacheHits / total) * 100.0;
            CacheHitRate = $"{cacheRatio:F1}%";
        }
        else
        {
            BlockedRatio = "0.0%";
            CacheHitRate = "0.0%";
        }

        // Generate Sparkline Data
        var history = _mainVm.CurrentHistory;
        if (history != null && history.Count > 1)
        {
            const double width = 100.0;
            const double height = 30.0;

            var points = new System.Text.StringBuilder();
            var deltas = new System.Collections.Generic.List<long>();

            for (int i = 1; i < history.Count; i++)
            {
                long delta = history[i].TotalQueries - history[i - 1].TotalQueries;
                if (delta < 0) delta = 0; // Prevent negatives if service restarted
                deltas.Add(delta);
            }

            if (deltas.Count > 0)
            {
                long maxDelta = 1;
                foreach (var d in deltas) if (d > maxDelta) maxDelta = d;

                double stepX = deltas.Count > 1 ? width / (deltas.Count - 1) : width;

                for (int i = 0; i < deltas.Count; i++)
                {
                    double x = i * stepX;
                    double y = height - ((double)deltas[i] / maxDelta * height);
                    points.Append(System.Globalization.CultureInfo.InvariantCulture, $"{x:F1},{y:F1} ");
                }
                SparklinePoints = points.ToString().Trim();
            }
        }
        else
        {
            SparklinePoints = "0,30 100,30"; // Flat line fallback
        }

        // Update Top Domains
        var topBlockedList = TopDomainsTracker.GetTopBlocked(5);
        TopBlocked.Clear();
        foreach (var item in topBlockedList)
            TopBlocked.Add($"{item.Domain} ({item.Count})");

        var topAllowedList = TopDomainsTracker.GetTopAllowed(5);
        TopAllowed.Clear();
        foreach (var item in topAllowedList)
            TopAllowed.Add($"{item.Domain} ({item.Count})");

        // XDP Status
        int xdpMode = XdpConfigManager.Settings.XdpMode;
        XdpStatus = xdpMode switch
        {
            1 => "Monitor",
            2 => "Active",
            _ => "Off"
        };
        XdpDropCount = MetricsManager.Current.XdpDroppedPackets.ToString("N0");

        // Phase 11 — Upstream Latency
        int latencyMs = MetricsManager.Current.UpstreamLatencyMs;
        UpstreamLatencyMs = latencyMs;
        UpstreamLatencyDisplay = latencyMs < 0 ? "—" : $"{latencyMs} ms";

        // Phase 11 — Router Mode Status
        RouterModeStatus = RouterConfigManager.Settings.EnableRouterMode ? "Active" : "Off";

        // Phase 17 — Streaming Ads Blocked
        StreamingAdsBlockedToday = MetricsManager.Current.StreamingAdsBlocked.ToString("N0");

        // Phase 18 — HTTPS Proxy Meta
        ProxyStatus = HttpsProxyConfigManager.Settings.EnableHttpsProxy ? "Active" : "Off";
        ProxyAdsBlocked = MetricsManager.Current.ProxyAdsBlocked.ToString("N0");
        // ProxyActiveConnections is currently only known by the service, 
        // we'd need IPC to get the live count if we want it perfect, 
        // but for now we'll just show the blocked count.
    }
}
