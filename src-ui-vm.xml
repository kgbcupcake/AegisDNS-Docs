using System;
using System.Collections.Generic;
using System.Collections.ObjectModel;
using System.Reactive;
using System.Reactive.Linq;
using System.Runtime.Versioning;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.Core.Monitoring;
using AegisDNS.Core.Utilities;
using AegisDNS.UI;

using Avalonia.Media;
using Avalonia.Threading;

using ReactiveUI;

namespace AegisDNS.ViewModels;

// UI ViewModel: logger injection deferred — Avalonia ViewModels are not DI-constructed; Debug.WriteLine retained.
[SupportedOSPlatform("linux")]
public class MainViewModel : ViewModelBase
{
    // --- Log Properties ---
    public ObservableCollection<LogEntry> Logs { get; } = new();

    // --- Dashboard Properties ---
    private string _statusText = "OFFLINE";
    private IBrush _statusBrush = Brushes.DimGray;
    private string _blockedCountText = "0";
    private string _lastRequestText = "Waiting for traffic...";
    private IBrush _lastRequestBrush = Brushes.Gray;
    private double _pulseBlur = 10;
    private double _pulseTimer = 0;

    // --- Protection Properties ---
    private string _toggleBtnText = "ACTIVATE PROTECTION";
    private IBrush _toggleBtnBrush = Brushes.DarkSlateGray;
    private bool _isBusy = false;
    private bool _isServiceOnline = false;

    public class MetricsPayload { public long Total { get; set; } public long Blocked { get; set; } public long CacheHits { get; set; } }

    private MetricsPayload _currentMetrics = new();
    public MetricsPayload CurrentMetrics
    {
        get => _currentMetrics;
        private set => this.RaiseAndSetIfChanged(ref _currentMetrics, value);
    }

    private List<MetricsSnapshot> _currentHistory = new();
    public List<MetricsSnapshot> CurrentHistory
    {
        get => _currentHistory;
        private set => this.RaiseAndSetIfChanged(ref _currentHistory, value);
    }

    private readonly CancellationTokenSource _cts = new();

    public MainViewModel()
    {
        // --- Navigation ---
        NavigateToDashboard = ReactiveCommand.Create(() => { });
        NavigateToProtection = ReactiveCommand.Create(() => { });
        NavigateToSettings = ReactiveCommand.Create(() => { });
        ShowLog = ReactiveCommand.Create(() => { });

        // --- Tray Commands ---
        ToggleWindow = ReactiveCommand.Create(() =>
        {
            WindowToggleRequested?.Invoke(this, EventArgs.Empty);
        });

        ExitApp = ReactiveCommand.Create(() =>
        {
            AppExitRequested?.Invoke(this, EventArgs.Empty);
        });

        // --- Protection Commands ---
        ToggleProtection = ReactiveCommand.CreateFromTask(async () =>
        {
            IsBusy = true;
            var result = await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("Toggle"));

            await Task.Delay(500);
            await UpdateState();
            if (IsServiceOnline) AegisDNS.UI.Audio.AudioFeedbackManager.PlayActionSuccess();
            IsBusy = false;
        });

        StartService = ReactiveCommand.CreateFromTask(async () =>
        {
            IsBusy = true;
            OnLogReceived("🚀 Attempting to start AegisDNS Service...");
            if (await ServiceLauncher.StartServiceAsync())
            {
                await Task.Delay(3000); // Wait for boot
                await UpdateState();
                if (IsServiceOnline) AegisDNS.UI.Audio.AudioFeedbackManager.PlayActionSuccess();
            }
            else
            {
                OnLogReceived("❌ Failure: Could not start the Aegis Service.");
            }
            IsBusy = false;
        });

        ForceStop = ReactiveCommand.CreateFromTask(async () =>
        {
            await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("Toggle"));
            await UpdateState();
        });


        // Start the broadcast listener with retry
        Task.Run(() => ConnectWithRetryAsync(_cts.Token));

        // Timer-based updates for status and counters
        Observable.Interval(TimeSpan.FromMilliseconds(2000))
            .ObserveOn(RxApp.MainThreadScheduler)
            .Subscribe(async _ => await UpdateState());

        ConfigManager.SettingsChanged += () =>
        {
            // Force UI update on main thread
            Dispatcher.UIThread.InvokeAsync(RefreshSettings);
        };
    }

    private async Task ConnectWithRetryAsync(CancellationToken token)
    {
        const int maxRetries = 10;
        const int delayMs = 2000;

        for (int attempt = 1; attempt <= maxRetries; attempt++)
        {
            if (token.IsCancellationRequested) return;

            try
            {
                OnLogReceived($"📡 IPC connection attempt {attempt}/{maxRetries}...");
                await IpcSystem.StartBroadcastClientAsync(OnLogReceived, token);

                // If we get here, the client exited cleanly or the Socket closed — reconnect
                OnLogReceived("⚠️ IPC broadcast disconnected. Reconnecting...");
                attempt = 0; // Reset retry counter safely loop indefinitely while app runs
                await Task.Delay(delayMs, token);
            }
            catch (OperationCanceledException)
            {
                return;
            }
            catch (Exception ex)
            {
                OnLogReceived($"⚠️ IPC attempt {attempt} failed: {ex.Message}");
                if (attempt < maxRetries)
                {
                    await Task.Delay(delayMs, token);
                }
            }
        }

        OnLogReceived("❌ IPC connection failed after 10 retries. Service process may be dead.");
        // UI thread dispatcher (fire and forget)
        _ = Dispatcher.UIThread.InvokeAsync(() =>
        {
            IsServiceOnline = false;
            StatusText = "SERVICE DISCONNECTED";
            StatusBrush = Brushes.DarkRed;
        });
    }

    private void OnLogReceived(string message)
    {
        if (message == "TRIAL_EXPIRED")
        {
            Dispatcher.UIThread.InvokeAsync(() =>
            {
                var licenseWindow = new LicenseWindow();
                licenseWindow.Show();
            });
            return;
        }

        // Ensure the collection is updated on the UI thread
        Dispatcher.UIThread.InvokeAsync(() =>
        {
            var entry = LogEntry.Parse(message);
            Logs.Add(entry);
            if (Logs.Count > 500) // Keep the log buffer from growing infinitely
            {
                Logs.RemoveAt(0);
            }

            // Also update the dashboard's last request preview
            if (ConfigManager.Settings.ShowTrafficPreview)
            {
                if (message.StartsWith("🔎") || message.StartsWith("🚫"))
                {
                    string displayMsg = message.Length > 45 ? message.Substring(0, 42) + "..." : message;
                    var brush = message.StartsWith("🚫") ? Brushes.Red : Brushes.Gray;
                    LastRequestText = displayMsg;
                    LastRequestBrush = brush;
                }
            }

            if (message.Contains("sentinel", StringComparison.OrdinalIgnoreCase) && message.Contains("🚫"))
            {
                AiThreatDetected?.Invoke(this, message);
            }
        });
    }

    private async Task UpdateState()
    {
        // 1. Try IPC for Service Status
        var statusPacket = await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("GetStatus"));
        System.Diagnostics.Debug.WriteLine($"[MainViewModel.UpdateState] IPC GetStatus response: null={statusPacket == null}, command='{statusPacket?.Command ?? "<null>"}', payload='{statusPacket?.Payload ?? "<null>"}'");
        IsServiceOnline = statusPacket != null;
        bool isEngineRunning = statusPacket?.Payload == "ONLINE";

        // 2. Sync metrics if service is online
        if (isEngineRunning)
        {
            var metricsPacket = await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("GetMetrics"));
            if (!string.IsNullOrEmpty(metricsPacket?.Payload))
            {
                try
                {
                    CurrentMetrics = JsonSerializer.Deserialize<MetricsPayload>(metricsPacket.Payload) ?? new();
                    BlockedCountText = CurrentMetrics.Blocked.ToString("N0");
                }
                catch (JsonException ex)
                {
                    System.Diagnostics.Debug.WriteLine($"⚠️ JSON invalid: {ex.Message}");
                    CurrentMetrics = new();
                    BlockedCountText = CurrentMetrics.Blocked.ToString("N0");
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"⚠️ Load failed: {ex.Message}");
                    CurrentMetrics = new();
                    BlockedCountText = CurrentMetrics.Blocked.ToString("N0");
                }
            }

            var historyPacket = await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("GetHistory"));
            if (!string.IsNullOrEmpty(historyPacket?.Payload))
            {
                try
                {
                    CurrentHistory = JsonSerializer.Deserialize<List<MetricsSnapshot>>(historyPacket.Payload) ?? new();
                }
                catch (JsonException ex)
                {
                    System.Diagnostics.Debug.WriteLine($"⚠️ JSON invalid: {ex.Message}");
                    CurrentHistory = new();
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"⚠️ Load failed: {ex.Message}");
                    CurrentHistory = new();
                }
            }
        }

        StatusText = isEngineRunning ? "ONLINE 🛡️" : (IsServiceOnline ? "OFFLINE" : "SERVICE DISCONNECTED");
        StatusBrush = isEngineRunning ? Brushes.LimeGreen : Brushes.DimGray;

        ToggleBtnText = isEngineRunning ? "DEACTIVATE PROTECTION" : "ACTIVATE PROTECTION";
        ToggleBtnBrush = isEngineRunning ? Brushes.DarkRed : Brushes.DarkSlateGray;

        if (isEngineRunning && ConfigManager.Settings.EnableNeonGlow)
        {
            _pulseTimer += 0.1;
            PulseBlur = 8 + (Math.Sin(_pulseTimer) * 4);
        }
        else
        {
            PulseBlur = 0;
        }
    }

    // --- Bindable Properties for Dashboard ---
    public string StatusText { get => _statusText; set => this.RaiseAndSetIfChanged(ref _statusText, value); }
    public IBrush StatusBrush { get => _statusBrush; set => this.RaiseAndSetIfChanged(ref _statusBrush, value); }
    public string BlockedCountText { get => _blockedCountText; set => this.RaiseAndSetIfChanged(ref _blockedCountText, value); }
    public string LastRequestText { get => _lastRequestText; set => this.RaiseAndSetIfChanged(ref _lastRequestText, value); }
    public IBrush LastRequestBrush { get => _lastRequestBrush; set => this.RaiseAndSetIfChanged(ref _lastRequestBrush, value); }
    public double PulseBlur { get => _pulseBlur; set => this.RaiseAndSetIfChanged(ref _pulseBlur, value); }

    // --- Bindable Properties for Protection ---
    public string ToggleBtnText { get => _toggleBtnText; set => this.RaiseAndSetIfChanged(ref _toggleBtnText, value); }
    public IBrush ToggleBtnBrush { get => _toggleBtnBrush; set => this.RaiseAndSetIfChanged(ref _toggleBtnBrush, value); }
    public bool IsBusy { get => _isBusy; set => this.RaiseAndSetIfChanged(ref _isBusy, value); }
    public bool IsServiceOnline { get => _isServiceOnline; set => this.RaiseAndSetIfChanged(ref _isServiceOnline, value); }

    public ReactiveCommand<Unit, Unit> ToggleProtection { get; }
    public ReactiveCommand<Unit, Unit> StartService { get; }
    public ReactiveCommand<Unit, Unit> ForceStop { get; }


    // --- Navigation ---
    public ReactiveCommand<Unit, Unit> NavigateToDashboard { get; }
    public ReactiveCommand<Unit, Unit> NavigateToProtection { get; }
    public ReactiveCommand<Unit, Unit> NavigateToSettings { get; }
    public ReactiveCommand<Unit, Unit> ShowLog { get; }

    // --- Tray Commands ---
    public ReactiveCommand<Unit, Unit> ToggleWindow { get; }
    public ReactiveCommand<Unit, Unit> ExitApp { get; }

    public event EventHandler? WindowToggleRequested;
    public event EventHandler? AppExitRequested;
    public event EventHandler<string>? AiThreatDetected;

    public bool IsStealthMode
    {
        get => ConfigManager.Settings.StealthMode;
        set { /* Read-only reflection of config, but setter needed for binding if two-way */ }
    }

    public void RefreshSettings()
    {
        this.RaisePropertyChanged(nameof(IsStealthMode));
    }

    // Call this when the application is closing to stop the listener
    public void Stop()
    {
        _cts.Cancel();
    }
}
