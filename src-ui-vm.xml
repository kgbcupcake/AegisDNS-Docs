using System;
using System.Reactive;
using System.Runtime.Versioning;
using System.Threading.Tasks;

using AegisDNS.Core;

using ReactiveUI;

namespace AegisDNS.ViewModels;

[SupportedOSPlatform("linux")]
public class XdpSettingsViewModel : ViewModelBase
{
    private string _resolvedInterface = "detecting...";
    private string _kernelModeLabel = "NOT LOADED";
    private long _dropCount;

    public XdpSettingsViewModel()
    {
        SaveSettings = ReactiveCommand.CreateFromTask(async () =>
        {
            await Task.Run(() => XdpConfigManager.Save());
            return Unit.Default;
        });

        DetachXdp = ReactiveCommand.CreateFromTask(async () =>
        {
            var result = await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("XDP_DETACH"));
            if (result != null)
                KernelModeLabel = "NOT LOADED";
        });

        ReconfigureXdp = ReactiveCommand.CreateFromTask(async () =>
        {
            var result = await IpcSystem.SendCommandAsync(new IpcSystem.IpcPacket("XDP_RECONFIGURE"));
            if (result != null)
                KernelModeLabel = "RECONFIGURING...";
        });

        // Resolve interface display on load
        Task.Run(() =>
        {
            string iface = XdpConfigManager.Settings.XdpInterface;
            if (string.Equals(iface, "auto", StringComparison.OrdinalIgnoreCase))
            {
                try
                {
                    string[] lines = System.IO.File.ReadAllLines("/proc/net/route");
                    for (int i = 1; i < lines.Length; i++)
                    {
                        string[] fields = lines[i].Split('\t', StringSplitOptions.RemoveEmptyEntries);
                        if (fields.Length >= 2 && fields[1] == "00000000")
                        {
                            ResolvedInterface = $"{fields[0]} (auto-detected)";
                            return;
                        }
                    }
                }
                catch { /* Linux only — expected to fail on Windows */ }
                ResolvedInterface = "eth0 (auto-detected)";
            }
            else
            {
                ResolvedInterface = iface;
            }
        });
    }

    // ── Commands ─────────────────────────────────────────────────────────────
    public ReactiveCommand<Unit, Unit> SaveSettings { get; }
    public ReactiveCommand<Unit, Unit> DetachXdp { get; }
    public ReactiveCommand<Unit, Unit> ReconfigureXdp { get; }

    // ── XDP Mode ────────────────────────────────────────────────────────────
    public int XdpMode
    {
        get => XdpConfigManager.Settings.XdpMode;
        set { XdpConfigManager.Settings.XdpMode = value; this.RaisePropertyChanged(); }
    }

    public bool IsOff
    {
        get => XdpMode == 0;
        set { if (value) XdpMode = 0; this.RaisePropertyChanged(); this.RaisePropertyChanged(nameof(IsMonitor)); this.RaisePropertyChanged(nameof(IsBlock)); }
    }

    public bool IsMonitor
    {
        get => XdpMode == 1;
        set { if (value) XdpMode = 1; this.RaisePropertyChanged(); this.RaisePropertyChanged(nameof(IsOff)); this.RaisePropertyChanged(nameof(IsBlock)); }
    }

    public bool IsBlock
    {
        get => XdpMode == 2;
        set { if (value) XdpMode = 2; this.RaisePropertyChanged(); this.RaisePropertyChanged(nameof(IsOff)); this.RaisePropertyChanged(nameof(IsMonitor)); }
    }

    // ── Interface ───────────────────────────────────────────────────────────
    public string XdpInterface
    {
        get => XdpConfigManager.Settings.XdpInterface;
        set { XdpConfigManager.Settings.XdpInterface = value; this.RaisePropertyChanged(); }
    }

    public string ResolvedInterface
    {
        get => _resolvedInterface;
        set => this.RaiseAndSetIfChanged(ref _resolvedInterface, value);
    }

    // ── Protection Rules ────────────────────────────────────────────────────
    public bool XdpRfc1918Protection
    {
        get => XdpConfigManager.Settings.XdpRfc1918Protection;
        set { XdpConfigManager.Settings.XdpRfc1918Protection = value; this.RaisePropertyChanged(); }
    }

    public bool XdpAlertOnDrop
    {
        get => XdpConfigManager.Settings.XdpAlertOnDrop;
        set { XdpConfigManager.Settings.XdpAlertOnDrop = value; this.RaisePropertyChanged(); }
    }

    // ── Live Stats ──────────────────────────────────────────────────────────
    public string KernelModeLabel
    {
        get => _kernelModeLabel;
        set => this.RaiseAndSetIfChanged(ref _kernelModeLabel, value);
    }

    public long DropCount
    {
        get => _dropCount;
        set => this.RaiseAndSetIfChanged(ref _dropCount, value);
    }

    public void RefreshMetrics()
    {
        DropCount = MetricsManager.Current.XdpDroppedPackets;
    }
}
