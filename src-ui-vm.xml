    }

    public int AiCheckIntervalMinutes
    {
        get => AiConfigManager.Settings.AiCheckIntervalMinutes;
        set
        {
            // Validate: Min 5 minutes, Max 1 day (1440)
            if (value < 5) value = 5;
            if (value > 1440) value = 1440;
            AiConfigManager.Settings.AiCheckIntervalMinutes = value;
            this.RaisePropertyChanged();
        }
    }

    public ReactiveCommand<Unit, Unit> SaveSettings { get; }
