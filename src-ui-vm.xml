using System.Collections.Generic;
using System.Collections.ObjectModel;
using System.IO;
using System.Reactive;

using AegisDNS.Core.ProcessTracking;

using ReactiveUI;

namespace AegisDNS.ViewModels;

public class ProcessRulesViewModel : ReactiveObject
{
    private readonly ProcessRuleEngine _engine = new();

    public ObservableCollection<ProcessDnsRule> Rules { get; } = [];

    public ReactiveCommand<Unit, Unit> AddRule { get; }
    public ReactiveCommand<ProcessDnsRule, Unit> RemoveRule { get; }
    public ReactiveCommand<Unit, Unit> Save { get; }

    // New rule fields
    private string _newProcessName = "";
    public string NewProcessName
    {
        get => _newProcessName;
        set => this.RaiseAndSetIfChanged(ref _newProcessName, value);
    }

    // Running processes (loaded on open) for the process picker
    public ObservableCollection<string> RunningProcesses { get; } = [];

    public ProcessRulesViewModel()
    {
        // Load existing rules
        foreach (var rule in _engine.GetAll())
            Rules.Add(rule);

        AddRule = ReactiveCommand.Create(ExecuteAddRule);
        RemoveRule = ReactiveCommand.Create<ProcessDnsRule>(ExecuteRemoveRule);
        Save = ReactiveCommand.Create(ExecuteSave);

        RefreshRunningProcesses();
    }

    private void ExecuteAddRule()
    {
        if (string.IsNullOrWhiteSpace(NewProcessName)) return;
        Rules.Add(new ProcessDnsRule { ProcessName = NewProcessName.Trim() });
        NewProcessName = "";
    }

    private void ExecuteRemoveRule(ProcessDnsRule rule)
    {
        Rules.Remove(rule);
    }

    private void ExecuteSave()
    {
        _engine.Save(Rules);
    }

    /// <summary>Enumerates /proc to list currently running process names.</summary>
    public void RefreshRunningProcesses()
    {
        RunningProcesses.Clear();
        try
        {
            var seen = new HashSet<string>();
            foreach (var pidDir in Directory.EnumerateDirectories("/proc"))
            {
                if (!int.TryParse(Path.GetFileName(pidDir), out _)) continue;
                string commPath = Path.Combine(pidDir, "comm");
                if (!File.Exists(commPath)) continue;
                string name = File.ReadAllText(commPath).Trim();
                if (!string.IsNullOrWhiteSpace(name) && seen.Add(name))
                    RunningProcesses.Add(name);
            }
        }
        catch { }
    }
}
