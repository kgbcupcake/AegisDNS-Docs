using AegisDNS.Core;
using AegisDNS.Core.Ai;
using AegisDNS.Core.Monitoring;

using Microsoft.Extensions.Hosting;
using Microsoft.Extensions.Logging;

namespace AegisDNS.Service.Src;

public class AiSentinelWorker : BackgroundService
{
    private readonly AegisEngine _engine;
    private readonly ILogger<AiSentinelWorker> _logger;
    private readonly IAiProviderFactory _aiFactory;

    public AiSentinelWorker(AegisEngine engine, ILogger<AiSentinelWorker> logger)
    {
        _engine = engine;
        _logger = logger;
        _aiFactory = new AiProviderFactory();
    }

    protected override async Task ExecuteAsync(CancellationToken stoppingToken)
    {
        // Wait for engine startup before first scan
        await Task.Delay(TimeSpan.FromSeconds(10), stoppingToken);

        while (!stoppingToken.IsCancellationRequested)
        {
            try
            {
                if (AiConfigManager.Settings.EnableAiSentinel && _engine.IsRunning)
                {
                    var history = _engine.GetHistory();

                    if (history.Count > 0)
                    {
                        var provider = _aiFactory.GetProviderWithFallback(AiConfigManager.Settings);
                        if (provider != null)
                        {
                            var result = await provider.AnalyzeAsync(history, AiConfigManager.Settings);

                            if (result != null)
                            {
                                if (result.Contains("THREAT", StringComparison.OrdinalIgnoreCase))
                                {
                                    await IpcSystem.BroadcastLogAsync($"🧠 AI SENTINEL: {result}");
                                }
                                else
                                {
                                    _logger.LogDebug("[AiSentinel] Scan clean: {Result}", result);
                                }
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "[AiSentinel] Error.");
                // Don't broadcast errors to UI — AI is optional, failures shouldn't alarm the user
            }

            await Task.Delay(TimeSpan.FromMinutes(AiConfigManager.Settings.AiCheckIntervalMinutes), stoppingToken);
        }
    }
}
