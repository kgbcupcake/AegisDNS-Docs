/* SPDX-License-Identifier: GPL-2.0 */
/*
 * aegisdns.bpf.h — Shared data structures for the AegisDNS eBPF kernel program.
 *
 * These structs are shared between the kernel-space eBPF program (C) and the
 * userspace loader (C# via P/Invoke). All structs MUST use fixed-width types
 * and #pragma pack(1) to ensure byte-for-byte layout compatibility.
 *
 * Copyright (c) 2026 AegisDNS. All rights reserved.
 */

#pragma once

#ifdef __VMLINUX_H__
/* BPF kernel context: vmlinux.h already provides all type definitions.
 * Do not re-include linux/types.h (causes redefinition errors) and do not
 * apply pack(1) (causes unaligned field access in kernel structs). */
#else
/* Userspace context: include types and apply pack(1) for C#/.NET interop. */
#pragma pack(push, 1)
#include <linux/types.h>
#endif

/* ── Constants ─────────────────────────────────────────────────────────────── */

/* Maximum domain name length we'll inspect (capped at 64 for verifier safety) */
#define AEGIS_MAX_DOMAIN_LEN 64

/* Actions the kernel program can take on a DNS packet */
#define AEGIS_ACTION_PASS    0   /* Allow the query through                  */
#define AEGIS_ACTION_BLOCK   1   /* Drop the packet                          */
#define AEGIS_ACTION_MONITOR 2   /* Pass but flag for AI analysis             */

/* ── Ring Buffer Event ─────────────────────────────────────────────────────── */

/*
 * Event sent from kernel to userspace via ring buffer every time a DNS query
 * is intercepted. Userspace reads these to feed into the AegisDNS engine.
 */
struct aegis_dns_event {
    __u32 pid;                          /* PID of the process making the query  */
    __u32 uid;                          /* UID of the process                   */
    __u8  action;                       /* AEGIS_ACTION_PASS/BLOCK/MONITOR      */
    __u8  protocol;                     /* 0 = UDP, 1 = TCP                     */
    __u16 query_type;                   /* DNS record type (A=1, AAAA=28, etc.) */
    __u64 timestamp_ns;                 /* ktime_get_ns() at intercept time     */
    char  domain[AEGIS_MAX_DOMAIN_LEN]; /* Queried domain (null-terminated)     */
    char  comm[16];                     /* Process name (task_comm from kernel)  */
};

/* ── Block Decision Hash Map Structures ────────────────────────────────────── */

/*
 * Key for the block decision hash map.
 * Userspace (.NET) writes entries here, kernel reads them.
 */
struct aegis_block_key {
    char domain[AEGIS_MAX_DOMAIN_LEN];
};

/*
 * Value for the block decision hash map.
 */
struct aegis_block_val {
    __u8  action;       /* AEGIS_ACTION_BLOCK or AEGIS_ACTION_MONITOR          */
    __u64 block_time;   /* Timestamp when block was added (for TTL enforcement) */
    __u32 hit_count;    /* How many times this block has been triggered         */
};

#ifndef __VMLINUX_H__
#pragma pack(pop)
#endif
</file>

