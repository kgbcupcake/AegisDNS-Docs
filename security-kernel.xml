// SPDX-License-Identifier: GPL-2.0
/*
 * aegisdns.bpf.c — AegisDNS eBPF kernel program.
 *
 * Intercepts all DNS traffic (UDP port 53) at the cgroup/skb level.
 * Checks a userspace-populated block map and drops blocked queries.
 * Emits events to a ring buffer for userspace processing.
 *
 * This program runs inside the Linux kernel. The BPF verifier enforces
 * memory safety — every pointer dereference must be bounds-checked.
 *
 * Copyright (c) 2026 AegisDNS. All rights reserved.
 */

#include "vmlinux.h"
#include <bpf/bpf_helpers.h>
#include <bpf/bpf_endian.h>
#include <bpf/bpf_tracing.h>
#include "aegisdns.bpf.h"

/* Licence declaration is mandatory for BPF programs that use GPL helpers */
char LICENSE[] SEC("license") = "GPL";

/* ── MAP 1: Ring buffer — kernel writes events, userspace reads them ──────── */
/* Capacity: 4 MB ring buffer (~16,000 events before wrapping)               */
struct {
    __uint(type, BPF_MAP_TYPE_RINGBUF);
    __uint(max_entries, 4 * 1024 * 1024);
} aegis_events SEC(".maps");

/* ── MAP 2: Block decision hash map — userspace writes, kernel reads ──────── */
/* Max 500,000 entries covers all Hagezi blocklist entries                    */
struct {
    __uint(type, BPF_MAP_TYPE_HASH);
    __uint(max_entries, 500000);
    __type(key,   struct aegis_block_key);
    __type(value, struct aegis_block_val);
} aegis_blocks SEC(".maps");

/* ── MAP 3: Per-CPU stats — total intercepted, total blocked ─────────────── */
struct aegis_stats {
    __u64 total_intercepted;
    __u64 total_blocked;
    __u64 total_passed;
};

struct {
    __uint(type, BPF_MAP_TYPE_PERCPU_ARRAY);
    __uint(max_entries, 1);
    __type(key,   __u32);
    __type(value, struct aegis_stats);
} aegis_stats_map SEC(".maps");

/* ── MAP 4: Per-CPU domain scratch buffer — avoids BPF 512-byte stack limit  */
struct aegis_domain_buf {
    char domain[AEGIS_MAX_DOMAIN_LEN];
};

struct {
    __uint(type, BPF_MAP_TYPE_PERCPU_ARRAY);
    __uint(max_entries, 1);
    __type(key,   __u32);
    __type(value, struct aegis_domain_buf);
} aegis_domain_scratch SEC(".maps");

/* ── MAP 5: Per-CPU block-key scratch buffer — avoids BPF stack limit ──────  */
struct {
    __uint(type, BPF_MAP_TYPE_PERCPU_ARRAY);
    __uint(max_entries, 1);
    __type(key,   __u32);
    __type(value, struct aegis_block_key);
} aegis_key_scratch SEC(".maps");

/* ── CONTEXT: Passed to copy_callback via bpf_loop ──────────────────────── */
/*                                                                            */
/* Lives on copy_label's stack frame.  bpf_loop passes a PTR_TO_MEM to the  */
/* callback — all fields are readable and writable by the callback.          */
struct copy_ctx {
    __u8  bytes[64]; /* label bytes pre-loaded from the packet         */
    __u32 len;       /* number of valid bytes in bytes[] (≤ 63)        */
    __u32 pos;       /* write cursor into aegis_domain_scratch->domain */
};

/* ── CALLBACK: Per-byte logic — verifier sees this body exactly once ─────── */
/*                                                                            */
/* bpf_loop() is a BPF helper (kernel ≥ 5.17).  The verifier treats the     */
/* entire loop as a single BPF_CALL instruction and never iterates over this */
/* body, making state explosion impossible by design.                        */
/*                                                                            */
/* skb is NOT in the context because storing PTR_TO_CTX through a void *ctx */
/* loses the type — the verifier would see a scalar, not PTR_TO_CTX, inside */
/* the callback.  Instead, copy_label pre-loads the label bytes into         */
/* ctx->bytes[] before the bpf_loop call.  The callback works entirely from  */
/* plain ctx memory and a global map lookup; no skb pointer is needed.       */
/*                                                                            */
/* Returns 0 (continue) or 1 (stop).                                        */
static int
copy_callback(__u32 index, void *_ctx)
{
    struct copy_ctx *ctx = _ctx;

    if (index >= ctx->len)
        return 1; /* past this label's bytes — stop */

    __u32 zero = 0;
    struct aegis_domain_buf *out = bpf_map_lookup_elem(&aegis_domain_scratch, &zero);
    if (!out)
        return 1;

    /* index & 63 proves the array access is in-bounds to the verifier
     * (index ≤ 62 from bpf_loop, so & 63 is a no-op at runtime). */
    __u8 c = ctx->bytes[index & 63];
    if (c >= 'A' && c <= 'Z') c |= 32;
    /* Load pos into a local __u32 before using it as a map-value offset.
     * Without this, LLVM emits a sign-extend (s>>=32) on the 32-bit struct
     * field load, which the verifier rejects as a potentially negative offset. */
    __u32 p = ctx->pos;
    if (p < AEGIS_MAX_DOMAIN_LEN - 1) {
        out->domain[p] = c;
        ctx->pos = p + 1;
    }

    return 0; /* continue */
}

/* ── SUBPROGRAM: Copy one DNS label into the output buffer ───────────────── */
/*                                                                            */
/* Pre-loads the label's bytes from the packet (skb is PTR_TO_CTX here),    */
/* then delegates per-byte processing to copy_callback via bpf_loop().       */
/* The verifier sees the loop as one helper call — no back-edges, no state   */
/* explosion regardless of label length.                                     */
/*                                                                            */
/* Output is written directly to aegis_domain_scratch by the callback;       */
/* the out parameter is therefore not needed and is absent.                  */
/*                                                                            */
/* BPF subprograms accept at most 5 arguments — 3 used here: skb, off, pos. */
/*                                                                            */
/* Returns the updated write position.                                        */
static __attribute__((noinline)) __u32
copy_label(struct __sk_buff *skb, __u32 off, __u32 pos)
{
    __u8 label_len = 0;

    if (off == 0) return pos;
    if (bpf_skb_load_bytes(skb, off - 1, &label_len, 1) < 0) return pos;
    if (label_len == 0 || label_len > 63) return pos;

    struct copy_ctx ctx = {};
    ctx.len = (__u32)label_len;
    ctx.pos = pos;

    /* Pre-load all label bytes in one call while skb is still PTR_TO_CTX.
     * label_len ≤ 63 < 64 = sizeof(ctx.bytes), so the write is in-bounds. */
    if (bpf_skb_load_bytes(skb, off, ctx.bytes, label_len) < 0) return pos;

    bpf_loop(63, copy_callback, &ctx, 0);

    return ctx.pos;
}

/* ── SUBPROGRAM: Extract domain name from raw DNS wire format ────────────── */
/*                                                                            */
/* DNS wire format uses length-prefixed labels: \x06google\x03com\x00         */
/* This converts it to dotted notation: google.com                           */
/*                                                                            */
/* Label bytes are written to aegis_domain_scratch by copy_callback() via    */
/* bpf_loop() inside copy_label().  This subprogram handles only label       */
/* iteration, dot insertion into out[], and off advancement.                 */
/* The verifier sees each copy_label call as a single BPF_CALL instruction.  */
/*                                                                            */
/* Returns the number of characters written to `out`, or 0 on empty/error.   */
static __attribute__((noinline)) __u32
extract_domain(struct __sk_buff *skb, __u32 dns_payload_offset,
               char *out, __u32 out_len)
{
    __u32 off = dns_payload_offset + 12;
    __u32 pos = 0;
    __u32 i;

    for (i = 0; i < 32; i++) {
        __u32 label_len = 0;
        if (off > 0xFFFF) break;
        if (bpf_skb_load_bytes(skb, off, &label_len, 1) < 0) break;
        off++;
        if (label_len == 0) break;
        if ((label_len & 0xC0) == 0xC0) break;
        if (label_len > 63) break;
        if (pos > 0 && pos < out_len - 1) out[pos++] = '.';
        /* Clamp off to ≤ 511 before the call so the verifier enters copy_label
         * with a compact scalar range for the `off` argument.  Without this,
         * the verifier tracks off up to 0xFFFF, producing byte_off ranges too
         * wide to merge at the inner loop back-edge (max_states_per_insn=41). */
        if (off > 511) break;
        pos = copy_label(skb, off, pos);
        if (pos >= AEGIS_MAX_DOMAIN_LEN) pos = AEGIS_MAX_DOMAIN_LEN - 1;
        off += label_len;
        if (off > 0xFFFF) break;
    }
    if (pos < out_len) out[pos] = '\0';
    return pos;
}

/* ── HELPER: Check block map and return action ───────────────────────────── */
static __always_inline __u8
check_block_map(const char *domain)
{
    /* Use per-CPU scratch to avoid placing 256-byte key on the BPF stack */
    __u32 zero = 0;
    struct aegis_block_key *key = bpf_map_lookup_elem(&aegis_key_scratch, &zero);
    if (!key)
        return AEGIS_ACTION_PASS;

    __builtin_memset(key->domain, 0, sizeof(key->domain));

    /* Safe copy — BPF verifier requires bounded copies */
    bpf_probe_read_kernel_str(key->domain, sizeof(key->domain), domain);

    struct aegis_block_val *val = bpf_map_lookup_elem(&aegis_blocks, key);
    if (val) {
        /* Atomically increment hit count */
        __sync_fetch_and_add(&val->hit_count, 1);
        return val->action;
    }

    return AEGIS_ACTION_PASS;
}

/* ── HELPER: Emit event to ring buffer ───────────────────────────────────── */
static __always_inline void
emit_event(const char *domain, __u8 action, __u8 protocol, __u16 qtype)
{
    struct aegis_dns_event *event;

    event = bpf_ringbuf_reserve(&aegis_events, sizeof(*event), 0);
    if (!event)
        return; /* Ring buffer full — drop event, NEVER drop packets */

    event->pid          = bpf_get_current_pid_tgid() >> 32;
    event->uid          = bpf_get_current_uid_gid() & 0xFFFFFFFF;
    event->action       = action;
    event->protocol     = protocol;
    event->query_type   = qtype;
    event->timestamp_ns = bpf_ktime_get_ns();
    bpf_get_current_comm(event->comm, sizeof(event->comm));
    bpf_probe_read_kernel_str(event->domain, sizeof(event->domain), domain);

    bpf_ringbuf_submit(event, 0);
}

/* ── HOOK: cgroup/skb — fires on every socket packet in the cgroup ───────── */
/*                                                                            */
/* This is the main intercept point. Runs for ALL processes in the cgroup.   */
/* Return 1 = allow packet, Return 0 = drop packet.                         */
/*                                                                            */
/* INVARIANT: On any parse error, ALWAYS return 1 (pass). Dropping           */
/* legitimate traffic is worse than letting a threat through.                */
SEC("cgroup_skb/egress")
int aegis_dns_intercept(struct __sk_buff *skb)
{
    void *data     = (void *)(long)skb->data;
    void *data_end = (void *)(long)skb->data_end;

    /* ── Update per-CPU stats ────────────────────────────────────────────── */
    __u32 stats_key = 0;
    struct aegis_stats *stats = bpf_map_lookup_elem(&aegis_stats_map, &stats_key);
    if (stats)
        __sync_fetch_and_add(&stats->total_intercepted, 1);

    /* ── Only process IP packets ─────────────────────────────────────────── */
    /* Check the EtherType / protocol field from the skb                     */
    __u8  protocol      = 0;
    __u32 dns_offset    = 0;
    __u16 dest_port     = 0;

    /* ── Parse IPv4 headers ──────────────────────────────────────────────── */
    struct iphdr *iph = data;
    if ((void *)(iph + 1) > data_end)
        return 1; /* Can't parse — pass through safely */

    /* Only handle IPv4 for now (IPv6 support in Phase 14-B) */
    if (iph->version != 4)
        return 1;

    /* Validate IHL — minimum 5 (20 bytes), maximum 15 (60 bytes) */
    if (iph->ihl < 5 || iph->ihl > 15)
        return 1;

    /* Validate full IP header fits in packet */
    if ((void *)iph + (iph->ihl * 4) > data_end)
        return 1;

    if (iph->protocol == IPPROTO_UDP) {
        /* ── UDP DNS (most common) ───────────────────────────────────────── */
        struct udphdr *udph = (void *)iph + (iph->ihl * 4);
        if ((void *)(udph + 1) > data_end)
            return 1;

        dest_port = bpf_ntohs(udph->dest);
        if (dest_port != 53)
            return 1; /* Not DNS — pass through */

        dns_offset = (void *)udph - data + sizeof(*udph);
        protocol   = 0; /* UDP */

    } else if (iph->protocol == IPPROTO_TCP) {
        /* ── TCP DNS ─────────────────────────────────────────────────────── */
        struct tcphdr *tcph = (void *)iph + (iph->ihl * 4);
        if ((void *)(tcph + 1) > data_end)
            return 1;

        dest_port = bpf_ntohs(tcph->dest);
        if (dest_port != 53)
            return 1; /* Not DNS — pass through */

        /* TCP DNS has a 2-byte length prefix before the DNS message */
        dns_offset = (void *)tcph - data + (tcph->doff * 4) + 2;
        protocol   = 1; /* TCP */

    } else {
        return 1; /* Not UDP or TCP — pass through */
    }

    /* ── Extract domain name from DNS wire format ────────────────────────── */
    /* Use per-CPU scratch buffer to avoid placing 256 bytes on the BPF stack */
    __u32 scratch_zero = 0;
    struct aegis_domain_buf *scratch = bpf_map_lookup_elem(&aegis_domain_scratch, &scratch_zero);
    if (!scratch)
        return 1;

    __builtin_memset(scratch->domain, 0, sizeof(scratch->domain));
    __u32 domain_len = extract_domain(skb, dns_offset,
                                      scratch->domain, sizeof(scratch->domain));
    if (domain_len == 0)
        return 1; /* Couldn't parse — pass through safely */

    /* ── Extract DNS query type (A, AAAA, etc.) ──────────────────────────── */
    /* QType is 2 bytes after the domain name's terminating zero             */
    __u16 qtype = 0;
    {
        __u32 qtype_off = dns_offset + 12 + domain_len + 1;
        if (qtype_off <= 0xFFFF) {
            __u8 qtype_bytes[2] = {0, 0};
            if (bpf_skb_load_bytes(skb, qtype_off, qtype_bytes, 2) == 0)
                qtype = ((__u16)qtype_bytes[0] << 8) | qtype_bytes[1];
        }
    }

    /* ── Check block map ─────────────────────────────────────────────────── */
    __u8 action = check_block_map(scratch->domain);

    /* ── Emit event to ring buffer regardless of action ──────────────────── */
    emit_event(scratch->domain, action, protocol, qtype);

    /* ── Apply the decision ──────────────────────────────────────────────── */
    if (action == AEGIS_ACTION_BLOCK) {
        if (stats)
            __sync_fetch_and_add(&stats->total_blocked, 1);
        return 0; /* DROP the packet — DNS query never reaches upstream */
    }

    if (stats)
        __sync_fetch_and_add(&stats->total_passed, 1);

    return 1; /* PASS — allow the DNS query through */
}
