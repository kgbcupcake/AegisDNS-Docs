// AegisDNS.BpfLoader/AegisBpfLoader.cs

using System;
using System.IO;
using System.Runtime.InteropServices;
using System.Text;
using System.Threading;
using System.Threading.Channels;
using System.Threading.Tasks;

using AegisDNS.Core;

namespace AegisDNS.BpfLoader;

public static class AegisBpfLoader
{
    private const string BpfFsPinPath = "/sys/fs/bpf/aegisdns";
    private const string CgroupPath = "/sys/fs/cgroup/";

    public static bool WasLoaded { get; private set; }

    private static IntPtr _bpfObj = IntPtr.Zero;
    private static int _bpfBlocksMapFd = -1;
    private static int _bpfEventsMapFd = -1;
    private static int _bpfProgFd = -1;
    private static uint _bpfProgId = 0;   // kernel-assigned program ID; used by IsAttached()
    private static IntPtr _ringBuffer = IntPtr.Zero;

    // GC root for the delegate used by native code
    private static RingBufferCallback? _ringBufferCallback;

    private static Channel<AegisDnsEvent>? _eventChannel;
    private static Task? _pollingTask;
    private static Task? _eventConsumerTask;
    private static bool _isStopping = false;

    // libc imports for open/close
    [DllImport("libc", SetLastError = true)]
    private static extern int open(string pathname, int flags);

    [DllImport("libc", SetLastError = true)]
    private static extern int close(int fd);

    private const int O_RDONLY = 0;

    public static async Task<bool> LoadAndAttach(string bpfObjectPath, AegisEngine engine)
    {
        if (!OperatingSystem.IsLinux())
        {
            engine.Broadcast("⚠️ eBPF is only available on Linux.");
            return false;
        }

        try
        {
            // 1. Find the already-loaded program by walking kernel program IDs.
            //    bpf_object__load via P/Invoke returns E2BIG on this program;
            //    the program was loaded externally (bpftool) and is already
            //    verified in the kernel.  We get its fd directly and skip load.
            engine.Broadcast("🔍 Searching kernel BPF programs for aegis_dns_intercept...");
            _bpfProgFd = FindExistingProgFd();
            if (_bpfProgFd < 0)
            {
                engine.Broadcast("❌ aegis_dns_intercept not found in kernel. " +
                                 "Load it first: sudo bpftool prog load " +
                                 $"{bpfObjectPath} /sys/fs/bpf/aegisdns/aegis_dns_intercept");
                return false;
            }
            engine.Broadcast($"✅ Found aegis_dns_intercept in kernel — attaching without reload.");

            // 2. Recover map fds.  Try the BPF pin path first (fast); if the
            //    pins are absent fall back to iterating kernel map IDs by name.
            _bpfBlocksMapFd = LibBpf.ObjGet($"{BpfFsPinPath}/aegis_blocks");
            if (_bpfBlocksMapFd < 0)
                _bpfBlocksMapFd = FindMapFdByName("aegis_blocks");

            _bpfEventsMapFd = LibBpf.ObjGet($"{BpfFsPinPath}/aegis_events");
            if (_bpfEventsMapFd < 0)
                _bpfEventsMapFd = FindMapFdByName("aegis_events");

            if (_bpfBlocksMapFd < 0 || _bpfEventsMapFd < 0)
                engine.Broadcast("⚠️ BPF maps not found — block sync and event streaming unavailable.");

            // 3. Remove any aegis_dns_intercept programs left in the cgroup by
            //    previous crash/restart cycles before attaching our fresh copy.
            //    Without this, stale programs accumulate and DisplacedDetect creates
            //    an infinite TamperMonitor reattach loop.
            DetachAllStaleFromCgroup(engine);

            // 4. Attach the program fd to the root cgroup
            if (!AttachToCgroup(engine)) { Cleanup(); return false; }

            // 5. Sync blocklist into the kernel map (no-op if map fd unavailable)
            if (_bpfBlocksMapFd >= 0)
                await SyncBlocklistToKernel(engine);

            // 6. Start ring buffer polling (skipped if events map fd unavailable)
            if (_bpfEventsMapFd >= 0)
                StartRingBuffer(engine);

            WasLoaded = true;
            return true;
        }
        catch (Exception ex)
        {
            engine.Broadcast($"❌ BPF Loader exception: {ex.Message}");
            Cleanup();
            return false;
        }
    }

    // Walk every BPF program currently loaded in the kernel and return an fd
    // for the first one named "aegis_dns_intercept" (the kernel truncates names
    // to BPF_OBJ_NAME_LEN-1 = 15 chars, so we match the prefix).
    // Returns a valid fd that the caller owns, or -1 if not found.
    private static unsafe int FindExistingProgFd()
    {
        uint nextId = 0;
        while (LibBpf.ProgGetNextId(nextId, ref nextId) == 0)
        {
            int fd = LibBpf.ProgGetFdById(nextId);
            if (fd < 0) continue;

            var  info    = new BpfProgInfo();
            uint infoLen = (uint)sizeof(BpfProgInfo);
            int  res     = LibBpf.ObjGetInfoByFd(fd, new IntPtr(&info), ref infoLen);
            if (res == 0)
            {
                // BPF_OBJ_NAME_LEN is 16; the kernel stores at most 15 printable
                // chars.  "aegis_dns_intercept" (19 chars) is stored as
                // "aegis_dns_inter" + '\0'.  Match the prefix to be robust.
                string name = Marshal.PtrToStringAnsi(new IntPtr(info.Name)) ?? string.Empty;
                if (name.StartsWith("aegis_dns_inter", StringComparison.Ordinal))
                {
                    _bpfProgId = nextId; // record kernel ID for IsAttached() checks
                    return fd;           // caller takes ownership
                }
            }

            close(fd);
        }
        return -1;
    }

    // Walk every BPF map currently loaded in the kernel and return an fd for
    // the first one whose name exactly matches mapName.
    // Map names are at most BPF_OBJ_NAME_LEN-1 = 15 chars; "aegis_blocks"
    // and "aegis_events" are both 12 chars so no truncation occurs.
    // Returns a valid fd that the caller owns, or -1 if not found.
    private static unsafe int FindMapFdByName(string mapName)
    {
        uint nextId = 0;
        while (LibBpf.MapGetNextId(nextId, ref nextId) == 0)
        {
            int fd = LibBpf.MapGetFdById(nextId);
            if (fd < 0) continue;

            var  info    = new BpfMapInfo();
            uint infoLen = (uint)sizeof(BpfMapInfo);
            int  res     = LibBpf.ObjGetInfoByFd(fd, new IntPtr(&info), ref infoLen);
            if (res == 0)
            {
                string name = Marshal.PtrToStringAnsi(new IntPtr(info.Name)) ?? string.Empty;
                if (string.Equals(name, mapName, StringComparison.Ordinal))
                    return fd; // caller takes ownership
            }

            close(fd);
        }
        return -1;
    }

    private static bool AttachToCgroup(AegisEngine engine)
    {
        int cgroupFd = open(CgroupPath, O_RDONLY);
        if (cgroupFd < 0)
        {
            int err = Marshal.GetLastWin32Error();
            engine.Broadcast($"❌ Failed to open cgroup {CgroupPath} (errno {err}).");
            return false;
        }

        try
        {
            // Attach to egress (outgoing packets).
            // BPF_F_ALLOW_MULTI lets multiple programs coexist in the cgroup slot,
            // preventing EINVAL when a stale copy from a previous cycle was not fully detached.
            int attachRes = LibBpf.ProgAttach(_bpfProgFd, cgroupFd, BpfAttachType.CgroupSkb, BpfAttachFlags.AllowMulti);
            if (attachRes < 0)
            {
                engine.Broadcast($"❌ Failed to attach BPF program to cgroup (errno {attachRes}).");
                return false;
            }
            return true;
        }
        finally
        {
            close(cgroupFd);
        }
    }

    public static bool Reattach()
    {
        if (_bpfProgFd < 0) return false;

        int cgroupFd = open(CgroupPath, O_RDONLY);
        if (cgroupFd < 0) return false;

        try
        {
            int attachRes = LibBpf.ProgAttach(_bpfProgFd, cgroupFd, BpfAttachType.CgroupSkb, BpfAttachFlags.AllowMulti);
            return attachRes == 0;
        }
        finally
        {
            close(cgroupFd);
        }
    }

    public static bool IsAttached()
    {
        // Check actual cgroup attachment state rather than the BPF pin directory.
        // The pin directory persists across detach/reattach and does not reflect
        // whether our specific program is currently active in the cgroup.
        if (_bpfProgId == 0 || _bpfProgFd < 0) return false;

        int cgroupFd = open(CgroupPath, O_RDONLY);
        if (cgroupFd < 0) return false;

        try
        {
            return IsProgramAttachedToCgroup(cgroupFd, _bpfProgId);
        }
        finally
        {
            close(cgroupFd);
        }
    }

    // Returns true if the program with the given kernel ID appears in the list
    // of programs attached to cgroupFd with BpfAttachType.CgroupSkb.
    private static unsafe bool IsProgramAttachedToCgroup(int cgroupFd, uint progId)
    {
        uint cnt         = 64;
        uint attachFlags = 0;
        uint* ids        = stackalloc uint[(int)cnt];

        int res = LibBpf.ProgQuery(cgroupFd, BpfAttachType.CgroupSkb, 0,
                                   ref attachFlags, new IntPtr(ids), ref cnt);
        if (res < 0) return false;

        for (uint i = 0; i < cnt; i++)
        {
            if (ids[i] == progId) return true;
        }
        return false;
    }

    // Detach every aegis_dns_intercept program currently attached to the cgroup.
    // Called at the start of LoadAndAttach to prevent stale copies left by previous
    // crash/restart cycles from triggering the TamperMonitor reattach loop.
    private static unsafe void DetachAllStaleFromCgroup(AegisEngine engine)
    {
        int cgroupFd = open(CgroupPath, O_RDONLY);
        if (cgroupFd < 0) return;

        try
        {
            uint cnt         = 64;
            uint attachFlags = 0;
            uint* ids        = stackalloc uint[(int)cnt];

            int res = LibBpf.ProgQuery(cgroupFd, BpfAttachType.CgroupSkb, 0,
                                       ref attachFlags, new IntPtr(ids), ref cnt);
            if (res < 0) return;

            for (uint i = 0; i < cnt; i++)
            {
                int fd = LibBpf.ProgGetFdById(ids[i]);
                if (fd < 0) continue;

                try
                {
                    var  info    = new BpfProgInfo();
                    uint infoLen = (uint)sizeof(BpfProgInfo);
                    if (LibBpf.ObjGetInfoByFd(fd, new IntPtr(&info), ref infoLen) == 0)
                    {
                        string name = Marshal.PtrToStringAnsi(new IntPtr(info.Name)) ?? string.Empty;
                        if (name.StartsWith("aegis_dns_inter", StringComparison.Ordinal))
                        {
                            int r = LibBpf.ProgDetach2(fd, cgroupFd, BpfAttachType.CgroupSkb);
                            engine.Broadcast(r == 0
                                ? $"🧹 Detached stale aegis_dns_intercept (id={ids[i]})."
                                : $"⚠️  Could not detach stale id={ids[i]} (errno {r}).");
                        }
                    }
                }
                finally
                {
                    close(fd);
                }
            }
        }
        finally
        {
            close(cgroupFd);
        }
    }

    private static Task SyncBlocklistToKernel(AegisEngine engine)
    {
        _ = Task.Run(async () =>
        {
            try
            {
                engine.Broadcast("🔄 Syncing domain blocklist to kernel eBPF map (background)...");
                var blocklist = engine.GetCurrentBlocklist();
                int count = 0;
                foreach (var domain in blocklist)
                {
                    AddBlock(domain);
                    count++;
                    if (count % 1000 == 0)
                        await Task.Delay(5);
                }
                engine.Broadcast($"✅ Synced {count} domains to kernel.");
            }
            catch (Exception ex)
            {
                engine.Broadcast($"⚠️ Blocklist sync error: {ex.Message}");
            }
        });

        return Task.CompletedTask;
    }

    public static unsafe void AddBlock(string domain)
    {
        if (_bpfBlocksMapFd < 0 || string.IsNullOrWhiteSpace(domain)) return;
        AegisBlockKey key = default;
        byte[] domainBytes = Encoding.UTF8.GetBytes(domain.ToLower());
        int len = Math.Min(domainBytes.Length, 63);
        Marshal.Copy(domainBytes, 0, (IntPtr)key.Domain, len);
        AegisBlockVal val = new AegisBlockVal
        {
            Action = AegisAction.Block,
            BlockTime = (ulong)DateTimeOffset.UtcNow.ToUnixTimeMilliseconds() * 1000000,
            HitCount = 0
        };
        LibBpf.MapUpdate(_bpfBlocksMapFd, new IntPtr(&key), new IntPtr(&val), 0);
    }

    public static unsafe void RemoveBlock(string domain)
    {
        if (_bpfBlocksMapFd < 0 || string.IsNullOrWhiteSpace(domain)) return;

        AegisBlockKey key = default;
        byte[] domainBytes = Encoding.UTF8.GetBytes(domain.ToLower());
        int len = Math.Min(domainBytes.Length, 255);

        byte* pKeyDomain = key.Domain;
        Marshal.Copy(domainBytes, 0, (IntPtr)pKeyDomain, len);

        LibBpf.MapDelete(_bpfBlocksMapFd, new IntPtr(&key));
    }

    private static void StartRingBuffer(AegisEngine engine)
    {
        _eventChannel = Channel.CreateBounded<AegisDnsEvent>(new BoundedChannelOptions(10000)
        {
            FullMode = BoundedChannelFullMode.DropOldest, // Never block native thread
            SingleReader = true,
            SingleWriter = true
        });

        // Must pin delegate to static field
        _ringBufferCallback = HandleRingBufferEvent;

        _ringBuffer = LibBpf.RingBufferNew(_bpfEventsMapFd, _ringBufferCallback, IntPtr.Zero, 0);
        if (_ringBuffer == IntPtr.Zero)
        {
            engine.Broadcast("❌ Failed to create ring buffer consumer.");
            return;
        }

        _isStopping = false;

        // Start native polling loop
        _pollingTask = Task.Factory.StartNew(() =>
        {
            while (!_isStopping)
            {
                int res = LibBpf.RingBufferPoll(_ringBuffer, 100);
                if (res < 0)
                {
                    // Log error but keep polling, might be transient
                    engine.Broadcast($"⚠️ Ring buffer poll error: {res}");
                    Thread.Sleep(100);
                }
            }
        }, TaskCreationOptions.LongRunning);

        // Start async event consumer
        _eventConsumerTask = ConsumeEventsAsync(engine);
    }

    private static int HandleRingBufferEvent(IntPtr ctx, IntPtr data, ulong size)
    {
        if (_isStopping || _eventChannel == null) return 1; // stop polling

        if (size >= (ulong)Marshal.SizeOf<AegisDnsEvent>())
        {
            AegisDnsEvent evt = Marshal.PtrToStructure<AegisDnsEvent>(data);
            _eventChannel.Writer.TryWrite(evt);
        }

        return 0; // continue
    }

    private static async Task ConsumeEventsAsync(AegisEngine engine)
    {
        if (_eventChannel == null) return;

        try
        {
            await foreach (var evt in _eventChannel.Reader.ReadAllAsync())
            {
                if (evt.Action == AegisAction.Block)
                {
                    unsafe
                    {
                        string domain = Marshal.PtrToStringUTF8((IntPtr)evt.Domain) ?? "unknown";
                        engine.Broadcast($"🛡️ [eBPF Kernel Drop] {domain}");
                    }
                }
            }
        }
        catch (ChannelClosedException)
        {
            // Expected on shutdown
        }
    }

    public static void Detach()
    {
        _isStopping = true;

        if (_eventChannel != null)
        {
            _eventChannel.Writer.TryComplete();
        }

        // Wait a brief moment for poll loop to exit
        if (_pollingTask != null)
        {
            _pollingTask.Wait(200);
        }

        if (_ringBuffer != IntPtr.Zero)
        {
            LibBpf.RingBufferFree(_ringBuffer);
            _ringBuffer = IntPtr.Zero;
        }

        if (_bpfProgFd >= 0)
        {
            int cgroupFd = open(CgroupPath, O_RDONLY);
            if (cgroupFd >= 0)
            {
                LibBpf.ProgDetach2(_bpfProgFd, cgroupFd, BpfAttachType.CgroupSkb);
                close(cgroupFd);
            }
        }

        Cleanup();
        WasLoaded = false;
    }

    private static void Cleanup()
    {
        if (_bpfObj != IntPtr.Zero)
        {
            LibBpf.ObjectUnpin(_bpfObj, BpfFsPinPath);
            LibBpf.ObjectClose(_bpfObj);
            _bpfObj = IntPtr.Zero;
        }
        _bpfBlocksMapFd = -1;
        _bpfEventsMapFd = -1;
        _bpfProgFd      = -1;
        _bpfProgId      = 0;
    }
