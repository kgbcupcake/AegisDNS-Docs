// AegisDNS.XdpLoader/XdpStructs.cs

using System.Runtime.InteropServices;

namespace AegisDNS.XdpLoader;

/// <summary>
/// Mirror of struct aegis_xdp_event in xdp/aegis_xdp.c.
/// Naturally aligned: 4+2+1+1 = 8 bytes, no gaps.
/// </summary>
[StructLayout(LayoutKind.Sequential)]
public struct AegisXdpEvent
{
    /// <summary>Source IP address in network byte order.</summary>
    public uint SrcIp;
    /// <summary>DNS transaction ID from the dropped response.</summary>
    public ushort DnsTxId;
    /// <summary>Drop reason code (see <see cref="XdpReason"/>).</summary>
    public byte Reason;
    /// <summary>Padding byte for alignment with C struct.</summary>
    public byte Pad;
}

/// <summary>
/// Reason codes matching kernel-side drop reasons in aegis_xdp.c.
/// </summary>
public static class XdpReason
{
    /// <summary>Source IP was in the xdp_blocked_ips map.</summary>
    public const byte BlockedIp = 0x01;
    /// <summary>First A record resolved to RFC 1918 private address (rebinding attack).</summary>
    public const byte Rfc1918Rebind = 0x02;
    /// <summary>DNS header was malformed (too short or invalid).</summary>
    public const byte Malformed = 0x03;
}
