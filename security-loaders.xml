// AegisDNS.XdpLoader/AegisXdpLoader.cs
// XDP ingress DNS shield — mirrors AegisBpfLoader.cs structure

using System;
using System.Buffers.Binary;
using System.IO;
using System.Runtime.InteropServices;
using System.Threading;
using System.Threading.Channels;
using System.Threading.Tasks;

using AegisDNS.Core;

namespace AegisDNS.XdpLoader;

/// <summary>
/// Loads, attaches, and manages the XDP ingress DNS filter program.
/// Mirrors <c>AegisBpfLoader</c> in structure — same static class pattern,
/// same ring buffer/GC root mechanics.
/// </summary>
public static class AegisXdpLoader
{
    /// <summary>True once LoadAndAttach has succeeded.</summary>
    public static bool WasLoaded { get; private set; }

    // ── Static BPF state ────────────────────────────────────────────────────
    private static IntPtr _bpfObj = IntPtr.Zero;
    private static int _bpfProgFd = -1;
    private static int _blockedIpsMapFd = -1;
    private static int _eventsMapFd = -1;
    private static int _dropCounterMapFd = -1;
    private static IntPtr _ringBuffer = IntPtr.Zero;

    // GC root — prevent delegate from being collected while native code holds a pointer
    private static RingBufferCallback? _ringBufferCallback;

    private static Channel<AegisXdpEvent>? _eventChannel;
    private static Task? _pollingTask;
    private static Task? _eventConsumerTask;
    private static volatile bool _isStopping;

    // XDP attachment state — needed for Reattach() and IsAttached()
    private static uint _ifindex;
    private static uint _attachFlags;
    private static string _resolvedIface = "";

    /// <summary>Fires for every XDP drop event received from the kernel.</summary>
    public static event EventHandler<AegisXdpEvent>? XdpDropDetected;

    // ── Public API ──────────────────────────────────────────────────────────

    /// <summary>
    /// Opens the XDP object, loads it into the kernel, attaches to the specified
    /// network interface, and starts the ring buffer poll loop.
    /// </summary>
    /// <param name="xdpObjectPath">Path to the compiled aegis_xdp.o file.</param>
    /// <param name="interfaceName">"auto" to detect the default route interface, or an explicit interface name.</param>
    /// <param name="mode">Off/Monitor/Block — Monitor attaches but does not populate the blocked IPs map.</param>
    /// <param name="engine">AegisEngine instance for broadcast logging.</param>
    /// <returns>True if attached successfully, false otherwise.</returns>
    public static Task<bool> LoadAndAttach(
        string xdpObjectPath, string interfaceName, XdpMode mode, AegisEngine engine)
    {
        return Task.Run(() =>
        {
            if (!OperatingSystem.IsLinux())
            {
                engine.Broadcast("⚠️ XDP is only available on Linux.");
                return false;
            }

            try
            {
                // 1. Open Object
                _bpfObj = LibXdp.ObjectOpen(xdpObjectPath);
                if (_bpfObj == IntPtr.Zero)
                {
                    engine.Broadcast($"❌ Failed to open XDP object: {xdpObjectPath}");
                    return false;
                }

                // 2. Load into kernel
                int loadRes = LibXdp.ObjectLoad(_bpfObj);
                if (loadRes < 0)
                {
                    engine.Broadcast($"❌ XDP load failed (errno {loadRes}). Kernel may be too old or verifier rejected it.");
                    Cleanup();
                    return false;
                }

                // 3. Find XDP program by name
                IntPtr progPtr = LibXdp.FindProgramByName(_bpfObj, "xdp_ingress");
                if (progPtr == IntPtr.Zero)
                {
                    engine.Broadcast("❌ Failed to find XDP program 'xdp_ingress'.");
                    Cleanup();
                    return false;
                }

                _bpfProgFd = LibXdp.ProgramFd(progPtr);
                if (_bpfProgFd < 0)
                {
                    engine.Broadcast("❌ Failed to get XDP program fd.");
                    Cleanup();
                    return false;
                }

                // 4. Get Map FDs
                IntPtr blockedIpsMap = LibXdp.FindMapByName(_bpfObj, "xdp_blocked_ips");
                if (blockedIpsMap != IntPtr.Zero) _blockedIpsMapFd = LibXdp.MapFd(blockedIpsMap);

                IntPtr eventsMap = LibXdp.FindMapByName(_bpfObj, "xdp_events");
                if (eventsMap != IntPtr.Zero) _eventsMapFd = LibXdp.MapFd(eventsMap);

                IntPtr counterMap = LibXdp.FindMapByName(_bpfObj, "xdp_drop_counter");
                if (counterMap != IntPtr.Zero) _dropCounterMapFd = LibXdp.MapFd(counterMap);

                if (_blockedIpsMapFd < 0 || _eventsMapFd < 0)
                {
                    engine.Broadcast("❌ Failed to get XDP map fds.");
                    Cleanup();
                    return false;
                }

                // 5. Resolve interface
                _resolvedIface = ResolveInterface(interfaceName);
                engine.Broadcast($"🔍 XDP target interface: {_resolvedIface}");

                _ifindex = LibXdp.IfNameToIndex(_resolvedIface);
                if (_ifindex == 0)
                {
                    engine.Broadcast($"❌ Failed to resolve interface '{_resolvedIface}' to ifindex.");
                    Cleanup();
                    return false;
                }

                // 6. Attach — try native mode first, fall back to SKB
                if (!AttachToInterface(engine))
                {
                    Cleanup();
                    return false;
                }

                // 7. Start ring buffer poll loop
                StartRingBuffer(engine);

                WasLoaded = true;
                return true;
            }
            catch (Exception ex)
            {
                engine.Broadcast($"❌ XDP Loader exception: {ex.Message}");
                Cleanup();
                return false;
            }
        });
    }

    /// <summary>Detaches the XDP program and cleans up all state. Idempotent.</summary>
    public static void Detach()
    {
        _isStopping = true;

        _eventChannel?.Writer.TryComplete();

        if (_pollingTask != null)
        {
            _pollingTask.Wait(200);
            _pollingTask = null;
        }

        if (_ringBuffer != IntPtr.Zero)
        {
            LibXdp.RingBufferFree(_ringBuffer);
            _ringBuffer = IntPtr.Zero;
        }

        // Detach from interface — passing -1 removes the XDP program
        if (_ifindex > 0)
        {
            LibXdp.SetLinkXdpFd((int)_ifindex, -1, 0);
        }

        Cleanup();
        WasLoaded = false;
    }

    /// <summary>Re-attaches the XDP program using stored ifindex and prog fd.</summary>
    /// <returns>True if successfully reattached.</returns>
    public static bool Reattach()
    {
        if (_bpfProgFd < 0 || _ifindex == 0) return false;
        int result = LibXdp.SetLinkXdpFd((int)_ifindex, _bpfProgFd, _attachFlags);
        return result == 0;
    }

    /// <summary>Checks if the XDP program is still attached to the interface.</summary>
    public static bool IsAttached()
    {
        if (_ifindex == 0 || string.IsNullOrEmpty(_resolvedIface)) return false;
        // Query current XDP prog attached to interface via /sys/class/net/{iface}/xdp
        string xdpPath = $"/sys/class/net/{_resolvedIface}/xdp";
        return Directory.Exists(xdpPath);
    }

    /// <summary>Reads the per-CPU drop counter from the kernel map and returns the sum.</summary>
    public static unsafe long GetDropCount()
    {
        if (_dropCounterMapFd < 0) return 0;

        int key = 0;
        // Per-CPU array: allocate space for up to 128 CPUs
        long* values = stackalloc long[128];

        int res = LibXdp.MapLookup(_dropCounterMapFd, (IntPtr)(&key), (IntPtr)values);
        if (res < 0) return 0;

        long total = 0;
        int numCpus = Environment.ProcessorCount;
        for (int i = 0; i < numCpus && i < 128; i++)
            total += values[i];

        return total;
    }

    /// <summary>Adds an IPv4 address to the kernel-side blocked IPs map.</summary>
    /// <param name="ipv4NetworkOrder">IP address in network byte order.</param>
    /// <param name="reason">Reason code for the block.</param>
    public static unsafe void AddBlockedIp(uint ipv4NetworkOrder, byte reason)
    {
        if (_blockedIpsMapFd < 0) return;
        LibXdp.MapUpdate(_blockedIpsMapFd, (IntPtr)(&ipv4NetworkOrder), (IntPtr)(&reason), 0);
    }

    /// <summary>Removes an IPv4 address from the kernel-side blocked IPs map.</summary>
    public static unsafe void RemoveBlockedIp(uint ipv4NetworkOrder)
    {
        if (_blockedIpsMapFd < 0) return;
        LibXdp.MapDelete(_blockedIpsMapFd, (IntPtr)(&ipv4NetworkOrder));
    }

    // ── Private methods ─────────────────────────────────────────────────────

    private static bool AttachToInterface(AegisEngine engine)
    {
        // Try native DRV mode first (fastest — runs at NIC driver level)
        _attachFlags = LibXdp.XDP_FLAGS_DRV_MODE;
        int result = LibXdp.SetLinkXdpFd((int)_ifindex, _bpfProgFd, _attachFlags);

        if (result < 0)
        {
            // errno 95 = EOPNOTSUPP — fallback to generic SKB mode
            engine.Broadcast("⚠️ Native XDP not supported on this NIC — falling back to SKB mode.");
            _attachFlags = LibXdp.XDP_FLAGS_SKB_MODE;
            result = LibXdp.SetLinkXdpFd((int)_ifindex, _bpfProgFd, _attachFlags);

            if (result < 0)
            {
                engine.Broadcast($"❌ XDP attach failed in both native and SKB modes (errno {result}).");
                return false;
            }

            engine.Broadcast("📡 XDP attached in SKB (generic) mode.");
        }
        else
        {
            engine.Broadcast("⚡ XDP attached in native driver mode — maximum throughput.");
        }

        return true;
    }

    private static string ResolveInterface(string interfaceName)
    {
        if (!string.Equals(interfaceName, "auto", StringComparison.OrdinalIgnoreCase))
            return interfaceName;

        // Parse /proc/net/route to find the default route interface
        try
        {
            string[] lines = File.ReadAllLines("/proc/net/route");
            for (int i = 1; i < lines.Length; i++) // skip header
            {
                string[] fields = lines[i].Split('\t', StringSplitOptions.RemoveEmptyEntries);
                if (fields.Length >= 2 && fields[1] == "00000000")
                    return fields[0]; // Iface column
            }
        }
        catch
        {
            // Fall through to default
        }

        return "eth0"; // Final fallback
    }

    private static void StartRingBuffer(AegisEngine engine)
    {
        _eventChannel = Channel.CreateBounded<AegisXdpEvent>(new BoundedChannelOptions(10000)
        {
            FullMode = BoundedChannelFullMode.DropOldest,
            SingleReader = true,
            SingleWriter = true
        });

        // Must pin delegate to static field — GC root
        _ringBufferCallback = HandleRingBufferEvent;

        _ringBuffer = LibXdp.RingBufferNew(_eventsMapFd, _ringBufferCallback, IntPtr.Zero, 0);
        if (_ringBuffer == IntPtr.Zero)
        {
            engine.Broadcast("❌ Failed to create XDP ring buffer consumer.");
            return;
        }

        _isStopping = false;

        // Native polling loop on a dedicated thread
        _pollingTask = Task.Factory.StartNew(() =>
        {
            while (!_isStopping)
            {
                int res = LibXdp.RingBufferPoll(_ringBuffer, 100);
                if (res < 0)
                {
                    engine.Broadcast($"⚠️ XDP ring buffer poll error: {res}");
                    Thread.Sleep(100);
                }
            }
        }, TaskCreationOptions.LongRunning);

        // Async event consumer
        _eventConsumerTask = ConsumeEventsAsync(engine);
    }

    private static int HandleRingBufferEvent(IntPtr ctx, IntPtr data, ulong size)
    {
        if (_isStopping || _eventChannel == null) return 1;

        if (size >= (ulong)Marshal.SizeOf<AegisXdpEvent>())
        {
            AegisXdpEvent evt = Marshal.PtrToStructure<AegisXdpEvent>(data);
            _eventChannel.Writer.TryWrite(evt);
        }

        return 0;
    }

    private static async Task ConsumeEventsAsync(AegisEngine engine)
    {
        if (_eventChannel == null) return;

        try
        {
            await foreach (var evt in _eventChannel.Reader.ReadAllAsync())
            {
                string ip = FormatIp(evt.SrcIp);
                string reason = FormatReason(evt.Reason);
                engine.Broadcast($"🛡️ XDP: {reason} — src: {ip}, txid: {evt.DnsTxId}");

                MetricsManager.IncrementXdpDropped();
                XdpDropDetected?.Invoke(null, evt);
            }
        }
        catch (ChannelClosedException)
        {
            // Expected on shutdown
        }
    }

    private static string FormatIp(uint ipNetworkOrder)
    {
        uint ip = BinaryPrimitives.ReverseEndianness(ipNetworkOrder);
        return $"{(ip >> 24) & 0xFF}.{(ip >> 16) & 0xFF}.{(ip >> 8) & 0xFF}.{ip & 0xFF}";
    }

    private static string FormatReason(byte reason)
    {
        return reason switch
        {
            XdpReason.BlockedIp => "blocked IP",
            XdpReason.Rfc1918Rebind => "RFC1918 rebinding attack",
            XdpReason.Malformed => "malformed packet",
            _ => $"unknown reason (0x{reason:X2})"
        };
    }

    private static void Cleanup()
    {
        if (_bpfObj != IntPtr.Zero)
        {
            LibXdp.ObjectClose(_bpfObj);
            _bpfObj = IntPtr.Zero;
        }
        _bpfProgFd = -1;
        _blockedIpsMapFd = -1;
        _eventsMapFd = -1;
        _dropCounterMapFd = -1;
        _ifindex = 0;
        _attachFlags = 0;
        _resolvedIface = "";
    }
}
