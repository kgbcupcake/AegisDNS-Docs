using System.Security.Cryptography;
using System.Text;
using System.Text.Json;

namespace AegisDNS.Core.Security;

// static class: logger injection deferred — all methods are static, DI not applicable.
public class IntegrityChecker
{
    // RSA-2048 Public Key for Integrity Manifest Verification
    // Generated specifically for this instance.
    public const string IntegrityPublicKey = @"-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAuOi6SwJGTwgGinKDyXu+
diqOt7FgER3hYaLrGkmcFqBGT+Pbo4TtFrL/zg0t6fwiVVOKcAYlZB+XGD2Lfyut
IQxjJUAdO1cNxzYhY3flgISB6LbIfz2jdayV1x8CzzZyzef5vGRVz80qfQPXAMDN
eNsogAd6sEB0s+lI6dmPxL9QWvFBW+SRkFifk5S8HRqgFKkhe2n1dGCa1NGHrB7t
OOu5wyIrroAEDftNBQtZQnfJ9/2ly+YnFtB7/5WTRwv/DGoWxZXxH10X5BvNBNFz
5ivK8zqb1bUP5ev0eqOK641OFcVJZjfuEL2VS6zH08+AYXRAbCFnNTgNUE65hUfs
5wIDAQAB
-----END PUBLIC KEY-----";

    public static async Task<bool> VerifyEnvironmentAsync()
    {
        try
        {
            string baseDir = AppDomain.CurrentDomain.BaseDirectory;
            string manifestPath = Path.Combine(baseDir, "integrity.manifest");
            string sigPath = Path.Combine(baseDir, "integrity.manifest.sig");

            if (!File.Exists(manifestPath) || !File.Exists(sigPath))
            {
                System.Diagnostics.Debug.WriteLine("[Integrity] Missing manifest or signature. Integrity verification severely compromised.");
                return false;
            }

            // 1. Verify Signature
            byte[] manifestBytes = await File.ReadAllBytesAsync(manifestPath);
            byte[] signatureBytes = await File.ReadAllBytesAsync(sigPath);

            using var rsa = RSA.Create();
            rsa.ImportFromPem(IntegrityPublicKey);

            if (!rsa.VerifyData(manifestBytes, signatureBytes, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1))
            {
                System.Diagnostics.Debug.WriteLine("[Integrity] Signature Verification FAILED.");
                return false;
            }

            Dictionary<string, string>? manifest;
            try
            {
                manifest = JsonSerializer.Deserialize<Dictionary<string, string>>(manifestBytes);
            }
            catch (JsonException)
            {
                return false;
            }
            if (manifest == null) return false;

            // 3. Check Files
            foreach (var kvp in manifest)
            {
                string filename = kvp.Key;
                string expectedHash = kvp.Value;
                string filePath = Path.Combine(baseDir, filename);

                if (!File.Exists(filePath)) return false;

                using var sha = SHA256.Create();
                using var stream = File.OpenRead(filePath);
                byte[] hashBytes = await sha.ComputeHashAsync(stream);
                string actualHash = Convert.ToBase64String(hashBytes);

                if (actualHash != expectedHash)
                {
                    System.Diagnostics.Debug.WriteLine($"[Integrity] Mismatch: {filename}");
                    return false;
                }
            }

            return true;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Integrity] Check failed: {ex.Message}");
            return false;
        }
    }
}
