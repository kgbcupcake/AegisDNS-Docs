using System;
using System.Diagnostics;
using System.IO;
using System.Runtime.InteropServices;
using System.Security.Cryptography;
using System.Text;

namespace AegisDNS.Licensing;

/// <summary>
/// Cross-platform AES-256-GCM token storage.
/// Key is derived from HardwareIdentity.Get() so tokens are HWID-bound
/// and will fail to decrypt on any other machine.
///
/// Disk format: [12-byte nonce][16-byte GCM tag][ciphertext]
/// No headers, no JSON wrapper — raw binary for minimum attack surface.
/// </summary>
public static class AesGcmTokenStore
{
    private const int NonceSize = 12;   // 96-bit nonce — GCM standard
    private const int TagSize = 16;   // 128-bit authentication tag

    public static string GetTokenPath(string appName = "AegisDNS")
    {
        // Linux → XDG Base Dir spec
        string xdgData = Environment.GetEnvironmentVariable("XDG_DATA_HOME")
                      ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
                                      ".local", "share");
        return Path.Combine(xdgData, appName, "activation.token");
    }

    private static byte[] DeriveKey()
    {
        byte[] ikm = Encoding.UTF8.GetBytes(HardwareIdentity.Get());
        byte[] salt = Encoding.UTF8.GetBytes("AegisDNS|TokenKey|v1");
        return HKDF.DeriveKey(HashAlgorithmName.SHA256, ikm, 32, salt);
    }

    public static void Encrypt(string plaintext, string path)
    {
        byte[] key = DeriveKey();
        byte[] nonce = new byte[NonceSize];
        byte[] tag = new byte[TagSize];
        byte[] input = Encoding.UTF8.GetBytes(plaintext);
        byte[] ciphertext = new byte[input.Length];

        RandomNumberGenerator.Fill(nonce);

        using var aes = new AesGcm(key, TagSize);
        aes.Encrypt(nonce, input, ciphertext, tag);

        byte[] blob = new byte[NonceSize + TagSize + ciphertext.Length];
        Buffer.BlockCopy(nonce, 0, blob, 0, NonceSize);
        Buffer.BlockCopy(tag, 0, blob, NonceSize, TagSize);
        Buffer.BlockCopy(ciphertext, 0, blob, NonceSize + TagSize, ciphertext.Length);

        string? dir = Path.GetDirectoryName(path);
        if (!string.IsNullOrEmpty(dir) && !Directory.Exists(dir))
            Directory.CreateDirectory(dir);
        File.WriteAllBytes(path, blob);
    }

    public static string? Decrypt(string path)
    {
        Debug.WriteLine($"[AesGcmTokenStore.Decrypt] Path='{path}'");
        if (!File.Exists(path))
        {
            Debug.WriteLine("[AesGcmTokenStore.Decrypt] File missing.");
            return null;
        }

        try
        {
            byte[] blob = File.ReadAllBytes(path);
            Debug.WriteLine($"[AesGcmTokenStore.Decrypt] Blob length={blob.Length} bytes.");
            if (blob.Length < NonceSize + TagSize + 1)
                throw new CryptographicException("Token file too short — corrupted.");

            byte[] nonce = blob[..NonceSize];
            byte[] tag = blob[NonceSize..(NonceSize + TagSize)];
            byte[] ciphertext = blob[(NonceSize + TagSize)..];
            byte[] plaintext = new byte[ciphertext.Length];

            using var aes = new AesGcm(DeriveKey(), TagSize);
            aes.Decrypt(nonce, ciphertext, tag, plaintext);
            string result = Encoding.UTF8.GetString(plaintext);
            Debug.WriteLine($"[AesGcmTokenStore.Decrypt] Success. Plaintext length={result.Length}.");
            return result;
        }
        catch (AuthenticationTagMismatchException ex)
        {
            Debug.WriteLine($"[AesGcmTokenStore.Decrypt] AuthenticationTagMismatchException: {ex.Message}. Deleting token.");
            TryDelete(path);
            return null;
        }
        catch (CryptographicException ex)
        {
            Debug.WriteLine($"[AesGcmTokenStore.Decrypt] CryptographicException: {ex.Message}. Deleting token.");
            TryDelete(path);
            return null;
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[AesGcmTokenStore.Decrypt] Unexpected exception ({ex.GetType().Name}): {ex.Message}");
            return null;
        }
    }

    public static bool Exists(string path) => File.Exists(path);
    public static void TryDelete(string path) { try { if (File.Exists(path)) File.Delete(path); } catch { } }
}
