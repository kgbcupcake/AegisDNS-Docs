using System;
using System.Diagnostics;

namespace AegisDNS.Core.Utilities;

/// <summary>
/// Blocks telemetry at the DNS level by adding known telemetry domains to the blocklist.
/// Works on all platforms via the existing BlocklistManager — no OS-specific code needed.
/// </summary>
public static class TelemetryBlocker
{
    // Well-known telemetry domains across common software vendors
    private static readonly string[] TelemetryDomains =
    [
        // Microsoft
        "telemetry.microsoft.com",
        "vortex.data.microsoft.com",
        "settings-win.data.microsoft.com",
        "watson.telemetry.microsoft.com",
        "oca.telemetry.microsoft.com",
        "telecommand.telemetry.microsoft.com",
        "sqm.telemetry.microsoft.com",
        // Google
        "clients4.google.com",
        "update.googleapis.com",
        "safebrowsing.googleapis.com",
        // Apple
        "metrics.icloud.com",
        "xp.apple.com",
        // Common analytics
        "analytics.google.com",
        "www.google-analytics.com",
        "segment.io",
        "api.segment.io",
        "mixpanel.com",
        "api.mixpanel.com",
        "amplitude.com",
        "api.amplitude.com",
        "hotjar.com",
        "static.hotjar.com",
        // Advertising
        "doubleclick.net",
        "googlesyndication.com",
        "googleadservices.com",
        "facebook.com/tr",
        "connect.facebook.net",
    ];

    public static void ApplyBlocking(bool enable)
    {
        if (!ConfigManager.Settings.TelemetryOptIn && enable)
        {
            Debug.WriteLine("[TelemetryBlocker] Skipped: user has not opted in.");
            return;
        }

        try
        {
            foreach (var domain in TelemetryDomains)
            {
                if (enable)
                    AiLearnedBlocklist.Add(domain);
                else
                    AiLearnedBlocklist.Remove(domain);
            }
            Debug.WriteLine(enable ? "[TelemetryBlocker] Domains blocked." : "[TelemetryBlocker] Domains unblocked.");
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[TelemetryBlocker] Error: {ex.Message}");
        }
    }
}
