using System;
using System.Diagnostics;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.Core.Ai;
using AegisDNS.Core.Utilities;
using AegisDNS.Service.Src; // Need this for Debug.WriteLine

using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Hosting;

namespace AegisDNS.Service;

// Pre-host bootstrap class — DI not yet available. Log() wraps Debug.WriteLine + Console.WriteLine intentionally.
public class Program
{
    public static void Main(string[] args)
    {
        // SAFE LOGGING: Writes to Console if possible, otherwise to VS Output
        Log("==========================================");
        Log("   🔥 AEGIS SERVICE LAUNCHING... 🔥       ");
        Log("==========================================");

        // --- INSTALLER COMMAND HOOKS ---
        if (args.Length > 0 && args[0] == "--install-snapshot")
        {
            Log("Creating pre-install DNS snapshot...");
            try
            {
                var active = System.Net.NetworkInformation.NetworkInterface.GetAllNetworkInterfaces()
                    .FirstOrDefault(ni => ni.OperationalStatus == System.Net.NetworkInformation.OperationalStatus.Up &&
                                          ni.GetIPProperties().GatewayAddresses.Count > 0 &&
                                          ni.NetworkInterfaceType != System.Net.NetworkInformation.NetworkInterfaceType.Loopback);

                if (active != null)
                {
                    var dnsAddresses = active.GetIPProperties().DnsAddresses;
                    var dns = dnsAddresses.Select(a => a.ToString()).ToList();

                    // DHCP detection: Primary and Secondary 0.0.0.0 or Empty list
                    bool wasDhcp = dns.Count == 0 || dns.All(d => d == "0.0.0.0");

                    if (!DnsSnapshot.Exists())
                    {
                        DnsSnapshot.Save(dns, wasDhcp, active.Name);
                        Log($"Snapshot saved for ({active.Name})");
                    }
                    else
                    {
                        Log("Snapshot already exists. Keeping original.");
                    }
                }
                Environment.Exit(0);
            }
            catch (Exception ex)
            {
                Log($"Failed to create snapshot: {ex.Message}");
                Environment.Exit(1);
            }
            return;
        }

        if (args.Length > 0 && args[0] == "--uninstall-restore")
        {
            Log("Restoring DNS settings before uninstall...");
            try
            {
                AegisEngine.RestoreSystemDns();
                Log("DNS restored successfully.");
                Environment.Exit(0);
            }
            catch (Exception ex)
            {
                Log($"Failed to restore DNS: {ex.Message}");
                Environment.Exit(1);
            }
            return;
        }

        // ------------------------------------------------------------
        // ROLLBACK HEALTH CHECK
        // ------------------------------------------------------------
        if (!AegisDNS.Core.Utilities.RollbackManager.RunHealthCheck())
        {
            Log("[CRITICAL] Health check failed on startup. Initiating rollback...");
            AegisDNS.Core.Utilities.RollbackManager.Restore();
            Environment.Exit(1);
            return;
        }

        // ── BOOT INTEGRITY ENFORCEMENT (Phase 8 — B.1) ──────────────────────────
        // Verify all binaries match the signed integrity manifest.
        // Exit(10) signals installer/monitor: tampered binary detected.
        // If the manifest files are absent this is treated as a dev/unsigned build —
        // log a warning and continue rather than refusing to start.
        string baseDir = AppDomain.CurrentDomain.BaseDirectory;
        string manifestPath    = Path.Combine(baseDir, "integrity.manifest");
        string manifestSigPath = Path.Combine(baseDir, "integrity.manifest.sig");

        if (!File.Exists(manifestPath) || !File.Exists(manifestSigPath))
        {
            Log("[WARNING] integrity.manifest / integrity.manifest.sig not found — " +
                "skipping boot integrity check (dev or unsigned build).");
        }
        else
        {
            try
            {
                bool integrityOk = AegisDNS.Core.Security.IntegrityChecker.VerifyEnvironmentAsync()
                    .GetAwaiter().GetResult();
                if (!integrityOk)
                {
                    Log("[CRITICAL] Boot integrity check FAILED. Binary may be tampered. Exiting.");
                    Environment.Exit(10);
                    return;
                }
                Log("[OK] Boot integrity verified.");
            }
            catch (Exception ex)
            {
                Log($"[CRITICAL] Boot integrity check threw: {ex.Message}. Exiting.");
                Environment.Exit(10);
                return;
            }
        }
        // ── END BOOT INTEGRITY ───────────────────────────────────────────────────

        // ------------------------------------------------------------
        // HARDENING PHASE: LICENSE CHECK
        // ------------------------------------------------------------
        try
        {
            string? rawLicense = ResolveLicenseKey(args);

            AegisDNS.Licensing.LicenseManager.EnsureActivated(rawLicense);

            if (!AegisDNS.Licensing.LicenseManager.IsLicenseValid())
            {
                string msg = "[WARNING]: License validation failed (RSA Signature / HWID Mismatch). Downgrading to Community Tier. Core protection remains active.";
                Log(msg);
            }
        }
        catch (Exception ex)
        {
            Log($"[CRITICAL]: License check crashed: {ex.Message}");
            // Still allow it to run - we fail open
        }
        // ------------------------------------------------------------

        try
        {
            CreateHostBuilder(args).Build().Run();
        }
        catch (Exception ex)
        {
            Log($"[CRITICAL FAILURE]: {ex.Message}");
            if (Environment.UserInteractive)
            {
                try { Console.ReadLine(); } catch { }
            }
        }
    }

    // Helper to print logs without crashing if there is no window
    static void Log(string message)
    {
        // 1. Try writing to the VS Debug Output (Always works)
        Debug.WriteLine(message);

        // 2. Try writing to Console (Might fail if running as Service)
        try
        {
            // Do NOT set Console.Title - that causes the crash!
            Console.WriteLine(message); // Changed to Console.WriteLine
        }
        catch { /* Ignore if no console exists */ }
    }

    private static string? ResolveLicenseKey(string[] args)
    {
        string licenseFilePath = GetLicenseKeyPath();
        string? fileLicense = TryReadLicenseKeyFromFile(licenseFilePath);
        if (!string.IsNullOrWhiteSpace(fileLicense))
        {
            Log($"License key loaded from {licenseFilePath}.");
            return fileLicense;
        }

        string? argLicense = TryGetLicenseKeyFromArgs(args);
        if (!string.IsNullOrWhiteSpace(argLicense))
        {
            Log("License key loaded from --license-key argument.");
            return argLicense;
        }

        Log("No license key found — running in trial/free mode");
        return null;
    }

    private static string GetLicenseKeyPath()
    {
        string home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        return Path.Combine(home, ".config", "aegisdns", "license.key");
    }

    private static string? TryReadLicenseKeyFromFile(string licenseFilePath)
    {
        if (!File.Exists(licenseFilePath))
        {
            return null;
        }

        EnsureLicenseFilePermissionsAre600(licenseFilePath);

        try
        {
            // Treat as a single-line secret. If multiple lines exist, we only use the first line.
            string[] lines = File.ReadAllLines(licenseFilePath);
            if (lines.Length == 0)
            {
                return null;
            }

            string firstLine = lines[0].Trim();
            return string.IsNullOrWhiteSpace(firstLine) ? null : firstLine;
        }
        catch (IOException ex)
        {
            Log($"[WARNING] Failed to read license file '{licenseFilePath}': {ex.Message}");
            return null;
        }
        catch (UnauthorizedAccessException ex)
        {
            Log($"[WARNING] Access denied reading license file '{licenseFilePath}': {ex.Message}");
            return null;
        }
    }

    private static void EnsureLicenseFilePermissionsAre600(string licenseFilePath)
    {
        try
        {
            UnixFileMode mode = File.GetUnixFileMode(licenseFilePath);
            UnixFileMode secureMode = UnixFileMode.UserRead | UnixFileMode.UserWrite;

            if (mode != secureMode)
            {
                int octalMode = ((int)mode) & 0xFFF;
                string modeText = Convert.ToString(octalMode, 8).PadLeft(3, '0');
                Log($"[WARNING] License key file permissions are {modeText}. Expected 600; attempting to fix.");

                try
                {
                    File.SetUnixFileMode(licenseFilePath, secureMode);
                    Log("License key file permissions set to 600.");
                }
                catch (IOException ex)
                {
                    Log($"[WARNING] Failed to set permissions to 600 for '{licenseFilePath}': {ex.Message}");
                }
                catch (UnauthorizedAccessException ex)
                {
                    Log($"[WARNING] Failed to set permissions to 600 for '{licenseFilePath}': {ex.Message}");
                }
            }
        }
        catch (IOException ex)
        {
            Log($"[WARNING] Could not verify permissions on '{licenseFilePath}': {ex.Message}");
        }
        catch (UnauthorizedAccessException ex)
        {
            Log($"[WARNING] Could not verify permissions on '{licenseFilePath}': {ex.Message}");
        }
        catch (PlatformNotSupportedException)
        {
            // Linux is the only supported platform, but keep this non-fatal.
        }
    }

    private static string? TryGetLicenseKeyFromArgs(string[] args)
    {
        for (int i = 0; i < args.Length; i++)
        {
            string arg = args[i];
            if (arg.Equals("--license-key", StringComparison.Ordinal))
            {
                if (i + 1 >= args.Length || args[i + 1].StartsWith("--", StringComparison.Ordinal))
                {
                    Log("[WARNING] --license-key was provided without a value.");
                    return null;
                }

                string value = args[i + 1].Trim();
                return string.IsNullOrWhiteSpace(value) ? null : value;
            }

            if (arg.StartsWith("--license-key=", StringComparison.Ordinal))
            {
                string value = arg["--license-key=".Length..].Trim();
                if (string.IsNullOrWhiteSpace(value))
                {
                    Log("[WARNING] --license-key was provided without a value.");
                    return null;
                }

                return value;
            }
        }

        return null;
    }

    // Added CreateHostBuilder method
    public static IHostBuilder CreateHostBuilder(string[] args) =>
        Host.CreateDefaultBuilder(args)
            .UseSystemd()
            .ConfigureServices((hostContext, services) =>
            {
                services.AddSingleton<AegisEngine>();
                // Update Engine (Phase 5)
                services.AddSingleton<UpdateManager>();
                // Plugin Architecture (Phase 6)
                services.AddSingleton<PluginManager>();

                // Worker: The main background loop
                services.AddHostedService<Worker>();
                // AiSentinel: The AI analysis worker
                services.AddHostedService<AiSentinelWorker>();
                services.AddHostedService<WeeklyReportWorker>();
            });
}
