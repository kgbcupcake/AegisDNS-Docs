using System;
using System.Diagnostics;
using System.IO;
using System.Runtime.InteropServices;

namespace AegisDNS.Core;

/// Manages AegisDNS auto-start on boot.
/// Linux: writes/removes a systemd user service or XDG autostart entry.
/// </summary>
public static class BootManager
{
    private const string AppName = "aegisdns-ui";

    // XDG autostart — works on all Linux DEs (GNOME, KDE, XFCE, etc.)
    private static string XdgAutostartDir =>
        Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
                     ".config", "autostart");

    private static string XdgAutostartFile =>
        Path.Combine(XdgAutostartDir, "aegisdns.desktop");

    public static void SetStartup(bool enable)
    {
        SetStartupLinux(enable);
    }

    public static bool IsStartupEnabled()
    {
        return File.Exists(XdgAutostartFile);
    }

    private static void SetStartupLinux(bool enable)
    {
        try
        {
            if (enable)
            {
                Directory.CreateDirectory(XdgAutostartDir);
                string exePath = Environment.ProcessPath ?? "/opt/AegisDNS/AegisDNSUI";
                string desktop = $"""
[Desktop Entry]
Type=Application
Name=AegisDNS
Exec={exePath}{(ConfigManager.Settings.StartMinimized ? " --minimized" : "")}
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
Comment=AegisDNS DNS Privacy Shield — auto-start
""";
                File.WriteAllText(XdgAutostartFile, desktop);
            }
            else
            {
                if (File.Exists(XdgAutostartFile))
                    File.Delete(XdgAutostartFile);
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[BootManager] Autostart error: {ex.Message}");
        }
    }
}
