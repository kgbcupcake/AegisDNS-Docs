using System;
using System.IO;
using System.Runtime.Versioning;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;

using AegisDNS.BpfLoader;
using AegisDNS.Core;
using AegisDNS.Core.ExtensionApi;
using AegisDNS.Core.Monitoring;
using AegisDNS.Core.PolicyEngine;
using AegisDNS.Core.Utilities;
using AegisDNS.Licensing;
using AegisDNS.WebDashboard;
using AegisDNS.XdpLoader;

using Microsoft.Extensions.Hosting;
using Microsoft.Extensions.Logging;

namespace AegisDNS.Service.Src;

[SupportedOSPlatform("linux")]
public class Worker : BackgroundService
{
    private readonly ILogger<Worker> _logger;
    private readonly ILoggerFactory _loggerFactory;
    private readonly AegisEngine _engine;
    private readonly TamperMonitor _tamperMonitor;
    private readonly UpdateManager _updateManager;
    private readonly PluginManager _pluginManager;
    private readonly System.Timers.Timer _metricsTimer;
    private WebDashboardHost? _webDashboard;
    private DevicePolicyEngine? _policyEngine;
    private ExtensionApiHost? _extensionApi;
    private LatencyMonitor? _latencyMonitor;
    private AegisDNS.Core.Proxy.HttpsProxyHost? _proxyHost;
    /// <summary>Long-lived HttpClient dedicated to cloud sync background tasks (non-hot-path).</summary>
    private readonly System.Net.Http.HttpClient _cloudClient = new();

    public Worker(ILogger<Worker> logger, ILoggerFactory loggerFactory, AegisEngine engine, UpdateManager updateManager, PluginManager pluginManager)
    {
        _logger = logger;
        _loggerFactory = loggerFactory;
        _engine = engine;
        _updateManager = updateManager;
        _pluginManager = pluginManager;

        // Setup Tamper Monitor to broadcast logs
        _tamperMonitor = new TamperMonitor(engine, async (msg) => await IpcSystem.BroadcastLogAsync(msg));

        // Wire up Engine logs to UI
        _engine.LogReceived += async (msg) => await IpcSystem.BroadcastLogAsync(msg);

        // Setup Metrics Snapshot Timer (5 mins)
        _metricsTimer = new System.Timers.Timer(TimeSpan.FromMinutes(5).TotalMilliseconds);
        _metricsTimer.Elapsed += (s, e) => MetricsHistory.RecordSnapshot();
        _metricsTimer.AutoReset = true;

        // Phase 18 — Internet Survivability: ensure iptables cleanup on crash
        AppDomain.CurrentDomain.ProcessExit += (s, e) => AegisDNS.Core.Proxy.TrafficRedirector.Disable();
        AppDomain.CurrentDomain.UnhandledException += (s, e) => AegisDNS.Core.Proxy.TrafficRedirector.Disable();
    }

    protected override async Task ExecuteAsync(CancellationToken stoppingToken)
    {
        try
        {

        _logger.LogDebug("[Worker] Service starting");

        // Force config managers to initialize NOW, before any background tasks can
        // pre-empt them or throw. ConfigManager.AppFolder is already confirmed correct.
        _ = DnsConfigManager.Settings;
        _ = SecurityConfigManager.Settings;
        _logger.LogInformation("[Worker] Config managers initialized: dns={DnsPath}, security={SecPath}",
            System.IO.Path.Combine(ConfigManager.AppFolder, "dns.config.json"),
            System.IO.Path.Combine(ConfigManager.AppFolder, "security.config.json"));

        // 1. START IPC IMMEDIATELY (Critical Fix)
        // This ensures the UI can connect instantly, even if download is slow.
        var commandServer = IpcSystem.StartCommandServerAsync(OnIpcCommand, stoppingToken);
        // Broadcast server is fire-and-forget: it waits for a UI client to connect and
        // must never block or crash the Worker regardless of whether a client is present.
        _ = Task.Run(() => IpcSystem.StartBroadcastServerAsync(stoppingToken));

        _logger.LogDebug("[Worker] IPC server open, waiting for UI");

        // 2. Run Startup Tasks in Background
        _ = Task.Run(async () =>
        {
            try
            {
                await IpcSystem.BroadcastLogAsync("⏳ Service initializing...");

                if (!_engine.GetCurrentBlocklist().Any())
                {
                    await IpcSystem.BroadcastLogAsync("📥 Blocklist empty — downloading multi-source blocklists...");
                    await _engine.UpdateBlocklistAsync();
                }

                // Initialize Plugins (Phase 6)
                await _pluginManager.LoadPluginsAsync();

                // Load historical metrics
                MetricsHistory.Load();
                _metricsTimer.Start();

                // Apply Telemetry Blocking if enabled
                if (BlocklistConfigManager.Settings.BlockTelemetry)
                {
                    TelemetryBlocker.ApplyBlocking(true);
                }

                // Phase 11 — Browser Extension API (all tiers)
                if (RouterConfigManager.Settings.EnableExtensionApi)
                {
                    try
                    {
                        _extensionApi = new ExtensionApiHost(_engine, _loggerFactory.CreateLogger<ExtensionApiHost>());
                        _extensionApi.Start(RouterConfigManager.Settings.ExtensionApiPort);
                        _engine.Broadcast($"🌐 Extension API listening on port {RouterConfigManager.Settings.ExtensionApiPort}");
                    }
                    catch (Exception ex) { await IpcSystem.BroadcastLogAsync($"⚠️ Extension API failure: {ex.Message}"); }
                }

                // Phase 11 — Latency Monitor (all tiers)
                if (DnsConfigManager.Settings.EnableLatencyMonitor)
                {
                    try
                    {
                        _latencyMonitor = new LatencyMonitor(_engine);
                        _latencyMonitor.Start();
                    }
                    catch (Exception ex) { await IpcSystem.BroadcastLogAsync($"⚠️ Latency Monitor failure: {ex.Message}"); }
                }

                await IpcSystem.BroadcastLogAsync("⚙️ Service Ready. Click 'ACTIVATE' to start the shield.");

                // Phase 16 — Policy engine (Enterprise only)
                if (SecurityConfigManager.Settings.EnablePolicyEngine
                    && (LicenseManager.CurrentTier >= LicenseManager.LicenseTier.Enterprise || LicenseManager.CurrentTier == LicenseManager.LicenseTier.Founder || LicenseManager.CurrentTier == LicenseManager.LicenseTier.Developer))
                {
                    try
                    {
                        _policyEngine = new DevicePolicyEngine(_loggerFactory.CreateLogger<DevicePolicyEngine>());
                        _policyEngine.Initialize();
                        await IpcSystem.BroadcastLogAsync("🛡️ Device Policy Engine initialized.");
                    }
                    catch (Exception ex) { await IpcSystem.BroadcastLogAsync($"⚠️ Policy Engine failure: {ex.Message}"); }
                }

                // Phase 16 — Web dashboard (Pro+ only)
                if (SecurityConfigManager.Settings.EnableWebDashboard
                    && LicenseManager.CurrentTier >= LicenseManager.LicenseTier.Pro)
                {
                    try
                    {
                        _webDashboard = new WebDashboardHost(_engine, _policyEngine ?? new DevicePolicyEngine(_loggerFactory.CreateLogger<DevicePolicyEngine>()), _loggerFactory.CreateLogger<WebDashboardHost>());
                        await _webDashboard.StartAsync(SecurityConfigManager.Settings.WebDashboardPort, stoppingToken);
                        _engine.Broadcast("🌐 Web dashboard active on port " + SecurityConfigManager.Settings.WebDashboardPort);
                    }
                    catch (Exception ex) { await IpcSystem.BroadcastLogAsync($"⚠️ Web Dashboard failure: {ex.Message}"); }
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "[Startup Error]");
                await IpcSystem.BroadcastLogAsync($"❌ Error: {ex.Message}");
            }
        }, stoppingToken);

        // 3. Start Auto-Update Background Loop (Phase 5)
        _ = Task.Run(async () =>
        {
            while (!stoppingToken.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromHours(6), stoppingToken);
                    var update = await _updateManager.CheckForUpdatesAsync();

                    if (update != null)
                    {
                        await IpcSystem.BroadcastLogAsync($"🆕 Update Found: v{update.Version}");
                        await IpcSystem.BroadcastLogAsync("⬇️ Downloading update...");
                        if (await _updateManager.DownloadAndInstallAsync(update))
                        {
                            await IpcSystem.BroadcastLogAsync("✅ Update downloaded. Installing...");
                            // Process will exit when installer runs
                        }
                    }
                }
                catch (OperationCanceledException)
                {
                    return; // Service stopping — exit cleanly
                }
                catch (Exception ex)
                {
                    _logger.LogError(ex, "[AutoUpdate] Error");
                    // Wait before retrying to avoid tight error loop
                    try { await Task.Delay(TimeSpan.FromMinutes(5), stoppingToken); }
                    catch (OperationCanceledException) { return; }
                }
            }
        }, stoppingToken);

        // 4. Phase 13 — Cloud Metrics Sync (every 15 minutes, non-fatal)
        _ = Task.Run(async () =>
        {
            while (!stoppingToken.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromMinutes(15), stoppingToken);

                    if (!SecurityConfigManager.Settings.CloudSyncEnabled
                        || !ConfigManager.Settings.TelemetryOptIn
                        || string.IsNullOrEmpty(SecurityConfigManager.Settings.DeviceApiToken))
                        continue;

                    var metrics = MetricsManager.Current;
                    var payload = System.Text.Json.JsonSerializer.Serialize(new
                    {
                        totalQueries = metrics.TotalQueries,
                        blockedQueries = metrics.BlockedQueries,
                        cacheHits = metrics.CacheHits,
                        upstreamLatencyMs = 0,
                        recordedAt = DateTime.UtcNow
                    });

                    var client = _cloudClient;
                    using var req = new System.Net.Http.HttpRequestMessage(
                        System.Net.Http.HttpMethod.Post,
                        $"{SecurityConfigManager.Settings.CloudApiEndpoint}/api/metrics/ingest");
                    req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue(
                        "Bearer", SecurityConfigManager.Settings.DeviceApiToken);
                    req.Content = new System.Net.Http.StringContent(
                        payload, System.Text.Encoding.UTF8, "application/json");

                    var response = await client.SendAsync(req, stoppingToken);
                    if (response.IsSuccessStatusCode)
                        _logger.LogInformation("[CloudSync] Metrics ingested");
                    else
                        _logger.LogWarning("[CloudSync] Metrics ingest returned {0}", response.StatusCode);
                }
                catch (OperationCanceledException) { break; }
                catch (Exception ex)
                {
                    _logger.LogWarning("[CloudSync:Metrics] Non-fatal error: {0}", ex.Message);
                }
            }
        }, stoppingToken);

        // 5. Phase 13 — Cloud Heartbeat + Policy Sync + Command Poll (every 60s, non-fatal)
        _ = Task.Run(async () =>
        {
            while (!stoppingToken.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromMinutes(1), stoppingToken);

                    if (!SecurityConfigManager.Settings.CloudSyncEnabled
                        || string.IsNullOrEmpty(SecurityConfigManager.Settings.DeviceApiToken))
                        continue;

                    var client = _cloudClient;

                    // ── Heartbeat ─────────────────────────────────────────────
                    using var hbReq = new System.Net.Http.HttpRequestMessage(
                        System.Net.Http.HttpMethod.Post,
                        $"{SecurityConfigManager.Settings.CloudApiEndpoint}/api/device/heartbeat");
                    hbReq.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue(
                        "Bearer", SecurityConfigManager.Settings.DeviceApiToken);
                    hbReq.Content = new System.Net.Http.StringContent(
                        $"{{\"version\":\"1.0.0\",\"uptime\":0}}", System.Text.Encoding.UTF8, "application/json");

                    var hbResp = await client.SendAsync(hbReq, stoppingToken);
                    if (hbResp.IsSuccessStatusCode)
                    {
                        var hbJson = await hbResp.Content.ReadAsStringAsync(stoppingToken);
                        using var hbDoc = System.Text.Json.JsonDocument.Parse(hbJson);
                        int serverPolicyVersion = hbDoc.RootElement.GetProperty("policyVersion").GetInt32();

                        // ── Policy Sync if version changed ────────────────────
                        if (serverPolicyVersion > SecurityConfigManager.Settings.CloudPolicyVersion)
                        {
                            try
                            {
                                using var polReq = new System.Net.Http.HttpRequestMessage(
                                    System.Net.Http.HttpMethod.Get,
                                    $"{SecurityConfigManager.Settings.CloudApiEndpoint}/api/policy/current");
                                polReq.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue(
                                    "Bearer", SecurityConfigManager.Settings.DeviceApiToken);

                                var polResp = await client.SendAsync(polReq, stoppingToken);
                                if (polResp.IsSuccessStatusCode)
                                {
                                    var polJson = await polResp.Content.ReadAsStringAsync(stoppingToken);
                                    using var polDoc = System.Text.Json.JsonDocument.Parse(polJson);
                                    var rulesJson = polDoc.RootElement.GetProperty("rules").GetRawText();

                                    // Apply atomically via DevicePolicyEngine
                                    if (_policyEngine is not null)
                                    {
                                        _policyEngine.ApplyPolicy(rulesJson);
                                        await IpcSystem.BroadcastLogAsync($"☁️ Cloud policy v{serverPolicyVersion} applied.");
                                    }

                                    // Cache policy locally
                                    Directory.CreateDirectory(ConfigManager.AppFolder);
                                    await File.WriteAllTextAsync(
                                        Path.Combine(ConfigManager.AppFolder, "policy_cache.json"), polJson, stoppingToken);

                                    SecurityConfigManager.Settings.CloudPolicyVersion = serverPolicyVersion;
                                    SecurityConfigManager.Settings.CloudSyncFailureCount = 0;
                                    SecurityConfigManager.Save();
                                }
                            }
                            catch (Exception pex)
                            {
                                SecurityConfigManager.Settings.CloudSyncFailureCount++;
                                SecurityConfigManager.Save();
                                _logger.LogWarning("[CloudSync:Policy] Non-fatal fetch error: {0}", pex.Message);
                                if (SecurityConfigManager.Settings.CloudSyncFailureCount >= 3)
                                    await IpcSystem.BroadcastLogAsync("⚠️ Cloud policy sync failed 3 times. Using cached policy.");
                            }
                        }
                    }

                    // ── Command Poll ──────────────────────────────────────────
                    using var cmdReq = new System.Net.Http.HttpRequestMessage(
                        System.Net.Http.HttpMethod.Get,
                        $"{SecurityConfigManager.Settings.CloudApiEndpoint}/api/command/pending");
                    cmdReq.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue(
                        "Bearer", SecurityConfigManager.Settings.DeviceApiToken);

                    var cmdResp = await client.SendAsync(cmdReq, stoppingToken);
                    if (cmdResp.IsSuccessStatusCode)
                    {
                        var cmdJson = await cmdResp.Content.ReadAsStringAsync(stoppingToken);
                        using var cmdDoc = System.Text.Json.JsonDocument.Parse(cmdJson);
                        foreach (var cmd in cmdDoc.RootElement.EnumerateArray())
                        {
                            var commandId = cmd.GetProperty("commandId").GetString();
                            var commandName = cmd.GetProperty("command").GetString();
                            string result = "Success";
                            try
                            {
                                switch (commandName)
                                {
                                    case "RefreshBlocklist":
                                        await _engine.UpdateBlocklistAsync();
                                        break;
                                    case "RestartEngine":
                                        _engine.Stop();
                                        _engine.Start();
                                        break;
                                    case "DiagnosticDump":
                                        var diagPath = Path.Combine(
                                            ConfigManager.AppFolder,
                                            $"diagnostics_{DateTime.UtcNow:yyyyMMdd_HHmmss}.json");
                                        await File.WriteAllTextAsync(diagPath,
                                            System.Text.Json.JsonSerializer.Serialize(new
                                            {
                                                timestamp = DateTime.UtcNow,
                                                totalQueries = MetricsManager.Current.TotalQueries,
                                                blockedQueries = MetricsManager.Current.BlockedQueries,
                                                engineRunning = _engine.IsRunning
                                            }), stoppingToken);
                                        break;
                                }
                            }
                            catch (Exception cex)
                            {
                                result = "Failed";
                                _logger.LogWarning("[CloudCmd] Command {0} failed: {1}", commandName, cex.Message);
                            }

                            // Ack command
                            try
                            {
                                using var ackReq = new System.Net.Http.HttpRequestMessage(
                                    System.Net.Http.HttpMethod.Post,
                                    $"{SecurityConfigManager.Settings.CloudApiEndpoint}/api/command/ack");
                                ackReq.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue(
                                    "Bearer", SecurityConfigManager.Settings.DeviceApiToken);
                                ackReq.Content = new System.Net.Http.StringContent(
                                    System.Text.Json.JsonSerializer.Serialize(new { commandId, result }),
                                    System.Text.Encoding.UTF8, "application/json");
                                await client.SendAsync(ackReq, stoppingToken);
                            }
                            catch (Exception aex)
                            {
                                _logger.LogWarning("[CloudCmd] Ack failed: {0}", aex.Message);
                            }
                        }
                    }
                }
                catch (OperationCanceledException) { break; }
                catch (Exception ex)
                {
                    _logger.LogWarning("[CloudSync:Heartbeat] Non-fatal error: {0}", ex.Message);
                }
            }
        }, stoppingToken);

        // Keep service alive (broadcast server runs independently as fire-and-forget above)
        await commandServer;

        } // end try
        catch (Exception ex)
        {
            var crashLog = $"[{DateTime.UtcNow:O}] Worker.ExecuteAsync fatal exception:{Environment.NewLine}{ex}{Environment.NewLine}";
            _logger.LogCritical(ex, "[Worker] Fatal exception — service is dying");
            try
            {
                Directory.CreateDirectory("/var/log/aegisdns");
                File.AppendAllText("/var/log/aegisdns/worker-crash.log", crashLog);
            }
            catch
            {
                // If we can't write the crash log, there's nothing more we can do.
            }
            throw;
        }
    }


    private async Task<IpcSystem.IpcPacket> OnIpcCommand(IpcSystem.IpcPacket packet)
    {
        _logger.LogDebug("[IPC] Received command: {Command}", packet.Command);

        return packet.Command switch
        {
            "GetStatus" => HandleGetStatusCommand(),
            "GetMetrics" => new IpcSystem.IpcPacket("MetricsResponse", JsonSerializer.Serialize(new { Total = MetricsManager.Current.TotalQueries, Blocked = MetricsManager.Current.BlockedQueries, CacheHits = MetricsManager.Current.CacheHits })),
            "GetHistory" => new IpcSystem.IpcPacket("HistoryResponse", JsonSerializer.Serialize(MetricsHistory.GetLast(60))),
            "Toggle" => await HandleToggleCommand(),
            "UpdateBlocklists" => await HandleUpdateBlocklistsCommand(),
            "XDP_DETACH" => HandleXdpDetach(),
            "XDP_RECONFIGURE" => await HandleXdpReconfigure(),
            _ => new IpcSystem.IpcPacket("Error", "Unknown Command")
        };
    }

    private IpcSystem.IpcPacket HandleGetStatusCommand()
    {
        string status = _engine.IsRunning ? "ONLINE" : "OFFLINE";
        var tier = LicenseManager.CurrentTier;
        _logger.LogInformation("[IPC] GetStatus -> status={Status}, serviceLicenseTier={Tier}", status, tier);
        return new IpcSystem.IpcPacket("StatusResponse", status);
    }

    private async Task<IpcSystem.IpcPacket> HandleUpdateBlocklistsCommand()
    {
        await _engine.UpdateBlocklistAsync();
        return new IpcSystem.IpcPacket("UpdateResponse", "OK");
    }

    private async Task<IpcSystem.IpcPacket> HandleToggleCommand()
    {
        await Task.Run(async () =>
        {
            if (_engine.IsRunning)
            {
                _tamperMonitor.Stop();
                if (OperatingSystem.IsLinux())
                {
                    AegisDNS.Core.Proxy.TrafficRedirector.Disable();
                    _proxyHost?.Stop();
                    _proxyHost = null;

                    AegisBpfLoader.Detach();
                    AegisXdpLoader.Detach();
                }
                _engine.Stop();
            }
            else
            {
                _engine.Start();
                _tamperMonitor.Start();

                if (OperatingSystem.IsLinux())
                {
                    // Phase 18 — HTTPS Proxy
                    if (HttpsProxyConfigManager.Settings.EnableHttpsProxy &&
                        LicenseManager.CurrentTier >= LicenseManager.LicenseTier.Pro)
                    {
                        if (AegisDNS.Core.Security.CertificateManager.IsCaInstalled())
                        {
                            try
                            {
                                _proxyHost = new AegisDNS.Core.Proxy.HttpsProxyHost(
                                    HttpsProxyConfigManager.Settings.ProxyPort,
                                    HttpsProxyConfigManager.Settings.MaxProxyConnections);
                                _proxyHost.Start();
                                AegisDNS.Core.Proxy.TrafficRedirector.Enable(HttpsProxyConfigManager.Settings.ProxyPort);
                                _engine.Broadcast("🔒 HTTPS Ad Interception active — URL patterns enabled");
                            }
                            catch (Exception ex)
                            {
                                _logger.LogError(ex, "[Proxy] Failed to start");
                                _engine.Broadcast($"⚠️ HTTPS Proxy failure: {ex.Message}");
                            }
                        }
                        else
                        {
                            _engine.Broadcast("⚠️ HTTPS Proxy disabled — CA certificate not installed");
                        }
                    }

                    if (XdpConfigManager.Settings.EnableEbpf)
                    {
                        string bpfObjPath = Path.Combine(AppContext.BaseDirectory, "kernel", "aegisdns.bpf.o");

                        if (File.Exists(bpfObjPath))
                        {
                            bool bpfLoaded = await AegisBpfLoader.LoadAndAttach(bpfObjPath, _engine);
                            if (bpfLoaded)
                                _engine.Broadcast("🔥 eBPF kernel hook active — maximum protection enabled");
                            else
                                _engine.Broadcast("⚠️ eBPF load failed — running in iptables mode");
                        }
                        else
                        {
                            _engine.Broadcast("⚠️ aegisdns.bpf.o not found — run install.sh to compile kernel program");
                        }
                    }
                }

                // Phase 15: XDP Ingress Shield (Enterprise only)
                await AttachXdpAsync();
            }
        });

        return new IpcSystem.IpcPacket("ToggleResponse", _engine.IsRunning ? "ONLINE" : "OFFLINE");
    }

    private async Task AttachXdpAsync()
    {
        if (!OperatingSystem.IsLinux()) return;

        var xdpMode = (XdpMode)XdpConfigManager.Settings.XdpMode;
        if (xdpMode == XdpMode.Off) return;

        string xdpObjPath = Path.Combine(AppContext.BaseDirectory, "xdp", "aegis_xdp.o");
        if (!File.Exists(xdpObjPath))
        {
            _engine.Broadcast("⚠️ aegis_xdp.o not found — run install.sh to compile XDP program");
            return;
        }

        bool loaded = await AegisXdpLoader.LoadAndAttach(
            xdpObjPath,
            XdpConfigManager.Settings.XdpInterface,
            xdpMode,
            _engine);

        if (loaded)
            _engine.Broadcast("⚡ XDP ingress shield active — kernel-level DNS response filtering enabled");
        else
            _engine.Broadcast("⚠️ XDP load failed — eBPF egress protection remains active");
    }

    private IpcSystem.IpcPacket HandleXdpDetach()
    {
        if (OperatingSystem.IsLinux())
            AegisXdpLoader.Detach();
        return new IpcSystem.IpcPacket("XdpResponse", "DETACHED");
    }

    private async Task<IpcSystem.IpcPacket> HandleXdpReconfigure()
    {
        if (OperatingSystem.IsLinux())
        {
            AegisXdpLoader.Detach();
            await AttachXdpAsync();
        }
        return new IpcSystem.IpcPacket("XdpResponse", "RECONFIGURED");
    }

    public override async Task StopAsync(CancellationToken cancellationToken)
    {
        _metricsTimer.Stop();
        _metricsTimer.Dispose();

        // Phase 11 — stop Extension API and Latency Monitor before engine
        _extensionApi?.Stop();
        _latencyMonitor?.Stop();

        await _pluginManager.ShutdownPluginsAsync();
        if (OperatingSystem.IsLinux())
        {
            AegisDNS.Core.Proxy.TrafficRedirector.Disable();
            _proxyHost?.Stop();

            AegisBpfLoader.Detach();
            AegisXdpLoader.Detach();
        }
        if (_webDashboard != null)
            await _webDashboard.StopAsync().ConfigureAwait(false);
        await base.StopAsync(cancellationToken);
    }
}
