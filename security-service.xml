using System;
using System.Diagnostics;
using System.Linq;
using System.Net.NetworkInformation;
using System.Runtime.InteropServices;
using System.Threading;
using System.Threading.Tasks;

using AegisDNS.BpfLoader;
using AegisDNS.Core;
using AegisDNS.XdpLoader;

namespace AegisDNS.Service.Src;

public class TamperMonitor
{
    private readonly AegisEngine _engine;
    private readonly Action<string> _broadcastAction;
    private CancellationTokenSource? _cts;

    public TamperMonitor(AegisEngine engine, Action<string> broadcastAction)
    {
        _engine = engine;
        _broadcastAction = broadcastAction;
    }

    public void Start()
    {
        if (_cts != null) return;
        _cts = new CancellationTokenSource();

        // Linux/Other: Use polling (WMI not available)
        Task.Run(() => MonitorLoop(_cts.Token), _cts.Token);
    }

    public void Stop()
    {
        _cts?.Cancel();
        _cts = null;
    }

    private async Task MonitorLoop(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            if (_engine.IsRunning)
            {
                CheckAndRepair();
                CheckBpfAttachment();
                CheckXdpAttachment();
            }
            await Task.Delay(5000, token); // Check every 5 seconds
        }
    }

    private void CheckAndRepair()
    {
        // Native Linux doesn't easily tampered like Windows System DNS since we use resolvectl
        // but we keep the stub if we switch back to tracking /etc/resolv.conf manually
    }

    private string DetectActiveInterface()
    {
        if (DnsConfigManager.Settings.PreferredAdapter != "Auto-Detect")
            return DnsConfigManager.Settings.PreferredAdapter;

        var active = NetworkInterface.GetAllNetworkInterfaces()
            .FirstOrDefault(ni => ni.OperationalStatus == OperationalStatus.Up &&
                                  ni.GetIPProperties().GatewayAddresses.Count > 0 &&
                                  ni.NetworkInterfaceType != NetworkInterfaceType.Loopback);

        return active?.Name ?? string.Empty;
    }

    private void RestoreLoopback(string interfaceName)
    {
        try
        {
            var psi = new ProcessStartInfo("resolvectl")
            {
                CreateNoWindow = true,
                UseShellExecute = false
            };
            psi.ArgumentList.Add("dns");
            psi.ArgumentList.Add(interfaceName);
            psi.ArgumentList.Add("127.0.0.1");
            Process.Start(psi)?.WaitForExit();
        }
        catch (Exception ex)
        {
            _broadcastAction($"⚠️ Restoration Failed: {ex.Message}");
        }
    }

    private void CheckBpfAttachment()
    {

        // Only check if BPF was successfully loaded on startup
        if (!AegisBpfLoader.WasLoaded) return;

        if (!AegisBpfLoader.IsAttached())
        {
            _broadcastAction("🚨 TAMPER DETECTED: eBPF kernel hook was detached! Reattaching...");

            // Attempt to reattach
            bool reattached = AegisBpfLoader.Reattach();
            if (reattached)
                _broadcastAction("🛡️ eBPF kernel hook reattached successfully");
            else
                _broadcastAction("❌ eBPF reattach failed — falling back to iptables redirect");
        }
    }

    private void CheckXdpAttachment()
    {

        // Only check if XDP was successfully loaded
        if (!AegisXdpLoader.WasLoaded) return;

        if (!AegisXdpLoader.IsAttached())
        {
            _broadcastAction("🚨 TAMPER DETECTED: XDP ingress hook was detached! Reattaching...");

            bool reattached = AegisXdpLoader.Reattach();
            if (reattached)
                _broadcastAction("🛡️ XDP ingress hook reattached successfully");
            else
                _broadcastAction("❌ XDP reattach failed — eBPF egress protection remains active");
        }
    }
}
