using System;
using System.Linq;
using System.Threading;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.Core.Ai;
using AegisDNS.Core.Utilities;

using Microsoft.Extensions.Hosting;
using Microsoft.Extensions.Logging;

namespace AegisDNS.Service.Src;

public class WeeklyReportWorker : BackgroundService
{
    private readonly ILogger<WeeklyReportWorker> _logger;
    private DateOnly _lastReported = DateOnly.MinValue;

    public WeeklyReportWorker(ILogger<WeeklyReportWorker> logger)
    {
        _logger = logger;
    }

    protected override async Task ExecuteAsync(CancellationToken stoppingToken)
    {
        while (!stoppingToken.IsCancellationRequested)
        {
            try
            {
                var now = DateTime.Now;
                // e.g. Sunday 8 PM
                if (now.DayOfWeek == DayOfWeek.Sunday && now.Hour == 20)
                {
                    var today = DateOnly.FromDateTime(DateTime.Now);
                    if (_lastReported == today)
                    {
                        await Task.Delay(TimeSpan.FromMinutes(10), stoppingToken);
                        continue;
                    }
                    _lastReported = today;

                    // Basic debounce using Task.Delay so it only runs once in that hour
                    var topBlocked = TopDomainsTracker.GetTopBlocked().Select(k => k.Domain).Take(10);
                    var topAllowed = TopDomainsTracker.GetTopAllowed().Select(k => k.Domain).Take(10);

                    if (topBlocked.Any() || topAllowed.Any())
                    {
                        await AiReportsManager.GenerateWeeklyReportAsync(topBlocked, topAllowed);
                    }

                    await Task.Delay(TimeSpan.FromHours(1), stoppingToken);
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "[WeeklyReportWorker] Error.");
            }

            // Check every 10 minutes
            await Task.Delay(TimeSpan.FromMinutes(10), stoppingToken);
        }
    }
}
