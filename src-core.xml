<file path="src/AegisDNS.Core/Monitoring/DomainRoleManager.cs">
using System;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Linq;

namespace AegisDNS.Core.Monitoring;

/// <summary>
/// Thread-safe storage and retrieval of Domain Role Records.
/// </summary>
public class DomainRoleManager
{
    // The master dictionary updated asynchronously by the scoring pipeline.
    private readonly ConcurrentDictionary<string, DomainRoleRecord> _roles = new(StringComparer.OrdinalIgnoreCase);

    /// <summary>
    /// Retrieves a point-in-time snapshot of the domain's current behavioral record.
    /// Returns null if the domain has no historical profiling yet.
    /// This is safe and fast for the synchronous resolver path.
    /// </summary>
    public DomainRoleRecord? GetRoleSnapshot(string domain)
    {
        if (_roles.TryGetValue(domain, out var record))
        {
            return record;
        }
        return null;
    }

    /// <summary>
    /// Fetches or initializes a role record for updating within the async pipeline.
    /// </summary>
    public DomainRoleRecord GetOrCreateRecord(string domain)
    {
        return _roles.GetOrAdd(domain, d => new DomainRoleRecord(d));
    }

    /// <summary>
    /// Returns all records that are currently flagged for enforcement based on their active score thresholds.
    /// </summary>
    public IReadOnlyCollection<string> GetActivelyBlockedDomains()
    {
        return _roles.Values
            .Where(r => r.ShouldBlock())
            .Select(r => r.Domain)
            .ToList()
            .AsReadOnly();
    }

    /// <summary>
    /// Updates the record explicitly. Since we modify object references returned by GetOrCreateRecord, 
    /// this usually isn't necessary unless struct copies become involved, but exists for completeness.
    /// </summary>
    public void UpdateRecord(DomainRoleRecord updatedRecord)
    {
        _roles.AddOrUpdate(updatedRecord.Domain, updatedRecord, (_, _) => updatedRecord);
    }
}
