<file path="src/AegisDNS.Core/Security/CertificateManager.cs">
using System;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Security.Cryptography;
using System.Security.Cryptography.X509Certificates;
using System.Text;
using System.Threading.Tasks;

using AegisDNS.Licensing;

namespace AegisDNS.Core.Security;

/// <summary>
/// Phase 18 — Local CA Certificate Manager.
/// Manages the generation and installation of the local root CA used for HTTPS interception.
/// Also handles dynamic generation of per-host ECDSA P-256 certificates.
/// </summary>
public static class CertificateManager
{
    private static readonly string CaDir = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
        ".config", "aegisdns", "ca");

    private static readonly string PfxPath = Path.Combine(CaDir, "aegisdns-ca.pfx");
    private static readonly string PemPath = Path.Combine(CaDir, "aegisdns-ca.pem");
    private static readonly string PassphrasePath = Path.Combine(CaDir, "ca.key.token");

    private static readonly ConcurrentDictionary<string, (X509Certificate2 Cert, DateTime Expiry)> _certCache = new();

    private static X509Certificate2? _caCert;

    static CertificateManager()
    {
        if (!Directory.Exists(CaDir))
            Directory.CreateDirectory(CaDir);
    }

    /// <summary>
    /// Gets or generates the local CA certificate.
    /// </summary>
    public static X509Certificate2 GetOrGenerateCa()
    {
        if (_caCert != null) return _caCert;

        if (File.Exists(PfxPath))
        {
            try
            {
                string? passphrase = AesGcmTokenStore.Decrypt(PassphrasePath);
                if (passphrase != null)
                {
                    _caCert = X509CertificateLoader.LoadPkcs12FromFile(PfxPath, passphrase, X509KeyStorageFlags.Exportable);
                    return _caCert;
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[CertificateManager] Failed to load CA: {ex.Message}");
            }
        }

        return GenerateCa();
    }

    private static X509Certificate2 GenerateCa()
    {
        Debug.WriteLine("[CertificateManager] Generating new Local CA...");

        using var rsa = RSA.Create(2048);
        var request = new CertificateRequest(
            "CN=AegisDNS Local CA, O=AegisDNS",
            rsa,
            HashAlgorithmName.SHA256,
            RSASignaturePadding.Pkcs1);

        request.CertificateExtensions.Add(
            new X509BasicConstraintsExtension(true, false, 0, true));

        request.CertificateExtensions.Add(
            new X509KeyUsageExtension(
                X509KeyUsageFlags.KeyCertSign | X509KeyUsageFlags.CrlSign,
                true));

        var notBefore = DateTimeOffset.UtcNow.AddDays(-1);
        var notAfter = notBefore.AddYears(10);

        var cert = request.CreateSelfSigned(notBefore, notAfter);

        // Export with a random passphrase
        string passphrase = Guid.NewGuid().ToString("N");
        byte[] pfxData = cert.Export(X509ContentType.Pfx, passphrase);

        File.WriteAllBytes(PfxPath, pfxData);
        if (OperatingSystem.IsLinux())
            File.SetUnixFileMode(PfxPath, UnixFileMode.UserRead | UnixFileMode.UserWrite);

        // Store passphrase securely
        AesGcmTokenStore.Encrypt(passphrase, PassphrasePath);

        // Export public PEM for trust store installation
        string pem = cert.ExportCertificatePem();
        File.WriteAllText(PemPath, pem);
        if (OperatingSystem.IsLinux())
            File.SetUnixFileMode(PemPath, UnixFileMode.UserRead | UnixFileMode.UserWrite);

        _caCert = X509CertificateLoader.LoadPkcs12(pfxData, passphrase, X509KeyStorageFlags.Exportable);
        return _caCert;
    }

    /// <summary>
    /// Installs the CA certificate into the system trust store using pkexec for elevation.
    /// </summary>
    public static async Task<bool> InstallCaCertAsync()
    {
        if (!File.Exists(PemPath)) GetOrGenerateCa();

        return await Task.Run(() =>
        {
            try
            {
                string targetPath = "/usr/local/share/ca-certificates/aegisdns-ca.crt";
                string updateCmd = "update-ca-certificates";

                // Check for Fedora/RHEL path
                if (Directory.Exists("/etc/pki/ca-trust/source/anchors/"))
                {
                    targetPath = "/etc/pki/ca-trust/source/anchors/aegisdns-ca.crt";
                    updateCmd = "update-ca-trust";
                }

                var psi = new ProcessStartInfo("pkexec")
                {
                    UseShellExecute = false,
                    CreateNoWindow = true
                };

                // Use 'sh -c' to combine commands under sudo/pkexec
                psi.ArgumentList.Add("sh");
                psi.ArgumentList.Add("-c");
                psi.ArgumentList.Add($"cp \"{PemPath}\" \"{targetPath}\" && {updateCmd}");

                var process = Process.Start(psi);
                process?.WaitForExit();

                return process?.ExitCode == 0;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[CertificateManager] Installation failed: {ex.Message}");
                return false;
            }
        });
    }

    /// <summary>
    /// Removes the CA certificate from the system trust store.
    /// </summary>
    public static async Task<bool> RemoveCaCertAsync()
    {
        return await Task.Run(() =>
        {
            try
            {
                string targetPath = "/usr/local/share/ca-certificates/aegisdns-ca.crt";
                string updateCmd = "update-ca-certificates";

                if (File.Exists("/etc/pki/ca-trust/source/anchors/aegisdns-ca.crt"))
                {
                    targetPath = "/etc/pki/ca-trust/source/anchors/aegisdns-ca.crt";
                    updateCmd = "update-ca-trust";
                }

                var psi = new ProcessStartInfo("pkexec")
                {
                    UseShellExecute = false,
                    CreateNoWindow = true
                };

                psi.ArgumentList.Add("sh");
                psi.ArgumentList.Add("-c");
                psi.ArgumentList.Add($"rm -f \"{targetPath}\" && {updateCmd}");

                var process = Process.Start(psi);
                process?.WaitForExit();

                return process?.ExitCode == 0;
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[CertificateManager] Removal failed: {ex.Message}");
                return false;
            }
        });
    }

    /// <summary>
    /// Generates a short-lived ECDSA P-256 certificate for the specified hostname.
    /// Signed by the local CA.
    /// </summary>
    public static X509Certificate2 GenerateHostCert(string hostname)
    {
        if (_certCache.TryGetValue(hostname, out var cached) && cached.Expiry > DateTime.UtcNow.AddMinutes(5))
        {
            return cached.Cert;
        }

        var ca = GetOrGenerateCa();

        using var ecdsa = ECDsa.Create(ECCurve.NamedCurves.nistP256);
        var request = new CertificateRequest(
            $"CN={hostname}",
            ecdsa,
            HashAlgorithmName.SHA256);

        var sanBuilder = new SubjectAlternativeNameBuilder();
        sanBuilder.AddDnsName(hostname);
        request.CertificateExtensions.Add(sanBuilder.Build());

        // Host certs are NOT CAs
        request.CertificateExtensions.Add(new X509BasicConstraintsExtension(false, false, 0, true));

        // Key usage for TLS server
        request.CertificateExtensions.Add(new X509KeyUsageExtension(X509KeyUsageFlags.DigitalSignature, true));
        request.CertificateExtensions.Add(new X509EnhancedKeyUsageExtension(
            new OidCollection { new Oid("1.3.6.1.5.5.7.3.1") }, // Server Auth
            false));

        var notBefore = DateTimeOffset.UtcNow.AddMinutes(-5);
        var notAfter = notBefore.AddHours(24);

        // Serial number generation (must be positive)
        byte[] serialNumber = new byte[8];
        RandomNumberGenerator.Fill(serialNumber);
        serialNumber[0] &= 0x7F; // Ensure positive

        // Sign with CA
        using var hostCert = request.Create(ca, notBefore, notAfter, serialNumber);

        // We MUST associate the private key with the certificate for SslStream to use it.
        var certWithKey = hostCert.CopyWithPrivateKey(ecdsa);

        _certCache[hostname] = (certWithKey, notAfter.UtcDateTime);
        return certWithKey;
    }

    /// <summary>
    /// Checks if the CA certificate is installed in the system trust store.
    /// </summary>
    public static bool IsCaInstalled()
    {
        if (File.Exists("/usr/local/share/ca-certificates/aegisdns-ca.crt")) return true;
        if (File.Exists("/etc/pki/ca-trust/source/anchors/aegisdns-ca.crt")) return true;

        return false;
    }
}
