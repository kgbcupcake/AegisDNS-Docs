using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Net.NetworkInformation;

namespace AegisDNS.Core.Platform;

public class LinuxDnsManager : ISystemDnsManager
{
    private readonly Action<string> _logger;
    private List<string> _originalDns = new();

    public LinuxDnsManager(Action<string> logger)
    {
        _logger = logger;
    }

    public void SetDns(string ip)
    {
        try
        {
            string interfaceName = DetectActiveInterface();
            if (string.IsNullOrEmpty(interfaceName))
            {
                _logger("⚠️ No active network interface detected for DNS configuration.");
                return;
            }

            _originalDns = GetDnsServers(interfaceName);
            _logger($"🛠️ Applying DNS settings ({ip}) to {interfaceName}...");

            // Try resolvectl first (standard on systemd distros)
            if (HasCommand("resolvectl"))
            {
                int rc1 = RunCommand("resolvectl", ["dns", interfaceName, ip]);
                int rc2 = RunCommand("resolvectl", ["domain", interfaceName, "~."]);
                if (rc1 == 0 && rc2 == 0)
                {
                    _logger("✅ DNS configured via resolvectl.");
                }
                else
                {
                    _logger($"⚠️ resolvectl failed (exit {rc1},{rc2}). Falling back to /etc/resolv.conf...");
                    WriteResolvConf(ip);
                }
            }
            else
            {
                _logger("⚠️ resolvectl not found. Falling back to /etc/resolv.conf...");
                WriteResolvConf(ip);
            }

            // Tell NetworkManager to pin DNS to 127.0.0.1 via the connection profile.
            string? connName = GetNmConnectionName(interfaceName);
            if (connName != null)
            {
                RunNmcli(interfaceName, ["con", "modify", connName, "ipv4.dns", "127.0.0.1", "ipv4.ignore-auto-dns", "yes", "ipv4.dns-priority", "-100"]);
                RunNmcli(interfaceName, ["device", "reapply", interfaceName]);
            }
            else
            {
                _logger($"⚠️ No active NetworkManager connection found for {interfaceName} — nmcli DNS pin skipped.");
            }
        }
        catch (Exception ex)
        {
            _logger($"❌ LinuxDnsManager.SetDns Error: {ex.Message}");
        }
    }

    public void RestoreDns()
    {
        try
        {
            string interfaceName = DetectActiveInterface();
            if (string.IsNullOrEmpty(interfaceName)) return;

            bool restoredViaResolvectl = false;
            if (HasCommand("resolvectl"))
            {
                _logger($"🛠️ Restoring DNS settings on {interfaceName} via resolvectl...");
                int rc1 = RunCommand("resolvectl", ["dns", interfaceName, ""]);
                int rc2 = RunCommand("resolvectl", ["domain", interfaceName, ""]);
                restoredViaResolvectl = rc1 == 0 && rc2 == 0;
                if (!restoredViaResolvectl)
                    _logger($"⚠️ resolvectl restore failed (exit {rc1},{rc2}). Falling back to backup...");
            }

            // Release NetworkManager's DNS pin so DHCP DNS is restored after con up.
            string? connName = GetNmConnectionName(interfaceName);
            if (connName != null)
            {
                RunNmcli(interfaceName, ["con", "modify", connName, "ipv4.dns", "", "ipv4.ignore-auto-dns", "no", "ipv4.dns-priority", "0"]);
                RunNmcli(interfaceName, ["device", "reapply", interfaceName]);
            }
            else
            {
                _logger($"⚠️ No active NetworkManager connection found for {interfaceName} — nmcli DNS restore skipped.");
            }

            if (!restoredViaResolvectl && File.Exists("/etc/resolv.conf.bak"))
            {
                _logger("🛠️ Restoring /etc/resolv.conf from backup...");
                File.Copy("/etc/resolv.conf.bak", "/etc/resolv.conf", true);
            }
            _logger("✅ DNS restored successfully.");
        }
        catch (Exception ex)
        {
            _logger($"⚠️ LinuxDnsManager.RestoreDns Error: {ex.Message}");
        }
    }

    public string GetCurrentDns()
    {
        string interfaceName = DetectActiveInterface();
        if (string.IsNullOrEmpty(interfaceName)) return "Unknown";

        var dnsServers = GetDnsServers(interfaceName);
        return dnsServers.Any() ? string.Join(", ", dnsServers) : "DHCP/Unknown";
    }

    private string DetectActiveInterface()
    {
        var active = NetworkInterface.GetAllNetworkInterfaces()
            .FirstOrDefault(ni => ni.OperationalStatus == OperationalStatus.Up &&
                                  ni.GetIPProperties().GatewayAddresses.Count > 0 &&
                                  ni.NetworkInterfaceType != NetworkInterfaceType.Loopback);

        return active?.Name ?? string.Empty;
    }

    private List<string> GetDnsServers(string interfaceName)
    {
        var active = NetworkInterface.GetAllNetworkInterfaces()
            .FirstOrDefault(ni => ni.Name == interfaceName);

        if (active != null)
        {
            return active.GetIPProperties().DnsAddresses.Select(a => a.ToString()).ToList();
        }
        return new List<string>();
    }

    private bool HasCommand(string cmd)
    {
        try
        {
            var psi = new ProcessStartInfo("which")
            {
                RedirectStandardOutput = true,
                UseShellExecute = false,
                CreateNoWindow = true
            };
            psi.ArgumentList.Add(cmd);
            using var proc = Process.Start(psi);
            proc?.WaitForExit();
            return proc?.ExitCode == 0;
        }
        catch { return false; }
    }

    private int RunCommand(string command, string[] args)
    {
        var psi = new ProcessStartInfo(command)
        {
            CreateNoWindow = true,
            UseShellExecute = false
        };
        foreach (var arg in args)
            psi.ArgumentList.Add(arg);

        var proc = Process.Start(psi);
        proc?.WaitForExit(5000);
        return proc?.ExitCode ?? -1;
    }

    // Returns the NetworkManager connection name whose DEVICE matches interfaceName,
    // by parsing `nmcli -t -f NAME,DEVICE con show --active` (output: "Name:device\n").
    // Returns null if nmcli is unavailable or no matching connection is found.
    private string? GetNmConnectionName(string interfaceName)
    {
        try
        {
            var psi = new ProcessStartInfo("nmcli")
            {
                RedirectStandardOutput = true,
                UseShellExecute = false,
                CreateNoWindow = true
            };
            foreach (var arg in new[] { "-t", "-f", "NAME,DEVICE", "con", "show", "--active" })
                psi.ArgumentList.Add(arg);

            using var proc = Process.Start(psi);
            if (proc == null) return null;
            string output = proc.StandardOutput.ReadToEnd();
            proc.WaitForExit(5000);

            foreach (var line in output.Split('\n', StringSplitOptions.RemoveEmptyEntries))
            {
                // Format: "Connection Name:device"  (colon-separated, terse mode)
                int sep = line.LastIndexOf(':');
                if (sep < 0) continue;
                string device = line[(sep + 1)..];
                if (string.Equals(device, interfaceName, StringComparison.Ordinal))
                    return line[..sep];
            }
        }
        catch (Exception ex)
        {
            _logger($"⚠️ GetNmConnectionName failed: {ex.Message} (non-fatal).");
        }
        return null;
    }

    private void RunNmcli(string interfaceName, string[] args)
    {
        try
        {
            int rc = RunCommand("nmcli", args);
            if (rc != 0)
                _logger($"⚠️ nmcli {string.Join(" ", args)} exited {rc} (non-fatal).");
        }
        catch (Exception ex)
        {
            _logger($"⚠️ nmcli call failed for {interfaceName}: {ex.Message} (non-fatal).");
        }
    }

    private void WriteResolvConf(string ip)
    {
        const string resolvPath = "/etc/resolv.conf";
        const string backupPath = "/etc/resolv.conf.bak";

        if (File.Exists(resolvPath))
        {
            File.Copy(resolvPath, backupPath, overwrite: true);
        }

        string existing = File.Exists(resolvPath) ? File.ReadAllText(resolvPath) : "";
        // Remove existing AegisDNS header if present to avoid duplicating
        if (existing.StartsWith("# Generated by AegisDNS\n"))
        {
            existing = string.Join("\n", existing.Split('\n').Skip(2));
        }
        string content = $"# Generated by AegisDNS\nnameserver {ip}\n" + existing;
        File.WriteAllText(resolvPath, content);
    }
}
