using AegisDNS.Core.Utilities;

namespace AegisDNS.Core.Ai.Providers;

/// <summary>
/// Gemini provider — uses Google's Generative Language API for DNS threat analysis.
/// </summary>
public class GeminiProvider : IAiProvider
{


    public Task<string> AnalyzeAsync(IReadOnlyCollection<QueryHistoryEntry> history, AiConfig settings)
    {
        if (history.Count == 0) return Task.FromResult("No queries to analyze.");
        return AskAsync(PromptBuilder.Build(history), settings);
    }

    public async Task<string> AskAsync(string prompt, AiConfig settings)
    {
        string apiKey = SecureCredentialStore.GetCredential("Gemini")?.ApiKey ?? "";
        if (string.IsNullOrEmpty(apiKey))
            return "CLEAR: Gemini provider requires an API key. Configure in AI Sentinel Settings.";

        var requestBody = new
        {
            contents = new[]
            {
                new { parts = new[] { new { text = prompt } } }
            }
        };

        string model = string.IsNullOrEmpty(settings.AiModel) ? "gemini-pro" : settings.AiModel;
        string url = $"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={apiKey}";

        var content = new StringContent(JsonSerializer.Serialize(requestBody), Encoding.UTF8, "application/json");
        var response = await SharedHttpClient.Instance.PostAsync(url, content);
        response.EnsureSuccessStatusCode();

        var json = await response.Content.ReadAsStringAsync();
        using var doc = JsonDocument.Parse(json);

        if (doc.RootElement.TryGetProperty("candidates", out var candidates) && candidates.GetArrayLength() > 0)
        {
            var firstCandidate = candidates[0];
            if (firstCandidate.TryGetProperty("content", out var contentObj) &&
                contentObj.TryGetProperty("parts", out var parts) &&
                parts.GetArrayLength() > 0)
            {
                return parts[0].GetProperty("text").GetString() ?? "Empty response from Gemini.";
            }
        }

        return "Unexpected response format from Gemini.";
    }
}
