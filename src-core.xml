using System;

namespace AegisDNS.Core.Monitoring;

public enum ThreatConfidence
{
    Low,      // Log only — MonetizationScore 0.50–0.64
    Medium,   // Log + notify — MonetizationScore 0.65–0.74
    High,     // Auto-learn + notify — MonetizationScore 0.75–0.89
    Critical  // Immediate block + prominent notification — MonetizationScore >= 0.90
}

public static class ThreatConfidenceEvaluator
{
    public static ThreatConfidence Evaluate(DomainRoleRecord record)
    {
        if (!record.ShouldBlock()) return ThreatConfidence.Low;

        return record.MonetizationScore switch
        {
            >= 0.90 => ThreatConfidence.Critical,
            >= 0.75 => ThreatConfidence.High,
            >= 0.65 => ThreatConfidence.Medium,
            _ => ThreatConfidence.Low
        };
    }
}
