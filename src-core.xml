<file path="src/AegisDNS.Core/Utilities/SafeListingManager.cs">
using System;
using System.Collections.Generic;
using System.Collections.Immutable;
using System.IO;
using System.Linq;
using System.Text.Json;

namespace AegisDNS.Core.Utilities;

/// <summary>
/// Manages domains reported as false positives.
/// Automatically adds them to the Allowlist to bypass blocking.
/// </summary>
public static class SafeListingManager
{
    private static readonly string AppFolder = Path.Combine(
        Environment.GetEnvironmentVariable("XDG_DATA_HOME")
            ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), ".local", "share", "aegisdns"),
        "AegisDNS");
    private static readonly string FpPath = Path.Combine(AppFolder, "false_positives.json");

    private static ImmutableHashSet<string> _falsePositives = ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase);

    static SafeListingManager()
    {
        Load();
    }

    public static void Report(string domain)
    {
        if (string.IsNullOrWhiteSpace(domain)) return;
        domain = domain.Trim().ToLowerInvariant();

        ImmutableInterlocked.Update(ref _falsePositives, current => current.Add(domain));

        // When reported as safe, actually add to allowlist immediately
        AllowlistManager.Add(domain);

        Save();
    }

    public static bool IsReported(string domain)
    {
        return _falsePositives.Contains(domain);
    }

    private static void Load()
    {
        try
        {
            if (!File.Exists(FpPath)) return;

            string json = File.ReadAllText(FpPath);
            if (string.IsNullOrWhiteSpace(json)) return;

            List<string>? loaded = null;
            try
            {
                loaded = JsonSerializer.Deserialize<List<string>>(json);
            }
            catch (JsonException ex)
            {
                System.Diagnostics.Debug.WriteLine($"⚠️ SafeListingManager: JSON corruption in {FpPath}: {ex.Message}");
            }

            if (loaded != null)
            {
                ImmutableInterlocked.Update(ref _falsePositives, _ => loaded.ToImmutableHashSet(StringComparer.OrdinalIgnoreCase));
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"⚠️ Failed to load false positives: {ex.Message}");
        }
    }

    private static void Save()
    {
        try
        {
            if (!Directory.Exists(AppFolder))
            {
                Directory.CreateDirectory(AppFolder);
            }

            var list = _falsePositives.ToList();
            string json = JsonSerializer.Serialize(list, new JsonSerializerOptions { WriteIndented = true });
            File.WriteAllText(FpPath, json);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Failed to save false positives: {ex.Message}");
        }
    }
}
