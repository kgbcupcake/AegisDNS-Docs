using System;
using System.Collections.Generic;
using System.Linq;
using System.Net.Http;
using System.Net.Http.Headers;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;

using AegisDNS.Core.Ai;
using AegisDNS.Core.Monitoring;
using AegisDNS.Core.Utilities;

namespace AegisDNS.Core.Ai.Providers;

public class OpenRouterProvider : IAiProvider
{

    public async Task<string> AnalyzeAsync(IReadOnlyCollection<QueryHistoryEntry> history, AiConfig settings)
    {
        // 1. Get API Key from Encrypted Vault
        var cred = SecureCredentialStore.GetCredential("OpenRouter");
        string apiKey = cred?.ApiKey ?? "";

        if (string.IsNullOrWhiteSpace(apiKey))
        {
            return "⚠️ OpenRouter API key not configured. Please set it in AI Sentinel Settings.";
        }

        // 2. Prepare Request
        var requestBody = new
        {
            model = !string.IsNullOrEmpty(settings.AiModel) ? settings.AiModel : "openai/gpt-3.5-turbo",
            messages = new[]
            {
                new { role = "system", content = "You are an AI security analyst for AegisDNS. Analyze the following DNS query logs for suspicious activity. Provide a concise summary of threats." },
                new { role = "user", content = FormatHistory(history) }
            },
            temperature = 0.7
        };

        var json = JsonSerializer.Serialize(requestBody);
        var content = new StringContent(json, Encoding.UTF8, "application/json");

        var request = new HttpRequestMessage(HttpMethod.Post, "https://openrouter.ai/api/v1/chat/completions");
        request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", apiKey);
        // OpenRouter specific headers for rankings/stats (optional but recommended)
        request.Headers.Add("HTTP-Referer", "https://github.com/kgbcupcake/AegisDNS");
        request.Headers.Add("X-Title", "AegisDNS");
        request.Content = content;

        // 3. Send & Parse
        try
        {
            var response = await SharedHttpClient.Instance.SendAsync(request);
            string responseString = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                return $"❌ OpenRouter Error ({response.StatusCode}): {responseString}";
            }

            using var doc = JsonDocument.Parse(responseString);
            var root = doc.RootElement;
            if (root.TryGetProperty("choices", out var choices) && choices.GetArrayLength() > 0)
            {
                var firstChoice = choices[0];
                if (firstChoice.TryGetProperty("message", out var message) &&
                    message.TryGetProperty("content", out var contentElem))
                {
                    return contentElem.GetString()?.Trim() ?? "No analysis returned.";
                }
            }
            return "❌ Failed to parse OpenRouter response.";
        }
        catch (Exception ex)
        {
            return $"❌ Exception: {ex.Message}";
        }
    }

    private string FormatHistory(IReadOnlyCollection<QueryHistoryEntry> history)
    {
        var sb = new StringBuilder();
        foreach (var entry in history.TakeLast(20))
        {
            sb.AppendLine($"[{entry.Timestamp:HH:mm:ss}] {entry.Domain} - {(entry.IsBlocked ? "BLOCKED" : "ALLOWED")}");
        }
        return sb.ToString();
    }
}
