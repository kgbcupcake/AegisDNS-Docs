<file path="src/AegisDNS.Core/Proxy/HttpsProxyHost.cs">
using System;
using System.Buffers;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Net;
using System.Net.Security;
using System.Net.Sockets;
using System.Security.Authentication;
using System.Security.Cryptography.X509Certificates;
using System.Threading;
using System.Threading.Tasks;

using AegisDNS.Core.Security;
using AegisDNS.Licensing;

namespace AegisDNS.Core.Proxy;

/// <summary>
/// Phase 18 — HTTPS Proxy Host.
/// Listens for redirected HTTPS traffic and delegates to ProxyConnectionHandler.
/// </summary>
public class HttpsProxyHost
{
    private TcpListener? _listener;
    private CancellationTokenSource? _cts;
    private readonly int _port;
    private readonly int _maxConnections;
    private int _currentConnections;

    public int ActiveConnections => _currentConnections;

    public HttpsProxyHost(int port = 8443, int maxConnections = 100)
    {
        _port = port;
        _maxConnections = maxConnections;
    }

    public void Start()
    {
        if (_listener != null) return;

        try
        {
            _listener = new TcpListener(IPAddress.Loopback, _port);
            _listener.Start();
            _cts = new CancellationTokenSource();

            _ = AcceptLoopAsync(_cts.Token);

            Debug.WriteLine($"[HttpsProxyHost] Listening on 127.0.0.1:{_port}");
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[HttpsProxyHost] Failed to start: {ex.Message}");
            _listener = null;
        }
    }

    public void Stop()
    {
        _cts?.Cancel();
        _listener?.Stop();
        _listener = null;
        Debug.WriteLine("[HttpsProxyHost] Stopped.");
    }

    private async Task AcceptLoopAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            try
            {
                var client = await _listener!.AcceptTcpClientAsync(ct);

                if (_currentConnections >= _maxConnections)
                {
                    client.Close();
                    continue;
                }

                _ = HandleConnectionAsync(client, ct);
            }
            catch (OperationCanceledException) { break; }
            catch (Exception ex)
            {
                Debug.WriteLine($"[HttpsProxyHost] Accept error: {ex.Message}");
            }
        }
    }

    private async Task HandleConnectionAsync(TcpClient client, CancellationToken ct)
    {
        Interlocked.Increment(ref _currentConnections);
        MetricsManager.IncrementProxyRequests(); // Assuming this will be added in 18.9

        try
        {
            using (client)
            {
                var handler = new ProxyConnectionHandler(client);
                await handler.ProcessAsync(ct);
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[HttpsProxyHost] Connection error: {ex.Message}");
        }
        finally
        {
            Interlocked.Decrement(ref _currentConnections);
        }
    }
}
