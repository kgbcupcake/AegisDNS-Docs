using System;
using System.IO;
using System.Text.Json;
using System.Text.Json.Serialization;

namespace AegisDNS.Core;

public enum UpstreamMode { Udp, DoH, DoT }
public enum LinuxDnsMethod { Resolvectl, ResolvConf, Auto }

[JsonSerializable(typeof(AppSettings))]
internal partial class AppConfigJsonContext : JsonSerializerContext
{
}

public class AppSettings
{
    public bool StartOnBoot { get; set; } = false;
    public bool StartMinimized { get; set; } = false;
    public bool MinimizeToTray { get; set; } = true;
    public bool EnableNeonGlow { get; set; } = true;
    public bool ShowTrafficPreview { get; set; } = true;
    public bool AutoUpdateBlocklists { get; set; } = true;
    public bool LogDnsRequests { get; set; } = true;

    // Pro-level customizations
    public string AccentColor { get; set; } = "#00FFFF"; // Custom Neon Cyan
    public int CacheSize { get; set; } = 1024;           // DNS Cache size in MB
    public bool StealthMode { get; set; } = false;       // Hide from taskbar/tray
    public string UpstreamPreset { get; set; } = "Google"; // Google, Cloudflare, OpenDNS
    public bool TelemetryOptIn { get; set; } = false;    // Explicit consent for AegisDNS telemetry

    // Phase 10 — AI Intelligence Layer
    public bool EnableWeeklySummary { get; set; } = true;  // Show weekly report on launch
    public bool EnableDailySummary { get; set; } = true;   // Show daily briefing on launch

    // Phase 10B — VFX & Appearance Engine

    // Glow
    public double GlowIntensity { get; set; } = 0.8;        // 0.0 - 1.0
    public double GlowRadius { get; set; } = 12.0;           // pixels
    public string GlowColor { get; set; } = "#00FFFF";       // hex

    // Background effects
    public string BackgroundEffect { get; set; } = "None";   // "None" | "DataStream" | "NetworkNodes" | "PulseWave"
    public bool CrtModeEnabled { get; set; } = false;

    // Window material
    public string WindowBackdrop { get; set; } = "Solid";    // "Solid" | "Acrylic" | "Mica"
    public double BackgroundOpacity { get; set; } = 1.0;     // 0.4 - 1.0

    // Accent gradient
    public string AccentColorPrimary { get; set; } = "#00FFFF";
    public string AccentColorSecondary { get; set; } = "#0080FF";

    // Typography
    public string LogFontFamily { get; set; } = "Consolas";
    public bool StrictMonospaceLog { get; set; } = true;

    // Audio
    public string AudioPack { get; set; } = "Muted";         // "Muted" | "SciFiTerminal" | "MinimalistClicks"
    public bool ThreatAlertSound { get; set; } = false;

    // Theme profiles
    public string ActiveThemeName { get; set; } = "Default";
}

public static class ConfigManager
{
    // Config lives unconditionally at /var/lib/aegisdns — avoids SELinux
    // config_home_t restrictions that block service-side writes under btrfs.
    public static readonly string AppFolder = "/var/lib/aegisdns";
    private static readonly string ConfigPath = Path.Combine(AppFolder, "user_config.json");

    public static AppSettings Settings { get; private set; } = new();

    private static string ResolveHomeDir()
    {
        string? aegisUiUser = Environment.GetEnvironmentVariable("AEGIS_UI_USER");
        if (!string.IsNullOrWhiteSpace(aegisUiUser))
            return Path.Combine("/home", aegisUiUser);
        return Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
    }

    static ConfigManager()
    {
        Console.Error.WriteLine($"[AegisDNS] Config base: {AppFolder}");
        Load();
    }

    public static void Load()
    {
        // Migrate from old ~/.config/AegisDNS/ path if new path has no config yet
        string homeConfigPath = Path.Combine(ResolveHomeDir(), ".config", "AegisDNS", "user_config.json");
        if (!File.Exists(ConfigPath) && File.Exists(homeConfigPath))
        {
            try
            {
                if (!Directory.Exists(AppFolder)) Directory.CreateDirectory(AppFolder);
                File.Copy(homeConfigPath, ConfigPath);
                System.Diagnostics.Debug.WriteLine($"Migrated config from {homeConfigPath}");
            }
            catch { }
        }

        // Migrate from legacy ~/Documents/AegisDNS/user_config.json
        string documentsLegacyPath = Path.Combine(ResolveHomeDir(), "Documents", "AegisDNS", "user_config.json");
        if (!File.Exists(ConfigPath) && File.Exists(documentsLegacyPath))
        {
            try
            {
                if (!Directory.Exists(AppFolder)) Directory.CreateDirectory(AppFolder);
                File.Copy(documentsLegacyPath, ConfigPath);
                System.Diagnostics.Debug.WriteLine("Migrated config from ~/Documents/AegisDNS/");
            }
            catch { }
        }

        try
        {
            if (!File.Exists(ConfigPath))
            {
                Save();
                return;
            }

            string json = File.ReadAllText(ConfigPath);

            if (string.IsNullOrWhiteSpace(json))
            {
                Settings = new AppSettings();
                return;
            }

            var loadedSettings = JsonSerializer.Deserialize(json, AppConfigJsonContext.Default.AppSettings);

            if (loadedSettings != null)
            {
                Settings = loadedSettings;
                System.Diagnostics.Debug.WriteLine($"Config loaded successfully from {ConfigPath}");
            }
        }
        catch (JsonException ex)
        {
            System.Diagnostics.Debug.WriteLine($"Config JSON invalid: {ex.Message}. Resetting to defaults.");
            Settings = new AppSettings();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Load failed: {ex.Message}. Resetting to defaults.");
            Settings = new AppSettings();
        }
    }

    public static event Action? SettingsChanged;

    public static void Save()
    {
        try
        {
            if (!Directory.Exists(AppFolder))
            {
                Directory.CreateDirectory(AppFolder);
            }

            var options = new JsonSerializerOptions { WriteIndented = true };
            string json = JsonSerializer.Serialize(Settings, typeof(AppSettings), new AppConfigJsonContext(options));

            File.WriteAllText(ConfigPath, json);
            if (OperatingSystem.IsLinux())
            {
                File.SetUnixFileMode(ConfigPath, UnixFileMode.UserRead | UnixFileMode.UserWrite);
            }

            System.Diagnostics.Debug.WriteLine($"Config saved successfully to {ConfigPath}");
            SettingsChanged?.Invoke();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Save failed: {ex.Message}");
        }
    }
}
