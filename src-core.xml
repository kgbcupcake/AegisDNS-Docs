using System;
using System.Collections.Generic;
using System.Runtime.Versioning;
using System.Threading.Tasks;

using AegisDNS.Core;
using AegisDNS.Licensing;

namespace AegisDNS.Core;

/// <summary>
/// High-level façade over BlocklistUpdater.
/// Selects the correct Hagezi blocklist URLs based on license tier and settings.
/// </summary>
public class BlocklistManager
{
    private readonly BlocklistUpdater _updater = new();

    /// <summary>
    /// Fetches and parses the appropriate blocklists based on license tier and settings.
    /// </summary>
    public async Task<IEnumerable<string>> FetchAndParseAsync(Func<string, Task>? logger = null)
    {
        var urls = GetActiveBlocklistUrls();

        // Bridge async logger to sync Action for BlocklistUpdater
        Action<string>? syncLogger = logger != null
            ? msg => logger(msg).ConfigureAwait(false)
            : null;

        var domains = new List<string>(await _updater.UpdateMultipleAsync(urls, syncLogger));

        // Inject embedded gaming launcher domains (no network fetch — built in)
        if (BlocklistConfigManager.Settings.EnableGamingLauncherBlocking)
        {
            domains.AddRange(GamingLauncherDomains.GetAll());
            syncLogger?.Invoke("🎮 Gaming launcher ad domains loaded.");
        }

        return domains;
    }

    /// <summary>
    /// Returns the currently active blocklist URLs based on license and settings.
    /// </summary>
    public static List<string> GetActiveBlocklistUrls()
    {
        var urls = new List<string>();

        // 1. Determine Tier-based Primary List
#pragma warning disable CA1416
        LicenseManager.LicenseTier tier = LicenseManager.LicenseTier.Community;

#if DEBUG
        // Force highest tier for developer testing
        tier = LicenseManager.LicenseTier.Enterprise;
#endif

        string primaryList = tier switch
        {
            LicenseManager.LicenseTier.Pro or
            LicenseManager.LicenseTier.AegisPrime or
            LicenseManager.LicenseTier.Enterprise or
            LicenseManager.LicenseTier.Founder or
            LicenseManager.LicenseTier.Developer => HageziBlocklists.ProPlus,
            _ => HageziBlocklists.Normal
        };
#pragma warning restore CA1416
        urls.Add(primaryList);

        // 2. Add-on Lists based on User Settings
        var s = BlocklistConfigManager.Settings;
        if (s.EnableThreatIntelligence) urls.Add(HageziBlocklists.ThreatIntelligence);
        if (s.EnableFakeBlocking) urls.Add(HageziBlocklists.Fake);
        if (s.EnablePopUpAdsBlocking) urls.Add(HageziBlocklists.PopUpAds);
        if (s.EnableDynamicDnsBlocking) urls.Add(HageziBlocklists.DynamicDns);
        if (s.EnableNrdBlocking) urls.Add(HageziBlocklists.NewlyRegisteredDomains);
        if (s.EnableGamblingBlocking) urls.Add(HageziBlocklists.Gambling);
        if (s.BlockAdultContent) urls.Add(HageziBlocklists.Nsfw);

        return urls;
    }

    /// <summary>
    /// Returns the currently selected primary blocklist URL (Legacy Support).
    /// </summary>
    [Obsolete("Use GetActiveBlocklistUrls instead.")]
    public static string GetActiveUrl()
    {
        var urls = GetActiveBlocklistUrls();
        return urls.Count > 0 ? urls[0] : string.Empty;
    }
}
