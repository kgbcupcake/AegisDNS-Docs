<file path="src/AegisDNS.Core/Utilities/AllowlistManager.cs">
using System;
using System.Collections.Generic;
using System.Collections.Immutable;
using System.IO;
using System.Linq;
using System.Text.Json;
using System.Text.Json.Serialization;

namespace AegisDNS.Core.Utilities;



/// <summary>
/// Manages the user allowlist — domains that bypass blocklist checking entirely.
/// Stored separately from blocklist — never overwritten by blocklist updates.
/// </summary>
public static class AllowlistManager
{
    private static readonly string AppFolder =
        Environment.GetEnvironmentVariable("XDG_DATA_HOME") ?? "/var/lib/aegisdns";
    private static readonly string AllowlistPath = Path.Combine(AppFolder, "user_allowlist.json");

    // Thread-safe immutable set for O(1) lookups in the high-performance query path
    private static ImmutableHashSet<string> _allowlist = ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase);

    static AllowlistManager()
    {
        Load();
    }

    /// <summary>
    /// Checks if a domain is explicitly allowed. Fast O(1) lookup.
    /// </summary>
    public static bool Contains(string domain)
    {
        return _allowlist.Contains(domain);
    }

    /// <summary>
    /// Atomically adds a domain to the allowlist and saves to disk.
    /// </summary>
    public static void Add(string domain)
    {
        if (string.IsNullOrWhiteSpace(domain)) return;

        var cleanDomain = domain.Trim().ToLowerInvariant();
        bool added = false;

        ImmutableInterlocked.Update(ref _allowlist, current =>
        {
            if (current.Contains(cleanDomain))
            {
                added = false;
                return current;
            }
            added = true;
            return current.Add(cleanDomain);
        });

        if (added)
        {
            Save();
        }
    }

    /// <summary>
    /// Atomically removes a domain from the allowlist and saves to disk.
    /// </summary>
    public static void Remove(string domain)
    {
        if (string.IsNullOrWhiteSpace(domain)) return;

        var cleanDomain = domain.Trim().ToLowerInvariant();
        bool removed = false;

        ImmutableInterlocked.Update(ref _allowlist, current =>
        {
            if (!current.Contains(cleanDomain))
            {
                removed = false;
                return current;
            }
            removed = true;
            return current.Remove(cleanDomain);
        });

        if (removed)
        {
            Save();
        }
    }

    /// <summary>
    /// Clears the entire allowlist.
    /// </summary>
    public static void Clear()
    {
        ImmutableInterlocked.Update(ref _allowlist, _ => ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase));
        Save();
    }

    /// <summary>
    /// Returns a sorted list of all allowed domains, suitable for UI display.
    /// </summary>
    public static IReadOnlyList<string> GetAll()
    {
        return _allowlist.OrderBy(d => d).ToList();
    }

    /// <summary>
    /// Loads the allowlist from disk. Called automatically on startup.
    /// </summary>
    public static void Load()
    {
        try
        {
            if (!File.Exists(AllowlistPath))
            {
                // File doesn't exist yet, start empty
                ImmutableInterlocked.Update(ref _allowlist, _ => ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase));
                return;
            }

            string json = File.ReadAllText(AllowlistPath);
            if (string.IsNullOrWhiteSpace(json)) return;

            string[]? loadedDomains;
            try { loadedDomains = JsonSerializer.Deserialize<string[]>(json); }
            catch (JsonException) { return; }
            if (loadedDomains != null && loadedDomains.Length > 0)
            {
                ImmutableInterlocked.Update(ref _allowlist, _ => ImmutableHashSet.CreateRange(StringComparer.OrdinalIgnoreCase, loadedDomains));
                System.Diagnostics.Debug.WriteLine($"✅ Allowlist loaded successfully: {loadedDomains.Length} domains");
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"⚠️ Allowlist load failed: {ex.Message}. Starting empty.");
            ImmutableInterlocked.Update(ref _allowlist, _ => ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase));
        }
    }

    /// <summary>
    /// Imports a list of domains from plain text content (one per line).
    /// </summary>
    public static void ImportFromText(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return;

        var domains = text.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                          .Select(d => d.Trim().ToLowerInvariant())
                          .Where(d => !string.IsNullOrWhiteSpace(d));

        ImmutableInterlocked.Update(ref _allowlist, current => current.Union(domains));
        Save();
    }

    /// <summary>
    /// Exports the allowlist as a newline-separated string.
    /// </summary>
    public static string ExportToText()
    {
        return string.Join(Environment.NewLine, GetAll());
    }

    /// <summary>
    /// Saves the current allowlist to disk atomically.
    /// </summary>
    private static void Save()
    {
        try
        {
            if (!Directory.Exists(AppFolder))
            {
                Directory.CreateDirectory(AppFolder);
            }

            string[] domainsToSave = _allowlist.ToArray();
            var options = new JsonSerializerOptions { WriteIndented = true };
            string json = JsonSerializer.Serialize(domainsToSave, options);

            File.WriteAllText(AllowlistPath, json);
            System.Diagnostics.Debug.WriteLine($"💾 Allowlist saved successfully ({domainsToSave.Length} domains)");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Allowlist save failed: {ex.Message}");
        }
    }
}
