    public int XdpMode { get; set; } = 2;           // 0=Off, 1=Monitor, 2=Block
    public string XdpInterface { get; set; } = "auto";
    public bool XdpRfc1918Protection { get; set; } = true;
    public bool XdpAlertOnDrop { get; set; } = true;
}

[JsonSerializable(typeof(XdpSettings))]
internal partial class XdpConfigJsonContext : JsonSerializerContext { }

public static class XdpConfigManager
{
    private static readonly string ConfigPath = Path.Combine(ConfigManager.AppFolder, "xdp.config.json");
    private static readonly string LegacyConfigPath = Path.Combine(ConfigManager.AppFolder, "user_config.json");

    public static XdpSettings Settings { get; private set; } = new();

    static XdpConfigManager() => Load();

    public static void Load()
    {
        // One-time migration from legacy user_config.json
        if (!File.Exists(ConfigPath) && File.Exists(LegacyConfigPath))
        {
            try
            {
                string legacyJson = File.ReadAllText(LegacyConfigPath);
                var migrated = JsonSerializer.Deserialize(legacyJson, XdpConfigJsonContext.Default.XdpSettings);
                if (migrated != null)
                {
                    Settings = migrated;
                    Save();
                    System.Diagnostics.Debug.WriteLine("✅ XdpConfigManager: migrated from legacy user_config.json");
                    return;
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"⚠️ XdpConfigManager migration failed: {ex.Message}");
            }
        }

        try
        {
            if (!File.Exists(ConfigPath)) { Save(); return; }
            string json = File.ReadAllText(ConfigPath);
            if (string.IsNullOrWhiteSpace(json)) { Settings = new(); return; }
            try
            {
                var loaded = JsonSerializer.Deserialize(json, XdpConfigJsonContext.Default.XdpSettings);
                if (loaded != null) Settings = loaded;
            }
            catch (JsonException ex)
            {
                System.Diagnostics.Debug.WriteLine($"⚠️ xdp.config.json invalid: {ex.Message}");
                Settings = new();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"⚠️ XdpConfigManager load failed: {ex.Message}");
            Settings = new();
        }
    }

    public static void Save()
    {
        try
        {
            if (!Directory.Exists(ConfigManager.AppFolder)) Directory.CreateDirectory(ConfigManager.AppFolder);
            var options = new JsonSerializerOptions { WriteIndented = true };
            string json = JsonSerializer.Serialize(Settings, typeof(XdpSettings), new XdpConfigJsonContext(options));
            File.WriteAllText(ConfigPath, json);
            if (OperatingSystem.IsLinux())
                File.SetUnixFileMode(ConfigPath, UnixFileMode.UserRead | UnixFileMode.UserWrite);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ XdpConfigManager save failed: {ex.Message}");
        }
    }
}
