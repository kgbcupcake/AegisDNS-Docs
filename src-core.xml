using System;
using System.Collections.Generic;
using System.Threading;
using System.Threading.Channels;
using System.Threading.Tasks;

using AegisDNS.Core.Ai; // Using AiProviderFactory etc. (Assuming they exist. I saw them in Ai folder)
using AegisDNS.Core.Utilities;

using Microsoft.Extensions.Logging;

namespace AegisDNS.Core.Monitoring;

public class AiWatchdog
{
    private readonly AegisEngine _engine;
    private readonly ILogger<AiWatchdog> _logger;
    private readonly ChannelReader<string> _queueReader;
    private readonly CancellationTokenSource _cts;
    private readonly DomainRoleManager _roleManager;

    private static int _highThreatCount = 0;
    private static int _criticalThreatCount = 0;
    public static int HighThreatCount => _highThreatCount;
    public static int CriticalThreatCount => _criticalThreatCount;
    public static string LastDetectionDomain { get; private set; } = "None";
    public static DateTime? LastDetectionTime { get; private set; } = null;

    public AiWatchdog(AegisEngine engine, DomainRoleManager roleManager, ILogger<AiWatchdog> logger)
    {
        _engine = engine;
        _logger = logger;
        _queueReader = engine.AiQueueReader;
        _roleManager = roleManager;
        _cts = new CancellationTokenSource();
    }

    public void Start()
    {
        Task.Run(RunLoopAsync, _cts.Token);
    }

    public void Stop()
    {
        _cts.Cancel();
    }

    private async Task RunLoopAsync()
    {
        _logger.LogDebug("[AiWatchdog] Starting background behavioral scoring loop.");
        try
        {
            var batch = new List<string>();

            // Read in small batches to evaluate bursts
            while (!_cts.IsCancellationRequested)
            {
                // Wait for at least one item
                if (await _queueReader.WaitToReadAsync(_cts.Token))
                {
                    while (_queueReader.TryRead(out var domain))
                    {
                        batch.Add(domain);
                        if (batch.Count >= 50) break; // Process in chunks
                    }

                    ProcessBatch(batch);
                    batch.Clear();

                    // Small delay to window bursts
                    await Task.Delay(200, _cts.Token);
                }
            }
        }
        catch (OperationCanceledException)
        {
            _logger.LogDebug("[AiWatchdog] Loop cancelled.");
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[AiWatchdog] Fatal Error.");
        }
    }

    private void ProcessBatch(List<string> domains)
    {
        if (domains.Count == 0) return;

        bool containsMedia = false;
        bool containsAuth = false;

        var frequencies = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        foreach (var d in domains)
        {
            frequencies[d] = frequencies.TryGetValue(d, out int existing) ? existing + 1 : 1;

            if (d.Contains("video") || d.Contains("stream") || d.Contains("cdn") || d.Contains("media") ||
                d.Contains("hls") || d.Contains("manifest"))
                containsMedia = true;

            if (d.Contains("login") || d.Contains("auth") || d.Contains("sso") || d.Contains("oauth"))
                containsAuth = true;
        }

        SessionManager.UpdatePhase(domains.Count, containsMedia, containsAuth);
        var currentPhase = SessionManager.CurrentPhase;

        foreach (var kvp in frequencies)
        {
            var domain = kvp.Key;
            var count = kvp.Value;
            var record = _roleManager.GetOrCreateRecord(domain);

            record.LastSeenAt = DateTime.UtcNow;
            record.ResolutionBurstCount += count;

            if (currentPhase == SessionPhase.Login)
            {
                record.FunctionalScore = Math.Min(1.0, record.FunctionalScore + (count * 0.1));
            }
            else if (currentPhase == SessionPhase.MediaLoad)
            {
                // Boost CDN/media infrastructure seen during stream startup so Playback phase won't score it
                if (count > 3)
                    record.FunctionalScore = Math.Min(1.0, record.FunctionalScore + (count * 0.08));
                else if (domain.Contains("cdn") || domain.Contains("media") || domain.Contains("stream") ||
                         domain.Contains("hls") || domain.Contains("manifest"))
                    record.FunctionalScore = Math.Min(1.0, record.FunctionalScore + 0.15);
            }
            else if (currentPhase == SessionPhase.Playback)
            {
                // Safety gate: domains already seen as functional infrastructure are never aggressively scored
                bool isFunctionallyTrusted = record.FunctionalScore >= 0.20;

                // Tier 1: High-confidence SSAI beacon subdomains — almost exclusively ad verification
                bool isHighConfidenceBeacon =
                    !isFunctionallyTrusted &&
                    (
                        domain.StartsWith("beacon.") || domain.StartsWith("beacons.") ||
                        domain.StartsWith("ads.") || domain.StartsWith("ad.") ||
                        domain.StartsWith("pixel.") || domain.StartsWith("pixels.") ||
                        domain.StartsWith("impression.") || domain.StartsWith("impressions.") ||
                        // Short domain + burst during playback = beacon signature
                        (record.ResolutionBurstCount > 8 && domain.Length < 30)
                    );

                if (isHighConfidenceBeacon)
                {
                    record.MonetizationScore = Math.Min(1.0, record.MonetizationScore + (count * 0.35));
                    _logger.LogDebug("[AiWatchdog] SSAI beacon (high): {Domain} mono={Score:F2}", domain, record.MonetizationScore);
                }

                // Tier 2: Known SSAI vendor domains and precise keyword subdomains
                bool isMediumConfidenceBeacon =
                    !isFunctionallyTrusted && !isHighConfidenceBeacon &&
                    (
                        domain.Contains("tracking.") || domain.Contains("telemetry.") ||
                        domain.Contains(".metrics.") || domain.Contains("adserver") ||
                        domain.Contains("adtech") || domain.Contains("adsystem") ||
                        domain.Contains("doubleclick") || domain.Contains("googlesyndication") ||
                        domain.Contains("moatads") || domain.Contains("scorecardresearch") ||
                        domain.Contains("quantserve") || domain.Contains("comscore") ||
                        domain.Contains("imasdk") || domain.Contains("freewheel") ||
                        domain.Contains("auditude")
                    );

                if (isMediumConfidenceBeacon)
                {
                    record.MonetizationScore = Math.Min(1.0, record.MonetizationScore + (count * 0.15));
                    record.TelemetryScore = Math.Min(1.0, record.TelemetryScore + 0.10);
                    _logger.LogDebug("[AiWatchdog] SSAI beacon (medium): {Domain} mono={Score:F2}", domain, record.MonetizationScore);
                }

                // Tier 3: Burst anomaly — unknown domain, high burst, not seen during MediaLoad
                bool isBurstAnomaly =
                    !isFunctionallyTrusted && !isHighConfidenceBeacon && !isMediumConfidenceBeacon &&
                    record.ResolutionBurstCount > 15 && count >= 3;

                if (isBurstAnomaly)
                {
                    record.MonetizationScore = Math.Min(1.0, record.MonetizationScore + (count * 0.08));
                    _logger.LogDebug("[AiWatchdog] Burst anomaly: {Domain} burst={Burst}", domain, record.ResolutionBurstCount);
                }
            }

            record.ResolutionBurstCount = Math.Max(0, record.ResolutionBurstCount - 1);

            if (record.ShouldBlock())
            {
                var confidence = ThreatConfidenceEvaluator.Evaluate(record);

                switch (confidence)
                {
                    case ThreatConfidence.Low:
                        // Log only — don't block yet
                        _logger.LogDebug("[AiWatchdog] LOW confidence: {Domain} ({Score:F2})", domain, record.MonetizationScore);
                        break;

                    case ThreatConfidence.Medium:
                        {
                            var rep = DomainReputationAnalyzer.Analyze(domain);
                            _engine.TriggerLog($"⚠️ AI THREAT (Medium): {domain} — monitoring ({rep.Summary})");
                            break;
                        }

                    case ThreatConfidence.High:
                        {
                            if (!AllowlistManager.Contains(domain))
                            {
                                System.Threading.Interlocked.Increment(ref _highThreatCount);
                                LastDetectionDomain = domain;
                                LastDetectionTime = DateTime.UtcNow;
                                AiLearnedBlocklist.Add(domain);
                                var rep = DomainReputationAnalyzer.Analyze(domain);
                                _engine.TriggerLog($"🤖 AI LEARNED (High confidence): {domain} ({rep.Summary})");
                            }
                            break;
                        }

                    case ThreatConfidence.Critical:
                        // Immediate block + static list + loud notification
                        if (!AllowlistManager.Contains(domain))
                        {
                            System.Threading.Interlocked.Increment(ref _criticalThreatCount);
                            LastDetectionDomain = domain;
                            LastDetectionTime = DateTime.UtcNow;
                            _engine.AddToBlocklist(domain);
                            AiLearnedBlocklist.Add(domain);
                            _engine.TriggerLog($"🚨 AI CRITICAL THREAT: {domain} — BLOCKED IMMEDIATELY");
                        }
                        break;
                }
            }
        }
    }
}
