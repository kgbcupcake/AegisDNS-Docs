<file path="src/AegisDNS.Core/ExtensionApi/ExtensionApiHost.cs">
using System;
using System.Linq;
using System.Net;
using System.Security.Cryptography;
using System.Text;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;

using Microsoft.Extensions.Logging;

namespace AegisDNS.Core.ExtensionApi;

/// <summary>
/// Minimal loopback HTTP API for the browser extension companion.
/// Uses HttpListener — zero new NuGet packages.
/// Endpoints:
///   GET /status   → { shieldActive, blockedToday, totalToday }
///   GET /page?url → { blockedOnPage, blockedDomains }
/// </summary>
public sealed class ExtensionApiHost
{
    private readonly AegisEngine _engine;
    private readonly ILogger<ExtensionApiHost> _logger;
    private HttpListener? _listener;
    private CancellationTokenSource? _cts;
    private string? _token;

    /// <summary>
    /// The secret token callers must include as X-AegisDNS-Token on every request.
    /// Generated fresh on each Start() call. Write this to disk for the extension to read.
    /// </summary>
    public string? Token => _token;

    public ExtensionApiHost(AegisEngine engine, ILogger<ExtensionApiHost> logger)
    {
        _engine = engine;
        _logger = logger;
    }

    /// <summary>
    /// Starts the API server. Non-fatal: if port is in use, logs and skips.
    /// </summary>
    public void Start(int port)
    {
        try
        {
            _token = Convert.ToHexString(RandomNumberGenerator.GetBytes(16));

            _listener = new HttpListener();
            _listener.Prefixes.Add($"http://127.0.0.1:{port}/");
            _listener.Start();

            _cts = new CancellationTokenSource();
            _ = Task.Run(() => ListenAsync(_cts.Token));

            _logger.LogInformation("[ExtensionApi] Listening on port {Port}", port);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[ExtensionApi] Failed to start on port {Port}. Extension API unavailable.", port);
            _listener = null;
        }
    }

    public void Stop()
    {
        _cts?.Cancel();
        try { _listener?.Stop(); } catch { }
        _listener = null;
    }

    private async Task ListenAsync(CancellationToken token)
    {
        while (!token.IsCancellationRequested && _listener?.IsListening == true)
        {
            HttpListenerContext ctx;
            try
            {
                ctx = await _listener.GetContextAsync().ConfigureAwait(false);
            }
            catch
            {
                break;
            }

            _ = Task.Run(() => HandleRequest(ctx), CancellationToken.None);
        }
    }

    private void HandleRequest(HttpListenerContext ctx)
    {
        try
        {
            var req = ctx.Request;
            var resp = ctx.Response;

            // Loopback-only enforcement
            if (!IPAddress.IsLoopback(req.RemoteEndPoint.Address))
            {
                resp.StatusCode = 403;
                resp.Close();
                return;
            }

            // Token validation — X-AegisDNS-Token must match the secret generated at startup.
            // This is the primary defense; CORS alone is insufficient for a local API.
            string? clientToken = req.Headers["X-AegisDNS-Token"];
            if (!string.Equals(clientToken, _token, StringComparison.Ordinal))
            {
                resp.StatusCode = 403;
                resp.Close();
                return;
            }

            // CORS — reflect origin only for http(s)://localhost and http(s)://127.0.0.1.
            // Never wildcard; never reflect unknown origins; "null" origin is intentionally excluded.
            string? origin = req.Headers["Origin"];
            if (origin != null &&
                (origin.Equals("http://localhost", StringComparison.OrdinalIgnoreCase) ||
                 origin.Equals("https://localhost", StringComparison.OrdinalIgnoreCase) ||
                 origin.Equals("http://127.0.0.1", StringComparison.OrdinalIgnoreCase) ||
                 origin.Equals("https://127.0.0.1", StringComparison.OrdinalIgnoreCase)))
            {
                resp.Headers.Add("Access-Control-Allow-Origin", origin);
            }
            // Origin absent (non-browser request) → proceeds normally; no CORS header needed.
            // Origin present but not in allowlist → header omitted; request still rejected above
            //   if the token is wrong, or silently served without CORS if the token was correct.

            resp.Headers.Add("Cache-Control", "no-cache");
            resp.ContentType = "application/json; charset=utf-8";
            resp.StatusCode = 200;

            string path = req.Url?.AbsolutePath?.TrimEnd('/') ?? "";
            string responseJson;

            if (string.Equals(path, "/status", StringComparison.OrdinalIgnoreCase))
            {
                responseJson = HandleStatus();
            }
            else if (string.Equals(path, "/page", StringComparison.OrdinalIgnoreCase))
            {
                string urlParam = req.QueryString["url"] ?? "";
                responseJson = HandlePage(urlParam);
            }
            else
            {
                resp.StatusCode = 404;
                responseJson = "{\"error\":\"Not found\"}";
            }

            byte[] bytes = Encoding.UTF8.GetBytes(responseJson);
            resp.ContentLength64 = bytes.Length;
            resp.OutputStream.Write(bytes, 0, bytes.Length);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[ExtensionApi] Handler error.");
        }
        finally
        {
            try { ctx.Response.Close(); } catch { }
        }
    }

    private string HandleStatus()
    {
        var metrics = MetricsManager.Current;
        return JsonSerializer.Serialize(new
        {
            shieldActive = _engine.IsRunning,
            blockedToday = metrics.BlockedQueries,
            totalToday = metrics.TotalQueries
        });
    }

    private string HandlePage(string urlParam)
    {
        if (string.IsNullOrWhiteSpace(urlParam))
            return "{\"blockedOnPage\":0,\"blockedDomains\":[]}";

        string baseDomain;
        try
        {
            var uri = new Uri(urlParam.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                ? urlParam : "https://" + urlParam);
            baseDomain = uri.Host.ToLowerInvariant();
        }
        catch
        {
            return "{\"blockedOnPage\":0,\"blockedDomains\":[]}";
        }

        // Search last 200 history entries for blocked queries matching this domain
        var history = _engine.GetHistory();
        var blocked = history
            .Where(e => e.IsBlocked &&
                        (e.Domain.Equals(baseDomain, StringComparison.OrdinalIgnoreCase) ||
                         e.Domain.EndsWith("." + baseDomain, StringComparison.OrdinalIgnoreCase)))
            .Select(e => e.Domain)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return JsonSerializer.Serialize(new
        {
            blockedOnPage = blocked.Length,
            blockedDomains = blocked
        });
    }
}
