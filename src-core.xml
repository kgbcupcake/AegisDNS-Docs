using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Runtime.InteropServices;
using System.Threading.Tasks;

namespace AegisDNS.Core.Proxy;

/// <summary>
/// Phase 18 — Traffic Redirector.
/// Manages iptables rules to redirect HTTPS traffic to the local proxy.
/// </summary>
public static class TrafficRedirector
{
    private static bool _isEnabled;

    public static bool IsEnabled() => _isEnabled;

    public static void Enable(int proxyPort)
    {
        if (_isEnabled) return;

        try
        {
            Debug.WriteLine($"[TrafficRedirector] Enabling redirection to port {proxyPort}...");

            // 1. Skip loopback (so proxy can connect to upstream)
            // -I OUTPUT 1 inserts at the top
            RunIptables("-t", "nat", "-I", "OUTPUT", "1", "-p", "tcp", "--dport", "443", "-o", "lo", "-j", "RETURN");

            // 2. Redirect all other outbound 443 to local proxy
            RunIptables("-t", "nat", "-A", "OUTPUT", "-p", "tcp", "--dport", "443", "-j", "REDIRECT", "--to-port", proxyPort.ToString());

            _isEnabled = true;
            Debug.WriteLine("[TrafficRedirector] HTTPS redirection active.");
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[TrafficRedirector] Enable failed: {ex.Message}");
            Disable(); // Cleanup any partial rules
        }
    }

    public static void Disable()
    {
        try
        {
            Debug.WriteLine("[TrafficRedirector] Disabling redirection...");

            // Use -D to delete the exact rules we added. 
            // We'll call it multiple times to be sure, and catch errors if rules don't exist.

            // Delete the REDIRECT rule first
            RunIptables("-t", "nat", "-D", "OUTPUT", "-p", "tcp", "--dport", "443", "-j", "REDIRECT", "--to-port", HttpsProxyConfigManager.Settings.ProxyPort.ToString());

            // Delete the loopback RETURN rule
            RunIptables("-t", "nat", "-D", "OUTPUT", "-p", "tcp", "--dport", "443", "-o", "lo", "-j", "RETURN");

            _isEnabled = false;
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[TrafficRedirector] Disable error (non-fatal): {ex.Message}");
        }
    }

    private static void RunIptables(params string[] args)
    {
        if (!OperatingSystem.IsLinux()) return;

        try
        {
            // Note: Service has CAP_NET_ADMIN so this should work without pkexec if running as service.
            // If running in dev mode, it might need pkexec.
            string cmd = "iptables";

            var psi = new ProcessStartInfo(cmd)
            {
                CreateNoWindow = true,
                UseShellExecute = false
            };

            foreach (var arg in args)
                psi.ArgumentList.Add(arg);

            using var process = Process.Start(psi);
            process?.WaitForExit(5000);

            if (process?.ExitCode != 0)
            {
                Debug.WriteLine($"[TrafficRedirector] iptables {string.Join(" ", args)} returned {process?.ExitCode}");
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[TrafficRedirector] iptables execution failed: {ex.Message}");
        }
    }
}
