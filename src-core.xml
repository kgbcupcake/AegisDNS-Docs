using System;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Linq;

namespace AegisDNS.Core.Utilities;

/// <summary>
/// Thread-safe top-N domain tracker using ConcurrentDictionary.
/// Resets every 24 hours automatically.
/// Provides top 10 blocked and top 10 allowed domains.
/// </summary>
public static class TopDomainsTracker
{
    private static readonly ConcurrentDictionary<string, long> _blockedDomains = new(StringComparer.OrdinalIgnoreCase);
    private static readonly ConcurrentDictionary<string, long> _allowedDomains = new(StringComparer.OrdinalIgnoreCase);

    private static readonly ConcurrentDictionary<string, long> _weeklyBlockedDomains = new(StringComparer.OrdinalIgnoreCase);
    private static readonly ConcurrentDictionary<string, long> _weeklyAllowedDomains = new(StringComparer.OrdinalIgnoreCase);

    // Auto-reset timer
    private static readonly System.Timers.Timer _resetTimer;

    static TopDomainsTracker()
    {
        // Calculate milliseconds until UTC midnight
        DateTime now = DateTime.UtcNow;
        DateTime tomorrow = now.Date.AddDays(1);
        double msUntilMidnight = (tomorrow - now).TotalMilliseconds;

        _resetTimer = new System.Timers.Timer(msUntilMidnight);
        _resetTimer.Elapsed += (s, e) =>
        {
            _blockedDomains.Clear();
            _allowedDomains.Clear();

            // Reset interval to exactly 24 hours for subsequent fires
            _resetTimer.Interval = TimeSpan.FromHours(24).TotalMilliseconds;
        };
        _resetTimer.AutoReset = true;
        _resetTimer.Start();
    }

    /// <summary>
    /// Atomic increment for a blocked domain.
    /// </summary>
    public static void RecordBlocked(string domain)
    {
        if (string.IsNullOrWhiteSpace(domain)) return;
        _blockedDomains.AddOrUpdate(domain, 1, (_, count) => count + 1);
        _weeklyBlockedDomains.AddOrUpdate(domain, 1, (_, count) => count + 1);
    }

    /// <summary>
    /// Atomic increment for an allowed domain.
    /// </summary>
    public static void RecordAllowed(string domain)
    {
        if (string.IsNullOrWhiteSpace(domain)) return;
        _allowedDomains.AddOrUpdate(domain, 1, (_, count) => count + 1);
        _weeklyAllowedDomains.AddOrUpdate(domain, 1, (_, count) => count + 1);
    }

    /// <summary>
    /// Returns the top N blocked domains by count.
    /// </summary>
    public static IReadOnlyList<(string Domain, long Count)> GetTopBlocked(int n = 10)
    {
        // Note: OrderBy on a ConcurrentDictionary takes a snapshot automatically.
        return _blockedDomains
            .OrderByDescending(kvp => kvp.Value)
            .Take(n)
            .Select(kvp => (kvp.Key, kvp.Value))
            .ToList();
    }

    /// <summary>
    /// Returns the top N allowed domains by count.
    /// </summary>
    public static IReadOnlyList<(string Domain, long Count)> GetTopAllowed(int n = 10)
    {
        return _allowedDomains
            .OrderByDescending(kvp => kvp.Value)
            .Take(n)
            .Select(kvp => (kvp.Key, kvp.Value))
            .ToList();
    }

    public static IReadOnlyList<(string Domain, long Count)> GetWeeklyTopBlocked(int n = 10)
    {
        return _weeklyBlockedDomains
            .OrderByDescending(kvp => kvp.Value)
            .Take(n)
            .Select(kvp => (kvp.Key, kvp.Value))
            .ToList();
    }

    public static IReadOnlyList<(string Domain, long Count)> GetWeeklyTopAllowed(int n = 10)
    {
        return _weeklyAllowedDomains
            .OrderByDescending(kvp => kvp.Value)
            .Take(n)
            .Select(kvp => (kvp.Key, kvp.Value))
            .ToList();
    }

    public static void ClearWeeklyStats()
    {
        _weeklyBlockedDomains.Clear();
        _weeklyAllowedDomains.Clear();
    }
}
