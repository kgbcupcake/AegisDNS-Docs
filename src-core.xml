using System.Collections.Concurrent;

namespace AegisDNS.Core.Monitoring;

public sealed class QueryHistoryBuffer
{
    private readonly int _capacity;
    private readonly ConcurrentQueue<QueryHistoryEntry> _entries = new();

    public QueryHistoryBuffer(int capacity)
    {
        _capacity = capacity;
    }

    public void Add(string domain, bool isBlocked, string blockReason = "", TimeSpan? sessionAge = null)
    {
        var entry = new QueryHistoryEntry(
            domain,
            isBlocked,
            DateTime.UtcNow,
            blockReason,
            sessionAge
        );

        _entries.Enqueue(entry);

        // Trim overflow
        while (_entries.Count > _capacity)
        {
            _entries.TryDequeue(out _);
        }
    }

    public IReadOnlyCollection<QueryHistoryEntry> GetSnapshot()
    {
        return _entries.ToArray();
    }
}
