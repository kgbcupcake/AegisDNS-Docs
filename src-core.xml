using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Threading.Tasks;

using AegisDNS.Core.Monitoring;

namespace AegisDNS.Core.Ai;

public static class AiReportsManager
{
    private static readonly string ReportsFolder = Path.Combine(
        Environment.GetEnvironmentVariable("XDG_DATA_HOME") ?? "/var/lib/aegisdns",
        "AiWeeklyReports");

    public static async Task GenerateWeeklyReportAsync(IEnumerable<string> topBlocked, IEnumerable<string> topAllowed)
    {
        if (!AiConfigManager.Settings.EnableAiSentinel) return;

        var factory = new AiProviderFactory();
        var provider = factory.GetProviderWithFallback(AiConfigManager.Settings);

        if (provider == null) return;

        var prompt = $"Summarize the following blocked domains and top allowed domains over the past week into a 3-paragraph executive summary for a home user.\n\n" +
                     $"Top Blocked:\n{string.Join("\n", topBlocked)}\n\n" +
                     $"Top Allowed:\n{string.Join("\n", topAllowed)}";

        try
        {
            var report = await provider.AskAsync(prompt, AiConfigManager.Settings);

            if (!Directory.Exists(ReportsFolder))
                Directory.CreateDirectory(ReportsFolder);

            string filename = $"report_{DateTime.Now:yyyy_MM_dd}.md";
            string path = Path.Combine(ReportsFolder, filename);

            await File.WriteAllTextAsync(path, $"# Weekly AI Security Report\n\n{report}");

            await IpcSystem.BroadcastLogAsync($"📊 Weekly AI Report generated: {filename}");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[AiReportsManager] Failed to generate report: {ex.Message}");
        }
    }
}
