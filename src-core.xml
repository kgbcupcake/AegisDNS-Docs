using System;
using System.Collections.Generic;
using System.Collections.Immutable;
using System.IO;
using System.Text.Json;
using System.Threading;

namespace AegisDNS.Core.ProcessTracking;

/// <summary>
/// Loads and evaluates per-process DNS rules from process_rules.json.
/// Uses ImmutableDictionary with atomic swap for lock-free reads in the hot path.
/// </summary>
public class ProcessRuleEngine
{
    private static readonly string DefaultRulesPath = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
        ".config", "aegisdns", "process_rules.json");

    private static readonly string AllowedBaseDir = Path.GetFullPath(Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
        ".config", "aegisdns"));

    private ImmutableDictionary<string, ProcessDnsRule> _rules =
        ImmutableDictionary<string, ProcessDnsRule>.Empty.WithComparers(StringComparer.OrdinalIgnoreCase);

    public ProcessRuleEngine()
    {
        Load();
    }

    /// <summary>
    /// Loads rules from disk. Missing file = no rules (not an error).
    /// </summary>
    public void Load(string? path = null)
    {
        string filePath = !string.IsNullOrWhiteSpace(path) ? path : DefaultRulesPath;
        filePath = Path.GetFullPath(filePath);
        if (!filePath.StartsWith(AllowedBaseDir, StringComparison.Ordinal)) return;
        try
        {
            if (!File.Exists(filePath))
            {
                Interlocked.Exchange(ref _rules,
                    ImmutableDictionary<string, ProcessDnsRule>.Empty.WithComparers(StringComparer.OrdinalIgnoreCase));
                return;
            }

            string json = File.ReadAllText(filePath);
            if (string.IsNullOrWhiteSpace(json)) return;

            ProcessDnsRule[]? rules;
            try { rules = JsonSerializer.Deserialize<ProcessDnsRule[]>(json); }
            catch (JsonException) { return; }

            if (rules == null) return;

            var builder = ImmutableDictionary.CreateBuilder<string, ProcessDnsRule>(StringComparer.OrdinalIgnoreCase);
            foreach (var rule in rules)
            {
                if (!string.IsNullOrWhiteSpace(rule.ProcessName))
                    builder[rule.ProcessName] = rule;
            }

            Interlocked.Exchange(ref _rules, builder.ToImmutable());
        }
        catch { }
    }

    /// <summary>
    /// Saves rules to disk and atomically reloads the in-memory dictionary.
    /// </summary>
    public void Save(IEnumerable<ProcessDnsRule> rules, string? path = null)
    {
        string filePath = !string.IsNullOrWhiteSpace(path) ? path : DefaultRulesPath;
        filePath = Path.GetFullPath(filePath);
        if (!filePath.StartsWith(AllowedBaseDir, StringComparison.Ordinal)) return;
        try
        {
            string? dir = Path.GetDirectoryName(filePath);
            if (!string.IsNullOrEmpty(dir) && !Directory.Exists(dir))
                Directory.CreateDirectory(dir);

            var list = new List<ProcessDnsRule>(rules);
            string json = JsonSerializer.Serialize(list, new JsonSerializerOptions { WriteIndented = true });
            File.WriteAllText(filePath, json);
        }
        catch { }

        Load(path);
    }

    /// <summary>
    /// Returns whether the domain should be blocked for the given process.
    /// Returns true = block, false = allow (bypass blocklist), null = apply normal rules.
    /// </summary>
    public bool? ShouldBlock(string processName, string domain)
    {
        if (string.IsNullOrWhiteSpace(processName)) return null;

        var rules = Volatile.Read(ref _rules);
        if (!rules.TryGetValue(processName, out var rule)) return null;

        if (rule.BlockAll) return true;
        if (rule.AllowAll) return false;
        return null;  // Custom mode: normal blocklist applies
    }

    /// <summary>Returns all current rules for UI display.</summary>
    public IEnumerable<ProcessDnsRule> GetAll() => _rules.Values;
}
