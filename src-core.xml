<file path="src/AegisDNS.Core/Core/BlocklistUpdater.cs">
using System;
using System.Collections.Generic;
using System.Collections.Immutable;
using System.IO;
using System.Linq;
using System.Net.Http;
using System.Security;
using System.Security.Cryptography;
using System.Text;
using System.Threading.Tasks;

using AegisDNS.Core.Utilities;

namespace AegisDNS.Core;

/// <summary>
/// Securely fetches and updates the remote DNS blocklist using RSA signature validation.
/// SECURITY: All updates require mandatory RSA-2048 signature verification.
/// No fallback to unverified caches — blocklist poisoning is prevented at all costs.
/// </summary>
public class BlocklistUpdater
{
    private readonly string _cachePath;

    // RSA-2048 Public Key for signature validation
    private const string PublicKeyPem = @"-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA46BFx4wG0iwX/JlBjSyq
7XSeuqj02nhZa93DIj++Ayk7IjSHttq1ZFifGieLv7F9nqbKmmQoNoYc2P7zVf9t
lVq/hwaON3Jx1EJYYS40FjvtFZGFdgWvias0M53QxRmWH40GVJMlAm6AZJ2RC1Zb
wrwxZrCV7iyDmcHCkmz9QvRRs3seTaRotQ80bTYR9xqEI1ug8d5De5Wsa6woOI/1
rJPCl3DJGiM4fR8YrT8IvmaJBBWgvN/1mOj6U0QnUHuxotZzLL32SbiT1JV6Kc+h
3zGYRbKXAHtspaQkkLiq/lw9emSuNycrdRxA4wfxcp5N146q+xAaodrr7I7NFlVm
qwIDAQAB
-----END PUBLIC KEY-----";


    public BlocklistUpdater()
    {
        _cachePath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "AegisDNS", "blocklist.v2.cache");
        Directory.CreateDirectory(Path.GetDirectoryName(_cachePath)!);
    }

    /// <summary>
    /// Fetches blocklists from multiple URLs, merges them, and deduplicates domains.
    /// </summary>
    public async Task<ImmutableHashSet<string>> UpdateMultipleAsync(IEnumerable<string> urls, Action<string>? logger)
    {
        var allDomains = ImmutableHashSet.CreateBuilder<string>(StringComparer.OrdinalIgnoreCase);
        int totalLoaded = 0;

        foreach (var url in urls)
        {
            try
            {
                logger?.Invoke($"🌐 Fetching blocklist: {url}");

                // For Hagezi lists, we skip RSA since we don't own the private key for external lists.
                // Our internal lists still require mandatory verification.
                bool isExternal = url.Contains("hagezi") || url.Contains("githubusercontent") || url.Contains("jsdelivr");

                var domains = await FetchAndVerifyAsync(url, !isExternal, logger);
                allDomains.UnionWith(domains);
                totalLoaded += domains.Count;
            }
            catch (Exception ex)
            {
                logger?.Invoke($"⚠️ Skipping {url} due to error: {ex.Message}");
            }
        }

        var result = allDomains.ToImmutable();
        logger?.Invoke($"✅ Merged results: {result.Count:N0} unique domains (from {totalLoaded:N0} raw entries).");
        return result;
    }

    private async Task<ImmutableHashSet<string>> FetchAndVerifyAsync(string url, bool requireSignature, Action<string>? logger)
    {
        byte[] data;
        try
        {
            data = await SharedHttpClient.Instance.GetByteArrayAsync(url);
        }
        catch (Exception ex)
        {
            throw new SecurityException($"Failed to fetch data from {url}: {ex.Message}", ex);
        }

        if (requireSignature)
        {
            byte[] signature;
            try
            {
                signature = await SharedHttpClient.Instance.GetByteArrayAsync(url + ".sig");
            }
            catch (HttpRequestException ex)
            {
                logger?.Invoke($"🔒 SECURITY HALT: Signature file (.sig) not found for {url}. Aborting.");
                throw new SecurityException($"Mandatory RSA-2048 signature file is missing for {url}.", ex);
            }

            if (!VerifySignature(data, signature))
            {
                logger?.Invoke($"🔒 SECURITY HALT: RSA signature verification FAILED for {url}. Aborting.");
                throw new SecurityException($"RSA-2048 signature verification failed for {url}.");
            }
            logger?.Invoke($"🛡️ Integrity verified for {url}.");
        }
        else
        {
            logger?.Invoke($"ℹ️ Skipping RSA verification for trusted external source: {url}");
        }

        return Parse(data);
    }

    /// <summary>
    /// Legacy single-URL update method.
    /// </summary>
    public async Task<ImmutableHashSet<string>> UpdateAsync(string url, Action<string>? logger)
    {
        return await FetchAndVerifyAsync(url, true, logger);
    }

    private bool VerifySignature(byte[] data, byte[] signature)
    {
        try
        {
            using var rsa = RSA.Create();
            rsa.ImportFromPem(PublicKeyPem);

            return rsa.VerifyData(data, signature, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1);
        }
        catch
        {
            return false;
        }
    }

    /// <summary>
    /// Normalizes domains: lowercase, trim, and remove trailing dots.
    /// </summary>
    private ImmutableHashSet<string> Parse(byte[] data)
    {
        var builder = ImmutableHashSet.CreateBuilder<string>(StringComparer.OrdinalIgnoreCase);

        using var ms = new MemoryStream(data);
        using var reader = new StreamReader(ms);

        while (reader.ReadLine() is { } line)
        {
            line = line.Trim();
            if (string.IsNullOrWhiteSpace(line) || line.StartsWith("#")) continue;

            // Handle hosts file format: "0.0.0.0 domain.com" or "domain.com"
            var parts = line.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
            string domain = parts.Length >= 2 ? parts[1] : parts[0];

            domain = domain.Trim().ToLower().TrimEnd('.');

            // Basic sanity check to avoid blocking local services
            if (!string.IsNullOrEmpty(domain) && domain != "localhost" && domain != "broadcasthost")
            {
                builder.Add(domain);
            }
        }

        return builder.ToImmutable();
    }
}
</file>

<file path="src/AegisDNS.Core/Core/StreamingBlockEngine.cs">
using AegisDNS.Core.Utilities;
using AegisDNS.Licensing;

namespace AegisDNS.Core;

/// <summary>
/// Evaluates DNS queries against streaming platform ad/tracking blocklists.
/// All checks are synchronous O(1) ImmutableHashSet lookups — no hot-path overhead.
/// Gated on Pro+ license tier. Phase 17 — DNS Streaming Ad Blocker.
/// </summary>
public static class StreamingBlockEngine
{
    /// <summary>
    /// Returns true if the given domain (or any of its parent domains) is in an enabled
    /// streaming platform blocklist. Returns false immediately for free-tier users.
    /// Subdomain matching: "foo.ads.spotify.com" matches because "ads.spotify.com" is listed.
    /// </summary>
    public static bool IsStreamingAdDomain(string domain)
    {
        if (LicenseManager.CurrentTier < LicenseManager.LicenseTier.Pro)
            return false;

        var settings = StreamingConfigManager.Settings;
        if (!settings.EnableStreamingAdBlock)
            return false;

        // Build candidate list: the domain itself plus all parent-label suffixes.
        // E.g. "foo.ads.spotify.com" → ["foo.ads.spotify.com", "ads.spotify.com", "spotify.com"]
        // This gives subdomain matching without any string allocation loop in the common case.
        ReadOnlySpan<char> remaining = domain.AsSpan();
        while (true)
        {
            string candidate = remaining.ToString();

            if (settings.BlockSpotifyAds && StreamingBlocklists.SpotifyAds.Contains(candidate)) return true;
            if (settings.BlockTwitchAds && StreamingBlocklists.TwitchAds.Contains(candidate)) return true;
            if (settings.BlockHuluAds && StreamingBlocklists.HuluAds.Contains(candidate)) return true;
            if (settings.BlockPeacockAds && StreamingBlocklists.PeacockAds.Contains(candidate)) return true;
            if (settings.BlockParamountAds && StreamingBlocklists.ParamountAds.Contains(candidate)) return true;
            if (settings.BlockYouTubeTracking && StreamingBlocklists.YouTubeTracking.Contains(candidate)) return true;

            int dot = remaining.IndexOf('.');
            if (dot < 0) break;
            remaining = remaining[(dot + 1)..];
        }

        return false;
    }
}
