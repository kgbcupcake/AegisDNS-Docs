<file path="src/AegisDNS.Core/Proxy/ProxyConnectionHandler.cs">
using System;
using System.Buffers;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Net;
using System.Net.Security;
using System.Net.Sockets;
using System.Security.Authentication;
using System.Security.Cryptography.X509Certificates;
using System.Text;
using System.Threading;
using System.Threading.Tasks;

using AegisDNS.Core.Security;

namespace AegisDNS.Core.Proxy;

/// <summary>
/// Phase 18 — Proxy Connection Handler.
/// Handles TLS termination, per-host certificate selection, and upstream relaying.
/// </summary>
public class ProxyConnectionHandler
{
    private readonly TcpClient _client;

    public ProxyConnectionHandler(TcpClient client)
    {
        _client = client;
    }

    public async Task ProcessAsync(CancellationToken ct)
    {
        try
        {
            var stream = _client.GetStream();

            // 1. Peek SNI from ClientHello
            // We need a custom peek mechanism because we need to read the data then reuse it for TLS or raw relay.
            var peekingStream = new PeekableStream(stream);
            string? hostName = await TryExtractSniAsync(peekingStream, ct);

            if (string.IsNullOrEmpty(hostName))
            {
                Debug.WriteLine("[Proxy] Failed to extract SNI or not a TLS ClientHello. Closing.");
                return;
            }

            // 2. Bypass check (Phase 18.5)
            if (IsBypassed(hostName))
            {
                Debug.WriteLine($"[Proxy] BYPASS: {hostName}");
                await RelayRawAsync(peekingStream, hostName, ct);
                return;
            }

            // 3. Terminate TLS with client
            var serverOptions = new SslServerAuthenticationOptions
            {
                ServerCertificateSelectionCallback = (sender, host) =>
                {
                    return CertificateManager.GenerateHostCert(host ?? hostName);
                },
                EnabledSslProtocols = SslProtocols.Tls12 | SslProtocols.Tls13,
                ClientCertificateRequired = false
            };

            using var clientSslStream = new SslStream(peekingStream, false);
            await clientSslStream.AuthenticateAsServerAsync(serverOptions, ct);

            // 4. Connect to upstream
            using var upstreamClient = new TcpClient();
            await upstreamClient.ConnectAsync(hostName, 443, ct);
            using var upstreamStream = upstreamClient.GetStream();

            using var upstreamSslStream = new SslStream(upstreamStream, false);
            await upstreamSslStream.AuthenticateAsClientAsync(hostName);

            // 5. Relay and Block (Phase 18.3)
            await RelayWithInterceptionAsync(clientSslStream, upstreamSslStream, hostName, ct);
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[ProxyHandler] Error: {ex.Message}");
        }
    }

    private bool IsBypassed(string hostName)
    {
        foreach (var pattern in HttpsProxyConfigManager.Settings.ProxyBypassDomains)
        {
            if (string.Equals(hostName, pattern, StringComparison.OrdinalIgnoreCase))
                return true;

            if (pattern.StartsWith("*."))
            {
                string suffix = pattern.Substring(1);
                if (hostName.EndsWith(suffix, StringComparison.OrdinalIgnoreCase))
                    return true;
            }
        }
        return false;
    }

    private async Task RelayRawAsync(PeekableStream clientStream, string hostName, CancellationToken ct)
    {
        using var upstreamClient = new TcpClient();
        await upstreamClient.ConnectAsync(hostName, 443, ct);
        using var upstreamStream = upstreamClient.GetStream();

        // Relay peeking buffer first
        if (clientStream.PeekedData.Length > 0)
        {
            await upstreamStream.WriteAsync(clientStream.PeekedData, ct);
        }

        var clientToUpstream = clientStream.CopyToAsync(upstreamStream, ct);
        var upstreamToClient = upstreamStream.CopyToAsync(clientStream, ct);

        await Task.WhenAll(clientToUpstream, upstreamToClient);
    }

    private async Task RelayWithInterceptionAsync(SslStream clientStream, SslStream upstreamStream, string hostName, CancellationToken ct)
    {
        var clientToUpstream = InterceptRequestsAsync(clientStream, upstreamStream, hostName, ct);
        var upstreamToClient = upstreamStream.CopyToAsync(clientStream, ct);

        await Task.WhenAny(clientToUpstream, upstreamToClient);
    }

    private async Task InterceptRequestsAsync(Stream source, Stream destination, string hostName, CancellationToken ct)
    {
        byte[] buffer = ArrayPool<byte>.Shared.Rent(16384);
        try
        {
            while (!ct.IsCancellationRequested)
            {
                int bytesRead = await source.ReadAsync(buffer, 0, buffer.Length, ct);
                if (bytesRead == 0) break;

                // Simple HTTP Request Line extraction
                string data = Encoding.UTF8.GetString(buffer, 0, Math.Min(bytesRead, 1024));
                int lineEnd = data.IndexOf("\r\n");
                if (lineEnd > 0)
                {
                    string requestLine = data.Substring(0, lineEnd);
                    var parts = requestLine.Split(' ');
                    if (parts.Length >= 2)
                    {
                        string method = parts[0];
                        string url = parts[1];

                        string path = url;
                        string query = "";
                        int queryIdx = url.IndexOf('?');
                        if (queryIdx >= 0)
                        {
                            path = url.Substring(0, queryIdx);
                            query = url.Substring(queryIdx + 1);
                        }

                        if (AdBlockingMiddleware.ShouldBlock(hostName, path, query))
                        {
                            MetricsManager.IncrementProxyAdsBlocked();
                            Debug.WriteLine($"[Proxy] BLOCKED: https://{hostName}{url}");
                            byte[] response = AdBlockingMiddleware.GetBlockResponse(path);
                            await source.WriteAsync(response, 0, response.Length, ct);
                            await source.FlushAsync(ct);
                            continue;
                        }
                    }
                }

                await destination.WriteAsync(buffer, 0, bytesRead, ct);
                await destination.FlushAsync(ct);
            }
        }
        catch { }
        finally
        {
            ArrayPool<byte>.Shared.Return(buffer);
        }
    }

    private async Task<string?> TryExtractSniAsync(PeekableStream stream, CancellationToken ct)
    {
        // We need to read the first 5 bytes to get record length
        byte[] header = new byte[5];
        if (await stream.PeekFullyAsync(header, ct) != 5) return null;

        if (header[0] != 0x16) return null;

        int recordLen = (header[3] << 8) | header[4];
        byte[] record = new byte[recordLen];
        if (await stream.PeekFullyAsync(record, ct, 5) != recordLen) return null;

        // Skip handshake header (1 byte type, 3 bytes length)
        // Handshake type 0x01 = ClientHello
        if (record[0] != 0x01) return null;

        try
        {
            int pos = 38; // Handshake header(4), Version(2), Random(32)
            if (pos >= record.Length) return null;

            int sessionIDLen = record[pos++];
            pos += sessionIDLen;
            if (pos >= record.Length) return null;

            int cipherSuiteLen = (record[pos] << 8) | record[pos + 1];
            pos += 2 + cipherSuiteLen;
            if (pos >= record.Length) return null;

            int compressionLen = record[pos++];
            pos += compressionLen;
            if (pos >= record.Length) return null;

            if (pos + 2 > record.Length) return null;
            int extensionsLen = (record[pos] << 8) | record[pos + 1];
            pos += 2;

            int end = pos + extensionsLen;
            while (pos + 4 <= end && pos + 4 <= record.Length)
            {
                int extType = (record[pos] << 8) | record[pos + 1];
                int extLen = (record[pos + 2] << 8) | record[pos + 3];
                pos += 4;

                if (extType == 0x00)
                {
                    if (pos + 2 > record.Length) return null;
                    int listLen = (record[pos] << 8) | record[pos + 1];
                    pos += 2;

                    if (pos + 3 > record.Length) return null;
                    int nameType = record[pos];
                    int nameLen = (record[pos + 1] << 8) | record[pos + 2];
                    pos += 3;

                    if (nameType == 0x00 && pos + nameLen <= record.Length)
                    {
                        return Encoding.UTF8.GetString(record, pos, nameLen);
                    }
                }
                pos += extLen;
            }
        }
        catch { }
        return null;
    }

    private class PeekableStream : Stream
    {
        private readonly Stream _inner;
        private readonly MemoryStream _peeked = new();
        private long _peekedReadPos = 0;

        public byte[] PeekedData => _peeked.ToArray();

        public PeekableStream(Stream inner) => _inner = inner;

        public async Task<int> PeekFullyAsync(byte[] buffer, CancellationToken ct, int offset = 0)
        {
            // This is a special peek that doesn't advance the logical stream position for the user
            // but populates the internal buffer.

            // If we already have enough data in peeked buffer at the specified offset
            if (_peeked.Length >= offset + buffer.Length)
            {
                var data = _peeked.ToArray();
                Buffer.BlockCopy(data, offset, buffer, 0, buffer.Length);
                return buffer.Length;
            }

            // Read from inner to fill peeked buffer up to required length
            int toRead = (offset + buffer.Length) - (int)_peeked.Length;
            byte[] temp = new byte[toRead];
            int read = await _inner.ReadAsync(temp, 0, toRead, ct);
            if (read > 0)
            {
                _peeked.Write(temp, 0, read);
            }

            if (_peeked.Length >= offset + buffer.Length)
            {
                var data = _peeked.ToArray();
                Buffer.BlockCopy(data, offset, buffer, 0, buffer.Length);
                return buffer.Length;
            }

            return (int)_peeked.Length - offset;
        }

        public override async ValueTask<int> ReadAsync(Memory<byte> buffer, CancellationToken cancellationToken = default)
        {
            if (_peekedReadPos < _peeked.Length)
            {
                int toCopy = Math.Min(buffer.Length, (int)(_peeked.Length - _peekedReadPos));
                _peeked.ToArray().AsMemory((int)_peekedReadPos, toCopy).CopyTo(buffer);
                _peekedReadPos += toCopy;
                return toCopy;
            }

            return await _inner.ReadAsync(buffer, cancellationToken);
        }

        // Standard Stream overrides
        public override bool CanRead => _inner.CanRead;
        public override bool CanSeek => false;
        public override bool CanWrite => _inner.CanWrite;
        public override long Length => _inner.Length;
        public override long Position { get => _inner.Position; set => throw new NotSupportedException(); }
        public override void Flush() => _inner.Flush();
        public override int Read(byte[] buffer, int offset, int count) => throw new NotSupportedException("Use ReadAsync");
        public override long Seek(long offset, SeekOrigin origin) => throw new NotSupportedException();
        public override void SetLength(long value) => throw new NotSupportedException();
        public override void Write(byte[] buffer, int offset, int count) => _inner.Write(buffer, offset, count);
        public override Task WriteAsync(byte[] buffer, int offset, int count, CancellationToken cancellationToken) => _inner.WriteAsync(buffer, offset, count, cancellationToken);
    }
}
