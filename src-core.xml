using System;

namespace AegisDNS.Core.Monitoring;

/// <summary>
/// Represents the behavioral role scores for a specific domain across time.
/// </summary>
public class DomainRoleRecord
{
    public string Domain { get; }

    // Role Scores (0.0 to 1.0)
    public double FunctionalScore { get; set; }
    public double TelemetryScore { get; set; }
    public double MonetizationScore { get; set; }

    // Metadata for behavioral tracking
    public DateTime FirstSeenAt { get; set; } = DateTime.UtcNow;
    public DateTime LastSeenAt { get; set; } = DateTime.UtcNow;

    // Counters within a sliding time window
    public int ResolutionBurstCount { get; set; }

    // Threshold constants used for blocking evaluation
    public const double MONETIZATION_BLOCK_THRESHOLD = 0.75;
    public const double FUNCTIONAL_SAFE_LIMIT = 0.30;

    public DomainRoleRecord(string domain)
    {
        Domain = domain;
        FunctionalScore = 0.0;
        TelemetryScore = 0.0;
        MonetizationScore = 0.0;
    }

    /// <summary>
    /// Determines if the domain's current scoring profile warrants active enforcement (blocking).
    /// </summary>
    public bool ShouldBlock()
    {
        return MonetizationScore > MONETIZATION_BLOCK_THRESHOLD &&
               FunctionalScore < FUNCTIONAL_SAFE_LIMIT;
    }
}
