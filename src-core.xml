<file path="src/AegisDNS.Core/Monitoring/DomainReputationContext.cs">
using System;
using System.Collections.Generic;
using System.Linq;

namespace AegisDNS.Core.Monitoring;

/// <summary>
/// Represents reputation information for a domain used in AI threat analysis.
/// </summary>
public record DomainReputationContext(
    string Domain,
    string TldRiskLevel,      // "High" / "Medium" / "Low"
    bool IsNewlyRegisteredPattern,  // Heuristic for random-looking subdomains
    bool MatchesKnownBadPattern,    // Known bad naming patterns
    double RiskScore,               // 0.0–1.0 computed from above
    string Summary                  // Human‑readable short description
);

public static class DomainReputationAnalyzer
{
    // High‑risk TLDs (commonly abused, low cost)
    private static readonly HashSet<string> HighRiskTlds = new(StringComparer.OrdinalIgnoreCase)
    {
        "xyz", "top", "click", "loan", "work", "date", "racing", "bid", "win", "gq", "cf", "ml", "ga", "tk"
    };

    // Medium‑risk TLDs
    private static readonly HashSet<string> MediumRiskTlds = new(StringComparer.OrdinalIgnoreCase)
    {
        "info", "biz", "online", "site", "website", "space", "fun", "live"
    };

    // Simple heuristic for random‑looking subdomains (e.g., long strings with high consonant ratio)
    private static bool LooksRandom(string subdomain)
    {
        if (string.IsNullOrEmpty(subdomain) || subdomain.Length < 8) return false;
        int consonants = subdomain.Count(c => !"aeiou".Contains(char.ToLowerInvariant(c)));
        double ratio = (double)consonants / subdomain.Length;
        return ratio > 0.7;
    }

    // Known bad patterns (common DGA or malware naming cues)
    private static readonly string[] BadPatterns = new[] { "malware", "dga", "track", "ads", "click" };

    public static DomainReputationContext Analyze(string domain)
    {
        // Split domain into subdomain and TLD
        var parts = domain.Split('.');
        string tld = parts.Length > 1 ? parts[^1] : string.Empty;
        string sub = parts.Length > 2 ? string.Join('.', parts, 0, parts.Length - 1) : string.Empty;

        string tldRisk = "Low";
        if (HighRiskTlds.Contains(tld)) tldRisk = "High";
        else if (MediumRiskTlds.Contains(tld)) tldRisk = "Medium";

        bool isRandom = LooksRandom(sub);
        bool matchesBad = BadPatterns.Any(p => domain.Contains(p, StringComparison.OrdinalIgnoreCase));

        // Compute a simple risk score (0‑1)
        double score = 0.0;
        if (tldRisk == "High") score += 0.4;
        else if (tldRisk == "Medium") score += 0.2;
        if (isRandom) score += 0.3;
        if (matchesBad) score += 0.3;
        if (score > 1.0) score = 1.0;

        string summary = $"{tldRisk}-risk TLD{(isRandom ? ", random‑looking subdomain" : "")}{(matchesBad ? ", known bad pattern" : "")}";

        return new DomainReputationContext(domain, tldRisk, isRandom, matchesBad, score, summary);
    }
}
</file>

<file path="src/AegisDNS.Core/Monitoring/LogEntry.cs">
using System;

namespace AegisDNS.Core.Monitoring;

public enum LogLevel
{
    Info,
    Warning,
    Error,
    Allow,
    Block,
    CacheHit,
    AiThreat,
    Request
}

public class LogEntry
{
    public DateTime Timestamp { get; set; } = DateTime.Now;
    public LogLevel Level { get; set; }
    public string Message { get; set; } = string.Empty;
    public string FullText => $"[{Timestamp:HH:mm:ss}] {Message}";
    public string Domain { get; set; } = string.Empty;

    public static LogEntry Parse(string rawMessage)
    {
        var entry = new LogEntry { Message = rawMessage };

        if (rawMessage.Contains("🚫 BLOCKED:") || rawMessage.Contains("🚫 AI-LEARNED BLOCK:"))
        {
            entry.Level = LogLevel.Block;
            entry.Domain = ExtractDomain(rawMessage);
        }
        else if (rawMessage.Contains("🤖 BEHAVIOR BLOCK") || rawMessage.Contains("🤖 AI LEARNED") ||
                 rawMessage.Contains("🤖 AI CRITICAL") || rawMessage.Contains("🚨 AI CRITICAL"))
        {
            entry.Level = LogLevel.AiThreat;
            entry.Domain = ExtractDomain(rawMessage);
        }
        else if (rawMessage.Contains("⚡ CACHE HIT:"))
        {
            entry.Level = LogLevel.CacheHit;
            entry.Domain = ExtractDomain(rawMessage);
        }
        else if (rawMessage.Contains("🔎 Request:"))
        {
            entry.Level = LogLevel.Request;
            entry.Domain = ExtractDomain(rawMessage);
        }
        else if (rawMessage.Contains("✅ ALLOWED:") || rawMessage.Contains("✅ ALLOWLISTED:"))
        {
            entry.Level = LogLevel.Allow;
            entry.Domain = ExtractDomain(rawMessage);
        }
        else if (rawMessage.Contains("❌") || rawMessage.Contains("error", StringComparison.OrdinalIgnoreCase))
        {
            entry.Level = LogLevel.Error;
        }
        else if (rawMessage.Contains("⚠️") || rawMessage.Contains("warning", StringComparison.OrdinalIgnoreCase))
        {
            entry.Level = LogLevel.Warning;
        }
        else
        {
            entry.Level = LogLevel.Info;
        }

        return entry;
    }

    private static string ExtractDomain(string message)
    {
        var colonIdx = message.LastIndexOf(':');
        if (colonIdx >= 0 && colonIdx < message.Length - 1)
        {
            var parts = message[(colonIdx + 1)..].Split('—', StringSplitOptions.TrimEntries);
            return parts[0].Trim();
        }
        return string.Empty;
    }
}
</file>

