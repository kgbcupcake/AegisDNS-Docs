<file path="src/AegisDNS.Core/Proxy/AdBlockingMiddleware.cs">
using System;
using System.Collections.Generic;
using System.Collections.Immutable;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Text;
using System.Text.Json;

namespace AegisDNS.Core.Proxy;

/// <summary>
/// Phase 18 — Ad Blocking Middleware.
/// Decides whether an HTTPS request should be blocked based on URL patterns.
/// </summary>
public static class AdBlockingMiddleware
{
    private static readonly string UserPatternsPath = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
        ".config", "aegisdns", "proxy_patterns.json");

    private static ImmutableList<AdPattern> _activePatterns = ImmutableList<AdPattern>.Empty;

    static AdBlockingMiddleware()
    {
        ReloadPatterns();
        HttpsProxyConfigManager.SettingsChanged += ReloadPatterns;
    }

    public static void ReloadPatterns()
    {
        var builder = ImmutableList.CreateBuilder<AdPattern>();

        // Add defaults based on settings
        if (HttpsProxyConfigManager.Settings.ProxyBlockYouTubeAds)
            builder.AddRange(AdUrlPatterns.YouTubePatterns);

        if (HttpsProxyConfigManager.Settings.ProxyBlockSpotifyAds)
            builder.AddRange(AdUrlPatterns.SpotifyPatterns);

        if (HttpsProxyConfigManager.Settings.ProxyBlockPrimeVideoAds)
            builder.AddRange(AdUrlPatterns.PrimeVideoPatterns);

        if (HttpsProxyConfigManager.Settings.ProxyBlockDisneyPlusAds)
            builder.AddRange(AdUrlPatterns.DisneyPlusPatterns);

        if (HttpsProxyConfigManager.Settings.ProxyBlockGenericAds)
            builder.AddRange(AdUrlPatterns.GenericAdPatterns);

        // Load user patterns if exist
        if (File.Exists(UserPatternsPath))
        {
            try
            {
                string json = File.ReadAllText(UserPatternsPath);
                var userPatterns = JsonSerializer.Deserialize<List<AdPattern>>(json);
                if (userPatterns != null)
                    builder.AddRange(userPatterns);
            }
            catch (JsonException ex)
            {
                Debug.WriteLine($"[AdBlockingMiddleware] Error parsing user patterns: {ex.Message}");
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[AdBlockingMiddleware] Error loading user patterns: {ex.Message}");
            }
        }

        _activePatterns = builder.ToImmutable();
    }

    public static bool ShouldBlock(string host, string path, string query)
    {
        // Optimization: if no patterns, always allowed
        if (_activePatterns.IsEmpty) return false;

        foreach (var pattern in _activePatterns)
        {
            if (MatchHost(host, pattern.HostPattern))
            {
                if (path.Contains(pattern.PathContains, StringComparison.OrdinalIgnoreCase))
                {
                    if (string.IsNullOrEmpty(pattern.QueryContains) ||
                        (!string.IsNullOrEmpty(query) && query.Contains(pattern.QueryContains, StringComparison.OrdinalIgnoreCase)))
                    {
                        return true;
                    }
                }
            }
        }

        return false;
    }

    private static bool MatchHost(string host, string pattern)
    {
        if (string.Equals(host, pattern, StringComparison.OrdinalIgnoreCase))
            return true;

        if (pattern.StartsWith("*."))
        {
            string suffix = pattern.Substring(1); // ".domain.com"
            return host.EndsWith(suffix, StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    public static byte[] GetBlockResponse(string path)
    {
        // Video content: return empty 200 (or minimal valid MP4 if needed, but 200 OK is usually enough)
        if (path.Contains(".mp4") || path.Contains(".m4v") || path.Contains("/videoplayback"))
        {
            return Encoding.UTF8.GetBytes("HTTP/1.1 200 OK\r\nContent-Length: 0\r\nConnection: close\r\n\r\n");
        }

        // JavaScript/tracking: 204 No Content
        if (path.Contains(".js") || path.Contains("/api/stats/ads"))
        {
            return Encoding.UTF8.GetBytes("HTTP/1.1 204 No Content\r\nConnection: close\r\n\r\n");
        }

        // Image ads: 1x1 transparent pixel
        if (path.Contains(".png") || path.Contains(".jpg") || path.Contains(".gif") || path.Contains(".webp"))
        {
            byte[] pixel = Convert.FromBase64String("R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7");
            string header = $"HTTP/1.1 200 OK\r\nContent-Type: image/gif\r\nContent-Length: {pixel.Length}\r\nConnection: close\r\n\r\n";
            byte[] headerBytes = Encoding.UTF8.GetBytes(header);
            byte[] response = new byte[headerBytes.Length + pixel.Length];
            Buffer.BlockCopy(headerBytes, 0, response, 0, headerBytes.Length);
            Buffer.BlockCopy(pixel, 0, response, headerBytes.Length, pixel.Length);
            return response;
        }

        // Default: 204 No Content
        return Encoding.UTF8.GetBytes("HTTP/1.1 204 No Content\r\nConnection: close\r\n\r\n");
    }
}
