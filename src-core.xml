<file path="src/AegisDNS.Core/Core/DnsSnapshot.cs">
using System.Diagnostics;
using System.Text.Json;

namespace AegisDNS.Core;

/// <summary>
/// Persists the user's original DNS configuration to disk so it can be
/// restored after a crash or reboot. Ensures internet survivability.
/// </summary>
public record DnsSnapshotData(
    List<string> OriginalDns,
    bool WasDhcp,
    string InterfaceName,
    DateTime Timestamp
);

public static class DnsSnapshot
{
    private static readonly string AppFolder =
        Environment.GetEnvironmentVariable("XDG_DATA_HOME") ?? "/var/lib/aegisdns";
    private static readonly string SnapshotPath = Path.Combine(AppFolder, "dns_snapshot.json");

    /// <summary>
    /// Atomically save the DNS snapshot (write temp → rename).
    /// </summary>
    public static void Save(List<string> originalDns, bool wasDhcp, string interfaceName)
    {
        try
        {
            var data = new DnsSnapshotData(originalDns, wasDhcp, interfaceName, DateTime.UtcNow);
            string json = JsonSerializer.Serialize(data, new JsonSerializerOptions { WriteIndented = true });

            string dir = Path.GetDirectoryName(SnapshotPath)!;
            if (!Directory.Exists(dir))
                Directory.CreateDirectory(dir);

            // Atomic write: temp file → rename
            string tempPath = SnapshotPath + ".tmp";
            File.WriteAllText(tempPath, json);
            File.Move(tempPath, SnapshotPath, overwrite: true);

            Debug.WriteLine($"[DnsSnapshot] Saved snapshot: {originalDns.Count} DNS entries for {interfaceName}");
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[DnsSnapshot] Save failed: {ex.Message}");
        }
    }

    /// <summary>
    /// Load a snapshot if it exists and is less than 24 hours old.
    /// </summary>
    public static DnsSnapshotData? Load()
    {
        try
        {
            if (!File.Exists(SnapshotPath))
                return null;

            string json = File.ReadAllText(SnapshotPath);
            DnsSnapshotData? data;
            try { data = JsonSerializer.Deserialize<DnsSnapshotData>(json); }
            catch (JsonException) { return null; }

            if (data == null)
                return null;

            // Reject stale snapshots (> 24 hours)
            if ((DateTime.UtcNow - data.Timestamp).TotalHours > 24)
            {
                Debug.WriteLine("[DnsSnapshot] Snapshot is stale (>24h). Deleting.");
                Delete();
                return null;
            }

            Debug.WriteLine($"[DnsSnapshot] Loaded snapshot: {data.OriginalDns.Count} DNS entries for {data.InterfaceName}");
            return data;
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[DnsSnapshot] Load failed: {ex.Message}");
            return null;
        }
    }

    /// <summary>
    /// Delete the snapshot after a successful DNS restore.
    /// </summary>
    public static void Delete()
    {
        try
        {
            if (File.Exists(SnapshotPath))
            {
                File.Delete(SnapshotPath);
                Debug.WriteLine("[DnsSnapshot] Snapshot deleted after successful restore.");
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[DnsSnapshot] Delete failed: {ex.Message}");
        }
    }

    /// <summary>
    /// Check if a snapshot exists (for startup crash recovery).
    /// </summary>
    public static bool Exists() => File.Exists(SnapshotPath);
}
