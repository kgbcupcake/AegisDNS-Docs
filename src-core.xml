<file path="src/AegisDNS.Core/PolicyEngine/DevicePolicyEngine.cs">
using System;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Net;
using System.Text.Json;
using System.Threading.Tasks;

using Microsoft.Extensions.Logging;

namespace AegisDNS.Core.PolicyEngine;

// ── Data Models ───────────────────────────────────────────────────────────────

public enum PolicyAction { Allow, Block, BlockCategories, SafeSearch, Log }

public class TimeRule
{
    public string Start { get; set; } = "00:00";
    public string End { get; set; } = "23:59";
    public PolicyAction Action { get; set; } = PolicyAction.Block;
    public List<string> Categories { get; set; } = new();
}

public class DomainRule
{
    public string Pattern { get; set; } = "";   // exact, *.wildcard, or regex:
    public PolicyAction Action { get; set; } = PolicyAction.Allow;
}

public class DevicePolicy
{
    public string DeviceName { get; set; } = "";
    public string Mac { get; set; } = "";   // primary identifier
    public string? Hostname { get; set; }
    public string? IpAddress { get; set; }
    public string GroupId { get; set; } = "";
    public List<TimeRule> TimeRules { get; set; } = new();
    public List<DomainRule> DomainRules { get; set; } = new();
    public bool SafeSearchEnabled { get; set; } = false;
    public bool BlockAllByDefault { get; set; } = false;
}

public class DeviceGroup
{
    public string Id { get; set; } = "";
    public string Name { get; set; } = "";
    public List<TimeRule> TimeRules { get; set; } = new();
    public List<DomainRule> DomainRules { get; set; } = new();
}

public enum PolicyResult { Allow, Block, SafeSearch }

public class PolicyDecision
{
    public PolicyResult Result { get; set; }
    public string Reason { get; set; } = "";
    public string RuleName { get; set; } = "";
}

// ── Engine ────────────────────────────────────────────────────────────────────

/// <summary>
/// Zero-trust per-device DNS policy engine.
/// Resolves per-device rules → group rules → time rules → default policy.
/// Hot-reloads from JSON on change — no restart required.
/// Thread-safe via ConcurrentDictionary + immutable snapshots.
/// </summary>
public sealed class DevicePolicyEngine
{
    private static readonly string PolicyDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.CommonApplicationData), "AegisDNS", "policies");

    private readonly ILogger<DevicePolicyEngine> _logger;
    private readonly ConcurrentDictionary<string, DevicePolicy> _devicePolicies = new(StringComparer.OrdinalIgnoreCase);
    private readonly ConcurrentDictionary<string, DeviceGroup> _groups = new(StringComparer.OrdinalIgnoreCase);
    private PolicyAction _defaultAction = PolicyAction.Allow;

    private FileSystemWatcher? _watcher;

    public DevicePolicyEngine(ILogger<DevicePolicyEngine> logger)
    {
        _logger = logger;
    }

    public void Initialize()
    {
        Directory.CreateDirectory(PolicyDir);
        LoadAll();
        StartFileWatcher();
    }

    private void LoadAll()
    {
        if (!Directory.Exists(PolicyDir)) return;
        _devicePolicies.Clear();
        _groups.Clear();

        foreach (var file in Directory.GetFiles(PolicyDir, "*.json"))
        {
            try
            {
                string json = File.ReadAllText(file);
                string name = Path.GetFileNameWithoutExtension(file);

                if (name == "default")
                {
                    try
                    {
                        var def = JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                        if (def?.TryGetValue("action", out string? act) == true)
                            _defaultAction = Enum.TryParse<PolicyAction>(act, true, out var a) ? a : PolicyAction.Allow;
                    }
                    catch (JsonException ex)
                    {
                        _logger.LogError(ex, "[DevicePolicyEngine] Failed to parse default policy {File}.", file);
                    }
                }
                else if (name.StartsWith("group_"))
                {
                    try
                    {
                        var group = JsonSerializer.Deserialize<DeviceGroup>(json);
                        if (group != null) _groups[group.Id] = group;
                    }
                    catch (JsonException ex)
                    {
                        _logger.LogError(ex, "[DevicePolicyEngine] Failed to parse group policy {File}.", file);
                    }
                }
                else
                {
                    try
                    {
                        var policy = JsonSerializer.Deserialize<DevicePolicy>(json);
                        if (policy != null) _devicePolicies[policy.Mac.ToUpperInvariant()] = policy;
                    }
                    catch (JsonException ex)
                    {
                        _logger.LogError(ex, "[DevicePolicyEngine] Failed to parse device policy {File}.", file);
                    }
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "[PolicyEngine] Failed to load {File}.", file);
            }
        }
    }

    private void StartFileWatcher()
    {
        if (!Directory.Exists(PolicyDir)) return;

        _watcher = new FileSystemWatcher(PolicyDir, "*.json")
        {
            NotifyFilter = NotifyFilters.LastWrite | NotifyFilters.FileName,
            EnableRaisingEvents = true
        };
        _watcher.Changed += (_, _) => LoadAll();
        _watcher.Created += (_, _) => LoadAll();
        _watcher.Deleted += (_, _) => LoadAll();
    }

    /// <summary>
    /// Resolves the policy for a domain query from a specific device MAC address.
    /// Resolution: Device Rule → Group Rule → Time Rule → Default
    /// </summary>
    public PolicyDecision Resolve(string domain, string clientMac, string? clientIp = null)
    {
        string mac = clientMac.ToUpperInvariant();
        var now = TimeOnly.FromDateTime(DateTime.Now);

        if (_devicePolicies.TryGetValue(mac, out DevicePolicy? policy))
        {
            foreach (var rule in policy.TimeRules)
            {
                if (IsInTimeWindow(now, rule.Start, rule.End))
                {
                    if (rule.Action == PolicyAction.Block)
                        return new PolicyDecision { Result = PolicyResult.Block, Reason = "Device time rule", RuleName = $"Time {rule.Start}-{rule.End}" };
                    if (rule.Action == PolicyAction.Allow)
                        return new PolicyDecision { Result = PolicyResult.Allow, Reason = "Device time allow", RuleName = $"Time {rule.Start}-{rule.End}" };
                }
            }

            foreach (var rule in policy.DomainRules)
            {
                if (MatchesDomain(domain, rule.Pattern))
                    return rule.Action == PolicyAction.Allow
                        ? new PolicyDecision { Result = PolicyResult.Allow, Reason = "Device domain rule", RuleName = rule.Pattern }
                        : new PolicyDecision { Result = PolicyResult.Block, Reason = "Device domain rule", RuleName = rule.Pattern };
            }

            if (policy.BlockAllByDefault)
                return new PolicyDecision { Result = PolicyResult.Block, Reason = "Device block-all default" };

            if (policy.SafeSearchEnabled)
                return new PolicyDecision { Result = PolicyResult.SafeSearch, Reason = "Device SafeSearch enabled" };

            if (!string.IsNullOrEmpty(policy.GroupId) && _groups.TryGetValue(policy.GroupId, out DeviceGroup? group))
            {
                var groupDecision = ResolveGroup(group, domain, now);
                if (groupDecision != null) return groupDecision;
            }
        }

        return _defaultAction == PolicyAction.Block
            ? new PolicyDecision { Result = PolicyResult.Block, Reason = "Default policy: block" }
            : new PolicyDecision { Result = PolicyResult.Allow, Reason = "Default policy: allow" };
    }

    private static PolicyDecision? ResolveGroup(DeviceGroup group, string domain, TimeOnly now)
    {
        foreach (var rule in group.TimeRules)
            if (IsInTimeWindow(now, rule.Start, rule.End))
                return new PolicyDecision
                {
                    Result = rule.Action == PolicyAction.Block ? PolicyResult.Block : PolicyResult.Allow,
                    Reason = $"Group '{group.Name}' time rule",
                    RuleName = $"Time {rule.Start}-{rule.End}"
                };

        foreach (var rule in group.DomainRules)
            if (MatchesDomain(domain, rule.Pattern))
                return new PolicyDecision
                {
                    Result = rule.Action == PolicyAction.Allow ? PolicyResult.Allow : PolicyResult.Block,
                    Reason = $"Group '{group.Name}' domain rule",
                    RuleName = rule.Pattern
                };

        return null;
    }

    public void SaveDevicePolicy(DevicePolicy policy)
    {
        Directory.CreateDirectory(PolicyDir);
        string safeName = policy.Mac.Replace(":", "-").ToUpperInvariant();
        File.WriteAllText(Path.Combine(PolicyDir, $"{safeName}.json"),
            JsonSerializer.Serialize(policy, new JsonSerializerOptions { WriteIndented = true }));
        _devicePolicies[policy.Mac.ToUpperInvariant()] = policy;
    }

    public void SaveGroup(DeviceGroup group)
    {
        Directory.CreateDirectory(PolicyDir);
        File.WriteAllText(Path.Combine(PolicyDir, $"group_{group.Id}.json"),
            JsonSerializer.Serialize(group, new JsonSerializerOptions { WriteIndented = true }));
        _groups[group.Id] = group;
    }

    public IEnumerable<DevicePolicy> GetAllPolicies() => _devicePolicies.Values;
    public IEnumerable<DeviceGroup> GetAllGroups() => _groups.Values;

    /// <summary>
    /// Atomically applies a cloud-pushed policy bundle from JSON.
    /// Replaces all in-memory policies and groups without restarting.
    /// Thread-safe: new state visible to Resolve() only after the swap is complete.
    /// </summary>
    public void ApplyPolicy(string policyJson)
    {
        try
        {
            var newPolicies = JsonSerializer.Deserialize<List<DevicePolicy>>(policyJson,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (newPolicies is null) return;
            _devicePolicies.Clear();
            foreach (var p in newPolicies)
                _devicePolicies[p.Mac.ToUpperInvariant()] = p;
            _logger.LogInformation("[DevicePolicyEngine] Cloud policy applied: {0} device rules.", newPolicies.Count);
        }
        catch (JsonException ex)
        {
            Debug.WriteLine($"[DevicePolicyEngine] Failed to apply cloud policy: {ex.Message} — keeping existing rules.");
            _logger.LogError(ex, "[DevicePolicyEngine] Failed to apply cloud policy — keeping existing rules.");
        }
    }

    private static bool IsInTimeWindow(TimeOnly now, string start, string end)
    {
        if (!TimeOnly.TryParse(start, out var s) || !TimeOnly.TryParse(end, out var e)) return false;
        return s <= e ? (now >= s && now <= e) : (now >= s || now <= e); // handles midnight wrap
    }

    private static bool MatchesDomain(string domain, string pattern)
    {
        if (pattern.StartsWith("regex:"))
        {
            try
            {
                return System.Text.RegularExpressions.Regex.IsMatch(domain, pattern[6..],
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase,
                    TimeSpan.FromSeconds(1));
            }
            catch (System.Text.RegularExpressions.RegexMatchTimeoutException)
            {
                // _logger not available in static method — logged as Debug.WriteLine by design
                System.Diagnostics.Debug.WriteLine($"[PolicyEngine] Regex timeout for pattern: {pattern}");
                return false; // Fail-closed: treat timed-out regex as no match
            }
        }
        if (pattern.StartsWith("*."))
        {
            string suffix = pattern[2..];
            return domain.Equals(suffix, StringComparison.OrdinalIgnoreCase)
                || domain.EndsWith("." + suffix, StringComparison.OrdinalIgnoreCase);
        }
        return domain.Equals(pattern, StringComparison.OrdinalIgnoreCase);
    }
}
