<file path="src/AegisDNS.Core/Dns/DotClient.cs">
using System;
using System.IO;
using System.Net.Security;
using System.Net.Sockets;
using System.Security.Cryptography;
using System.Text;

using ARSoft.Tools.Net;
using ARSoft.Tools.Net.Dns;

namespace AegisDNS.Core.Dns;

/// <summary>
/// DNS over TLS (DoT) upstream resolver. Connects to upstream:853 using TLS 1.2+.
/// DNS wire format: 2-byte big-endian length prefix + standard DNS query bytes (RFC 7858).
/// Maintains a persistent connection and reconnects on failure.
/// Implements IUpstreamResolver for clean swap in Engine.cs.
/// </summary>
public sealed class DotClient : IUpstreamResolver, IDisposable
{
    private readonly string _upstream;
    private TcpClient? _tcp;
    private SslStream? _ssl;

    public DotClient(string upstream)
    {
        _upstream = upstream;
    }

    public DnsMessage? Resolve(DomainName name, RecordType recordType, RecordClass recordClass)
    {
        try
        {
            EnsureConnected();
            if (_ssl == null) return null;

            byte[] queryBytes = BuildDnsQuery(name, recordType, recordClass);

            // RFC 7858: 2-byte length prefix (big-endian) + query bytes
            byte[] lenPrefix = [
                (byte)(queryBytes.Length >> 8),
                (byte)(queryBytes.Length & 0xFF)
            ];

            _ssl.Write(lenPrefix, 0, 2);
            _ssl.Write(queryBytes, 0, queryBytes.Length);
            _ssl.Flush();

            // Read response length prefix
            byte[] respLen = new byte[2];
            ReadExact(_ssl, respLen, 2);
            int responseLength = (respLen[0] << 8) | respLen[1];

            if (responseLength <= 0 || responseLength > 65535)
            {
                Disconnect();
                return null;
            }

            byte[] responseBytes = new byte[responseLength];
            ReadExact(_ssl, responseBytes, responseLength);

            return DnsMessage.Parse(responseBytes);
        }
        catch
        {
            Disconnect();
            return null;
        }
    }

    private void EnsureConnected()
    {
        if (_tcp?.Connected == true && _ssl != null) return;

        Disconnect();

        var tcp = new TcpClient
        {
            SendTimeout = 5000,
            ReceiveTimeout = 5000
        };

        // 3-second connection timeout
        bool connected = tcp.ConnectAsync(_upstream, 853).Wait(3000);
        if (!connected)
        {
            tcp.Dispose();
            throw new TimeoutException($"DoT connection to {_upstream}:853 timed out");
        }

        var ssl = new SslStream(tcp.GetStream(), false);

        // Require TLS 1.2 minimum; validate server certificate fully (no bypass)
        ssl.AuthenticateAsClient(_upstream,
            clientCertificates: null,
            enabledSslProtocols: System.Security.Authentication.SslProtocols.Tls12 | System.Security.Authentication.SslProtocols.Tls13,
            checkCertificateRevocation: true);

        _tcp = tcp;
        _ssl = ssl;
    }

    private void Disconnect()
    {
        try { _ssl?.Dispose(); } catch { }
        try { _tcp?.Dispose(); } catch { }
        _ssl = null;
        _tcp = null;
    }

    public void Dispose() => Disconnect();

    private static void ReadExact(Stream stream, byte[] buffer, int count)
    {
        int offset = 0;
        while (offset < count)
        {
            int read = stream.Read(buffer, offset, count - offset);
            if (read == 0) throw new EndOfStreamException("DoT connection closed mid-read");
            offset += read;
        }
    }

    private static byte[] BuildDnsQuery(DomainName name, RecordType recordType, RecordClass recordClass)
    {
        using var ms = new MemoryStream();
        using var w = new BinaryWriter(ms);

        // Transaction ID — must be cryptographically random to resist DNS spoofing
        ushort txId = (ushort)RandomNumberGenerator.GetInt32(1, 65536);
        WriteBigEndian(w, txId);

        // Flags: Standard query, Recursion Desired
        WriteBigEndian(w, (ushort)0x0100);

        // QDCOUNT=1, ANCOUNT=0, NSCOUNT=0, ARCOUNT=0
        WriteBigEndian(w, (ushort)1);
        WriteBigEndian(w, (ushort)0);
        WriteBigEndian(w, (ushort)0);
        WriteBigEndian(w, (ushort)0);

        // QNAME — encode each label
        string domainStr = name.ToString().TrimEnd('.');
        foreach (var label in domainStr.Split('.'))
        {
            if (string.IsNullOrEmpty(label)) continue;
            byte[] labelBytes = Encoding.ASCII.GetBytes(label);
            w.Write((byte)labelBytes.Length);
            w.Write(labelBytes);
        }
        w.Write((byte)0);  // root label terminator

        WriteBigEndian(w, (ushort)recordType);
        WriteBigEndian(w, (ushort)recordClass);

        return ms.ToArray();
    }

    private static void WriteBigEndian(BinaryWriter w, ushort value)
    {
        w.Write((byte)(value >> 8));
        w.Write((byte)(value & 0xFF));
    }

    /// <summary>
    /// Sends a test query to each preset upstream and returns latency in milliseconds.
    /// Used by LatencyMonitor.CompareUpstreams().
    /// </summary>
    public static (string Upstream, long LatencyMs) MeasureLatency(string upstream)
    {
        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            using var client = new DotClient(upstream);
            var result = client.Resolve(DomainName.Parse("example.com"), RecordType.A, RecordClass.INet);
            sw.Stop();
            return (upstream, result != null ? sw.ElapsedMilliseconds : -1);
        }
        catch
        {
            sw.Stop();
            return (upstream, -1);
        }
    }
}
