using System;
using System.Diagnostics;
using System.IO;
using System.Linq;

namespace AegisDNS.Core.Utilities;

/// <summary>
/// Handles system rollback and recovery during failed updates.
/// </summary>
// static class: logger injection deferred — DI not available on static classes.
public static class RollbackManager
{
    private static readonly string AppDataDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "AegisDNS");
    private static readonly string RollbackDir = Path.Combine(AppDataDir, "_rollback");
    private static readonly string InstallDir = AppContext.BaseDirectory;

    /// <summary>
    /// Creates a backup of the current installation binaries and config.
    /// </summary>
    public static bool CreateBackup()
    {
        try
        {
            if (Directory.Exists(RollbackDir))
                Directory.Delete(RollbackDir, true);

            Directory.CreateDirectory(RollbackDir);

            // Copy critical files (Executables, DLLs, Config)
            foreach (var file in Directory.GetFiles(InstallDir))
            {
                string ext = Path.GetExtension(file).ToLower();
                if (ext == ".exe" || ext == ".dll" || ext == ".json" || ext == ".config")
                {
                    string dest = Path.Combine(RollbackDir, Path.GetFileName(file));
                    File.Copy(file, dest, true);
                }
            }

            Debug.WriteLine($"[RollbackManager] Backup created in {RollbackDir}");
            return true;
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[RollbackManager] Backup failed: {ex.Message}");
            return false;
        }
    }

    /// <summary>
    /// Performs a recovery by restoring files from the rollback directory.
    /// </summary>
    public static bool Restore()
    {
        try
        {
            if (!Directory.Exists(RollbackDir))
            {
                Debug.WriteLine("[RollbackManager] No rollback data found.");
                return false;
            }

            Debug.WriteLine("[RollbackManager] Initiating restore...");

            // Note: In a real-world scenario, this might need a separate stub executable 
            // since files might be in use. For now, we'll try basic restoration.
            foreach (var file in Directory.GetFiles(RollbackDir))
            {
                string dest = Path.Combine(InstallDir, Path.GetFileName(file));
                try
                {
                    File.Copy(file, dest, true);
                }
                catch (IOException)
                {
                    // If in use, we might need a post-reboot move or a separate restorer.
                    Debug.WriteLine($"[RollbackManager] Cannot restore {Path.GetFileName(file)}: File in use.");
                }
            }

            return true;
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[RollbackManager] Restore failed: {ex.Message}");
            return false;
        }
    }

    /// <summary>
    /// Runs a health check to ensure the service/UI core components are functional.
    /// </summary>
    public static bool RunHealthCheck()
    {
        try
        {
            // Check if we can load the ConfigManager (implicitly tests JSON parsing)
            if (ConfigManager.Settings == null)
                return false;

            return true;
        }
        catch
        {
            return false;
        }
    }
}
