<file path="src/AegisDNS.Core/Utilities/SecureCredentialStore.cs">
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Runtime.InteropServices;
using System.Security.Cryptography;
using System.Text;
using System.Text.Json;
using System.Text.Json.Serialization;

namespace AegisDNS.Core.Utilities;

/// <summary>
/// Per-provider credential entry stored in the encrypted vault.
/// </summary>
public class ProviderCredential
{
    public string ApiKey { get; set; } = "";
    public string Endpoint { get; set; } = "";
    public string Model { get; set; } = "";
    public string Email { get; set; } = "";
    public string OAuthToken { get; set; } = "";
    public string OAuthRefreshToken { get; set; } = "";
    public bool IsSignedIn { get; set; } = false;
    public DateTime LastUpdated { get; set; } = DateTime.MinValue;
}

/// <summary>
/// Root object stored in the encrypted vault file.
/// </summary>
public class CredentialVault
{
    public Dictionary<string, ProviderCredential> Providers { get; set; } = new(StringComparer.OrdinalIgnoreCase);
}

/// <summary>
/// On-disk envelope: encrypted payload + HMAC signature.
/// Editing any byte invalidates the signature.
/// </summary>
internal class SecureVaultEnvelope
{
    public string EncryptedData { get; set; } = "";
    public string Signature { get; set; } = "";
    public string Salt { get; set; } = "";
    public string IV { get; set; } = "";
}

[JsonSerializable(typeof(CredentialVault))]
[JsonSerializable(typeof(SecureVaultEnvelope))]
internal partial class VaultJsonContext : JsonSerializerContext { }

/// <summary>
/// AES-256-CBC encrypted credential store with HMAC-SHA256 integrity.
/// Machine-bound via hardware ID. Stored at /var/lib/aegisdns/ai_credentials.enc.
/// </summary>
public static class SecureCredentialStore
{
    private static readonly string AppFolder =
        Environment.GetEnvironmentVariable("XDG_DATA_HOME") ?? "/var/lib/aegisdns";
    private static readonly string VaultPath = Path.Combine(AppFolder, "ai_credentials.enc");

    // --- CONSTANTS ---

    /// <summary>
    /// Separator used to distinguish the vault namespace from the sub-key or domain within the SecureCredentialStore.
    /// This ensures isolation between different providers or namespaces.
    /// </summary>
    private static readonly byte[] _vaultDomainSeparator =
        Encoding.UTF8.GetBytes("AegisDNS-v1-CredentialVault-2026");

    private static CredentialVault _vault = new();

    /// <summary>Supported provider names for the UI.</summary>
    public static readonly string[] SupportedProviders = {
        "Ollama", "Gemini", "OpenAI", "Anthropic",
        "Mistral", "Groq", "LM Studio", "Deepseek", "Perplexity", "OpenRouter"
    };


    /// <summary>Providers that support browser sign-in via their dashboard.</summary>
    public static readonly HashSet<string> BrowserSignInProviders = new(StringComparer.OrdinalIgnoreCase)
    {
        "Gemini", "OpenAI", "Anthropic", "Mistral", "Groq", "Deepseek", "Perplexity", "OpenRouter"
    };

    static SecureCredentialStore()
    {
        Load();
    }

    // ===== PUBLIC API =====

    public static CredentialVault Vault => _vault;

    public static void SetCredential(string provider, string apiKey, string endpoint = "", string model = "")
    {
        var cred = GetOrCreate(provider);
        cred.ApiKey = apiKey;
        if (!string.IsNullOrEmpty(endpoint)) cred.Endpoint = endpoint;
        if (!string.IsNullOrEmpty(model)) cred.Model = model;
        cred.IsSignedIn = !string.IsNullOrWhiteSpace(apiKey);
        cred.LastUpdated = DateTime.UtcNow;
        Save();
    }

    public static void SetOAuthCredential(string provider, string email, string oauthToken, string refreshToken = "")
    {
        var cred = GetOrCreate(provider);
        cred.Email = email;
        cred.OAuthToken = oauthToken;
        cred.OAuthRefreshToken = refreshToken;
        cred.IsSignedIn = true;
        cred.LastUpdated = DateTime.UtcNow;
        Save();
    }

    public static ProviderCredential? GetCredential(string provider)
    {
        return _vault.Providers.TryGetValue(provider, out var cred) ? cred : null;
    }

    public static bool IsSignedIn(string provider)
    {
        return _vault.Providers.TryGetValue(provider, out var cred) && cred.IsSignedIn;
    }

    public static void SignOut(string provider)
    {
        if (_vault.Providers.ContainsKey(provider))
        {
            _vault.Providers.Remove(provider);
            Save();
        }
    }

    // ===== PERSISTENCE (AES-256) =====

    public static void Load()
    {
        try
        {
            if (!File.Exists(VaultPath))
            {
                _vault = new CredentialVault();
                return;
            }

            string json = File.ReadAllText(VaultPath);
            SecureVaultEnvelope? envelope;
            try
            {
                envelope = JsonSerializer.Deserialize(json, VaultJsonContext.Default.SecureVaultEnvelope);
            }
            catch (JsonException ex)
            {
                Debug.WriteLine($"⚠️ Vault envelope JSON parse failed: {ex.Message}. Starting fresh.");
                _vault = new CredentialVault();
                return;
            }
            if (envelope == null || string.IsNullOrEmpty(envelope.EncryptedData))
            {
                _vault = new CredentialVault();
                return;
            }

            string hwid = AegisDNS.Licensing.HardwareIdentity.Get();
            byte[] salt = Convert.FromBase64String(envelope.Salt);
            byte[] iv = Convert.FromBase64String(envelope.IV);
            byte[] derivedKey = DeriveKey(hwid, salt);

            // Verify HMAC
            byte[] encryptedBytes = Convert.FromBase64String(envelope.EncryptedData);
            byte[] expectedHmac = Convert.FromBase64String(envelope.Signature);
            if (!VerifyHmac(encryptedBytes, expectedHmac, derivedKey))
                throw new CryptographicException("Vault integrity check failed");

            // Decrypt
            string plaintext = DecryptAes(encryptedBytes, derivedKey, iv);
            CredentialVault? loaded;
            try
            {
                loaded = JsonSerializer.Deserialize(plaintext, VaultJsonContext.Default.CredentialVault);
            }
            catch (JsonException ex)
            {
                Debug.WriteLine($"⚠️ Vault payload JSON parse failed: {ex.Message}. Starting fresh.");
                _vault = new CredentialVault();
                return;
            }
            _vault = loaded ?? new CredentialVault();

            Debug.WriteLine($"🔐 Credential vault loaded: {_vault.Providers.Count} providers");
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"⚠️ Vault load failed: {ex.Message}. Starting fresh.");
            _vault = new CredentialVault();
        }
    }

    public static void Save()
    {
        try
        {
            if (!Directory.Exists(AppFolder))
                Directory.CreateDirectory(AppFolder);

            string hwid = AegisDNS.Licensing.HardwareIdentity.Get();
            byte[] salt = RandomNumberGenerator.GetBytes(32);
            byte[] iv = RandomNumberGenerator.GetBytes(16);
            byte[] derivedKey = DeriveKey(hwid, salt);

            var options = new JsonSerializerOptions { WriteIndented = false };
            string plaintext = JsonSerializer.Serialize(_vault, typeof(CredentialVault),
                new VaultJsonContext(options));

            byte[] encrypted = EncryptAes(plaintext, derivedKey, iv);
            byte[] hmac = ComputeHmac(encrypted, derivedKey);

            var envelope = new SecureVaultEnvelope
            {
                EncryptedData = Convert.ToBase64String(encrypted),
                Signature = Convert.ToBase64String(hmac),
                Salt = Convert.ToBase64String(salt),
                IV = Convert.ToBase64String(iv)
            };

            var envelopeOptions = new JsonSerializerOptions { WriteIndented = true };
            string envelopeJson = JsonSerializer.Serialize(envelope, typeof(SecureVaultEnvelope),
                new VaultJsonContext(envelopeOptions));

            File.WriteAllText(VaultPath, envelopeJson);
            Debug.WriteLine($"🔐 Credential vault saved ({_vault.Providers.Count} providers)");
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"❌ Vault save failed: {ex.Message}");
        }
    }

    // ===== CRYPTO INTERNALS =====

    private static byte[] DeriveKey(string hwid, byte[] salt)
    {
        byte[] keyMaterial = Encoding.UTF8.GetBytes(hwid);
        byte[] combined = new byte[keyMaterial.Length + _vaultDomainSeparator.Length];
        Buffer.BlockCopy(keyMaterial, 0, combined, 0, keyMaterial.Length);
        Buffer.BlockCopy(_vaultDomainSeparator, 0, combined, keyMaterial.Length, _vaultDomainSeparator.Length);

        return Rfc2898DeriveBytes.Pbkdf2(combined, salt, 100_000, HashAlgorithmName.SHA256, 32);
    }

    private static byte[] EncryptAes(string plaintext, byte[] key, byte[] iv)
    {
        using var aes = Aes.Create();
        aes.Key = key;
        aes.IV = iv;
        aes.Mode = CipherMode.CBC;
        aes.Padding = PaddingMode.PKCS7;

        using var encryptor = aes.CreateEncryptor();
        byte[] plaintextBytes = Encoding.UTF8.GetBytes(plaintext);
        return encryptor.TransformFinalBlock(plaintextBytes, 0, plaintextBytes.Length);
    }

    private static string DecryptAes(byte[] ciphertext, byte[] key, byte[] iv)
    {
        using var aes = Aes.Create();
        aes.Key = key;
        aes.IV = iv;
        aes.Mode = CipherMode.CBC;
        aes.Padding = PaddingMode.PKCS7;

        using var decryptor = aes.CreateDecryptor();
        byte[] plaintext = decryptor.TransformFinalBlock(ciphertext, 0, ciphertext.Length);
        return Encoding.UTF8.GetString(plaintext);
    }

    private static byte[] ComputeHmac(byte[] data, byte[] key)
    {
        using var hmac = new HMACSHA256(key);
        return hmac.ComputeHash(data);
    }

    private static bool VerifyHmac(byte[] data, byte[] expectedHmac, byte[] key)
    {
        byte[] computed = ComputeHmac(data, key);
        return CryptographicOperations.FixedTimeEquals(computed, expectedHmac);
    }



    // ===== HELPERS =====

    private static ProviderCredential GetOrCreate(string provider)
    {
        if (!_vault.Providers.TryGetValue(provider, out var cred))
        {
            cred = new ProviderCredential();
            _vault.Providers[provider] = cred;
        }
        return cred;
    }
}
