<file path="src/AegisDNS.Core/Utilities/PluginManager.cs">
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Reflection;
using System.Security.Cryptography;
using System.Text.Json;
using System.Threading.Tasks;

using AegisDNS.Core.Interfaces;

using Microsoft.Extensions.Logging;

namespace AegisDNS.Core.Utilities;

public class PluginManager
{
    private readonly List<IPlugin> _plugins = new();
    private readonly IServiceProvider _serviceProvider;
    private readonly ILogger<PluginManager> _logger;
    private readonly string _securityDir;

    public PluginManager(IServiceProvider serviceProvider, ILogger<PluginManager> logger)
    {
        _serviceProvider = serviceProvider;
        _logger = logger;
        _securityDir = Path.Combine(AppContext.BaseDirectory, "Security");
    }

    public async Task LoadPluginsAsync()
    {
        string pluginDir = Path.Combine(AppContext.BaseDirectory, "plugins");
        if (!Directory.Exists(pluginDir))
        {
            Directory.CreateDirectory(pluginDir);
            return;
        }

        var dlls = Directory.GetFiles(pluginDir, "*.dll");
        foreach (var dllPath in dlls)
        {
            try
            {
                // Attestation step
                if (!await AttestPluginAsync(dllPath))
                {
                    continue; // Rejected
                }

                // If attestation passes, load securely
                byte[] dllBytes = await File.ReadAllBytesAsync(dllPath);
                var assembly = Assembly.Load(dllBytes); // Load from memory for run-time protection
                var pluginTypes = assembly.GetTypes()
                    .Where(t => typeof(IPlugin).IsAssignableFrom(t) && !t.IsInterface && !t.IsAbstract);

                foreach (var type in pluginTypes)
                {
                    if (Activator.CreateInstance(type) is IPlugin plugin)
                    {
                        _logger.LogInformation("[PluginManager] Loading: {Name} v{Version}", plugin.Name, plugin.Version);
                        await plugin.InitializeAsync(_serviceProvider);
                        _plugins.Add(plugin);
                    }
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "[PluginManager] Failed to load {DllFile}.", Path.GetFileName(dllPath));
            }
        }
    }

    private async Task<bool> AttestPluginAsync(string dllPath)
    {
        string manifestPath = dllPath + ".manifest";
        string sigPath = dllPath + ".sig";

        if (!File.Exists(manifestPath) || !File.Exists(sigPath))
        {
            _logger.LogWarning("[PluginManager] Rejected {DllFile}: Missing signed manifest (.manifest or .sig).", Path.GetFileName(dllPath));
            return false;
        }

        // 1. Verify DLL Hash against Manifest
        byte[] dllBytes = await File.ReadAllBytesAsync(dllPath);
        using var sha = SHA256.Create();
        string actualHash = Convert.ToBase64String(sha.ComputeHash(dllBytes));

        var manifestJson = await File.ReadAllTextAsync(manifestPath);
        Dictionary<string, string>? manifestObj;
        try { manifestObj = JsonSerializer.Deserialize<Dictionary<string, string>>(manifestJson); }
        catch (JsonException ex)
        {
            _logger.LogError(ex, "[PluginManager] Malformed manifest JSON for {DllFile}.", Path.GetFileName(dllPath));
            return false;
        }

        if (manifestObj == null || !manifestObj.TryGetValue("Hash", out string? expectedHash) || expectedHash != actualHash)
        {
            _logger.LogWarning("[PluginManager] Rejected {DllFile}: Hash mismatch in manifest.", Path.GetFileName(dllPath));
            return false;
        }

        // 2. Verify Manifest Signature against the known plugin public key
        byte[] manifestBytes = await File.ReadAllBytesAsync(manifestPath);
        byte[] sigBytes = await File.ReadAllBytesAsync(sigPath);

        string pluginKeyPath = Path.Combine(_securityDir, "plugin_public.pem");
        if (!File.Exists(pluginKeyPath))
        {
            _logger.LogError("[PluginManager] Security directory or plugin_public.pem not found. Cannot verify plugin signatures.");
            return false;
        }

        try
        {
            string pem = await File.ReadAllTextAsync(pluginKeyPath);
            using var rsa = RSA.Create();
            rsa.ImportFromPem(pem);

            if (rsa.VerifyData(manifestBytes, sigBytes, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1))
            {
                // Successfully attested by the trusted plugin key
                return true;
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[PluginManager] Error verifying signature for {DllFile}.", Path.GetFileName(dllPath));
        }

        // Reject if verification failed
        _logger.LogWarning("[PluginManager] Rejected {DllFile}: Signature verification failed or signed with an unknown key.", Path.GetFileName(dllPath));
        return false;
    }

    public async Task ShutdownPluginsAsync()
    {
        foreach (var plugin in _plugins)
        {
            try
            {
                await plugin.ShutdownAsync();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "[PluginManager] Error stopping {Name}.", plugin.Name);
            }
        }
        _plugins.Clear();
    }
}
