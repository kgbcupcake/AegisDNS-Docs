using System;
using System.Collections.Generic;
using System.Collections.Immutable;
using System.IO;
using System.Linq;

namespace AegisDNS.Core.Utilities;

public static class AiLearnedBlocklist
{
    private static readonly string AppFolder = Path.Combine(
        Environment.GetEnvironmentVariable("XDG_DATA_HOME")
            ?? Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), ".local", "share", "aegisdns"),
        "AegisDNS");
    private static readonly string ListPath = Path.Combine(AppFolder, "ai_learned.blocklist");

    private static ImmutableHashSet<string> _list = ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase);

    private static readonly ImmutableHashSet<string> _permanentSafelist =
        ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase,
            "google.com", "www.google.com", "mail.google.com", "accounts.google.com",
            "googleapis.com", "gstatic.com",
            "youtube.com", "www.youtube.com", "youtu.be", "ytimg.com",
            "sync-v2.brave.com", "collector.wdp.brave.com", "brave.com",
            "claude.ai", "anthropic.com",
            "microsoft.com", "live.com", "outlook.com", "office.com",
            "apple.com", "icloud.com",
            "github.com", "githubusercontent.com",
            "cloudflare.com", "cdn.jsdelivr.net", "cdnjs.cloudflare.com"
        );

    public static event Action? CollectionChanged;

    public static int Count => _list.Count;

    public static void Load()
    {
        try
        {
            if (!File.Exists(ListPath))
            {
                ImmutableInterlocked.Update(ref _list, _ => ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase));
                return;
            }

            var lines = File.ReadAllLines(ListPath)
                            .Where(l => !string.IsNullOrWhiteSpace(l))
                            .Select(l => l.Trim().ToLowerInvariant())
                            .ToArray();

            if (lines.Length > 0)
            {
                ImmutableInterlocked.Update(ref _list, _ => ImmutableHashSet.CreateRange(StringComparer.OrdinalIgnoreCase, lines));
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"⚠️ AiLearnedBlocklist load failed: {ex.Message}");
            ImmutableInterlocked.Update(ref _list, _ => ImmutableHashSet.Create<string>(StringComparer.OrdinalIgnoreCase));
        }
    }

    public static bool Contains(string domain)
    {
        if (_permanentSafelist.Contains(domain)) return false;
        if (AllowlistManager.Contains(domain)) return false;
        return _list.Contains(domain);
    }

    public static void Add(string domain)
    {
        if (string.IsNullOrWhiteSpace(domain)) return;
        var cleanDomain = domain.Trim().ToLowerInvariant();

        if (_permanentSafelist.Contains(cleanDomain)) return;
        if (AllowlistManager.Contains(cleanDomain)) return;

        bool added = false;
        ImmutableInterlocked.Update(ref _list, current =>
        {
            if (current.Contains(cleanDomain))
            {
                added = false;
                return current;
            }
            added = true;
            return current.Add(cleanDomain);
        });

        if (added)
        {
            Save();
            CollectionChanged?.Invoke();
        }
    }

    public static void Remove(string domain)
    {
        if (string.IsNullOrWhiteSpace(domain)) return;
        var cleanDomain = domain.Trim().ToLowerInvariant();

        bool removed = false;
        ImmutableInterlocked.Update(ref _list, current =>
        {
            if (!current.Contains(cleanDomain))
            {
                removed = false;
                return current;
            }
            removed = true;
            return current.Remove(cleanDomain);
        });

        if (removed)
        {
            Save();
            CollectionChanged?.Invoke();
        }
    }

    public static IReadOnlyList<string> GetAll()
    {
        return _list.OrderBy(d => d).ToList();
    }

    private static void Save()
    {
        try
        {
            if (!Directory.Exists(AppFolder))
            {
                Directory.CreateDirectory(AppFolder);
            }
            File.WriteAllLines(ListPath, _list.ToArray());
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ AiLearnedBlocklist save failed: {ex.Message}");
        }
    }
}
