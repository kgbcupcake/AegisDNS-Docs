using System.Text;

using AegisDNS.Core.Monitoring;

namespace AegisDNS.Core.Ai;

/// <summary>
/// Shared prompt builder for all AI providers.
/// Constructs a security-focused analysis prompt from DNS query history.
/// </summary>
public static class PromptBuilder
{
    public static string Build(IReadOnlyCollection<QueryHistoryEntry> history)
    {
        var sb = new StringBuilder();
        sb.AppendLine("You are AegisDNS AI Sentinel — a DNS security analyzer.");
        sb.AppendLine("Analyze the following DNS query log for suspicious patterns.");
        sb.AppendLine();
        sb.AppendLine("These domains may have triggered anomalous traffic alerts. Look for DGA patterns or known tracking structures.");
        sb.AppendLine();
        sb.AppendLine("Flag domains that look like:");
        sb.AppendLine("- C2 (Command & Control) callbacks");
        sb.AppendLine("- DGA (Domain Generation Algorithm) generated domains");
        sb.AppendLine("- DNS tunneling / data exfiltration");
        sb.AppendLine("- Known malware or phishing infrastructure");
        sb.AppendLine("- Cryptominer communication");
        sb.AppendLine();
        sb.AppendLine("Response format:");
        sb.AppendLine("- If threat found: 'THREAT: [domain] — [reason]'");
        sb.AppendLine("- If clean: 'CLEAR: No threats detected.'");
        sb.AppendLine();
        sb.AppendLine("--- DNS QUERY LOG ---");

        foreach (var entry in history.TakeLast(50))
        {
            string status = entry.IsBlocked ? $"BLOCKED ({entry.BlockReason})" : "ALLOWED";
            string ageInfo = entry.SessionAge.HasValue ? $" [Age: {(int)entry.SessionAge.Value.TotalMinutes}m]" : "";
            string safeDomain = SanitizeDomain(entry.Domain);
            if (!string.IsNullOrEmpty(safeDomain))
            {
                sb.AppendLine($"[{entry.Timestamp:HH:mm:ss}] {status}: {safeDomain}{ageInfo}");
            }
        }

        return sb.ToString();
    }

    private static string SanitizeDomain(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return string.Empty;

        var sanitized = new StringBuilder(input.Length);
        foreach (char c in input)
        {
            // Allow only standard DNS/hostname characters, stripping out newlines/quotes for injection safety
            if (char.IsLetterOrDigit(c) || c == '.' || c == '-' || c == '_')
            {
                sanitized.Append(c);
            }
        }

        // DNS name max length is 253 characters
        if (sanitized.Length > 253)
        {
            return sanitized.ToString(0, 253);
        }

        return sanitized.ToString();
    }
}
