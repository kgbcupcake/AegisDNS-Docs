using System;
using System.Collections.Concurrent;
using System.Collections.Generic;
using System.Net;

namespace AegisDNS.Core.RouterMode;

/// <summary>Represents a device (source IP) that has sent queries through router mode.</summary>
public sealed class ConnectedDevice
{
    public string IpAddress { get; set; } = "";
    public DateTime LastSeen { get; set; }
    public long QueryCount { get; set; }
    public long BlockedCount { get; set; }
}

/// <summary>
/// Thread-safe tracker of devices sending queries when router mode is active.
/// Uses ConcurrentDictionary for lock-free updates from OnQueryReceived.
/// </summary>
public sealed class ConnectedDeviceTracker
{
    private static readonly ConnectedDeviceTracker _instance = new();
    public static ConnectedDeviceTracker Instance => _instance;

    private readonly ConcurrentDictionary<string, ConnectedDevice> _devices = new();

    private ConnectedDeviceTracker() { }

    /// <summary>
    /// Records a query from the given IP address. Called fire-and-forget from query hot path.
    /// </summary>
    public void RecordQuery(IPAddress address, bool blocked)
    {
        string key = address.ToString();
        _devices.AddOrUpdate(key,
            _ => new ConnectedDevice
            {
                IpAddress = key,
                LastSeen = DateTime.UtcNow,
                QueryCount = 1,
                BlockedCount = blocked ? 1 : 0
            },
            (_, existing) => new ConnectedDevice
            {
                IpAddress = key,
                LastSeen = DateTime.UtcNow,
                QueryCount = existing.QueryCount + 1,
                BlockedCount = existing.BlockedCount + (blocked ? 1 : 0)
            });
    }

    public IReadOnlyList<ConnectedDevice> GetDevices() =>
        new List<ConnectedDevice>(_devices.Values);

    public int DeviceCount => _devices.Count;
}
