using System;

namespace AegisDNS.Core.Monitoring;

public enum SessionPhase
{
    Idle,
    Login,
    MediaLoad,
    Playback
}

/// <summary>
/// Tracks the global streaming/browsing session phase to provide context to domain role scoring.
/// </summary>
// static class: logger injection deferred — all public API methods are static, DI not applicable.
public class SessionManager
{
    private static volatile SessionPhase _currentPhase = SessionPhase.Idle;
    private static DateTime _lastActivity = DateTime.UtcNow;

    public static SessionPhase CurrentPhase => _currentPhase;

    private const int IDLE_TIMEOUT_SECONDS = 300; // 5 minutes without major activity

    /// <summary>
    /// Evaluates incoming query volumes and patterns to heuristically update the global session phase.
    /// Needs to be called periodically from the async monitoring pipeline, not the resolver path.
    /// </summary>
    public static void UpdatePhase(int burstCount, bool containsKnownMediaEndpoints, bool containsKnownAuthEndpoints)
    {
        var now = DateTime.UtcNow;

        if (containsKnownAuthEndpoints && _currentPhase != SessionPhase.Playback)
        {
            SetPhase(SessionPhase.Login, now);
        }
        else if (containsKnownMediaEndpoints && burstCount > 5)
        {
            // A burst of media-related fragments detected
            SetPhase(SessionPhase.MediaLoad, now);
        }
        else if (_currentPhase == SessionPhase.MediaLoad && burstCount <= 5 && burstCount > 0)
        {
            // Burst subsided but activity continues = playback
            SetPhase(SessionPhase.Playback, now);
        }
        else if ((now - _lastActivity).TotalSeconds > IDLE_TIMEOUT_SECONDS)
        {
            SetPhase(SessionPhase.Idle, now);
        }

        if (burstCount > 0)
        {
            _lastActivity = now;
        }
    }

    private static void SetPhase(SessionPhase newPhase, DateTime timestamp)
    {
        if (_currentPhase != newPhase)
        {
            _currentPhase = newPhase;
            System.Diagnostics.Debug.WriteLine($"[SessionManager] Phase transitioned to: {newPhase} at {timestamp:T}");
        }
    }

    // Test method
    public static void ForcePhase(SessionPhase newPhase)
    {
        SetPhase(newPhase, DateTime.UtcNow);
    }
}
