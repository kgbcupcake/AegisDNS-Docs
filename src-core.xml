using System;
using System.Threading;

namespace AegisDNS.Core;

public class AegisMetrics
{
    internal long _totalQueries;
    internal long _blockedQueries;
    internal long _cacheHits;
    internal long _upstreamFailures;
    internal long _xdpDroppedPackets;
    internal long _upstreamLatencyMs = -1;  // -1 = unknown
    internal long _latencyWarning;           // 0 = false, 1 = true
    internal long _streamingAdsBlocked;      // Phase 17 — streaming ad block counter
    internal long _proxyRequests;            // Phase 18 — proxy requests counter
    internal long _proxyAdsBlocked;          // Phase 18 — proxy ads blocked counter

    public long TotalQueries => Interlocked.Read(ref _totalQueries);
    public long BlockedQueries => Interlocked.Read(ref _blockedQueries);
    public long CacheHits => Interlocked.Read(ref _cacheHits);
    public long UpstreamFailures => Interlocked.Read(ref _upstreamFailures);
    public long XdpDroppedPackets => Interlocked.Read(ref _xdpDroppedPackets);
    public long StreamingAdsBlocked => Interlocked.Read(ref _streamingAdsBlocked);
    public long ProxyRequests => Interlocked.Read(ref _proxyRequests);
    public long ProxyAdsBlocked => Interlocked.Read(ref _proxyAdsBlocked);

    /// <summary>Current upstream latency in milliseconds. -1 = unknown/unavailable.</summary>
    public int UpstreamLatencyMs => (int)Interlocked.Read(ref _upstreamLatencyMs);

    /// <summary>True when latency exceeds the configured alert threshold.</summary>
    public bool LatencyWarning => Interlocked.Read(ref _latencyWarning) == 1;
}

public static class MetricsManager
{
    private static readonly AegisMetrics _metrics = new();

    public static AegisMetrics Current => _metrics;

    public static void IncrementTotal() => Interlocked.Increment(ref _metrics._totalQueries);
    public static void IncrementBlocked() => Interlocked.Increment(ref _metrics._blockedQueries);
    public static void IncrementCacheHit() => Interlocked.Increment(ref _metrics._cacheHits);
    public static void IncrementUpstreamFailure() => Interlocked.Increment(ref _metrics._upstreamFailures);
    public static void IncrementXdpDropped() => Interlocked.Increment(ref _metrics._xdpDroppedPackets);
    public static void IncrementStreamingAdsBlocked() => Interlocked.Increment(ref _metrics._streamingAdsBlocked);
    public static void IncrementProxyRequests() => Interlocked.Increment(ref _metrics._proxyRequests);
    public static void IncrementProxyAdsBlocked() => Interlocked.Increment(ref _metrics._proxyAdsBlocked);

    public static void SetUpstreamLatency(int ms) =>
        Interlocked.Exchange(ref _metrics._upstreamLatencyMs, ms);

    public static void SetLatencyWarning(bool warning) =>
        Interlocked.Exchange(ref _metrics._latencyWarning, warning ? 1L : 0L);
}
