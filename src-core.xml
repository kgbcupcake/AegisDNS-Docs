<file path="src/AegisDNS.Core/Monitoring/LatencyMonitor.cs">
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.Net;
using System.Threading;
using System.Threading.Tasks;

using ARSoft.Tools.Net;
using ARSoft.Tools.Net.Dns;

namespace AegisDNS.Core.Monitoring;

/// <summary>
/// Pings the configured upstream DNS server every 30 seconds using a real DNS query.
/// Records a rolling average of the last 5 samples and publishes to MetricsManager.
/// Non-fatal: failures set latency to -1 (displayed as "—").
/// </summary>
public sealed class LatencyMonitor
{
    private static readonly string[] PresetUpstreams = ["1.1.1.1", "8.8.8.8", "9.9.9.9"];
    private const int PingIntervalSeconds = 30;
    private const int RollingWindowSize = 5;

    private readonly AegisEngine _engine;
    private readonly Queue<long> _samples = new();
    private CancellationTokenSource? _cts;

    public LatencyMonitor(AegisEngine engine)
    {
        _engine = engine;
    }

    public void Start()
    {
        _cts = new CancellationTokenSource();
        _ = Task.Run(() => RunLoop(_cts.Token), _cts.Token);
    }

    public void Stop()
    {
        _cts?.Cancel();
    }

    private async Task RunLoop(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(PingIntervalSeconds), token).ConfigureAwait(false);
                PingCurrentUpstream();
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch { }
        }
    }

    private void PingCurrentUpstream()
    {
        try
        {
            string upstream = DnsConfigManager.Settings.PrimaryDns;
            if (!IPAddress.TryParse(upstream, out var upstreamIp)) return;

            var sw = Stopwatch.StartNew();
            var client = new DnsClient(new List<IPAddress> { upstreamIp }, 5000);
            var result = client.Resolve(DomainName.Parse("example.com"), RecordType.A, RecordClass.INet);
            sw.Stop();

            long latencyMs = result != null ? sw.ElapsedMilliseconds : -1;
            UpdateSamples(latencyMs);

            int thresholdMs = DnsConfigManager.Settings.LatencyAlertThresholdMs;

            if (latencyMs >= 0 && latencyMs > thresholdMs)
            {
                if (!MetricsManager.Current.LatencyWarning)
                {
                    MetricsManager.SetLatencyWarning(true);
                    _engine.Broadcast($"⚠️ DNS latency warning: {latencyMs}ms exceeds threshold of {thresholdMs}ms");
                }
            }
            else if (latencyMs >= 0)
            {
                MetricsManager.SetLatencyWarning(false);
            }
        }
        catch { }
    }

    private void UpdateSamples(long latencyMs)
    {
        lock (_samples)
        {
            if (latencyMs >= 0)
            {
                _samples.Enqueue(latencyMs);
                while (_samples.Count > RollingWindowSize)
                    _samples.Dequeue();

                long sum = 0;
                foreach (var s in _samples) sum += s;
                int avg = (int)(sum / _samples.Count);
                MetricsManager.SetUpstreamLatency(avg);
            }
            else
            {
                MetricsManager.SetUpstreamLatency(-1);
            }
        }
    }

    /// <summary>
    /// Sends one test query to each preset upstream and returns a list sorted by latency.
    /// Exposed for future "pick fastest upstream" feature.
    /// </summary>
    public IReadOnlyList<(string Upstream, long LatencyMs)> CompareUpstreams()
    {
        var results = new List<(string Upstream, long LatencyMs)>();
        foreach (var upstream in PresetUpstreams)
        {
            try
            {
                if (!IPAddress.TryParse(upstream, out var ip)) continue;
                var sw = Stopwatch.StartNew();
                var client = new DnsClient(new List<IPAddress> { ip }, 5000);
                var result = client.Resolve(DomainName.Parse("example.com"), RecordType.A, RecordClass.INet);
                sw.Stop();
                results.Add((upstream, result != null ? sw.ElapsedMilliseconds : -1L));
            }
            catch
            {
                results.Add((upstream, -1L));
            }
        }

        results.Sort((a, b) =>
        {
            if (a.LatencyMs < 0) return 1;
            if (b.LatencyMs < 0) return -1;
            return a.LatencyMs.CompareTo(b.LatencyMs);
        });

        return results.AsReadOnly();
    }
}
</file>

