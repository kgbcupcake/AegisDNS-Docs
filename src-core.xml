using System;
using System.Diagnostics;
using System.IO;
using System.Text.Json;

namespace AegisDNS.Core.Utilities;

/// <summary>
/// Manages enterprise-level policies and remote configuration enforcement.
/// </summary>
public static class EnterprisePolicyManager
{
    private static readonly string PolicyPath = Path.Combine(AppContext.BaseDirectory, "enterprise_policy.json");

    public class Policy
    {
        public bool ForceSafeSearch { get; set; } = false;
        public string[] MandatoryBlocklists { get; set; } = Array.Empty<string>();
        public bool DisableManualDnsOverride { get; set; } = false;
        public bool EnforceTelemetryServer { get; set; } = false;
        public string? AdminContact { get; set; }
    }

    private static Policy _activePolicy = new();

    static EnterprisePolicyManager()
    {
        LoadPolicy();
    }

    public static Policy ActivePolicy => _activePolicy;

    public static void LoadPolicy()
    {
        try
        {
            if (!File.Exists(PolicyPath)) return;

            string json = File.ReadAllText(PolicyPath);
            Policy? policy;
            try { policy = JsonSerializer.Deserialize<Policy>(json); }
            catch (JsonException) { return; }
            if (policy != null)
            {
                _activePolicy = policy;
                Debug.WriteLine("[EnterprisePolicyManager] Policy loaded and enforced.");
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[EnterprisePolicyManager] Failed to load policy: {ex.Message}");
        }
    }

    public static async Task FetchRemotePolicyAsync(string url)
    {
        try
        {
            if (!url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)) return;

            string json = await SharedHttpClient.Instance.GetStringAsync(url);

            Policy? policy;
            try { policy = JsonSerializer.Deserialize<Policy>(json); }
            catch (JsonException ex)
            {
                Debug.WriteLine($"[EnterprisePolicyManager] Remote policy JSON invalid: {ex.Message}");
                return;
            }

            if (policy != null)
            {
                _activePolicy = policy;
                File.WriteAllText(PolicyPath, json); // Persist for offline enforcement
                Debug.WriteLine("[EnterprisePolicyManager] Remote policy updated and persisted.");
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[EnterprisePolicyManager] Remote update failed: {ex.Message}");
        }
    }

    /// <summary>
    /// Checks if a setting is locked by enterprise policy.
    /// </summary>
    public static bool IsSettingLocked(string settingName)
    {
        if (_activePolicy.DisableManualDnsOverride)
        {
            if (settingName == "PrimaryDns" || settingName == "SecondaryDns" || settingName == "PreferredAdapter")
                return true;
        }

        return false;
    }
}
