namespace AegisDNS.Core;

/// <summary>
/// Curated list of domains used for ads, tracking, and telemetry
/// inside desktop gaming launchers. These domains serve promotional
/// content and analytics — blocking them does not affect gameplay,
/// authentication, downloads, or multiplayer.
///
/// Verified manually against each launcher. Update this list as
/// launchers add new ad domains.
/// </summary>
internal static class GamingLauncherDomains
{
    /// <summary>
    /// Returns all gaming launcher ad/tracking domains as a flat enumerable.
    /// Called by BlocklistManager when EnableGamingLauncherBlocking is true.
    /// </summary>
    public static IEnumerable<string> GetAll() => EpicGames
        .Concat(EaApp)
        .Concat(UbisoftConnect)
        .Concat(BattleNet)
        .Concat(XboxApp)
        .Concat(Steam);

    // ── EPIC GAMES LAUNCHER ───────────────────────────────────────────────────
    // Epic shows promotional banners and "recommended games" ads on the launcher
    // front page. These domains serve that content and track engagement with it.
    // Blocking them removes the banner content. The store, library, and game
    // downloads all continue working normally.
    private static readonly string[] EpicGames =
    [
        "tracking.epicgames.com",
        "tracking-website-prod07-epic.ol.epicgames.com",
        "ads.epicgames.com",
        "ad.epicgames.com",
        "discovery.epicgames.com",       // Launcher front-page "discovery" content (ads)
        "spectre.epicgames.com",          // Analytics / telemetry
        "eulatracking.epicgames.com",     // EULA engagement tracking
        "entitlementsvc.epicgames.com",   // Ad entitlement signals
        "publish-ds.epicgames.com",       // Publisher ad delivery
    ];

    // ── EA APP (formerly Origin) ──────────────────────────────────────────────
    // EA App shows promotional content for new games and DLC in the launcher
    // home screen and game library view. These domains serve and track those ads.
    private static readonly string[] EaApp =
    [
        "ads.ea.com",
        "ad.ea.com",
        "tracking.ea.com",
        "telemetry.ea.com",
        "analytics.ea.com",
