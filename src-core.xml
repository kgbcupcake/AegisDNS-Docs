<file path="src/AegisDNS.Core/Ai/AiConfigManager.cs">
using System;
using System.Collections.Generic;
using System.IO;
using System.Text.Json;
using System.Text.Json.Serialization;

namespace AegisDNS.Core.Ai;

public class AiConfig
{
    public bool EnableAiSentinel { get; set; } = false;
    public string AiProvider { get; set; } = "Ollama";
    public string AiEndpoint { get; set; } = "http://localhost:11434";
    public string AiModel { get; set; } = "llama3";
    public string AiApiKey { get; set; } = "";
    public int AiCheckIntervalMinutes { get; set; } = 2;
    public List<string> FallbackProviders { get; set; } = new();
}

[JsonSerializable(typeof(AiConfig))]
internal partial class AiConfigJsonContext : JsonSerializerContext { }

public static class AiConfigManager
{
    private static readonly string AppFolder =
        Environment.GetEnvironmentVariable("XDG_DATA_HOME") ?? "/var/lib/aegisdns";
    private static readonly string ConfigPath = Path.Combine(AppFolder, "Ai.config"); // User requested "Ai.config"

    public static AiConfig Settings { get; private set; } = new();

    static AiConfigManager()
    {
        Load();
    }

    public static void Load()
    {
        try
        {
            if (!File.Exists(ConfigPath))
            {
                Save();
                return;
            }

            string json = File.ReadAllText(ConfigPath);
            if (string.IsNullOrWhiteSpace(json))
            {
                Settings = new AiConfig();
                return;
            }

            try
            {
                var loaded = JsonSerializer.Deserialize(json, AiConfigJsonContext.Default.AiConfig);
                if (loaded != null)
                {
                    Settings = loaded;
                    System.Diagnostics.Debug.WriteLine($"✅ AI Config loaded: {ConfigPath}");
                }
            }
            catch (JsonException ex)
            {
                System.Diagnostics.Debug.WriteLine($"⚠️ JSON invalid: {ex.Message}");
                Settings = new AiConfig();
                return;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"⚠️ Load failed: {ex.Message}");
                Settings = new AiConfig();
                return;
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"⚠️ AI Config load failed: {ex.Message}");
            Settings = new AiConfig();
        }
    }

    public static void Save()
    {
        try
        {
            if (!Directory.Exists(AppFolder))
                Directory.CreateDirectory(AppFolder);

            var options = new JsonSerializerOptions { WriteIndented = true };
            string json = JsonSerializer.Serialize(Settings, typeof(AiConfig), new AiConfigJsonContext(options));
            File.WriteAllText(ConfigPath, json);
            System.Diagnostics.Debug.WriteLine($"💾 AI Config saved: {ConfigPath}");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ AI Config save failed: {ex.Message}");
        }
    }
}
