<file path="src/AegisDNS.Core/Core/DoHClient.cs">
using System.Net.Http.Headers;
using System.Text;

using AegisDNS.Core.Utilities;

using ARSoft.Tools.Net.Dns;

using Microsoft.Extensions.Logging;

namespace AegisDNS.Core;

public class DoHClient
{
    private readonly ILogger<DoHClient> _logger;

    public DoHClient(ILogger<DoHClient> logger)
    {
        _logger = logger;
    }

    public async Task<DnsMessage?> QueryAsync(string endpoint, DnsMessage query, CancellationToken token = default)
    {
        try
        {
            // --- MODERN APPROACH: Manual Serialization ---
            byte[] queryBytes = SerializeDnsQuery(query);

            using var content = new ByteArrayContent(queryBytes);
            content.Headers.ContentType = new MediaTypeHeaderValue("application/dns-message");

            var request = new HttpRequestMessage(HttpMethod.Post, endpoint)
            {
                Content = content
            };
            request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("application/dns-message"));

            var response = await SharedHttpClient.Instance.SendAsync(request, token);

            if (response.IsSuccessStatusCode)
            {
                byte[] responseBytes = await response.Content.ReadAsByteArrayAsync(token);
                // We still use the library to PARSE the answer, because parsing is hard.
                return DnsMessage.Parse(responseBytes);
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[DoH Failure]");
        }
        return null;
    }

    // This is the "Modern" helper. No reflection. Just pure binary writing.
    private byte[] SerializeDnsQuery(DnsMessage query)
    {
        using (var ms = new MemoryStream())
        using (var writer = new BinaryWriter(ms))
        {
            // 1. Transaction ID (2 bytes)
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness((ushort)query.TransactionID));

            // 2. Flags (2 bytes) - Standard Query usually 0x0100 (Recursion Desired)
            ushort flags = 0;
            if (query.IsRecursionDesired) flags |= 0x0100;
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness(flags)); // Big Endian

            // 3. Counts (Query Count = 1, others = 0)
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness((ushort)1)); // Questions
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness((ushort)0)); // Answers
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness((ushort)0)); // Authority
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness((ushort)0)); // Additional

            // 4. The Question Name
            var question = query.Questions[0];
            string[] labels = question.Name.ToString().Split('.');
            foreach (var label in labels)
            {
                if (string.IsNullOrEmpty(label)) continue;
                byte[] labelBytes = Encoding.ASCII.GetBytes(label);
                writer.Write((byte)labelBytes.Length);
                writer.Write(labelBytes);
            }
            writer.Write((byte)0); // End of name

            // 5. Type and Class
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness((ushort)question.RecordType));
            writer.Write(System.Buffers.Binary.BinaryPrimitives.ReverseEndianness((ushort)question.RecordClass));

            return ms.ToArray();
        }
    }
}
