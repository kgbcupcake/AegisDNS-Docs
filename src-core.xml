<file path="src/AegisDNS.Core/Utilities/MetricsHistory.cs">
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Text.Json;
using System.Threading;

namespace AegisDNS.Core.Utilities;

public record MetricsSnapshot(
    DateTime Timestamp,
    long TotalQueries,
    long BlockedQueries,
    long CacheHits,
    double BlockRate
);

/// <summary>
/// Stores periodic snapshots of query metrics for dashboard historical graphs.
/// Rolling window: keeps last 288 snapshots (24 hours at 5-minute intervals).
/// </summary>
public static class MetricsHistory
{
    private static readonly string AppFolder =
        Environment.GetEnvironmentVariable("XDG_DATA_HOME") ?? "/var/lib/aegisdns";
    private static readonly string HistoryPath = Path.Combine(AppFolder, "metrics_history.json");

    private const int MaxSnapshots = 288; // 24 hours at 5 min intervals
    private static List<MetricsSnapshot> _snapshots = new();
    private static readonly Lock _lock = new();

    /// <summary>
    /// Returns a copy of the current history.
    /// </summary>
    public static IReadOnlyList<MetricsSnapshot> Snapshots
    {
        get
        {
            lock (_lock)
            {
                return _snapshots.ToList();
            }
        }
    }

    /// <summary>
    /// Captures the current metrics state and appends it to history.
    /// </summary>
    public static void RecordSnapshot()
    {
        try
        {
            var current = MetricsManager.Current;
            long total = current.TotalQueries;
            long blocked = current.BlockedQueries;
            long cache = current.CacheHits;

            double rate = total > 0 ? (double)blocked / total * 100.0 : 0;

            var snapshot = new MetricsSnapshot(DateTime.UtcNow, total, blocked, cache, rate);

            lock (_lock)
            {
                _snapshots.Add(snapshot);

                // Trim to rolling window
                if (_snapshots.Count > MaxSnapshots)
                {
                    _snapshots.RemoveRange(0, _snapshots.Count - MaxSnapshots);
                }
            }

            Save();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Failed to record metrics snapshot: {ex.Message}");
        }
    }

    /// <summary>
    /// Returns the last N snapshots for graph rendering.
    /// </summary>
    public static IReadOnlyList<MetricsSnapshot> GetLast(int count)
    {
        lock (_lock)
        {
            return _snapshots.TakeLast(count).ToList();
        }
    }

    /// <summary>
    /// Loads from JSON on startup.
    /// </summary>
    public static void Load()
    {
        try
        {
            if (!File.Exists(HistoryPath)) return;

            string json = File.ReadAllText(HistoryPath);
            if (string.IsNullOrWhiteSpace(json)) return;

            List<MetricsSnapshot>? loaded;
            try { loaded = JsonSerializer.Deserialize<List<MetricsSnapshot>>(json); }
            catch (JsonException) { return; }
            if (loaded != null)
            {
                lock (_lock)
                {
                    _snapshots = loaded;
                    // Enforce size limit on load just in case
                    if (_snapshots.Count > MaxSnapshots)
                    {
                        _snapshots.RemoveRange(0, _snapshots.Count - MaxSnapshots);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"⚠️ Failed to load metrics history: {ex.Message}");
        }
    }

    /// <summary>
    /// Writes JSON to disk.
    /// </summary>
    private static void Save()
    {
        try
        {
            if (!Directory.Exists(AppFolder))
            {
                Directory.CreateDirectory(AppFolder);
            }

            List<MetricsSnapshot> copyToSave;
            lock (_lock)
            {
                copyToSave = _snapshots.ToList();
            }

            var options = new JsonSerializerOptions { WriteIndented = true };
            string json = JsonSerializer.Serialize(copyToSave, options);
            File.WriteAllText(HistoryPath, json);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"❌ Failed to save metrics history: {ex.Message}");
        }
    }
}
