using System;
using System.Collections.Generic;
using System.Threading.Tasks;

using AegisDNS.Core.Monitoring;

using Microsoft.Extensions.Logging;

namespace AegisDNS.Core.Ai.Providers;

public class FallbackAiProvider : IAiProvider
{
    private readonly IAiProviderFactory _factory;
    private readonly ILogger<FallbackAiProvider> _logger;

    public FallbackAiProvider(IAiProviderFactory factory, ILogger<FallbackAiProvider> logger)
    {
        _factory = factory;
        _logger = logger;
    }

    public Task<string> AnalyzeAsync(IReadOnlyCollection<QueryHistoryEntry> history, AiConfig config)
    {
        if (history.Count == 0) return Task.FromResult("No queries to analyze.");
        return AskAsync(PromptBuilder.Build(history), config);
    }

    public async Task<string> AskAsync(string prompt, AiConfig config)
    {
        var providersToTry = new List<string> { config.AiProvider };
        if (config.FallbackProviders != null)
        {
            providersToTry.AddRange(config.FallbackProviders);
        }

        foreach (var providerName in providersToTry)
        {
            if (string.IsNullOrWhiteSpace(providerName) || providerName == "None") continue;

            try
            {
                var provider = _factory.GetProvider(providerName);
                if (provider != null)
                {
                    var result = await provider.AskAsync(prompt, config);
                    if (!string.IsNullOrEmpty(result))
                    {
                        return result;
                    }
                }
            }
            catch (Exception ex)
            {
                _logger.LogWarning(ex, "[AiSentinel] Provider '{ProviderName}' failed. Trying next...", providerName);
            }
        }

        _logger.LogWarning("[AiSentinel] All AI providers unavailable.");
        return string.Empty;
    }
}
