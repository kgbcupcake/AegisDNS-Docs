<file path="src/AegisDNS.Core/Utilities/UpdateManager.cs">
using System;
using System.Diagnostics;
using System.IO;
using System.IO.Compression;
using System.Net.Http;
using System.Security.Cryptography;
using System.Text.Json;
using System.Threading.Tasks;

using Microsoft.Extensions.Logging;

namespace AegisDNS.Core.Utilities;

public class UpdateManager
{
    public class UpdateManifest
    {
        public string Version { get; set; } = "";
        public string InstallerUrl { get; set; } = "";
        public string SHA256 { get; set; } = "";
        public string ReleaseNotes { get; set; } = "";
    }

    private readonly string _publicKeyPath;
    private readonly ILogger<UpdateManager> _logger;

    public UpdateManager(ILogger<UpdateManager> logger)
    {
        _logger = logger;
        _publicKeyPath = Path.Combine(AppContext.BaseDirectory, "Security", "update_public.pem");
    }

    public async Task<UpdateManifest?> CheckForUpdatesAsync()
    {
        try
        {
            string url = DnsConfigManager.Settings.UpdateCheckUrl;

            // 0. Enforce HTTPS
            if (!url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            {
                _logger.LogWarning("[UpdateManager] Blocked insecure update check (non-HTTPS).");
                return null;
            }

            // 1. Fetch Manifest
            byte[] manifestBytes = await SharedHttpClient.Instance.GetByteArrayAsync(url);

            // 2. Fetch Detached Signature (.sig manifest)
            byte[] signatureBytes = await SharedHttpClient.Instance.GetByteArrayAsync(url + ".sig");

            // 3. Verify Signature
            if (!VerifySignature(manifestBytes, signatureBytes))
            {
                _logger.LogWarning("[UpdateManager] Signature verification failed. Untrusted manifest.");
                return null;
            }

            // 4. Parse
            UpdateManifest? manifest;
            try
            {
                manifest = JsonSerializer.Deserialize<UpdateManifest>(manifestBytes, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            catch (JsonException ex)
            {
                _logger.LogError(ex, "[UpdateManager] Manifest JSON parse failed.");
                return null;
            }

            if (manifest == null || !manifest.InstallerUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            {
                _logger.LogWarning("[UpdateManager] Manifest is null or uses insecure installer URL.");
                return null;
            }

            // 5. Version Check (Rollback Protection via TryParse)
            string currentVersionString = System.Reflection.Assembly
                .GetEntryAssembly()?.GetName().Version?.ToString(3) ?? "0.0.0";

            if (Version.TryParse(manifest?.Version, out Version? manifestVersion) &&
                Version.TryParse(currentVersionString, out Version? currentVersion))
            {
                if (manifestVersion > currentVersion)
                {
                    return manifest; // Valid upgrade strictly higher than current
                }
                else
                {
                    _logger.LogWarning("[UpdateManager] Manifest version {ManifestVersion} is not higher than current version {CurrentVersion}. Downgrade or same version prevented.", manifestVersion, currentVersion);
                    return null;
                }
            }
            else
            {
                _logger.LogWarning("[UpdateManager] Failed to parse versions. Update aborted to prevent attacks.");
                return null;
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[UpdateManager] Check failed.");
            return null;
        }
    }

    public async Task<bool> DownloadAndInstallAsync(UpdateManifest update)
    {
        string tempZipPath = Path.Combine(Path.GetTempPath(), $"AegisDNS_Update_{update.Version}.zip");
        string extractPath = Path.Combine(Path.GetTempPath(), $"AegisDNS_Update_{update.Version}_Extracted");

        try
        {
            // 1. Download ZIP
            byte[] archiveBytes = await SharedHttpClient.Instance.GetByteArrayAsync(update.InstallerUrl);

            // 2. Verify Hash
            using var sha = SHA256.Create();
            byte[] hashBytes = sha.ComputeHash(archiveBytes);
            string hashString = Convert.ToBase64String(hashBytes);

            if (hashString != update.SHA256)
            {
                // Fallback check for Hex
                string hexHash = BitConverter.ToString(hashBytes).Replace("-", "").ToLower();
                if (hexHash != update.SHA256.ToLower())
                {
                    _logger.LogError("[UpdateManager] Hash mismatch. Expected {Expected}, got {Actual}", update.SHA256, $"{hashString}/{hexHash}");
                    return false;
                }
            }

            // 3. Save ZIP
            await File.WriteAllBytesAsync(tempZipPath, archiveBytes);

            // 3.5 Backup for Rollback
            RollbackManager.CreateBackup();

            // 4. Extraction ZIP
            if (Directory.Exists(extractPath))
            {
                Directory.Delete(extractPath, true);
            }
            ZipFile.ExtractToDirectory(tempZipPath, extractPath, overwriteFiles: true);

            // 5. Locate and run the Linux installer
            string installerPath = Path.Combine(extractPath, "install.sh");
            if (!File.Exists(installerPath))
                installerPath = Path.Combine(extractPath, "setup.bin");

            if (File.Exists(installerPath))
            {
                // Assign executable rights
                var chmodPsi = new ProcessStartInfo("chmod") { UseShellExecute = false, CreateNoWindow = true };
                chmodPsi.ArgumentList.Add("+x");
                chmodPsi.ArgumentList.Add(installerPath);
                Process.Start(chmodPsi)?.WaitForExit();

                // Containment check — installer must be inside extractPath
                string fullInstallerPath = Path.GetFullPath(installerPath);
                string fullExtractPath = Path.GetFullPath(extractPath);
                if (!fullInstallerPath.StartsWith(fullExtractPath + Path.DirectorySeparatorChar,
                        StringComparison.Ordinal))
                {
                    Debug.WriteLine("[UpdateManager] Installer path escaped extract directory. Aborting.");
                    return false;
                }

                var psi = new ProcessStartInfo(fullInstallerPath)
                {
                    UseShellExecute = false,
                    CreateNoWindow = true
                };
                Process.Start(psi);
                return true;
            }

            _logger.LogError("[UpdateManager] Failed to find update payload inside the ZIP archive.");
            return false;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[UpdateManager] Install failed.");
            return false;
        }
        finally
        {
            try { if (File.Exists(tempZipPath)) File.Delete(tempZipPath); } catch { }
            try { if (Directory.Exists(extractPath)) Directory.Delete(extractPath, true); } catch { }
        }
    }

    private bool VerifySignature(byte[] data, byte[] signature)
    {
        try
        {
            if (!File.Exists(_publicKeyPath))
            {
                _logger.LogError("[UpdateManager] Missing keys: {KeyPath}", _publicKeyPath);
                return false;
            }

            string pem = File.ReadAllText(_publicKeyPath);

            using var rsa = RSA.Create();
            rsa.ImportFromPem(pem);
            return rsa.VerifyData(data, signature, HashAlgorithmName.SHA256, RSASignaturePadding.Pkcs1);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "[UpdateManager] Verification error.");
            return false;
        }
    }
}
