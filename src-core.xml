using System;
using System.Diagnostics;

namespace AegisDNS.Core.Utilities;

/// <summary>
/// Opens the provider's API key dashboard in the user's browser so they can
/// sign in with their account (Google, OpenAI, etc.) and copy an API key.
/// This is the standard approach for desktop apps — no OAuth client registration needed.
/// </summary>
public static class OAuthBrowserFlow
{
    /// <summary>
    /// Provider → API key dashboard URL.
    /// User signs in with their account on the provider's site,
    /// then copies the API key back into AegisDNS.
    /// </summary>
    private static readonly System.Collections.Generic.Dictionary<string, string> DashboardUrls = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Gemini"] = "https://aistudio.google.com/apikey",
        ["OpenAI"] = "https://platform.openai.com/api-keys",
        ["Anthropic"] = "https://console.anthropic.com/settings/keys",
        ["Mistral"] = "https://console.mistral.ai/api-keys/",
        ["Groq"] = "https://console.groq.com/keys",
        ["Deepseek"] = "https://platform.deepseek.com/api_keys",
        ["Perplexity"] = "https://www.perplexity.ai/settings/api",
        ["OpenRouter"] = "https://openrouter.ai/keys"
    };

    /// <summary>
    /// Opens the provider's API key page in the default browser.
    /// Returns true if the provider has a dashboard URL.
    /// </summary>
    public static bool OpenProviderDashboard(string provider)
    {
        if (!DashboardUrls.TryGetValue(provider, out var url))
        {
            Debug.WriteLine($"⚠️ No dashboard URL for provider: {provider}");
            return false;
        }

        OpenBrowser(url);
        return true;
    }

    /// <summary>
    /// Check whether a provider has a browser sign-in dashboard.
    /// </summary>
    public static bool HasDashboard(string provider)
        => DashboardUrls.ContainsKey(provider);

    /// <summary>
    /// Open URL in the default system browser.
    /// </summary>
    private static void OpenBrowser(string url)
    {
        if (string.IsNullOrWhiteSpace(url) || !url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            Debug.WriteLine($"❌ Blocked insecure/invalid URL: {url}");
            return;
        }

        try
        {
            var psi = new ProcessStartInfo("xdg-open")
            {
                UseShellExecute = false,
                CreateNoWindow = true
            };
            psi.ArgumentList.Add(url);
            Process.Start(psi);

            Debug.WriteLine($"🌐 Opened browser: {url}");
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"❌ Failed to open browser: {ex.Message}");
        }
    }
}
