<file path="src/AegisDNS.Core/Scheduling/ScheduleEngine.cs">
using System;
using System.Collections.Generic;
using System.Collections.Immutable;
using System.IO;
using System.Text.Json;
using System.Threading;

namespace AegisDNS.Core.Scheduling;

/// <summary>
/// Evaluates whether the current time falls within any active schedule for a domain.
/// Uses ImmutableList with atomic swap for lock-free reads in the hot path.
/// </summary>
public class ScheduleEngine
{
    private static readonly string DefaultSchedulesPath = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
        ".config", "aegisdns", "schedules.json");

    private static readonly string AllowedBaseDir = Path.GetFullPath(Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
        ".config", "aegisdns"));

    private ImmutableList<BlockSchedule> _schedules = ImmutableList<BlockSchedule>.Empty;
    private long _pausedUntilTicks;  // UTC ticks; 0 = not paused

    public ScheduleEngine()
    {
        Load();
    }

    /// <summary>Loads schedules from disk. Missing file = no schedules.</summary>
    public void Load(string? path = null)
    {
        string filePath = !string.IsNullOrWhiteSpace(path) ? path : DefaultSchedulesPath;
        filePath = Path.GetFullPath(filePath);
        if (!filePath.StartsWith(AllowedBaseDir, StringComparison.Ordinal)) return;
        try
        {
            if (!File.Exists(filePath))
            {
                Interlocked.Exchange(ref _schedules, ImmutableList<BlockSchedule>.Empty);
                return;
            }

            string json = File.ReadAllText(filePath);
            if (string.IsNullOrWhiteSpace(json)) return;

            BlockSchedule[]? loaded;
            try { loaded = JsonSerializer.Deserialize<BlockSchedule[]>(json); }
            catch (JsonException) { return; }

            if (loaded == null) return;
            Interlocked.Exchange(ref _schedules, ImmutableList.CreateRange(loaded));
        }
        catch { }
    }

    /// <summary>Saves schedules to disk and atomically reloads in-memory list.</summary>
    public void Save(IEnumerable<BlockSchedule> schedules, string? path = null)
    {
        string filePath = !string.IsNullOrWhiteSpace(path) ? path : DefaultSchedulesPath;
        filePath = Path.GetFullPath(filePath);
        if (!filePath.StartsWith(AllowedBaseDir, StringComparison.Ordinal)) return;
        try
        {
            string? dir = Path.GetDirectoryName(filePath);
            if (!string.IsNullOrEmpty(dir) && !Directory.Exists(dir))
                Directory.CreateDirectory(dir);

            var list = new List<BlockSchedule>(schedules);
            string json = JsonSerializer.Serialize(list, new JsonSerializerOptions { WriteIndented = true });
            File.WriteAllText(filePath, json);
        }
        catch { }

        Load(path);
    }

    /// <summary>Suspends all schedule enforcement until the specified UTC time.</summary>
    public void PauseUntil(DateTime utcUntil)
    {
        Interlocked.Exchange(ref _pausedUntilTicks, utcUntil.ToUniversalTime().Ticks);
    }

    public bool IsPaused => DateTime.UtcNow.Ticks < Interlocked.Read(ref _pausedUntilTicks);

    public DateTime PausedUntil => new DateTime(Interlocked.Read(ref _pausedUntilTicks), DateTimeKind.Utc).ToLocalTime();

    /// <summary>
    /// Synchronous O(n) check over all enabled schedules.
    /// Returns true if the domain should be blocked by any active schedule.
    /// </summary>
    public bool IsScheduledBlock(string domain)
    {
        if (IsPaused) return false;

        var schedules = Volatile.Read(ref _schedules);
        var now = DateTime.Now;
        var currentDay = now.DayOfWeek;
        var currentTime = now.TimeOfDay;

        foreach (var schedule in schedules)
        {
            if (!schedule.Enabled) continue;

            // Day check — empty = all days
            if (schedule.DaysOfWeek.Length > 0)
            {
                bool dayMatch = false;
                foreach (var d in schedule.DaysOfWeek)
                {
                    if (d == currentDay) { dayMatch = true; break; }
                }
                if (!dayMatch) continue;
            }

            // Time window check
            if (currentTime < schedule.StartTime || currentTime > schedule.EndTime) continue;

            // Keyword check
            foreach (var kw in schedule.CategoryKeywords)
            {
                if (!string.IsNullOrWhiteSpace(kw) &&
                    domain.Contains(kw, StringComparison.OrdinalIgnoreCase))
                {
                    return true;
                }
            }
        }

        return false;
    }

    public ImmutableList<BlockSchedule> GetAll() => Volatile.Read(ref _schedules);
}
